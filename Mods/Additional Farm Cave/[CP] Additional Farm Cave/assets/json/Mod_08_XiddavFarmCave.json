{

    "Changes": [


//■■■ Xiddav's Farm Cave ■■■


  //★★★ 全種類共通でDTで変更制御 ★★★

    //●入り口が閉じた状態
      {
        "Action": "EditMap",
        "Target": "Maps/FarmCave",
        "FromFile": "assets/tmx/Mod_08_XiddavFarmCave/Ts_AFC_Entrance_Close_XiddavFC_{{Ts_AFC_XiddavFC_CaveType}}.tmx",
        "ToArea": { "X": 11, "Y": 0, "Width": 9, "Height": 7 },
        "When": { "Ts_AFC_OpenImmediately": "false" }
      },

    //●メールで入り口を開放
      {
        "Action": "EditMap",
        "Target": "Maps/FarmCave",
        "FromFile": "assets/tmx/Mod_08_XiddavFarmCave/Ts_AFC_Entrance_Open_XiddavFC_{{Ts_AFC_XiddavFC_CaveType}}.tmx",
        "ToArea": { "X": 11, "Y": 0, "Width": 9, "Height": 7 },
        "When": {
          "HasFlag": "{{ModId}}_CaveOpenMail",
          "Ts_AFC_OpenImmediately": "false"
        },
        "Update": "OnLocationChange"
      },

    //●ModConfigの設定で開放
      {
        "Action": "EditMap",
        "Target": "Maps/FarmCave",
        "FromFile": "assets/tmx/Mod_08_XiddavFarmCave/Ts_AFC_Entrance_Open_XiddavFC_{{Ts_AFC_XiddavFC_CaveType}}.tmx",
        "ToArea": { "X": 11, "Y": 0, "Width": 9, "Height": 7 },
        "When": { "Ts_AFC_OpenImmediately": "true" }
      },

    //●FarmCaveにワープ追加
      {
        "Action": "EditMap",
        "Target": "Maps/FarmCave",
        "TextOperations": [
          {
            "Operation": "Append",
            "Target": ["MapProperties", "Warp"],
            "Value": "16 {{DT_warp_FC_IN_Y}} Custom_AdditionalFarmCave 9 {{DT_warp_FC_OUT_Y}}",
            "Delimiter": " "
          }
        ],
        "When": { "Ts_AFC_AvoidCertainBugs": "false" }
      },

    //●FarmCaveにワープ追加 2
      {
        "Action": "EditMap",
        "Target": "Maps/FarmCave",
        "TextOperations": [
          {
            "Operation": "Append",
            "Target": ["MapProperties", "Warp"],
            "Value": "16 {{DT_warp_FC_IN_Y}} Custom_AdditionalFarmCave 9 {{DT_warp_FC_OUT_Y}}",
            "Delimiter": " "
          }
        ],
        "When": { "Ts_AFC_AvoidCertainBugs": "true" }
      },

    //●AddFarmCaveのマップ編集 見た目を合わせる
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_AdditionalFarmCave",
        "FromFile": "assets/tmx/Mod_08_XiddavFarmCave/Ts_AFC_XiddavFC_{{Ts_AFC_XiddavFC_CaveType}}.tmx"
      },

    //●AddFarmCave 2 のマップ編集 見た目を合わせる
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_AdditionalFarmCave2",
        "FromFile": "assets/tmx/Mod_08_XiddavFarmCave/Ts_AFC_XiddavFC_{{Ts_AFC_XiddavFC_CaveType}}.tmx"
      },

    //●AddFarmCaveのワープ変更
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_AdditionalFarmCave",
        "MapProperties": { "Warp": "9 {{DT_warp_AdFC_IN_Y}} FarmCave 16 {{DT_warp_AdFC_OUT_Y}}" },
        "When": { "Ts_AFC_AvoidCertainBugs": "false" }
      },

    //●AddFarmCaveのワープ変更 2
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_AdditionalFarmCave2",
        "MapProperties": { "Warp": "9 {{DT_warp_AdFC_IN_Y}} FarmCave 16 {{DT_warp_AdFC_OUT_Y}}" },
        "When": { "Ts_AFC_AvoidCertainBugs": "true"  }
      }


    ]//▼▼"Changes"の終了▼▼
}
