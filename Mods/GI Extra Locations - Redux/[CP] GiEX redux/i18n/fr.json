    "Javi_lovedgift": "Voilà de la bonne marchandise.",
    "Javi_likedgift": "Pas mal, @.",
    "Javi_dislikedgift": "À quoi pensais-tu ?",
    "Javi_hatedgift": "C'est une mauvaise blague ?",
