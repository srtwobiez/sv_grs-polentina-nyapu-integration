    "Changes": [
        //Add minecarts
        //CustomCart1 Destination
        {
            "LogName": "jibb.CustomCart1.Destination",
            "Action": "EditData",
            "Target": "Data/Minecarts",
            "TargetField": ["Default", "Destinations"],
            "Entries": {
                "jibb.CustomCart1": {
                    "Id": "jibb.CustomCart1",
                    "TargetLocation": "{{CustomCart1.Map}}",
                    "DisplayName": "{{CustomCart1.Name}}",
                    "Price": "{{PriceToRide}}",
                    "TargetTile": {
                        "X": "{{Query: {{CustomCart1XTilePosition}}}}",
                        "Y": "{{Query: {{CustomCart1YTilePosition}}+1}}"
                    },
                    "TargetDirection": "down"
                }
            },
            "When": {"Enablejibb.CustomCart1": true}
        },
        //CustomCart1 map edits
        {
            "Action": "EditMap",
            "Target": "Maps/{{CustomCart1.Map}}",
            "FromFile": "assets/{{CustomCart1CartStyle}}.tmx",
            "FromArea": {
                "X": 0,
                "Y": 0,
                "Width": "{{Query:1+{{CustomCart1AssetXModifier}}}}",
                "Height": "{{Query:2+{{CustomCart1AssetYModifier}}}}"
            },
            "ToArea": {
                "X": "{{Query:{{CustomCart1CoordinatesX}}}}",
                "Y": "{{Query:{{CustomCart1CoordinatesY}}}}",
                "Width": "{{Query:1+{{CustomCart1AssetXModifier}}}}",
                "Height": "{{Query:2+{{CustomCart1AssetYModifier}}}}"
            },
            "MapTiles": [
                {
                    "Position": {
                        "X": "{{Query:{{CustomCart1XTilePosition}}}}",
                        "Y": "{{Query:{{CustomCart1YTilePosition}}}}"
                    },
                    "Layer": "Buildings",
                    "SetProperties": {
                        "Action": "MinecartTransport Default jibb.CustomCart1"
                    }
                }
            ],
            "PatchMode": "Overlay",
            "Priority": "Late",
            "When": {"Enablejibb.CustomCart1": true}
        },
        //CustomCart1 lighting
        {
            "Action": "EditMap",
            "Target": "Maps/{{CustomCart1.Map}}",
			"Priority": "Late",
            "TextOperations": [
				{
                    "Operation": "Append",
                    "Target": ["MapProperties", "DayTiles"],
                    "Value": "Buildings {{Query:{{CustomCart1CoordinatesX}}+2}} {{Query:{{CustomCart1CoordinatesY}}+1}} 510 Buildings2 {{Query:{{CustomCart1CoordinatesX}}+2}} {{Query:{{CustomCart1CoordinatesY}}+1}} 510",
                    "Delimiter": " " 
                },
				{
                    "Operation": "Append",
                    "Target": ["MapProperties", "Light"],
                    "Value": "{{Query:{{CustomCart1CoordinatesX}}+2}} {{Query:{{CustomCart1CoordinatesY}}+1}} 4",
                    "Delimiter": " " 
                },
				{
                    "Operation": "Append",
                    "Target": ["MapProperties", "NightTiles"],
                    "Value": "Buildings {{Query:{{CustomCart1CoordinatesX}}+2}} {{Query:{{CustomCart1CoordinatesY}}+1}} 507 Buildings2 {{Query:{{CustomCart1CoordinatesX}}+2}} {{Query:{{CustomCart1CoordinatesY}}+1}} 507",
                    "Delimiter": " " 
                },
            ],
            "When": {
                "Enablejibb.CustomCart1": true,
                "CustomCart1CartStyle": "CartEntrance",

            },
        },
