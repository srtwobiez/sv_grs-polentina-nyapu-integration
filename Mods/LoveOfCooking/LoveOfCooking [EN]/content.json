				"config.option.foodcanburn_name": "La comida puede quemarse",
				"config.option.foodcanburn_description": "¡Tienes una probabilidad de arruinar tu comida al cocinar!\nNo se recomienda a menos que disfrutes del fracaso.",
				"config.option.townkitchens_name": "Cocinas del pueblo",
				"config.option.townkitchens_description": "¡Te permite interactuar con cualquier cocina del pueblo!\nNecesitas tener amistad con alguien que viva allí.",
				"config.option.menuanimation_name": "Animaciones de menú",
				"config.option.menuanimation_description": "Si se debe reproducir una transición rápida al abrir el menú de cocina.\n\nRequiere el nuevo menú de cocina.",
				"config.option.cookinganimation_name": "Animaciones de cocina",
				"config.option.cookinganimation_description": "Si se debe reproducir una pequeña animación al cocinar en la cocina.\n\nRequiere el nuevo menú de cocina.",
