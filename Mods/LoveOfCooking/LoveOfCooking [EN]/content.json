				"config.option.cookingmenu_name": "Menú de cocina",
				"config.option.cookingmenu_description": "¡Reemplaza la interfaz de creación con un nuevo menú de cocina!\nLas recetas se guardan en tu libro de cocina para buscar, ordenar, filtrar y marcar como favoritas.\nLos ingredientes se añaden manualmente al cocinar.",
				"config.option.cookingskill_name": "Habilidad de cocina y recetas",
				"config.option.cookingskill_description": "¡Añade una nueva habilidad de cocina para subir de nivel!\nLos niveles de habilidad desbloquean nuevas recetas y profesiones.\nGana experiencia cocinando, con bonificaciones por recetas nuevas y avanzadas.",
				"config.option.cookingtool_name": "Herramienta de cocina y mejoras",
				"config.option.cookingtool_description": "¡Añade una nueva herramienta de cocina para mejorar!\nReduce el número de ingredientes utilizables al cocinar a 1, aumentando con el nivel de la herramienta.\nPuedes comprar mejoras al Herrero para cocinar recetas avanzadas.\n\nRequiere el nuevo menú de cocina.",
				"config.option.seasonings_name": "Más condimentos",
				"config.option.seasonings_description": "¡Añade nuevos sabores para mejorar tu cocina!\nIntroduce objetos de bajo valor que aumentan la calidad de la comida cocinada.\nSe consumen automáticamente al cocinar.",
				"config.option.foodbuffsstarthidden_name": "Efectos de comida ocultos al inicio",
				"config.option.foodbuffsstarthidden_description": "¡Los valores de los efectos no se muestran en las comidas hasta que las hayas probado!\nSi se desactiva, las comidas y recetas siempre mostrarán sus atributos.",
				"config.option.foodhealingtakestime_name": "La comida cura con el tiempo",
