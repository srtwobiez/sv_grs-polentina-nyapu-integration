				"config.info.cookingtool.subheading.1": "Mejoras de herramienta",

				"config.info.townkitchens.text.1": "Se puede cocinar en cualquier cocina del pueblo, siempre que seas amigo del dueño.\n¡Necesitarás un libro de cocina y recetas!",
