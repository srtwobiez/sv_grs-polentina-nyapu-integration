  "shirts.cray-faye-abstract-shirt.name": "Camisa Cray Faye Abstracta",
  "shirts.cray-faye-abstract-shirt.description": "El suelto y divertido proyecto secreto de Faye.",
  "shirts.dragon-sweetie-top.name": "Blusa Dulce de Dragón",
  "shirts.dragon-sweetie-top.description": "¡Fabulosamente dracónico!",
  "shirts.fab-dusk-suit.name": "Traje Fabuloso del Ocaso",
  "shirts.fab-dusk-suit.description": "¡Fabulosamente ébano!",
  "shirts.fairy-cutie-top.name": "Blusa de hadas",
  "shirts.fairy-cutie-top.description": "¡Rosadamente lindo!",
  "shirts.faye-rytale-pastel.name": "Pastel Cuento de Faye",
  "shirts.faye-rytale-pastel.description": "El proyecto secreto de diseño pastel de Faye.",
  "shirts.flora-golda-shirt.name": "Camiseta Flora Dorada",
  "shirts.flora-golda-shirt.description": "Parece que no tiene precio. Pero no es así.",
  "shirts.golden-mane-top.name": "Blusa Melena Dorada",
  "shirts.golden-mane-top.description": "¡Adecuado para la realeza!",
  "shirts.juninja-shirt.name": "Camiseta Junina",
  "shirts.juninja-shirt.description": "El diseño se inspiró en un rumor local sobre una fruta rodante.",
  "shirts.occult-dusk-top.name": "Blusa Ocaso oculto",
  "shirts.occult-dusk-top.description": "El sigilo es esencial para cumplir los deseos de la Dama...",
  "shirts.occult-leather-jacket.name": "Chaqueta de cuero oculta",
  "shirts.occult-leather-jacket.description": "Una variante de cuero del uniforme prescrito que llevan los sirvientes de la Dama de la Cola Roja.",
  "shirts.phoenix-confidence-jacket.name": "Chaqueta Confianza del Fénix",
  "shirts.phoenix-confidence-jacket.description": "Causa una impresión ardiente y llamativa.",
  "shirts.pika-impersonation-shirt.name": "Camiseta de imitación de Pika",
  "shirts.pika-impersonation-shirt.description": "Un remanente del día en que Lenny dictó una norma de vestimenta obligatoria en el cumpleaños de Pika sólo para fastidiarle.",
  "shirts.village-color-shirt.name": "Camiseta Color de la aldea",
  "shirts.village-color-shirt.description": "Un diseño abstracto compuesto por el color oficial de las aldeas.",
  "shirts.winter-royalty-top.name": "Blusa Realeza invernal",
  "shirts.winter-royalty-top.description": "¡Te ves realmente genial!",

  "weapons.amethyst-lance.name": "Lanza Amatista",
  "weapons.amethyst-lance.description": "Una antigua lanza hecha de cristales de amatista reforzados. Las leyendas dicen que esta arma fue utilizada una vez por el gobernante de un gran reino perdido.",
  "weapons.ark-blade.name": "Espada del Arca",
  "weapons.ark-blade.description": "Una espada perdida en el tiempo. En su empuñadura hay talladas ilustraciones de varias figuras.",
  "weapons.battery-powered-battle-hammer.name": "Martillo de batalla a pilas",
  "weapons.battery-powered-battle-hammer.description": "Un antiguo martillo que parece sospechosamente moderno en términos de diseño. Aún se desconocen muchas cosas sobre él. Sin embargo, es bastante potente.",
  "weapons.battle-dancers-fan.name": "Abanico de la Bailarina de Batalla",
  "weapons.battle-dancers-fan.description": "Abanico de afiladas hojas doradas. Cuenta la leyenda que esta arma era utilizada por las seductoras pero mortales bailarinas de batalla del pasado.",
  "weapons.blade-of-rubies.name": "Espada de Rubíes",
  "weapons.blade-of-rubies.description": "¡La hoja está hecha literalmente de rubíes reforzados!",
  "weapons.bladebane.name": "Navaja",
  "weapons.bladebane.description": "Un waraxe enorme con una cinta pálida envuelta alrededor del centro. Parece que lleva mucho tiempo sin usarse.",
  "weapons.bronze-lance.name": "Lanza de bronce",
  "weapons.bronze-lance.description": "Estar hecha de bronce no la convierte en un arma fiable. Aunque el cristal incrustado en su núcleo parece fortificar la lanza.",
  "weapons.bubble-club.name": "Clava Burbuja",
  "weapons.bubble-club.description": "Una clava muy contundente que produce burbujas al blandirla.",
  "weapons.celestine-sword.name": "Espada Celestina",
  "weapons.celestine-sword.description": "Una espada sagrada utilizada antaño por los seguidores de una religión ya extinta.",
  "weapons.cute-but-deadly-knife.name": "Cuchillo mono pero mortal",
  "weapons.cute-but-deadly-knife.description": "Cuchillo mono pero mortal.",
  "weapons.cutlasset.name": "Alfanje",
  "weapons.cutlasset.description": "Definitivamente reducirá los precios a la mitad.",
  "weapons.dagger-lily.name": "Daga Lily",
  "weapons.dagger-lily.description": "Una bonita y afilada daga cubierta de enredaderas y pétalos cristalizados de color púrpura.",
  "weapons.daggerkin.name": "Dagakin",
  "weapons.daggerkin.description": "Una daga lo suficientemente larga como para casi ser considerada una espada. Parece ser un arma muy popular entre los asesinos profesionales.",
  "weapons.deaths-daughter.name": "Hija de la Muerte",
  "weapons.deaths-daughter.description": "Una espada infame asociada a ser la musa del más allá.",
  "weapons.dusked-kunai.name": "Kunai del Ocaso",
  "weapons.dusked-kunai.description": "Un kunai especializado utilizado por los miembros de la Fuerza del Ocaso. Tiene una cuerda roja flexible unida a su base.",
  "weapons.fairy-needle.name": "Aguja de hadas",
  "weapons.fairy-needle.description": "Un arma caprichosa que te da vértigo por dentro.",
  "weapons.fathers-sorrow.name": "Pena del Padre",
  "weapons.fathers-sorrow.description": "Se cree que está maldita. Desde el más pequeño corte, una hoja así entrega misteriosamente miseria a sus víctimas... Pero, con el tiempo, también a su poseedor.",
  "weapons.fox-claw.name": "Garra de zorro",
  "weapons.fox-claw.description": "Una antigua daga utilizada por los seguidores del espíritu de la montaña.",
  "weapons.free-lance.name": "Lanza libre",
  "weapons.free-lance.description": "Es poco fiable debido a cómo se distribuye el peso. Pero es muy potente.",
  "weapons.frost-queens-blade.name": "Espada Reina de la Escarcha",
  "weapons.frost-queens-blade.description": "Es literalmente acero frío.",
  "weapons.golden-key-blade.name": "Cuchilla llave de oro",
  "weapons.golden-key-blade.description": "Una espada de forma extraña que pretende parecerse a una llave dorada. Debido al material de la espada, alcanza un alto precio.",
  "weapons.gourmet-cooking-knife.name": "Cuchillo de cocina gourmet",
  "weapons.gourmet-cooking-knife.description": "¡Cuchillo afilado para platos elegantes y de calidad! También sirve como arma mortal cuando no se usa para cocinar.",
  "weapons.guardian-greatsword.name": "Gran espada guardiana",
  "weapons.guardian-greatsword.description": "Arma de los antiguos guerreros nómadas que requiere una gran fuerza para blandirla correctamente.",
  "weapons.heartbreaker.name": "Rompecorazones",
  "weapons.heartbreaker.description": "Nudillos de latón con pinchos que ejercen una fuerza devastadora. Su nombre se debe al habitual knockback que sufren los enemigos al ser golpeados por uno de estos.",
  "weapons.icreon.name": "Icreon",
  "weapons.icreon.description": "Una antigua espada utilizada por una banda de cultistas que adoran a una deidad con una cola verde. Descubierta para ser usada comúnmente en sus rituales.",
  "weapons.laborforce.name": "Fuerza laboral",
  "weapons.laborforce.description": "Maza de confianza de un hombre honrado.",
  "weapons.lovesick.name": "Enamorado",
  "weapons.lovesick.description": "Un hacha de batalla con un cristal rosa en forma de corazón incrustado en el mango distal.",
  "weapons.military-saber.name": "Sable militar",
  "weapons.military-saber.description": "Un vestigio del pasado lejano. Según las leyendas, esta fue el arma utilizada por el héroe que evitó la emboscada en el valle que podría haber hecho perder a la república la primera guerra mundial.",
  "weapons.mountain-mistblade.name": "Espada Niebla de la Montaña",
  "weapons.mountain-mistblade.description": "Espada orgánica de energía espiritual y floral. Utiliza el ataque especial para disparar flores niebla a los enemigos, convirtiendo sus proyectiles en niebla inofensiva cuando son alcanzados.",
  "weapons.observers-hatchet.name": "Hacha del observador",
  "weapons.observers-hatchet.description": "Las leyendas que rodean a esta hacha cuentan que el primero en blandirla fue un guerrero silencioso y letal que disfrutaba observando constantemente a los demás. Se dice que el rubí incrustado en el cuerpo del hacha contiene el alma del guerrero, que sigue observando con agudeza en el más allá.",
  "weapons.occult-blade.name": "Espada oculta",
  "weapons.occult-blade.description": "Espada de doble filo con una estructura similar a la de una katana. La pequeña empuñadura roja representa a una mujer con una cola que la envuelve.",
  "weapons.pale-wings.name": "Alas pálidas",
  "weapons.pale-wings.description": "Arma de aspecto extraño que consta de un mango corto y cinco hojas ligeras y flexibles. Su guarda está adornada con gemas verdes y rojas.",
  "weapons.pearlskin-blade.name": "Espada de piel nacarada",
  "weapons.pearlskin-blade.description": "Una antigua espada restaurada de los tritones.",
  "weapons.prideful.name": "Orgullosa",
  "weapons.prideful.description": "Una daga adornada con esmeraldas en casi todas sus partes.",
  "weapons.princess-of-green.name": "Princesa de verde",
  "weapons.princess-of-green.description": "Una espada hecha de magia. Parece que las plantas que componen esta hoja están vivas, y son capaces de cambiar de forma para adaptarse. Un arma realmente interesante.",
  "weapons.prismarine-mallet.name": "Mazo Prismarino",
  "weapons.prismarine-mallet.description": "Mazo fabricado con un material desconocido. Según los investigadores, debe de ser un vestigio de una ciudad submarina perdida hace mucho tiempo.",
  "weapons.reaper-bane.name": "Perdición de la Muerte",
  "weapons.reaper-bane.description": "Usada por los guerreros que escaparon de las frías manos de la Muerte.",
  "weapons.ridgeback-hardshell.name": "Coraza Dorsal reforzada",
  "weapons.ridgeback-hardshell.description": "Un escudo de carey forrado de cobre en los bordes. Parece ser sólo un fragmento de un espécimen mucho mayor.",
  "weapons.river-harpoon.name": "Arpón de río",
  "weapons.river-harpoon.description": "Un arma delgada hecha específicamente para el combate bajo el agua. Parece estar imbuida por algún tipo de magia que hace que ignore el arrastre del agua.",
  "weapons.runic-greatsword.name": "Gran Espada Rúnica",
  "weapons.runic-greatsword.description": "La hoja está compuesta de cristal de obsidiana decorado con runas azul celeste.",
  "weapons.safeguards-edge.name": "Filo de salvaguarda",
  "weapons.safeguards-edge.description": "Espada que perteneció a un miembro de la guardia personal de un antiguo gobernante.",
  "weapons.sword-of-idols.name": "Espada de ídolos",
  "weapons.sword-of-idols.description": "Una espada antigua que se cree que ha pasado por diferentes generaciones de héroes y líderes. Mejor cuídala.",
  "weapons.the-green-gambler.name": "La Apostadora Verde",
  "weapons.the-green-gambler.description": "Una daga curva que recibe su nombre por sus misteriosas propiedades. Puede infligir grandes cantidades de daño o no infligir daño alguno.",
  "weapons.the-lucky-penny.name": "El penique de la suerte",
  "weapons.the-lucky-penny.description": "Se rumorea que la hoja se fundió a partir de varios peniques proclamados 'de la suerte' de diferentes personas. Si ese fuera el caso, ¿quién estuvo motivado para robar tantos de estos peniques para hacer una daga?",
  "weapons.the-madame.name": "La Dama",
  "weapons.the-madame.description": "Una gran espada adornada con piedras preciosas de amatista y diamante. Su grandioso diseño la hace parecer poco apta para el combate, aunque es sorprendentemente duradera.",
  "weapons.the-prankster.name": "La Bromista",
  "weapons.the-prankster.description": "Una espada pesada y ganchuda. Debe su nombre a que es demasiado inestable e impredecible para usarla en combate, aunque puede ser letal si se usa correctamente. El extraño diseño de la hoja es un gusto adquirido.",
  "weapons.the-silent-one.name": "La Silenciosa",
  "weapons.the-silent-one.description": "Una daga mística rodeada de un mito infame. Se dice que se produce un silencio ensordecedor cada vez que se usa esta daga para cometer un asesinato, y que se han visto entidades sobrenaturales mientras persiste el silencio.",
  "weapons.the-singing-dagger.name": "La Daga Cantante",
  "weapons.the-singing-dagger.description": "La misteriosa forma de la hoja crea una melodía silbante al blandirla. Muy poco práctica para asesinatos. También puede usarse como flauta. (No recomendado.)",
  "weapons.the-unbroken.name": "La Inquebrantable",
  "weapons.the-unbroken.description": "Una antigua espada llamada así por las leyendas que la rodean. Se dice que la hoja ha sido blandida por miles de usuarios diferentes, sin dejar nunca de servirles. Hecha de un material extraño e irrompible que se rumorea que está relacionado con los antiguos enanos.",
  "weapons.the-wild-whip.name": "El Látigo Salvaje",
  "weapons.the-wild-whip.description": "Un látigo con púas infame por la habilidad que se requiere para blandirlo. El látigo en sí está hecho de un material elástico forjado con trozos de iridio.",
  "weapons.tide-bringer.name": "Portador de la Marea",
  "weapons.tide-bringer.description": "Arma legendaria utilizada en su día por un héroe de una ciudad submarina perdida. Se dice que trajo la luz a los tiempos más oscuros de aquella antigua civilización.",
  "weapons.tough-love.name": "Amor Resistente",
  "weapons.tough-love.description": "Un pesado martillo de batalla con un golpe devastador. El ojo tiene una punta de lanza, que sirve como fuente adicional de daño. Según algunos aventureros, es bastante exagerado.",
  "weapons.treble-cleaver.name": "Cuchilla aguda",
  "weapons.treble-cleaver.description": "Un hacha doble ligera con filos muy afilados. La forma en que la hoja se enrosca alrededor del mango demuestra que el fabricante valoraba más el arte que la practicidad.",

  "objects.ancient-music-box.name": "Caja de música antigua",
  "objects.ancient-music-box.description": "Toca una melodía suave pero dulce. Tiene grabado un texto desvaído; 'mama esh'.",
  "objects.apricot-juice.name": "Zumo de albaricoque",
  "objects.apricot-juice.description": "¡Refrescante y relajante!",
  "objects.arugula-roll.name": "Rollo de rúcula",
  "objects.arugula-roll.description": "Rúcula fresca, bañada en salsa picante y descansando en un envoltorio de tortilla.",
  "objects.aurorean-iris.name": "Lirio Aurora",
  "objects.aurorean-iris.description": "'Sólo quiero que sepas quién soy'. - Algún cantante, probablemente.",
  "objects.autumn-dew-drop-juice.name": "Zumo de gotas de rocío otoñal",
  "objects.autumn-dew-drop-juice.description": "¡El sabor de las montañas, contenido en una sola bebida!",
  "objects.autumn-drop-berry.name": "Baya gota de otoño",
  "objects.autumn-drop-berry.description": "Sabe a noches lluviosas de otoño. Se encuentra comúnmente cerca de las crestas de las montañas. Tiene un sabor a nuez, pero dulce.",
  "objects.autumnal-serenity.name": "Serenidad otoñal",
  "objects.autumnal-serenity.description": "El especial de otoño de Pika. Con cada bocado, te 'enamorarás'.",
  "objects.bladetail-sturgeon.name": "Esturión de cola de espada",
  "objects.bladetail-sturgeon.description": "Un pez muy peligroso, con una cola tan afilada como una cuchilla. La sobrepesca provocó la disminución de la población de esta especie. Su cola puede haber servido como punta de flecha en la antigüedad.",
  "objects.caped-tree-frog.name": "Rana arborícola encapuchada",
  "objects.caped-tree-frog.description": "El dibujo rojo que cubre su cuello y espalda parece una capa. Cuando salta, mete un brazo mientras extiende el otro. Su rareza hizo que se convirtiera en una valiosa mascota entre los coleccionistas.",
  "objects.cardia-septal-jellyfish.name": "Medusa Cardia Septal",
  "objects.cardia-septal-jellyfish.description": "Verdadera maravilla biológica. Tiene un asombroso parecido con el tabique de un corazón y los ventrículos que lo conectan. Aunque es venenosa, está en peligro de extinción por su falta de movilidad.",
  "objects.cherry-berry-shakey.name": "Batido de cereza y bayas",
  "objects.cherry-berry-shakey.description": "¡Una bebida dulce y rica en cerezas adorada tanto por niños como por adultos!",
  "objects.cherry-pluot.name": "Pluot Cereza",
  "objects.cherry-pluot.description": "Una dulce mezcla de ciruela y albaricoque hibridación con una variante extranjera de cereza.",
  "objects.clementine-cake.name": "Tarta de clementina",
  "objects.clementine-cake.description": "¡Te hará pelar de maravilla!",
  "objects.clementine-juice.name": "Zumo de clementina",
  "objects.clementine-juice.description": "Un zumo dulce elaborado con la fruta local.",
  "objects.crimson-spiked-clam.name": "Almeja con púas carmesí",
  "objects.crimson-spiked-clam.description": "Una especie de almeja en peligro de extinción, cubierta de afiladas púas rojas. Tiene un precio muy alto por las perlas de color rubí que produce.",
  "objects.crunchy-bagel.name": "Bagel crujiente",
  "objects.crunchy-bagel.description": "¡Sencillo, dulce, redondo y crujiente!",
  "objects.cutthroat-trout.name": "Trucha degollada",
  "objects.cutthroat-trout.description": "Los dibujos rojos de su boca le dan un aspecto agresivo a pesar de ser dócil.",
  "objects.deep-ridge-angler.name": "Rape de las profundidades de la cresta",
  "objects.deep-ridge-angler.description": "Un pez legendario que se encuentra en el bosque profundo de la montaña. A menudo se confunde con un fantasma.",
  "objects.desert-tangelo.name": "Tangelo del desierto",
  "objects.desert-tangelo.description": "Un híbrido sin semillas de mandarina y pomelo que parece haber sido besado por el sol en el desierto.",
  "objects.elven-comb.name": "Peine de los Elfos",
  "objects.elven-comb.description": "Peine antiguo con gemas incrustadas. Los dibujos forman la palabra 'Zango'.",
  "objects.ember-blood-lime.name": "Lima Sanguinea de las Brasas",
  "objects.ember-blood-lime.description": "Una fruta relativamente ácida que es un cruce de mandarina y lima que es adecuada para salsas.",
  "objects.entombed-ring.name": "Anillo sepulcral",
  "objects.entombed-ring.description": "El anillo del interior de la gema parece tener un nombre grabado. El texto 'sheku' apenas puede leerse.",
  "objects.everfrost-stone.name": "Piedra escarchada",
  "objects.everfrost-stone.description": "¡Está helada al tacto! Se pueden congelar los dedos con sólo sostenerla demasiado tiempo.",
  "objects.fairytale-lionfish.name": "Pez león de cuento de hadas",
  "objects.fairytale-lionfish.description": "Una rara especie de pez león. Sus vibrantes colores le sirven de camuflaje. Se esconden en el arrecife de coral del Mar de las Gemas. Los rumores dicen que estos peces sirven como ingrediente para una antigua poción de amor.",
  "objects.fixer-eel.name": "Anguila fijadora",
  "objects.fixer-eel.description": "Un pariente cercano de la anguila eléctrica. Esta variante rara vez se encuentra en los ríos. Debe su nombre a la creencia local de que su carne puede curar cualquier tipo de enfermedad o tristeza. Debido a esta creencia, sufre de sobrepesca.",
  "objects.fluffy-apple-crumble.name": "Crumble de manzana esponjoso",
  "objects.fluffy-apple-crumble.description": "Por una manzana para siempre.",
  "objects.forage-souffle.name": "Suflé",
  "objects.forage-souffle.description": "Guarda silencio y nadie explotará.",
  "objects.forest-amancay.name": "Bosque Amancay",
  "objects.forest-amancay.description": "¡Sólo buenas vibraciones y sol emite esta flor!",
  "objects.forest-halva.name": "Bosque halva",
  "objects.forest-halva.description": "Una mezcla de diferentes dulces locales.",
  "objects.foxbloom.name": "Flor del zorro",
  "objects.foxbloom.description": "Una flor mítica que sólo existe en las leyendas. Desprende un aura sobrenatural.",
  "objects.freddies-sword.name": "Espada de Freddie",
  "objects.freddies-sword.description": "¡La espada de Freddie! Debe haberla perdido.",
  "objects.fried-fish-a-la-ridge.name": "Pescado frito a la cresta",
  "objects.fried-fish-a-la-ridge.description": "¡Un especial de Pika! El rico sabor umami se combina con un empanado crujiente y salado.",
  "objects.fried-mountain-greens.name": "Verduras de la montaña fritas",
  "objects.fried-mountain-greens.description": "¡Las verduras fritas nunca han sido tan sabrosas!",
  "objects.frost-clump-berry.name": "Baya de mata escarchada",
  "objects.frost-clump-berry.description": "Una extraña baya que sólo parece madurar cuando está cubierta de nieve. Sabe a uva con un toque de melón.",
  "objects.ginger-arugula-fried-rice.name": "Arroz frito con rúcula y jengibre",
  "objects.ginger-arugula-fried-rice.description": "Un humeante bol de arroz frito con verduras sazonado con jengibre. Bueno para el estómago si te encuentras mal.",
  "objects.ginger-rangpur-meringue.name": "Merengue de jengibre Rangpur",
  "objects.ginger-rangpur-meringue.description": "Un postre que combina la audacia del jengibre y el rangpur con la ligereza del merengue. A pesar de su riqueza, es bueno para la digestión.",
  "objects.glove-of-the-assassin.name": "Guante del Asesino",
  "objects.glove-of-the-assassin.description": "Te hace invisible a los enemigos hasta que estés directamente en su campo de visión. (Úsalo en la ranura del anillo.)",
  "objects.golden-rose-fin.name": "Aleta Rosa Dorada",
  "objects.golden-rose-fin.description": "Un pequeño pez con aletas anchas pero finas. Al nadar, el movimiento de estas singulares aletas le confiere una apariencia de danza mientras gira y se desplaza por el agua.",
  "objects.golden-skull-coral.name": "Coral calavera dorada",
  "objects.golden-skull-coral.description": "Réplica en forma de estatua dorada de una especie extinta de coral de la era antigua.",
  "objects.harvester-trout.name": "Trucha cosechadora",
  "objects.harvester-trout.description": "Obtuvo su nombre por 'cosechar' cultivos y plantas que crecen cerca del agua. Este comportamiento destructivo ha hecho que este pez sea considerado una plaga. A pesar de ello, sigue siendo popular debido a su carne tierna y aceitosa.",
  "objects.highland-blueberry-pie.name": "Tarta de arándanos de las Tierras Altas",
  "objects.highland-blueberry-pie.description": "A pesar de lo que su nombre pueda sugerir, ¡te saca el azul!",
  "objects.highland-butterwort.name": "Pinguicula de las Tierras Altas",
  "objects.highland-butterwort.description": "¡A los niños les encanta utilizarla en los juegos locales!",
  "objects.highland-chard.name": "Acelga de las Tierras Altas",
  "objects.highland-chard.description": "Una planta de hoja verde que se encuentra sobre todo en las crestas de las montañas. Tiene un sabor delicado pero picante que se vuelve amargo cuando hace demasiado calor. Se utiliza en ensaladas.",
  "objects.highland-ice-cream.name": "Helado de las Tierras Altas",
  "objects.highland-ice-cream.description": "Helado especial elaborado en Ridgeside Village. Una delicia que se disfruta mejor mientras se admira la vista de la ladera de la montaña.",
  "objects.highland-jostaberry.name": "Jostaberry de las Tierras Altas",
  "objects.highland-jostaberry.description": "Semejante a una grosella espinosa y una grosella negra fundidas en una, esta variante ha evolucionado hasta cultivarse en árboles y ser común en los continentes fríos.",
  "objects.highland-revani.name": "Basbusa de las Tierras Altas",
  "objects.highland-revani.description": "Un pastel dulce y cítrico.",
  "objects.holiday-ice.name": "Hielo navideño",
  "objects.holiday-ice.description": "¡Helado de una exótica fruta tropical! Incluso tiene una sombrillita para darle un toque tropical extra.",
  "objects.hollowed-bear.name": "Oso ahuecado",
  "objects.hollowed-bear.description": "Parece un viejo oso de peluche. Lo raro es que el exterior es rígido y por dentro está hueco.",
  "objects.honey-ginger-whitefish.name": "Pescado blanco con miel y jengibre",
  "objects.honey-ginger-whitefish.description": "Pescado blanco de montaña marinado en una clásica salsa agridulce. Es sorprendentemente suave para el estómago.",
  "objects.honey-glazed-salad.name": "Ensalada glaseada con miel",
  "objects.honey-glazed-salad.description": "Ensalada especial de Pika, glaseada con miel casera. ¡Súper dulce!",
  "objects.hundred-flavor-doughnut.name": "Rosquilla de cien sabores",
  "objects.hundred-flavor-doughnut.description": "¡Cada pizca sabe diferente!",
  "objects.inked-fossil.name": "Fósil entintado",
  "objects.inked-fossil.description": "La huella del cráneo en forma de dragón en el fósil parece estar delineada por algún tipo de tinta permanente. Lo extraño es que la tinta parece fresca para algo antiguo.",
  "objects.jumpy-coffee-cake.name": "Pastel de Café Saltarín",
  "objects.jumpy-coffee-cake.description": "¡¡Te mocha loco!!",
  "objects.kedi-delight.name": "Delicia Kedi",
  "objects.kedi-delight.description": "Dulce de almidón y azúcar, a menudo elaborado con sabores únicos.",
  "objects.keks-small-dream.name": "Pequeño Sueño de Kek",
  "objects.keks-small-dream.description": "Como el grande, pero con menos cantidad.",
  "objects.keks-style-shortcake.name": "Tarta estilo Kek",
  "objects.keks-style-shortcake.description": "¡Un dulce manjar! ¿Pero quién ha afeitado esa fresa?",
  "objects.lava-lily.name": "Lirio de lava",
  "objects.lava-lily.description": "Emite una sensación de calor. Una flor agradable para sostener en el frío.",
  "objects.lovers-sorrow.name": "Pena del amante",
  "objects.lovers-sorrow.description": "El misterio rodea a esta escultura de piedra de una rosa. Algunos dicen que es una flor antigua petrificada. Sea como fuere, este objeto se ha relacionado con desgracias que han caído sobre parejas que lo tenían en su poder.",
  "objects.lullaby-carp.name": "Carpa melodía de cuna",
  "objects.lullaby-carp.description": "Un misterio científico. Cuando se le deja solo, este pez produce melodías relajantes, aunque no posee ningún sistema interno que le permita 'cantar'.",
  "objects.matcha-latte.name": "Matcha Latte",
  "objects.matcha-latte.description": "El café y el té verde conviven en perfecta armonía.",
  "objects.mistbloom-syrup.name": "Jarabe Flor Niebla",
  "objects.mistbloom-syrup.description": "Néctar exprimido de Flores Niebla de la montaña, este extraño líquido puede ayudar a curar las náuseas.",
  "objects.moose-statue.name": "Estatua del Gran Espíritu del Río",
  "objects.moose-statue.description": "Una escultura de una deidad olvidada hace mucho tiempo.",
  "objects.mountain-arugula.name": "Rúcula de la montaña",
  "objects.mountain-arugula.description": "Cultivo de clima fresco que se encuentra en las crestas de las montañas. Según los lugareños, da un impulso temporal a la suerte.",
  "objects.mountain-chico.name": "Níspero de la montaña",
  "objects.mountain-chico.description": "Una fruta inusual que difiere de sus parientes. Esta variedad crece en arbustos silvestres en lugar de árboles.",
  "objects.mountain-hokkaido.name": "Hokkaido de la montaña",
  "objects.mountain-hokkaido.description": "La belleza que tiene suites bien con brisa de montaña.",
  "objects.mountain-mistbloom.name": "Flor Niebla de la montaña",
  "objects.mountain-mistbloom.description": "Una misteriosa flor brillante que florece durante los días de lluvia en el denso bosque de montaña. No emite ningún tipo de olor.",
  "objects.mountain-plumcot.name": "Plumcot de la montaña",
  "objects.mountain-plumcot.description": "Una mezcla perfectamente homogénea de ciruela y albaricoque que sólo se encuentra en las montañas de los continentes orientales. Algunos incluso dicen que son frutas de hueso.",
  "objects.mountain-redbelly-dace.name": "Lucio panza roja de la montaña",
  "objects.mountain-redbelly-dace.description": "Especie escurridiza y difícil de capturar. Su carne es muy sabrosa.",
  "objects.mountain-whitefish.name": "Pez blanco de la montaña",
  "objects.mountain-whitefish.description": "A pesar de reflejar la luz con facilidad, sus movimientos ágiles e irregulares lo hacen sorprendentemente difícil de pescar.",
  "objects.nightblack-diamond.name": "Diamante negro nocturno",
  "objects.nightblack-diamond.description": "Un diamante de bordes afilados con un tinte negro. La base apenas refleja la luz, así que asegúrate de no perderlo en la oscuridad.",
  "objects.northern-limequat.name": "Limequat del norte",
  "objects.northern-limequat.description": "A menudo un sustituto de limones o limas, ¡pero no subestimes esta fruta del norte! Es perfecta para equilibrar recetas dulces.",
  "objects.old-lucky-foxtail-charm.name": "Amuleto Cola de Zorro de la Suerte",
  "objects.old-lucky-foxtail-charm.description": "Una pulsera que solía pertenecer a tu abuela.",
  "objects.opal-halo.name": "Halo ópalo",
  "objects.opal-halo.description": "Una pieza de tocado antiguo con piedras de ópalo incrustadas. Tiene tallado un ángel en el lateral.",
  "objects.pale-candelabrum.name": "Candelabro pálido",
  "objects.pale-candelabrum.description": "Las velas están forradas con dibujos de calaveras. La mecha parece estar húmeda, lo que dificulta el encendido de las velas.",
  "objects.paradise-rangpur.name": "Rangpur del Paraíso",
  "objects.paradise-rangpur.description": "Una vez que lo pruebes, ¡definitivamente te llevará al paraíso con su sabor a lima intensamente ácido y ahumado! Perfecto para manjares con clase.",
  "objects.pebble-back-crab.name": "Cangrejo espalda de guijarros",
  "objects.pebble-back-crab.description": "Los guijarros que adornan su espalda son recogidos por el pez cuando es joven, sirviéndole como defensa y camuflaje. Algunos recogen accidentalmente piedras preciosas, por lo que son cazados en exceso por los humanos.",
  "objects.pillowsoft-cheezy-sandwich.name": "Sándwich de queso almohadillado",
  "objects.pillowsoft-cheezy-sandwich.description": "¡El queso es tan esponjoso!",
  "objects.pink-frosted-sprinkled-doughnut.name": "Rosquilla rosa glaseada espolvoreada",
  "objects.pink-frosted-sprinkled-doughnut.description": "De esto debe estar hecho el arco iris.",
  "objects.pumpkin-darling-slice.name": "Calabaza Rebanada Dulce",
  "objects.pumpkin-darling-slice.description": "¡Es calabaza guay!",
  "objects.relic-fox-mask.name": "Máscara Reliquia del Zorro",
  "objects.relic-fox-mask.description": "Una máscara antigua que se asemeja a un zorro. Tiene un texto escrito alrededor del borde del ojo: 'Mares agitados'.",
  "objects.richards-glasses.name": "Gafas de Richard",
  "objects.richards-glasses.description": "¡Las gafas de Richard! Las habrá perdido.",
  "objects.ridge-apple-cake.name": "Tarta de manzana de la cresta",
  "objects.ridge-apple-cake.description": "¡Dulce y reconfortante hasta la médula!",
  "objects.ridge-azorean-flower.name": "Flor Azores de la cresta",
  "objects.ridge-azorean-flower.description": "La primavera huele mejor gracias a esta flor.",
  "objects.ridge-bluegill.name": "Pez Azul de la cresta",
  "objects.ridge-bluegill.description": "¡Se mezcla bien con el agua del río! No lo pierdas de vista!",
  "objects.ridge-cherry.name": "Cereza de la cresta",
  "objects.ridge-cherry.description": "Un tipo de cereza que se encuentra cerca de las crestas de las montañas. Presenta un sabor ácido y dulce.",
  "objects.ridge-fruity-plate.name": "Plato afrutado de la cresta",
  "objects.ridge-fruity-plate.description": "¡Una ensalada de frutas rellena de frutas de montaña, cubierta con un aderezo especial!",
  "objects.ridge-mosaic-cake.name": "Tarta mosaico de la cresta",
  "objects.ridge-mosaic-cake.description": "Dulce compuesto de cacao y galletas.",
  "objects.ridge-wild-apple.name": "Manzana silvestre de la cresta",
  "objects.ridge-wild-apple.description": "Un tipo de manzana que tiene pequeñas espinas rojas a lo largo de la piel. Su sabor es idéntico al de la piña, con la diferencia de que hay menos cantidad para comer.",
  "objects.ridgeside-bass.name": "Lubina de Ridgeside",
  "objects.ridgeside-bass.description": "Un pez de montaña nativo de Ridgeside Village.",
  "objects.ridgeside-clementine.name": "Clementina de Ridgeside",
  "objects.ridgeside-clementine.description": "Muy parecida a una clementina normal; la diferencia es su regusto a nuez. El clima frío del invierno y la gran altitud impiden que esta fruta se pudra demasiado rápido.",
  "objects.ridgeside-monkshood.name": "Acónito de Ridgeside",
  "objects.ridgeside-monkshood.description": "Calma hasta al más cascarrabias.",
  "objects.ridgeside-shaketini.name": "Shaketini de Ridgeside",
  "objects.ridgeside-shaketini.description": "Una especialidad de la aldea de Ridgeside.",
  "objects.sapphire-pearl.name": "Perla zafiro",
  "objects.sapphire-pearl.description": "Una antigua reliquia de la cresta. Es una amalgama única de una gema de zafiro y una perla.",
  "objects.shell-bracelet.name": "Pulsera de conchas",
  "objects.shell-bracelet.description": "El olor del océano aún perdura en este antiguo accesorio. Un texto extranjero está grabado en el borde de la concha.",
  "objects.sierra-wintergreen.name": "Gaulteria de la Sierra",
  "objects.sierra-wintergreen.description": "Una flor preciosa para regalar y decorar durante las vacaciones de invierno.",
  "objects.silver-fish-bones.name": "Huesos de pez plateados",
  "objects.silver-fish-bones.description": "Una misteriosa reliquia de huesos de plata con forma de pez incrustados en piedra antigua.",
  "objects.skulpin-fish.name": "Skulpin",
  "objects.skulpin-fish.description": "Las espinas que rodean sus aletas son blandas a menos que se sobresalte. Así que sé amable.",
  "objects.snow-bowl-surprise.name": "Cuenco sorpresa nevada",
  "objects.snow-bowl-surprise.description": "Fruta silvestre local, maridada con virutas de hielo limpio, sirope y cerezas.",
  "objects.snowball-slurpee.name": "Sorbete Bola de nieve",
  "objects.snowball-slurpee.description": "Una mezcla de diferentes frutas de invierno. Una golosina invernal fresca y dulce.",
  "objects.sockeye-salmon.name": "Salmón Rojo",
  "objects.sockeye-salmon.description": "¡El codiciado pez legendario de Ridgeside Village! ¡Es dócil y le gusta comer cerezas!",
  "objects.spiritual-essence.name": "Esencia espiritual",
  "objects.spiritual-essence.description": "Una misteriosa colección de guijarros que brillan tenuemente.",
  "objects.springtime-primetime.name": "Horario estelar primaveral",
  "objects.springtime-primetime.description": "El especial de primavera de Pika. Tu apetito florece mientras lo contemplas.",
  "objects.strawberry-lover-pie.name": "Tarta Amante de Fresas",
  "objects.strawberry-lover-pie.description": "Te hace sentir un poco especial por dentro, monada de fresa.",
  "objects.summer-mountain-blessing.name": "Bendición montaña de verano",
  "objects.summer-mountain-blessing.description": "El especial de verano de Pika. El plato que te calienta, ¡en el buen sentido!",
  "objects.summit-iced-tea.name": "Té helado de la cumbre",
  "objects.summit-iced-tea.description": "¡El refresco especial de la cumbre!",
  "objects.summit-snowbell.name": "Campanilla de nieve de la cumbre",
  "objects.summit-snowbell.description": "¡Es una señal local de que se acerca el invierno!",
  "objects.sweet-cranberry-cheesecake.name": "Tarta de queso con arándanos dulces",
  "objects.sweet-cranberry-cheesecake.description": "Un dulce muy mono para una persona muy mono.",
  "objects.tropi-ugli-fruit.name": "Fruta Ugli Tropical",
  "objects.tropi-ugli-fruit.description": "No te dejes engañar por su nombre, esta es una fruta hermosa y sabrosa que es dulce y ácida con un toque de picante. Merece la pena probarla. ¿No es una belleza?",
  "objects.tropic-mango-cake.name": "Tarta de mango tropical",
  "objects.tropic-mango-cake.description": "Hecha de mangos, ¡esta tarta tiene mango!",
  "objects.village-hero-sculpture.name": "Escultura del héroe del pueblo",
  "objects.village-hero-sculpture.description": "Una figura vagamente familiar. Esta reliquia está cubierta de musgo, pero el material que compone el objeto no muestra signos de rotura.",
  "objects.violet-devils-claw.name": "Garra de diablo violeta",
  "objects.violet-devils-claw.description": "Su seductor aroma y su estética la hacen popular para perfumes y decoraciones.",
  "objects.warp-totem-ridgeside.name": "Tótem de Ridgeside",
  "objects.warp-totem-ridgeside.description": "Teletransporta directamente a Ridgeside Village. Se consume al usarlo.",
  "objects.waterfall-snakehead.name": "Cascada cabeza de serpiente",
  "objects.waterfall-snakehead.description": "Su cabeza en forma de serpiente se ha adaptado para ser dura como un canto rodado debido a la fuerza extrema de las cascadas que rodean su hábitat. Es uno de los peces legendarios de la cresta!",
  "objects.wild-apple-juice.name": "Zumo de Manzana Silvestre",
  "objects.wild-apple-juice.description": "¡Te hace tan manzanita!",
  "objects.winter-night-feast.name": "Fiesta nocturna invernal",
  "objects.winter-night-feast.description": "El especial de invierno de Pika. La comida que sigue dando, o eso dicen.",
  "objects.yellow-wood-sculpture.name": "Escultura de madera amarilla",
  "objects.yellow-wood-sculpture.description": "El rostro de la antigua figura me resulta vagamente familiar. Pero no se puede saber de quién se trata.",
  "objects.yuumas-ring.name": "Anillo de Yuuma",
  "objects.yuumas-ring.description": "¡El anillo de Yuuma! Debe haberlo perdido.",
  "objects.zesty-tuna.name": "Atún con salsa picante",
  "objects.zesty-tuna.description": "¡Atún ahumado con salsa de cítricos! Es una especialidad de Ridgeside.",
  //Deity rings
  "objects.the-beautiful-serpents-ring.name": "El hermoso Anillo de la Serpiente",
