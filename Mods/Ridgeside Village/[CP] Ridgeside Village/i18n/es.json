//Faye 6 heart
  "event-75160416.01": "¡Hola, @!$h#$b#Espera un segundo. Estoy esperando a Keahi.",
  "event-75160416.02": "¡Casi listo, Faye!$h",
  "event-75160416.03": "Hey ven y haz que se vea bonito, Keahi.",
  "event-75160416.04": "¡Ese fabuloso dúo de padre e hijo quería que probara la versión de Keahi de una tortilla!$h#$b#¡¿No es fabuloso?!$h",
  "event-75160416.05": "¡Hecho!$h#$b#¡Vamos! ¡Woop woop!$h",
  "event-75160416.06": "¡Ya está aquí!$h",
  "event-75160416.07": "¡Pruébalo! ¡Pruébalo!$h",
  "event-75160416.08": "Gracias de nuevo por seguirle la corriente, Faye.#$b#¡No te preocupes! Este hombrecito tiene algunas habilidades culinarias decentes.$h",
  "event-75160416.09": "¡Sabes que siempre soy bienvenida para una comida!$h#$b#¡Tiene una pinta fabulosa!$h",
  "event-75160416.10": "¡Come! ¡Come!$h",
  "event-75160416.11": "¡Fabulosamente delicioso!$h",
  "event-75160416.12": "¡Sí! ¡Faye dijo que estaba sabroso, papá!$h",
  "event-75160416.13": "¡Buen trabajo, chaval!$h",
  "event-75160416.14": "¡Hey @! Ven a comer un poco conmigo.$h#$b#Espera. Un mordisco más y es todo tuyo.",
  "event-75160416.15": "*munch munch* ¡Espera! ¡Último bocado! ¡Lo juro!$8",
  "event-75160416.16": "*munch* ¡Espera! ¡Juro que este es el último bocado!$8",
  "event-75160416.17": "Faye al final sólo consiguió darte una cucharada de tortilla.#¡Seguro que estaba sabrosa!",
  "event-75160416.18": "*Burp* ¡Siento mucho haberme dejado llevar! ¡Estaba tan rica!$h",

}
