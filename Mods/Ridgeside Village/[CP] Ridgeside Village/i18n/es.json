"MapString.rsv.52": "Clínica Ridgeside.",
"MapString.rsv.53": "Tienda de conveniencia Heaps.",
"MapString.rsv.54": "Residencia de Ahn Yojeong Faye.#¡Vendiendo ropa dentro!",
"MapString.rsv.55": "Residencia de Amethyne",
"MapString.rsv.56": "Residencia de los Rivera",
"MapString.rsv.57": "La naturaleza ha parecido tragarse este coche averiado.",
"MapString.rsv.58": "La matrícula dice 'CH1C0-R1C0'.",
"MapString.rsv.59": "¡Un barril lleno de peces!#Qué vista tan piscícola.", //keks is lovely!
"MapString.rsv.60": "¡Barriles y cajas llenas de provisiones!",
"MapString.rsv.61": "¿Quién dejó esta cesta de frutas aquí?",
"MapString.rsv.62": "Una linda casita de mascotas improvisada.#Un cartel está pegado a ella, dice:#'Torts'",

"MapString.rsv.ian13": "Los cajones de Sean.#¡Es un poco desordenado!",
"MapString.rsv.ian14": "Hay algo de ropa tirada por ahí.",

//eshadow u awesome!!
"MapString.rsv.faye1": "¡Una linda flor en una maceta con diseños de hadas!",
"MapString.rsv.faye2": "El tocador de Faye.#Debería practicar la decencia y ocuparme de mis asuntos.",
"MapString.rsv.faye3": "¡Las tijeras están increíblemente afiladas!#¡Ten cuidado ahora!",
"MapString.rsv.faye4": "¡Este trozo de tela es increíblemente suave y brillante!",
"MapString.rsv.faye5": "La rueda parece haber sido usada con cuidado.",
"MapString.rsv.faye6": "Una colección de diferentes sedas e hilos.",
"MapString.rsv.faye7": "'El baile de los hilos y las agujas.'#'Por Mamá Esh'",
"MapString.rsv.faye8": "Un papel lleno de diferentes números de contacto está pegado en el teléfono.",
"MapString.rsv.faye9": "¡La comida parece sabrosa!#Aunque no debería probar un bocado.",
"MapString.rsv.faye10": "Un elegante vino rosado.#¡Está medio lleno!#O también lo veo medio vacío.",
"MapString.rsv.faye11": "Parece una especie de formulario de solicitud de una famosa marca de ropa.",
"MapString.rsv.faye12": "Hay un dibujo de un diseño abstracto para un vestido.",
"MapString.rsv.faye13": "¡La radio está llena de pegatinas bonitas!",
"MapString.rsv.faye14": "'Los fundamentos del diseño'#'Por E. Shadow'",
"MapString.rsv.faye15": "La lista de tareas de Faye. Está dibujada con todo tipo de colores y divertidos rotuladores de gel, pero en su mayor parte está sin marcar...",
"MapString.rsv.faye16": "La lista de tareas de Irene. Aquí hay suficiente escritura como para llenar una novela, pero la caligrafía sigue siendo exquisita.",

"MapString.rsv.hotel34": "La máquina de café expreso es muy expresiva.",
"MapString.rsv.hotel35": "¡Un montón de utensilios de repostería ordenados!",
"MapString.rsv.hotel36": "¡Pasteles sabrosos en exhibición!",

//hi kedi, you're a-meow-zing
"MapString.rsv.clinic1": "¡Una colección de carpetas!#No parece que se trate de historiales clínicas.#¡Sería aterrador tenerlas a la vista si ese fuera el caso!",
"MapString.rsv.clinic2": "El sistema está bloqueado con una contraseña.",
"MapString.rsv.clinic3": "Parece una receta de algo.#Es un poco difícil de leer.",
"MapString.rsv.clinic4": "¡La cocina está limpia y ordenada!",
"MapString.rsv.clinic5": "El tocador de Paula.#¡Aprende a tener modales y déjalo estar!",
"MapString.rsv.clinic6": "Una colección de libros y literatura médica.",
"MapString.rsv.clinic7": "Parece que un libro ha sido depositado con demasiada prisa.#Se lee 'Diario'.#Lentamente lo devuelves.",

//hello harvz, you're awesome <
"MapString.rsv.3bros1": "Las estanterías están llenas de diferentes surtidos de artículos.",
"MapString.rsv.3bros2": "Una bolsa con la etiqueta 'Comida para mascotas'.#¿Para qué mascota exactamente? ¡No sale en ningún sitio!",
"MapString.rsv.3bros3": "El famoso acondicionador para el cabello 'Cuidado del cabello Harvz'.",
"MapString.rsv.3bros4": "Una nevera llena de botellas de agua.",
"MapString.rsv.3bros5": "Está vacía por dentro.#Parece que hay un garabato escrito en el borde.#'El escondite de Kia'.",
"MapString.rsv.3bros6": "'Negocio ocupado número 3' por Tia Kall.",
"MapString.rsv.3bros7": "20 maneras de cocinar fideos.#Un montón de notas de enfado están escritas por todas partes.",
"MapString.rsv.3bros8": "Un libro lleno de nombres.#'Sean - debe$10 por los refrescos#Sean - debe$5 por la sal#Keahi - debe$5 por los materiales de artesanía",
"MapString.rsv.3bros9": "'¡Venta sólo por tiempo limitado!'",
"MapString.rsv.3bros10": "Una pila de pesas.#Aunque están un poco polvorientas.",
"MapString.rsv.3bros11": "¡La nevera está llena de diferentes ingredientes!#A alguien le debe gustar cocinar.",
"MapString.rsv.3bros12": "Parece que la cocina ha sido limpiada recientemente.",
"MapString.rsv.3bros13": "Hay un montón de papeles arrugados en el interior.#En uno de ellos se puede ver un atisbo de los diseños de la casa.",
"MapString.rsv.3bros14": "¡Está lleno de tomates usados!",
"MapString.rsv.3bros15": "El portátil de Kiarra.#Parece que hay un cartel sin terminar.",
"MapString.rsv.3bros16": "La cómoda de la familia.#Todo parece caber dentro.",
"MapString.rsv.3bros17": "Está vacío por dentro.#Parece que hay un texto escrito en el borde.#'Escondite de respaldo de Kia'.",
"MapString.rsv.3bros18": "Tic-tac dice el ruidoso reloj.#Espera, parece que hay una nota dentro.#No puedes alcanzarla.",

//foggywizard is fabulous af!
//MAXSKELL IS AMAZING
"MapString.rsv.purplemansion1": "La planta parece sofisticada y cara.#¿Esto es real?",
"MapString.rsv.purplemansion2": "Una flor tan bonita.",
"MapString.rsv.purplemansion3": "Esta flor es linda.",
"MapString.rsv.purplemansion4": "Ternura surge de esta flor.",
"MapString.rsv.purplemansion5": "La flor desprende ternura.",
"MapString.rsv.purplemansion6": "La planta parece... intimidante.#¿Acaba de hablar?",
"MapString.rsv.purplemansion7": "Una decoración de aspecto majestuoso y costoso.#¡Mantén la distancia ya que parece que podría caer con un simple empujón!",
"MapString.rsv.purplemansion8": "¡Parece que podrías saltar a la pantalla en cualquier momento!",
"MapString.rsv.purplemansion9": "¿Por qué el televisor se siente atraído por el mando a distancia?#Porque lo enciende.",
"MapString.rsv.purplemansion10": "'Moda de ahora' de Kedi la kedi.",
"MapString.rsv.purplemansion11": "Parece un libro de fotos.#¡Contiene fotos de diferentes amatistas!",
"MapString.rsv.purplemansion12": "Diferente surtido de objetos todos escondidos dentro de cajas.",
"MapString.rsv.purplemansion13": "Un montón de objetos guardados ordenadamente en estanterías.",
"MapString.rsv.purplemansion14": "Etiquetado 'Mermelada de Umuwi'.",
"MapString.rsv.purplemansion15": "Etiquetado 'Frutas de East Scarp.'",
"MapString.rsv.purplemansion16": "El café aún está caliente.#Alguien lo habrá dejado aquí.",
"MapString.rsv.purplemansion17": "Una variedad de hermosas flores están expuestas dentro del cristal.#¡Se ven tan bonitas!",
"MapString.rsv.purplemansion18": "En la radio está sonando algún tipo de canción clásica.",
"MapString.rsv.purplemansion19": "Un acuario gigante vacío.#Parece que se están preparando para poner algo enorme dentro.",
"MapString.rsv.purplemansion20": "Esta estatua te parece bastante croacienta.",
"MapString.rsv.purplemansion21": "La estatua parece triste.#Parece que lleva un pajarito.",
"MapString.rsv.purplemansion22": "Está un poco inclinada hacia la derecha.#Hace que parezca que está torcida.",
"MapString.rsv.purplemansion23": "El legendario Junimo.#Sientes un poco de magia emanando de él.",
"MapString.rsv.purplemansion24": "Está cerrada con llave.#Al echar un vistazo desde los huecos, puedes ver algunos objetos brillantes escondidos dentro.",
"MapString.rsv.purplemansion25": "Una colección de pinturas.#Parece que son tratadas con cuidado.",
"MapString.rsv.purplemansion26": "'Pintura para principiantes' de Tai Yo.",
"MapString.rsv.purplemansion27": "Parece un boceto inacabado de un prado.",
"MapString.rsv.purplemansion28": "Un surtido diferente de colores.",
"MapString.rsv.purplemansion29": "El tocador de Irene.#No debería abrirlo.",
"MapString.rsv.purplemansion30": "La cómoda de Sonny.#Debería ocuparme de mis asuntos.",
"MapString.rsv.purplemansion31": "La estatua de Yoba.#Mirarla te hace sentir a gusto.",
"MapString.rsv.purplemansion32": "Un enorme cristal verde con la etiqueta 'Artefacto del Espíritu de la Montaña'.",
"MapString.rsv.purplemansion33": "Una gema extraña.#Hay una nota junto a ella.#'Usa esta gema para buscar el espíritu de la montaña.'#'O eso es lo que dijo ese comerciante'",
"MapString.rsv.purplemansion34": "'Los secretos de las montañas' de Grim.",
"MapString.rsv.purplemansion35": "'Semanal Yoba' por Ayr Ryn.",
"MapString.rsv.purplemansion36": "El tocadiscos está bloqueado por algún tipo de código de acceso.#Tal vez para evitar que los visitantes lo usen sin permiso.",
"MapString.rsv.purplemansion37": "¡Un enorme diccionario!#Actualmente está en la página que muestra la palabra 'Fiabilidad'.",
"MapString.rsv.purplemansion38": "Una pila de libros llena de marcadores.",
"MapString.rsv.purplemansion39": "El libro se titula 'La historia de los primeros Ferngill'",
"MapString.rsv.purplemansion40": "Parece que hay un papel escondido bajo la planta.#Hay un dibujo de un niño cogido de la mano con sus padres y su hermano con un garabato 'Te echo de menos.'",
