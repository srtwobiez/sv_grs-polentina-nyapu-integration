//Keahi Stink Bomb Prank

"keahiprank.Alissa": "Ey, em, ¿@?#$b#Parece que estás muy apestoso.$s^Parece que estás muy apestosa.$s#$b#Em, espero que no haya sido grosera.$s",
"keahiprank.Corine": "¿@? Estás muy apestoso.$s^¿@? Estás muy apestosa.$s#$b#¿Puedes ducharte antes de socializar?$s",
"keahiprank.Flor": "Emm... ¿@? ¿Te has olvidado de ducharte?$s",
"keahiprank.Maddie": "¿Qué es ese olor penetrante?$a#$b#¡Oh! ¡Eres tú!$7#$b#¡Por favor, cumple con las normas de higiene de la sociedad!$a",
"keahiprank.Ysabelle": "%Ysabelle te huele antes de casi vomitar.#$b#Uh, ¿@? Te aconsejo que te duches inmediatamente.$a",
"keahiprank.Ian": "¿Qué es ese olor?$a#$b#¡Oh! ¡Viene de ti!$u#$b#Emm... el trabajo duro hace que uno sude a veces, ¿verdad?$s#$b#Pero @, creo que te has saltado la ballena.$s",
"keahiprank.Jeric": "Oh, guau, ¿¡qué es ese olor!?$a#$b#¡Voy a vomitar!$s",
"keahiprank.Kenneth": "¿Oye @? ¿Ese olor viene de ti?$s#$b#Em, ¿has pisado algo?$s",
"keahiprank.Philip": "%Philip parece que va a devolver.$u#$b#¿Qué es ese olor sobrenatural?$u",
"keahiprank.Shiro": "Oh... ese olor me está mareando.$s#$b#¿¡De dónde viene ese olor!?$a",
"keahiprank.Aguar": "Hueles a azufre.#$b#Tal vez deberías bañarte más a menudo, @.",
"keahiprank.Bert": "¿Ese olor viene de ti?$u#$b#¡Oh Yoba, libérame de este olor penetrante!$s",
"keahiprank.Ezekiel": "¡Bah! ¡Hueles a leche de cabra de una semana!$a#$b#¡Aléjate de mí!$a",
"keahiprank.Freddie": "Incluso con esta vieja nariz, puedo decir que hay algo realmente malo en ese olor.$s",
"keahiprank.Jio": "Hueles como un espíritu de pantano.#$b#Por favor, vete.$h",
"keahiprank.Kiwi": "¡Kiwi cree que apestas!$s#$b#¡No te acerques, o Kiwi te apuñala!$a",
"keahiprank.Lenny": "¿Hueles algo?$u#$b#Ese olor.$a#$b#Una especie de olor apestoso.$s#$b#El olor apestoso que huele... apestoso.$s#$b#Por casualidad, ¿te encontraste con Keahi hoy, @?$4",
"keahiprank.Lola": "@, querido...^@, querida...#$b#Quizás quieras darte una ducha.$s",
"keahiprank.Olga": "¡Oh, no, lo ha hecho de nuevo!$a#$b#¡Keahi realmente va a conocer a su creadora hoy!$a",
"keahiprank.Pika": "Ah, hueles como la Pua Kupapau.$h#$b#Una flor conocida por su penetrante aroma.#$b#También es conocida como la flor del cadáver por su pútrido olor.",
"keahiprank.Richard": "¡Oh, no! ¡En mi hotel no!$a#$b#¡Ve a bañarte primero!$a",

"keahiprank.Keahi": "¡Ooohh! ¡Eso APESTA!$h#$b#REALMENTE deberías bañarte, @.$4",
"keahiprank.Trinnie": "¡Ey, @!$u#$b#¡Estás realmente apestoso!$h^¡Estás realmente apestosa!$h",
"keahiprank.Jas": "¡Ew!$s#$b#¡Hueles como las vacas de la tía Marnie!$s",
"keahiprank.Vincent": "¡Oye! ¿Qué es ese olor?#$b#AHHH, ¡MI NARIZ SE ESTÁ MURIENDO!$s",
"keahiprank.Yuuma": "Deberías darte un baño.#$b#Como que apestas.",

"keahiprank.Abigail": "¿¡Qué es ese olor!?$s#$b#¡Huele maligno!$s",
"keahiprank.Emily": "Oh, Yoba.$s#$b#Huele como la pizza de un mes que encontré en el sótano de Gus.$s",
"keahiprank.Haley": "¡Apestas!$a#$b#¡No te acerques a mí!$a",
"keahiprank.Leah": "Creo que es bueno ser uno con la naturaleza y todo, @...#$b#Pero creo que lo estás llevando demasiado lejos al no bañarte.$s",
"keahiprank.Maru": "¡Ese olor NO es saludable!$s",
"keahiprank.Penny": "¿Ese olor viene de ti, @?$s#$b#Oh, em...#$b#%Penny comienza a alejarse lentamente.",

"keahiprank.Alex": "%Alex se tapa la nariz.#$b#¿Estás bien ahí, @?$s",
"keahiprank.Elliott": "Oh, Yoba, hueles bastante... exótico.$s#$b#¿Quizás un chapuzón en el agua con montones y montones de aceites de baño podría despejar este aroma?$s",
"keahiprank.Harvey": "Ese olor...#$b#¿Tienes algún problema médico?$s#$b#Está bien, ya sabes...#$b#No te juzgaré como médico.",
"keahiprank.Sam": "¡Whoa! ¡¿Hueles eso?!$a#$b#¿¡De dónde viene eso!? ¡Es realmente asqueroso!$s",
"keahiprank.Sebastian": "¿Te has olvidado de bañarte o algo así, @?",
"keahiprank.Shane": "¡No te acerques a mí oliendo así!$a#$b#Báñate.$a",

"keahiprank.Caroline": "¿Acabas de hacer aerobic?#$b#Es bastante habitual ducharse después, ya sabes...$s",
"keahiprank.Clint": "No es asunto mío decirte esto, pero...#$b#...puede que hayas olvidado ducharte hoy.$s",
"keahiprank.Demetrius": "Ese olor... Conozco ese olor.#$b#Es de una especie local de chinche apestoso que se encuentra en las montañas.#$b#¿Te has... sentado encima?",
"keahiprank.Evelyn": "¡Oh, cariño, eso huele horrible!$s",
"keahiprank.George": "¡Tu olor me está molestando!#$b#¡Vete de mi presencia!$a",
"keahiprank.Gus": "¿Uh, @? ¿Puedes por favor salir de mi salón?$s#$b#Hueles horrible.$s",
"keahiprank.Jodi": "Oh, no, no me digas. ¿Fue Vincent o Keahi?#$b#¿¡O fueron los dos!?$s#$b#Creo que uno de ellos te gastó una broma...$s",
"keahiprank.Kent": "Qué asco. ¿Te duchas alguna vez?$a",
"keahiprank.Lewis": "Escucha, @. Trabajar duro es bueno, pero creo que deberías aprender a ducharte y relajarte de vez en cuando.$s#$b#Estás apestando el pueblo.$s",
"keahiprank.Linus": "Auch, te ha tocado el bicho apestoso de la cresta, ¿eh?#$b#He estado ahí, me ha pasado eso.#$b#Fue una pesadilla quitarlo.#$b#Me llevó horas refregar.$s",
"keahiprank.Marnie": "¿Qué es ese olor? ¡No puede ser ninguna de mis vacas!$s#$b#¿Em, @? ¿Eres tú?$s",
"keahiprank.Pam": "¿En nombre de Yoba, qué es ese olor? ¡Es horrible!$s#$b#¡Haces que desee no tener nariz!$u",
"keahiprank.Pierre": "Ese olor es malo para los negocios.$s#$b#Sugiero que vuelvas después de ducharte, @.$s",
"keahiprank.Robin": "¿Qué es ese olor? ¿Eres tú?$s#$b#¡No te juzgo! Pero realmente necesitas tomar un baño, @.",
"keahiprank.Sandy": "Ah, huele como el bicho apestoso de la cresta.$h#$b#¿Penetrante? Sí.#$b#Pero me hace extrañar el valle.$s",
"keahiprank.Willy": "Ese olor ahuyentará a todos los peces.#$b#Tienes que bañarte, @.",
"keahiprank.Wizard": "¡Ese olor es maligno!$a#$b#¡Se acabó!$a",

