"Acorn.Dialogue.random.20" : "¿Princesa?$s",

//NAOMI DIALOGUE (charlie you awesome being!)
"keahiprank.Naomi": "Oh, Dios mío... Ese horrible hedor, ¿lo hueles?$a#$b#Espera... ¡¿Ese olor viene de ti?! Oh vaya...$u",

//Naomi
//Spring
"Naomi.Dialogue.spring_1": "¿No te encanta la primavera? Un nuevo comienzo para la cresta, el valle...#$b#...para todos nosotros.$h",
"Naomi.Dialogue.spring_12": "¿Te veré mañana en el Festival del Huevo? Voy a llevar a los niños.$h",
"Naomi.Dialogue.spring_23": "La danza floral es mañana. Llevaré a Shiro y a Yuuma. ¿Asistirás?#$e#La Danza floral me recuerda a cuando era joven. La primera vez que el padre de Shiro y Yuuma me sacó a bailar...#$b#Ah, fue una época preciosa. Bailamos y bailamos como si nadie estuviera mirando.$h",

//Summer
"Naomi.Dialogue.summer_1": "Eugh, este calor es horrible. ¡Y todos los insectos!$a#$b#Por si no se nota, nunca he sido una persona muy veraniega. Me hace extrañar las oficinas con aire acondicionado de la ciudad.$a",
"Naomi.Dialogue.summer_10": "Oh, el gobernador estará aquí mañana para el Luau. Me pregunto si se acuerda de que un año alguien añadió toneladas de pimientos picantes a la sopa...#$e#¿Hm? ¿Quién lo hizo?#$b#Jaja, oh, definitivamente no fui yo...$h",
"Naomi.Dialogue.summer_27": "La Danza de las Medusas Lunares... un evento absolutamente hermoso. Llevaré a Shiro y a Yuuma mañana a verlo.#$e#Sé que es bastante tarde para que Yuuma se levante, pero siempre le han gustado las medusas. Creo que le recuerdan a su padre.$s",

//Fall
"Naomi.Dialogue.fall_1": "¡Oh, la mejor estación del año está aquí! ¡Calabazas, especias, todo lo bueno!$h#$b#...¿Qué? No te hagas el sorprendido, se me permite disfrutar de las cosas simples de la vida de vez en cuando.$a",
"Naomi.Dialogue.fall_15": "Hola, granjero. ¿Asistirás mañana a la Feria?^Hola, granjera. ¿Asistirás mañana a la Feria?#$b#No podré asistir debido al trabajo...$s#$b#Independientemente de ello, te deseo la mejor de las suertes en tu exposición agrícola.$h",
"Naomi.Dialogue.fall_26": "Hm, ¿la víspera de los espíritus? ¡Oh, Dios, no! ¡Preferiría dar cinco vueltas a la cresta antes que asistir a ese festival!$a#$e#¿Qué? ¡No, no tengo miedo!$a#$b#...Vale, tal vez tenga un poco de miedo. No me meto con esqueletos y espíritus. Quién sabe lo que podrían hacer.$s#$b#¡Espeluznante!$u",

//Winter
"Naomi.Dialogue.winter_1": "A pesar del frío, siempre he disfrutado del invierno. Marca el final de otro año, otro capítulo de la vida. Y luego, en la primavera, todo vuelve a empezar.$h",
"Naomi.Dialogue.winter_7": "Mi marido y yo nunca llevamos a Shiro y Yuuma al Festival del Hielo. ¡Demasiado lejos para estar de pie en el frío!$a",
"Naomi.Dialogue.winter_24": "Me encanta la Fiesta de la Estrella de Invierno porque realmente reúne a todo el mundo.$h#$e#Tengo mucho tiempo perdido que recuperar...$s#$b#Ahora estoy agradecida por cualquier momento que pueda pasar con mis hijos.$h",

//Days of the Week

//0 Hearts
"Naomi.Dialogue.Mon": "Hola, granjero. Espero que tengas un buen día.^Hola, granjera. Espero que tengas un buen día.",
"Naomi.Dialogue.Tue": "¿Podría disculparme? Tengo cosas que atender.",
"Naomi.Dialogue.Wed": "¿Hm? ¿Qué pasa? Estoy un poco ocupada en este momento.",
"Naomi.Dialogue.Thu": "Buen día para ti, granjero.^Buen día para ti, granjera.",
"Naomi.Dialogue.Fri": "Espero que Yuuma disfrute del fin de semana.",
"Naomi.Dialogue.Sat": "¿Puedo ayudarte en algo?",
"Naomi.Dialogue.Sun": "¿Has tenido un buen fin de semana, granjero?^¿Has tenido un buen fin de semana, granjera?",

//2 Hearts
"Naomi.Dialogue.Mon2": "Lo siento, no puedo pararme a charlar. Pero espero que tengas un buen día.",
"Naomi.Dialogue.Tue2": "Tengo que hablar con Lenny sobre la partida de cartas de la otra noche.#$b#Sé que hizo trampa.$a#$e#¿Qué? No soy una mala perdedora.$a#$b#Sólo sé que tenía una mano ganadora.$a",
"Naomi.Dialogue.Wed2": "Hola, granjero. Espero que tengas un día maravilloso.^Hola, granjera. Espero que tengas un día maravilloso.",
"Naomi.Dialogue.Thu2": "¿Manteniéndote ocupado?^¿Manteniéndote ocupada?#$e#No te olvides de parar y oler las flores de vez en cuando.#$b#Nunca sabes a dónde te llevará la vida.",
"Naomi.Dialogue.Fri2": "El otro día fui a casa de Jeric para intentar comprar mermelada.#$b#¡Ni siquiera estaba en casa!$a#$e#Qué clase de hombre de negocios...$a",
"Naomi.Dialogue.Sat2": "Me gustaría poder hablar, pero hoy estoy muy ocupada con mis hijos.$h#$b#Que tengas un buen día",
"Naomi.Dialogue.Sun2": "No hay descanso para los malvados, granjero.^No hay descanso para los malvados, granjera.#$b#Continúa con tu día.",

//4 Hearts
"Naomi.Dialogue.Mon4": "Se avecina otra semana muy ajetreada. Lo mejor para ti.$h",
"Naomi.Dialogue.Tue4": "¡Oh, hola! Mis disculpas, estaba ocupada pensando en el trabajo.#$b#Nunca se acaba, ¿sabes?",
"Naomi.Dialogue.Wed4": "Las estrellas de anoche estaban tan claras...$h#$b#Es increíble lo que se puede ver desde la aldea por la noche",
"Naomi.Dialogue.Thu4": "No puedo pararme a charlar, tengo que ir al trabajo.#$b#Espero que tengas un buen día.",
"Naomi.Dialogue.Fri4": "Yuuma quería que le buscara rúcula de la montaña...#$e#No me preguntes por qué. Ese niño me supera a veces.#$b#Chico tonto.$h",
"Naomi.Dialogue.Sat4": "Otro fin de semana, por fin.$h#$b#Disfruta de un tiempo para ti.$h",
"Naomi.Dialogue.Sun4": "Anoche me encontré una araña en el pelo mientras volvía a casa.$u#$b#Fue traumatizante. No preguntes.$a",

//6 Hearts
"Naomi.Dialogue.Mon6": "¡Granjero! Espero que te vaya bien.^¡Granjera! Espero que te vaya bien.",
"Naomi.Dialogue.Tue6": "Los chicos me tuvieron despierta hasta tarde anoche.#$e#Los quiero.$h#$b#Pero una vez que empiezan a jugar a los juegos de mesa, nunca se acaba.$u",
"Naomi.Dialogue.Wed6": "¿Qué opinas de las gallinas?#$e#Hm? Oh, lo siento, sé que ha sonado a aleatorio.#$b#Es que no me gustaría trabajar con algo tan sucio todos los días.$u#$b#Pero quizá para ti sea diferente.",
"Naomi.Dialogue.Thu6": "El tiempo no espera a nadie, recuérdalo, ¿vale?",
"Naomi.Dialogue.Fri6": "Una cosa que no echo de menos de Ridgeside es lo difícil que es conseguir y enviar el correo fuera del valle.$a#$e#¡He estado esperando una carta de mi marido durante una semana!$a#$b#¡Una semana!$a#$e#¡Espera, ¿y si se olvidó de contestar?$u#$b#Oh, ese hombre...$a",
"Naomi.Dialogue.Sat6": "Lenny y Lewis estaban discutiendo la otra tarde, y no dejo de pensar en ello.#$b#Ella le llamó 'vieja chirivía curtida'.#$b#Quiero decir, para Lenny, eso es un insulto bastante débil, incluso para una discusión entre hermanos.$h",
"Naomi.Dialogue.Sun6": "Ysabelle intentó que bailar con ella.$a#$b#¡Como si quisiera hacer el ridículo dejándome caer a su lado!$u",

//8 Hearts
"Naomi.Dialogue.Mon8": "Otra semana comienza mientras el fin de semana termina.#$b#Así es el ciclo de la vida, ¿verdad?$h",
"Naomi.Dialogue.Tue8": "Yuuma preguntaba ayer por su padre.#$b#No sé cuándo podrá volver a casa...$s#$e#Es tan duro.$s#$b#Lo siento, no era mi intención descargar eso sobre ti. Pero muchas gracias por escuchar.$4",
"Naomi.Dialogue.Wed8": "¿Sabes lo que no soporto?#$b#La lluvia.#$b#O la nieve.#$b#¡La precipitación! Causa estragos en mi agenda.#$e#Pero supongo que un día lluvioso significa que puedo pasar tiempo de calidad con mis hijos.",
"Naomi.Dialogue.Thu8": "Lenny nos invitó a los chicos y a mí a cenar la otra noche.#$e#¡La comida que hizo estaba deliciosa!$h#$b#Y sospechosamente familiar...#$e#Oh, mi Yoba. ¡Ella consiguió esa comida de Pika's!$u",
"Naomi.Dialogue.Fri8": "Sabes, quería decirte que es un verdadero placer charlar contigo.$h#$b#Aunque seas un granjero de pocas palabras.$h^Aunque seas una granjera de pocas palabras.$h",
"Naomi.Dialogue.Sat8": "Buen día para ti.#$e#Recuerda descansar, pero no dejes que tu trabajo te haga sufrir demasiado.",
"Naomi.Dialogue.Sun8": "He estado caminando mucho con Shiro.#$e#Desde luego, él está mejorando mucho, pero tengo que ser sincera, creo que yo también me estoy haciendo más fuerte.$h#$b#Y no sólo físicamente... Estar con él y con Yuuma me está haciendo sentir mucho mejor.$4#$b#Es curioso lo que puede hacer estar cerca de tus seres queridos, ¿eh?$h",

//10 Hearts
"Naomi.Dialogue.Mon10": "¡Hola! ¿Teniendo un día agradable, espero?#$b#El valle es siempre tan hermoso, sin importar el día o la estación.$h",
"Naomi.Dialogue.Tue10": "Es un buen día para relajarse y tomarse tiempo para uno misma, ¿no crees?$h",
"Naomi.Dialogue.Wed10": "Estar aquí es tan diferente de donde estaba por trabajo.#$b#Estoy realmente feliz de estar de vuelta en casa con mis hijos.$h",
"Naomi.Dialogue.Thu10": "Vi a Marnie viniendo de la casa de Lewis la otra noche.#$b#Entre tú y yo, hay algo que está pasando allí.#$b#Bueno, vale, quizás es algo obvio, pero aún así.$u",
"Naomi.Dialogue.Fri10": "Shiro ha ido mejorando, aunque él no lo crea.#$b#Una madre siempre lo nota.$h#$b#Estoy muy orgullosa de mis dos hijos.$4",
"Naomi.Dialogue.Sat10": "Espero que estés disfrutando del fin de semana.$h#$e#Sé que el trabajo nunca se detiene realmente para ti, pero una cosa que he aprendido a lo largo de los años es que a veces necesitas encontrar el tiempo para detenerte y apreciar lo que tienes.$h",
"Naomi.Dialogue.Sun10": "¿Disfrutando, granjero?^¿Disfrutando, granjera?#$e#Es muy amable de tu parte detenerte y hablar conmigo tanto como lo haces.$h#$b#Realmente aprecio tu amistad.",

//MALAYA DIALOGUE (ottersqueeks you da best!)
"keahiprank.Malaya": "Uh, ¿@? ¿Qué es ese olor...?$u#$b#Lo siento, creo que viene de ti.$s",

//Malaya
//Spring
"Malaya.Dialogue.spring_1": "¡La primavera está aquí!$4#$b#No puedo esperar a sentir la hierba bajo mis pies de nuevo.$4",
"Malaya.Dialogue.spring_12": "¿Te apuntas a la búsqueda de huevos mañana?#$b#Me pregunto si debería llevar algo de comida.",
"Malaya.Dialogue.spring_23": "Quizá pueda conseguir que Kimpoi baile conmigo en el festival este año.$h",

//Summer
"Malaya.Dialogue.summer_1": "¿Estás cultivando arándanos este año?#$b#Me encanta hacer la tarta de arándanos de las tierras altas durante esta temporada.$h",
"Malaya.Dialogue.summer_10": "Voy a ser sincera, voy al Luau por la pista de baile más que por la comida.$h",
"Malaya.Dialogue.summer_27": "Mañana podremos ver la migración de los Luna-, es decir, las medusas lunares.$h",

//Fall
"Malaya.Dialogue.fall_1": "El otoño está aquí, lo que significa que las jostaberries están de temporada.#$b#No puedo esperar a hacer algo delicioso con ellas.$h",
"Malaya.Dialogue.fall_15": "No puedo esperar a ver a todos mostrando su duro trabajo en la Feria mañana.",
"Malaya.Dialogue.fall_26": "Si Kimpoi va de marinero mañana, quizá yo sea una sirena.$h#$b#¿Por qué? Uhh, bueno. Coincidiría, ¿no?",

//Winter
"Malaya.Dialogue.winter_1": "Las clementinas están creciendo ahora.#$e#¿Debería hacer un pastel de clementinas para Alissa?#$b#¿Le gustan las sorpresas?",
"Malaya.Dialogue.winter_7": "No estoy segura de lo que me parece el festival de mañana.$s#$b#¿Se liberan los peces después?",
"Malaya.Dialogue.winter_14": "El Mercado Nocturno empieza mañana.#$e#Alissa adora la canción de la sirena.#$b#Quizás pueda enseñársela.",
"Malaya.Dialogue.winter_24": "Será estupendo ver a todos reunidos mañana.$h#$b#Ha sido un año muy largo.",

//Days of the Week

//0 Hearts
"Malaya.Dialogue.Mon": "¿Te gusta hornear, @?#$b#Es uno de mis pasatiempos favoritos. Después de ayudar a Kimpoi con el huerto, por supuesto.",
"Malaya.Dialogue.Tue": "%Malaya parece estar sumida en sus pensamientos.#$b#Hola, @. Lo siento, pero me gustaría estar sola hoy.",
"Malaya.Dialogue.Wed": "Me encanta vivir aquí en Ridgeside.#$b#Pero admito que me gustaría estar más cerca de la playa.",
"Malaya.Dialogue.Thu": "Alissa ha crecido mucho con los años...$s",
"Malaya.Dialogue.Fri": "¡Ten cuidado de no trabajar demasiado!#$b#Que tengas un buen día, @.$h",
"Malaya.Dialogue.Sat": "¡Oh, hola granjero!^¡Oh, hola granjera!#$b#¿Cómo empieza tu fin de semana?",
"Malaya.Dialogue.Sun": "Ridgeside no ha cambiado mucho durante nuestra ausencia, pero tengo problemas para desplazarme.$s",

//2 Hearts
"Malaya.Dialogue.Mon2": "Estoy tan feliz de que se haya instalado el teleférico.$h#$b#¿Sabías que antes teníamos que subir a pie por la ladera de la montaña?$u",
"Malaya.Dialogue.Tue2": "Es maravilloso volver a hablar con Olga.#$b#¡Trinnie también ha crecido mucho!$h",
"Malaya.Dialogue.Wed2": "¡Buenos días, @! Estaba a punto de ir a dar un paseo.#$b#¡Cuídate!$h",
"Malaya.Dialogue.Thu2": "Alissa tiene una voz maravillosa. Me recuerda a cuando era más joven.",
"Malaya.Dialogue.Fri2": "%Malaya está cantando para sí misma.#$b#Oh, @. No te había visto allí. ¿Esa canción? Es algo que aprendí cuando crecía.",
"Malaya.Dialogue.Sat2": "Bert y Olga discuten tanto como recuerdo.#$b#¡Aunque puedes oír el amor en sus voces!$h",
"Malaya.Dialogue.Sun2": "He visto a Trinnie coger una de las frutas de la cesta.#$b#Me alegro de que le gusten.$h",

//4 Hearts
"Malaya.Dialogue.Mon4": "Las Islas Helecho son un lugar tan encantador.#$b#Extraño nadar allá.$s",
"Malaya.Dialogue.Tue4": "No se lo digas a Kimpoi, @, pero a veces, le oigo cantar para sí mismo mientras trabaja.$h",
"Malaya.Dialogue.Wed4": "¡@! ¿Sabías que las carambolas se llaman así porque son estrellas fugaces que se posan y crecen?$u#$b#¡No tenía ni idea! Bert me lo acaba de decir.$h",
"Malaya.Dialogue.Thu4": "Estaba caminando cerca del bosque donde me pareció escuchar que había una pelea. ¿Has oído algo?",
"Malaya.Dialogue.Fri4": "Hola, @. Espero que te encuentres mejor hoy.$h",
"Malaya.Dialogue.Sat4": "%Malaya está cantando en voz baja.#$b#~Vagaré, lloraré y gemiré, todo por mi alegre marinero atrevido, hasta que vuelva.~$4#$b#¡Oh, @! Me has asustado.$u#$e#¿Reconoces esa canción? Es una de mis favoritas.$h",
"Malaya.Dialogue.Sun4": "Normalmente me quedo en los alrededores de Ridgeside cuando salgo a pasear.#$b#Tal vez hoy vaya al lago de la montaña.#$e#¡Si Kimpoi está preocupado, puede venir conmigo!$h",

//6 Hearts
"Malaya.Dialogue.Mon6": "Si tienes hambre, ¡te recomiendo mucho a Pika's!$h#$b#Sólo ha mejorado ahora que Keahi está ayudando.",
"Malaya.Dialogue.Tue6": "Trinnie se enfadó antes conmigo porque no me asusté cuando me cayó una lagartija encima.$h#$b#Alissa me explicó que se suponía que era una 'broma'. Sin embargo, las lagartijas dan buena suerte.",
"Malaya.Dialogue.Wed6": "Bert me dijo que hay un kiwi maldito rodando por la aldea.$u#$b#Espero no verlo nunca.$s",
"Malaya.Dialogue.Thu6": "¿Has viajado alguna vez al extranjero, @?#$e#Me encantaron todos los lugares nuevos que vi en mis viajes.$h#$b#Aunque me gustaría que las circunstancias fueran diferentes...$s#$e#%Malaya parece estar perdida en sus pensamientos.",
"Malaya.Dialogue.Fri6": "Lo segundo mejor de los viernes por la noche es ponerse al día con todo el mundo.$h#$e#¿Qué es lo mejor?#$b#¡Bailar, por supuesto!$h",
"Malaya.Dialogue.Sat6": "Kimpoi me contaba el otro día algunas viejas supersticiones de la navegación.#$b#¿Puedes creer que los plátanos estaban prohibidos a bordo?$u",
"Malaya.Dialogue.Sun6": "Hay algo mágico en Ridgeside.#$b#No podría imaginarme viviendo en otro lugar.$h",

//8 Hearts
"Malaya.Dialogue.Mon8": "Gracias por visitarme, @.#$b#Kimpoi no lo dice, pero sé que también le gusta tu compañía.$h",
"Malaya.Dialogue.Tue8": "Si necesitas ayuda en la granja, no dudes en pedirla.#$b#Puede que no lo parezca, pero ayudo a Kimpoi en las tareas.$h",
"Malaya.Dialogue.Wed8": "Jeric es un encanto.#$b#Me gusta comprarle productos para usarlos en mis recetas.",
"Malaya.Dialogue.Thu8": "Estaba a punto de buscarte, @.#$b#¿Te gustaría dar un paseo conmigo?",
"Malaya.Dialogue.Fri8": "El invernadero de la comunidad era un centro de actividad hace años.#$e#Creo que hay otro invernadero en alguna parte, pero Lenny no recuerda haberlo hecho construir.",
"Malaya.Dialogue.Sat8": "Cuando voy a la biblioteca, a veces tengo conversaciones con Gunther.#$b#Tiene muchas cosas perspicaces que decir.",
"Malaya.Dialogue.Sun8": "Sé que Kimpoi guarda la mejor fruta para mí.#$e#Aunque preferiría que la vendiera, sé que lo hace para demostrar su amor.#$b#También significa que puede comer más de mi cocina.",

//10 Hearts
"Malaya.Dialogue.Mon10": "Gracias por ser un alma tan amable, @. No sólo para mí, sino también para Kimpoi y Alissa.#$b#Mi familia aprecia todo lo que has hecho.",
"Malaya.Dialogue.Tue10": "No entiendo este misterio sobre la Atlántida.#$b#Personalmente, el lugar me pareció bastante deslucido.#$e#¿Cómo lo sé?$u#$b#Oh, eh, por nada. ¡Que tengas un buen día, @!$h",
"Malaya.Dialogue.Wed10": "¡@! ¡Estoy tan feliz! ¡Alissa me acaba de decir que quiere cantar un dúo conmigo!$4",
"Malaya.Dialogue.Thu10": "Lenny me estaba contando lo de Marnie y Lewis el otro día.#$e#No estoy familiarizada con ciertas normas, pero si la relación es un secreto conocido, ¿por qué callar?#$b#Quizás Kimpoi lo sepa.",
"Malaya.Dialogue.Fri10": "%Malaya tararea mientras camina con un baile en su paso.#$b#¡Es viernes otra vez, @! No sé por qué, pero este día me da mucha alegría.$h",
"Malaya.Dialogue.Sat10": "¿Ya has comido algo, @?#$e#Un granjero necesita mantener sus fuerzas.^Una granjera necesita mantener sus fuerzas.#$b#¡Aquí, he hecho extra!$h",
"Malaya.Dialogue.Sun10": "Olga preguntaba antes por la planta de tratamiento de agua.#$b#Escucho unos ruidos extraños procedentes de ella.",

//KIMPOI DIALOGUE (ottersqueeks you da best!)
"keahiprank.Kimpoi": "Oh, Yoba... Esto es peor que el mareo...$4",

//Kimpoi
//Spring
"Kimpoi.Dialogue.spring_1": "Se acabó el invierno. ¿Plantarás algún árbol nuevo este año?",
"Kimpoi.Dialogue.spring_12": "Ayudé a Keahi y Trinnie a decorar huevos para el festival de mañana. Salió... bien.$s",
"Kimpoi.Dialogue.spring_23": "Bert y Olga han estado practicando el baile para mañana.#$b#%Kimpoi empieza a hablar para sí mismo.#$b#Hmm, quizá debería practicar para Malaya.",

//Summer
"Kimpoi.Dialogue.summer_1": "Este calor me hace extrañar la brisa del mar.$s",
"Kimpoi.Dialogue.summer_10": "¿Debería llevar algo de fruta para la sopa de mañana?#$b#Tengo algo de rangpur fresco...#$b#%Kimpoi se pierde en sus pensamientos.",
"Kimpoi.Dialogue.summer_27": "Estoy emocionado por volver a ver las medusas migratorias.#$b#Alissa las adoraba cuando era pequeña.$h",

//Fall
"Kimpoi.Dialogue.fall_1": "En unas semanas, será la Feria.#$e#Hmm, Me será difícil dejar de lado la fruta.$s#$b#La cocina de Malaya se merece lo mejor.",
"Kimpoi.Dialogue.fall_15": "La Feria es mañana. ¿Tienes listo tu exposición agrícola?",
"Kimpoi.Dialogue.fall_26": "Malaya quiere hacer disfraces a juego mañana.#$b#¿Sería predecible un marinero? Hm...",

//Winter
"Kimpoi.Dialogue.winter_1": "En esta época del año no hay nada que dé frutos, pero hay que seguir cuidando los árboles.",
"Kimpoi.Dialogue.winter_7": "¿Te vas a presentar al concurso mañana?#$b#Alissa dijo que debería, pero hace tiempo.",
"Kimpoi.Dialogue.winter_14": "Hay muchos artículos exóticos en el Mercado Nocturno.#$b#Tal vez pueda conseguir más semillas de árboles.",
"Kimpoi.Dialogue.winter_24": "Mañana es la Fiesta de la Estrella de Invierno.#$b#¿Conoces la historia?",

//Days of the Week

//0 Hearts
"Kimpoi.Dialogue.Mon": "Hola, granjero. ¿Cómo están los árboles de tu tierra?^Hola, granjera. ¿Cómo están los árboles de tu tierra?",
"Kimpoi.Dialogue.Tue": "Olga es tan severa como la recuerdo.",
"Kimpoi.Dialogue.Wed": "¿Estás cerca de mi hija, Alissa?#$b#Veo que ha crecido mucho...$s",
"Kimpoi.Dialogue.Thu": "Oh, hola.#$b#El trabajo de un granjero nunca termina, eh.^El trabajo de una granjera nunca termina, eh.",
"Kimpoi.Dialogue.Fri": "Ah, @. Espero que tengas un buen día.",
"Kimpoi.Dialogue.Sat": "Malaya me regañó por trabajar el fin de semana...$s",
"Kimpoi.Dialogue.Sun": "Los árboles no necesitan ser regados, pero sí necesitan cuidados diarios.",

//2 Hearts
"Kimpoi.Dialogue.Mon2": "Ahora es mucho más fácil llegar a Pueblo Pelícano con el teleférico.",
"Kimpoi.Dialogue.Tue2": "Trinnie y Keahi son intensos.$s",
"Kimpoi.Dialogue.Wed2": "¿Van a la playa a menudo?#$b#A Malaya le encanta. Aunque nosotros vamos poco.",
"Kimpoi.Dialogue.Thu2": "Hola. Acuérdate de tomar un descanso.",
"Kimpoi.Dialogue.Fri2": "Malaya puede ser crédula. Se toma las palabras al pie de la letra.",
"Kimpoi.Dialogue.Sat2": "Siento no hablar mucho. Olga y yo somos así de parecidos.",
"Kimpoi.Dialogue.Sun2": "¿Has visto a Trinnie? Cogió una fruta y corrió a casa.",

//4 Hearts
"Kimpoi.Dialogue.Mon4": "Recuerda que el abono para árboles no funciona con los frutales.",
"Kimpoi.Dialogue.Tue4": "Bert me dice que has hecho grandes progresos en tu granja. Buen trabajo.$h",
"Kimpoi.Dialogue.Wed4": "Lenny no ha cambiado nada mientras Malaya y yo no estábamos. Algunas cosas nunca cambian.",
"Kimpoi.Dialogue.Thu4": "Oh, @. ¿Has descansado ya hoy?",
"Kimpoi.Dialogue.Fri4": "Es bonito que podamos ver el océano desde aquí.",
"Kimpoi.Dialogue.Sat4": "Me pareció ver un kiwi rodar lejos de uno de mis árboles antes.$u",
"Kimpoi.Dialogue.Sun4": "¿Cómo están tus árboles?#$b#Si necesitas ayuda, puedo hacer algo de tiempo.",

//6 Hearts
"Kimpoi.Dialogue.Mon6": "Hay días que echo de menos el mar.#$b#Pero nada es mejor que la tierra firme.",
"Kimpoi.Dialogue.Tue6": "No se lo digas a Malaya, pero guardo las mejores frutas para que cocine.",
"Kimpoi.Dialogue.Wed6": "A Freddie y Lola les gusta pasarse por aquí durante sus paseos.#$b#Han estado en lugares de los que nunca he oído hablar.",
"Kimpoi.Dialogue.Thu6": "Una golondrina pasó volando mientras trabajaba.#$b#La cosecha de esta temporada va a ser abundante.$h",
"Kimpoi.Dialogue.Fri6": "Willy nos visita a veces cuando viene a la cresta a pescar. Es agradable intercambiar historias.",
"Kimpoi.Dialogue.Sat6": "Cuando el trabajo se vuelve demasiado, me gusta contratar a Ian y Sean para que me ayuden.#$b#Aprecio su trabajo y su compañía.",
"Kimpoi.Dialogue.Sun6": "Alissa me cuenta todo lo que aprende de Marnie.#$b#Es genial verla tan emocionada.$h",

//8 Hearts
"Kimpoi.Dialogue.Mon8": "Jeric no me compra porque tiene poco espacio.#$b#Sin embargo, se pasa por aquí para contar historias sobre la vida en la ciudad.",
"Kimpoi.Dialogue.Tue8": "No se permitía silbar mientras se navegaba debido a la superstición.#$b#Por eso las canciones de mar son tan comunes.",
"Kimpoi.Dialogue.Wed8": "Malaya y yo nos conocimos hace años, en un crucero. Está tan hermosa como entonces.$h",
"Kimpoi.Dialogue.Thu8": "Estaba a punto de hacer una pausa, @.#$b#Si quieres unirte, eres feliz.$h",
"Kimpoi.Dialogue.Fri8": "El salón es demasiado ruidoso para mí en días como este. Voy por Malaya, y su brillante sonrisa hace que valga la pena.",
"Kimpoi.Dialogue.Sat8": "Malaya me dijo que ahora hay muchos artefactos en la biblioteca. ¿Fue tu trabajo? Gracias.$h",
"Kimpoi.Dialogue.Sun8": "Me enteré por Willy que vas a las minas locales. Seguro que te mantienes a salvo. ¿Tienes alguna buena historia?",

//10 Hearts
"Kimpoi.Dialogue.Mon10": "%Kimpoi está tarareando para sí mismo.#$e#Oh, @, ¿puedes oírme? Es una vieja canción que los otros marineros y yo cantábamos, llamada Fiddler's Green.$h#$e#Ahora estoy ocupado, pero si vienes mañana te la cuento.",
"Kimpoi.Dialogue.Tue10": "Veo que has vuelto para la historia. Fiddler's Green es una vieja leyenda sobre una vida después de la muerte para los marineros. Perdimos a más de un hombre en su día, y siempre nos decíamos que nos volveríamos a encontrar en Fiddler's Green. En fin, no te entretengo más. Que tengas un buen día, @.",
"Kimpoi.Dialogue.Wed10": "¿Has encontrado lagos en las minas? He oído leyendas de peces ahí abajo, pero nunca me he animado a ir yo mismo. Malaya insistiría en venir si lo hiciera.",
"Kimpoi.Dialogue.Thu10": "Oh, @, ya que estás aquí. Quería darte algo para mostrarte mi agradecimiento por todo lo que has hecho. Tanto por mí, como por mi familia. Toma, ten esto. [805]",
"Kimpoi.Dialogue.Fri10": "Pásate hoy por Pika's si tienes tiempo, @. Compartir historias con una cerveza es un buen final de semana.",
"Kimpoi.Dialogue.Sat10": "Malaya me preguntó sobre lo que estaba pasando con Marnie y Lewis. Sinceramente, yo tampoco lo entiendo. Le dije que era asunto de ellos, y pareció aceptar esa respuesta.",
"Kimpoi.Dialogue.Sun10": "Durante nuestros viajes, Malaya y yo comimos muchas comidas diferentes de muchos lugares. Sin embargo, si soy sincero, nada compite con la cocina de Pika.$h",

//UNDREYA DIALOGUE
"keahiprank.Undreya": "¿Por qué hueles tan raro?$u#$b#¡Ew! ¡No, no te acerques a mí hasta que eso se haya ido!$h",

//Undreya
//Spring
"Undreya.Dialogue.spring_1": "¡La nieve se ha ido!$h#$b#Es mucho más fácil esconderse entre las flores que entre la nieve.",
"Undreya.Dialogue.spring_12": "No vayas a recoger huevos sin revisarlos mañana.#$b#¡Podrías entregarme a los pueblerinos por accidente!$u",
"Undreya.Dialogue.spring_23": "¡Oye! ¿Vas a bailar mañana?#$b#¡Buena suerte! ¡Estaré observando desde algún lugar!$h",

//Summer
"Undreya.Dialogue.summer_1": "El verano es bonito y todo eso, pero... ¡El único problema que tengo es que algunas cosas que recojo se quedan pegadas por el sudor!$u#$b#*escalofrío*$u",
"Undreya.Dialogue.summer_10": "Siempre asisto al Luau. ¡Me encanta la sopa!$h#$b#También me gusta el cambio de repuesto de ese globo púrpura.#$b#Debería venir de visita más a menudo.$h",
"Undreya.Dialogue.summer_27": "¡Yo también quiero ver las medusas!$h#$b#¡Por supuesto, estaré allí mañana! ¡Sólo que te costará encontrarme!$h",

//Fall
"Undreya.Dialogue.fall_1": "Es divertido esconderse en las hojas, ¿sabes?$h",
"Undreya.Dialogue.fall_15": "¡Cuántos turistas vienen mañana!$h#$b#¡También muchos bolsillos!$h#$b#¡Esto va a ser divertido!$h",
"Undreya.Dialogue.fall_26": "Ummm... No me gusta lo que viene mañana...$s",

//Winter
"Undreya.Dialogue.winter_1": "¡Es difícil esconderse bajo la nieve!$a#$b#Quiero decir, es difícil encontrarme y todo eso.#$b#¡Pero hace tanto frío que no puedo quedarme quieta!$a",
"Undreya.Dialogue.winter_7": "Odio el pescado. ¡Qué asco!$a#$b#No me interesa el festival de mañana",
"Undreya.Dialogue.winter_24": "Debería aprender a ser una buena elfa de vez en cuando.#$b#A mi amigo no le gustaría que robara de más...$s#$e#Sí... debería aprender a ser buena de vez en cuando...$s",

//Days of the Week

//0 Hearts
"Undreya.Dialogue.Mon0": "¡Estoy aburrida!$s#$b#Quiero hacer algo divertido.$l",
"Undreya.Dialogue.Tue0": "Me pregunto qué es algo bueno para comer en este momento.#$b#Creo que podrían ser cerezas.$h",
"Undreya.Dialogue.Wed0": "Oh, hey, @.#$b#Día ocupado, ¿eh?",
"Undreya.Dialogue.Thu0": "Tu granja es un poco espeluznante.#$b#¿Eh? ¿Qué quiero decir?#$b#No lo sé, es que sentí que me observaban cuando intenté esconderme allá el otro día.$s",
"Undreya.Dialogue.Fri0": "%Undreya bosteza.#$b#¡No tengo sueño!$u#$b#%Undreya bosteza de nuevo.",
"Undreya.Dialogue.Sat0": "Creo que dejaré de robar carteras.#$b#Nah.$h",
"Undreya.Dialogue.Sun0": "Me gusta robar las sobras de los restaurantes.$h#$b#¡Me hace sentir rica!$h",

//2 Hearts
"Undreya.Dialogue.Mon2": "¿Estás bien? Nada. Sólo pensé que te veías pálido.^¿Estás bien? Nada. Sólo pensé que te veías pálida.",
"Undreya.Dialogue.Tue2": "¡Las cascadas de por aquí son tan ruidosas!#$b#¡Sin embargo, es genial, porque me facilitan arrebatar cosas!$h",
"Undreya.Dialogue.Wed2": "Hmm...$s#$b#Debería coger algo de ropa para poder vestirme.$h",
"Undreya.Dialogue.Thu2": "Algunos días, sólo quiero tumbarme en el campo y contemplar las estrellas.#$b#Si pudiera seguir viviendo haciendo sólo eso.$l",
"Undreya.Dialogue.Fri2": "¿Has oído hablar de los peces raros que hay por estos lares?#$b#No sé pescar, pero he oído que valen una fortuna.$h#$e#¿Quizás pueda pescar uno con cubos?$l",
"Undreya.Dialogue.Sat2": "¡Yo! ¡Casi me atrapan!$u#$b#¡Había un chico con el pelo castaño desordenado cerca de donde yo me escondía, y tropezó cerca de mí!$a#$b#¿Creo que vio mi pie? No lo sé, se quedó mirándolo un rato.#$e#Salí corriendo en cuanto tuve la oportunidad. ¡Estuvo tan cerca!$h",
"Undreya.Dialogue.Sun2": "Necesito urgentemente un baño.#$b#Sí, debería darme un baño.$h",

//4 Hearts
"Undreya.Dialogue.Mon4": "Ser una princesa... Eso nunca se me pasó por la cabeza.#$b#¿Sería una buena princesa? Creo que no.$l",
"Undreya.Dialogue.Tue4": "Me gusta esconderme alrededor del museo.#$b#Me hace sentir inteligente sólo con estar ahí.$h",
"Undreya.Dialogue.Wed4": "Aprendí a leer con periódicos y libros desechados.#$b#¡Te sorprendería saber cuántos libros buenos se tiran a la basura!$s",
"Undreya.Dialogue.Thu4": "A veces me gusta disfrazarme de conejita.#$b#¡Hay una señora en la aldea a la que le encanta abrazar a los conejitos!$h#$b#¡Tiene el pelo naranja y es muy bonita!$h#$b#¡Espero que algún día me abrace a mí también!$h",
"Undreya.Dialogue.Fri4": "Esconderse en los arbustos durante la temporada de bayas es increíble.#$b#¡Es como un buffet de comida todo lo que puedas comer!$h",
"Undreya.Dialogue.Sat4": "Ese tipo en la montaña es impresionante.#$b#¿Sabes, ese que vive en una tienda de campaña?$l#$b#Sí, es divertido verlo sobrevivir en la naturaleza a veces.$h",
"Undreya.Dialogue.Sun4": "%Undreya bosteza.#$b#Anoche no me fui a dormir temprano.$s#$b#¡Pero valió la pena! Pude volver a contemplar las estrellas.$h",

//6 Hearts
"Undreya.Dialogue.Mon6": "Hola, @.#$b#¿Qué pasa?#$e#¿Yo? Bueno, lo mismo de siempre, lo mismo de siempre.#$b#Esperando mi próximo arrebato.$h",
"Undreya.Dialogue.Tue6": "Me pregunto cuál es un buen plato para cocinar.#$b#¡Espera, no sé cocinar!$h",
"Undreya.Dialogue.Wed6": "Echo de menos saltar desde cascadas.#$b#Debería volver a hacerlo alguna vez.$h",
"Undreya.Dialogue.Thu6": "Si me convierto en un osa de peluche, tendría que admitir que me gusta que me abracen.#$b#¡Espera, no, no lo hago! ¡No has oído nada!$a",
"Undreya.Dialogue.Fri6": "Me pregunto si debería ampliar mi arsenal.#$b#Sin embargo, es demasiado trabajo aprender a transformarse en otras cosas.$s",
"Undreya.Dialogue.Sat6": "Hay un hombre muy guapo en el pueblo.$l#$b#¿Creo que se llamaba 'Jeric'?#$e#Sea lo que sea, su cartera daba pena.#$b#¡Así que se la devolví!$h",
"Undreya.Dialogue.Sun6": "¡Tengo mucha hambre!$s#$b#Oh, espera. Acabo de comer hace una hora.$h",

//8 Hearts
"Undreya.Dialogue.Mon8": "¡Hola! ¡Saludos! ¡Hola! ¡Hola!$h#$b#No es mucho, sólo estoy probando algunas palabras.$h",
"Undreya.Dialogue.Tue8": "Me pregunto si debería saludar a ese otro elfo.#$b#¿Sabes, el que lleva la chaqueta de cuero marrón con el pañuelo rojo?#$e#Me pregunto de qué va.#$b#Nah, me da pereza iniciar una conversación.$h",
"Undreya.Dialogue.Wed8": "Me encanta andar por el Salón del pueblo. Es mucho más fácil robar la comida allí por la noche.$h#$b#El restaurante al aire libre es un poco complicado porque, bueno, está al aire libre.$h",
"Undreya.Dialogue.Thu8": "Me encanta mirar las estrellas.#$b#¡Creo que cuando fallecemos, nos convertimos en una!$h#$e#Sé que está en algún lugar ahí arriba.$h",
"Undreya.Dialogue.Fri8": "Una vez robé una guitarra, pero no sabía cómo tocarla.$h#$b#¡Así que la convertí en un murciélago!$h",
"Undreya.Dialogue.Sat8": "¡Cavar bajo tierra es una estrategia eficaz para esconderse!#$b#¡El problema es que, a veces, algún bicho raro usa una azada y se pone a cavar por todas partes!$a#$b#¡No quiero acabar herida por eso!$a",
"Undreya.Dialogue.Sun8": "¡Quiero aprender a pescar!$h#$b#Debería coger una caña alguna vez.",

//10 Hearts
"Undreya.Dialogue.Mon10": "Echo de menos a Arthur...$s#$b#Pero, sé que está en algún lugar tranquilo.#$e#¿Puedes hacerme compañía algunos días, @?$h#$b#Eres un amigo increíble.^Eres una amiga increíble.",
"Undreya.Dialogue.Tue10": "¡Oye! ¡Mira qué cosa tan increíble encontré el otro día! [529 526 534]#$b#¡Todo tuyo, @!$h#$b#¡Lo mantuve limpio para ti!$l",
"Undreya.Dialogue.Wed10": "Si me convirtiera en princesa de un reino todopoderoso, ¿seguirías siendo mi amigo?^Si me convirtiera en princesa de un reino todopoderoso, ¿seguirías siendo mi amiga?#$e#¡Prometo que nunca estaré demasiado ocupada para ti, amigo!$h^¡Prometo que nunca estaré demasiado ocupada para ti, amiga!$h",
"Undreya.Dialogue.Thu10": "¡El otro día vi un destello del espíritu de la montaña!$u#$b#¡Yo! ¡Se veía muy bonita!$h#$b#Pero no me tomes la palabra, puede que sólo estuviera soñando despierta.",
"Undreya.Dialogue.Fri10": "¡Nunca robaría en mitad de la noche!$a#$b#¿¡Dónde está el honor!?$a#$e#¡Dicho esto, mirad esto! Ayer por la tarde cogí un bonito pañuelo!$h",
"Undreya.Dialogue.Sat10": "¡Eh, tú, @! ¿Puedo esconderme en los alrededores de tu granja la próxima vez?#$b#En realidad tengo mucha curiosidad por saber de dónde viene esa sensación de ser observada.#$b#Creo que es cerca del lado oeste de tu granja. No estoy segura.$l",
"Undreya.Dialogue.Sun10": "¿Crees en fantasmas? ¿Espíritus?$u#$b#¿Yo? ¿Tal vez? No lo sé.#$b#¡Quiero decir que creo en el espíritu de la montaña, al menos!$h",

//HELEN DIALOGUE
"keahiprank.Helen": "Querido, traes un olor tan desagradable.$u^Querida, traes un olor tan desagradable.$u#$b#Apuesto a que te ha gastado una broma el chico de Pika.$h#$e#Ese chico tiene potencial.",

//Randomized
"Helen.Dialogue.random.1": "Me pregunto cómo le irá a mi hija.#$b#Espero que haya encontrado su vocación.",
"Helen.Dialogue.random.2": "Jio es un activo inestimable para los Seguidores.#$b#Su habilidad con la espada es insuperable.#$b#Estoy orgullosa, como su mentora.$h",
"Helen.Dialogue.random.3": "Espero que mi marido esté bien.$s#$b#Echo mucho de menos su abrazo...$s",
"Helen.Dialogue.random.4": "Espero las próximas órdenes de la Profeta.#$b#Bliss debería estar aquí en cualquier momento para dar una tarea.",
"Helen.Dialogue.random.5": "Daia es increíblemente inteligente. Es una de las mejores eruditas entre los seguidores.$h#$b#Sólo es un poco... indecente con sus palabras y acciones.$a",
"Helen.Dialogue.random.6": "%Helen parece estar perdida en sus pensamientos.",
"Helen.Dialogue.random.7": "Me pregunto qué hace la Profeta en su tiempo libre.#$b#Es un misterio.",
"Helen.Dialogue.random.8": "Por favor, perdona a mi marido si a veces se pone gruñón.$s#$b#Es un buen hombre. Creo que es mi culpa que sea así...$s#$b#Debe haberse tomado muy a pecho mi falso fallecimiento.$s",
"Helen.Dialogue.random.9": "A veces visito a mi hija y a mi marido por la noche. Ellos no se dan cuenta.#$b#Oh, cómo anhelo su abrazo...$s",
"Helen.Dialogue.random.10": "A veces me pregunto si hice lo correcto...$s#$b#Espero que sí...$s",
"Helen.Dialogue.random.11": "¿Has pensado alguna vez en unirte a los seguidores?#$b#Me convertiría en tu entrenadora personal si quieres. ¡Extraño tener nuevos alumnos!$h",
"Helen.Dialogue.random.12": "¿Cómo va tu granja, @?#$b#¿Algún fenómeno extraño?#$b#¿Como, tal vez un fantasma o algo así?#$b#Oh, nada del otro mundo. Olvida que pregunté.$h",
"Helen.Dialogue.random.13": "La soportadora de la Profeta, Bliss, es una respetable asesina.#$b#No dejes que su apariencia te engañe para subestimarla.$h",
"Helen.Dialogue.random.14": "Me pregunto si mi hija habrá percibido mis raras visitas.#$b#Siempre he tenido la corazonada de que tiene buen instinto y reflejos.#$b#¡Pero no! Debería alejarse de este tipo de vida.$a",
"Helen.Dialogue.random.15": "Todo lo que hago es por mi familia.#$b#Algún día lo entenderás.",
"Helen.Dialogue.random.16": "No sé qué haría si mi hija se hiciera daño...$s#$b#¡Debe tener siempre cuidado! ¡La vi cortarse el dedo mientras cocinaba el otro día!$a",
"Helen.Dialogue.random.17": "Oh, hola, @.#$b#Mantente a salvo ahora.",
"Helen.Dialogue.random.18": "Acampar es terapéutico.#$b#Más importante, es crucial para las misiones.",
"Helen.Dialogue.random.19": "Echo de menos a mi Ezekiel...$s",
"Helen.Dialogue.random.20": "Estoy tentada de dejarle un regalo a Corine en su cumpleaños.#$b#Pero eso frustraría el propósito de mi 'muerte falsa' ahora, ¿no?",

//Before Festivals
"Helen.Dialogue.spring_12": "¡Ah, apuesto a que mi hija gana la búsqueda de huevos cada año!$h",
"Helen.Dialogue.spring_23": "Oh, cómo extraño bailar con mi amado.$s",
"Helen.Dialogue.summer_10": "Supervisaré cuidadosamente cómo se prepara la sopa mañana desde lejos para que mis seres queridos no sufran ningún dolor de estómago.$a",
"Helen.Dialogue.summer_27": "Echo de menos tener el abrazo de Ezekiel mientras vemos el mágico brillo de las medusas...$s#$b#Espero que esté bien...$s",
"Helen.Dialogue.fall_15": "La feria, ¿eh? Cuántos turistas entonces.#$b#Estaré atenta a los espías.",
"Helen.Dialogue.fall_19": "Todo mi romance con Ezekiel empezó por un tonto concurso entre chicos y chicas en la reunión de la aldea.$h#$b#Oh, cómo extraño esos tiempos más simples.",
"Helen.Dialogue.fall_26": "La víspera de los espíritus, ¿eh? Quizá pueda colarme con algún disfraz.$h",
"Helen.Dialogue.winter_7": "El festival del hielo... Oh, recuerdos.$s",
"Helen.Dialogue.winter_24": "Espero que mi familia disfrute mañana de la Estrella de Invierno.#$b#Lo celebraré con ellos desde la distancia.$h",
"Helen.Dialogue.winter_27": "Dile a mi querido Ezekiel que todo va a ir bien siempre que puedas, ¿vale?#$b#Necesita oírlo.$s",

//ANTON DIALOGUE (charlie!! nicee)
"keahiprank.Anton": "Vaya. No es por ser grosero, pero, uh...$u#$b#Apestas. Como, mucho.$u",

//Introduction
"Anton.Dialogue.Introduction": "¡Oh, hola! Encantado de conocerte, soy Anton.$h#$b#Si alguna vez necesitas que te hagan algo...#$b#Ve a ver a Robin. Ha. ¡Estoy seguro de que nos veremos por aquí!$h",

//Spring
"Anton.Dialogue.spring_1": "Sabes, no voy a mentir, estoy bastante contento de que el invierno haya terminado.#$b#No es la peor estación, pero definitivamente hace que trabajar al aire libre sea más difícil.$s#$b#Aunque todo el polen en primavera no es mucho mejor...$u",
"Anton.Dialogue.spring_12": "He pensado en ver si Lewis me deja ayudar con el festival del huevo, pero, eh... no sé, quizá el año que viene.$4",
"Anton.Dialogue.spring_23": "Oh, hey. La danza floral es mañana.#$b#Siempre me trae un montón de viejos recuerdos...$4#$b#Al menos será un bonito día para ello.$h",

//Summer
"Anton.Dialogue.summer_1": "Ah, ¡el verano ya está aquí!$h#$e#No hay nada como estar al aire libre bajo el sol mientras se trabaja en algún proyecto.$h#$b#O, eh... simplemente relajarse, supongo.",
"Anton.Dialogue.summer_10": "El gobernador va a estar en el valle mañana para ese gran Luau en la playa.#$e#Normalmente, ayudo a preparar, pero tal vez me quede fuera este año.$4#$b#No lo sé todavía.$s",
"Anton.Dialogue.summer_27": "Las medusas lunares son siempre algo tranquilizador.#$b#No siempre bajo a la playa a verlas, pero cuando lo hago, siempre parece que pone las cosas en perspectiva.$h",

//Fall
"Anton.Dialogue.fall_1": "¿Sabes lo que me gusta del otoño?#$b#Las hojas.$h#$e#Hay algo mágico en el simple hecho de caminar por la cresta cuando todas las hojas están cambiando de color y cayendo al suelo.$h",
"Anton.Dialogue.fall_15": "Sabes, sería muy chulo que la Feria tuviera algunas atracciones.$h#$e#Sé que en algunos ciudades, las ferias tienen grandes atracciones.#$b#Siempre me ha parecido peligroso, pero hombre, qué subidón apuesto que sería.$h",
"Anton.Dialogue.fall_26": "Sería genial que Lenny invirtiera en hacer algo para la Víspera de los Espíritus aquí en Ridgeside.#$b#No sé tú, pero a mí me parece que el bosque que rodea la cresta lo hace MUCHO más espeluznante que el valle.$h",

//Winter
"Anton.Dialogue.winter_1": "¡Hola, @! ¿Disfrutando del nuevo frío en el aire? El hotel de esta temporada es estupendo para las tardes; disfrutar del fuego y charlar con los amigos. ¿Qué es mejor?",
"Anton.Dialogue.winter_7": "El Festival del Hielo es mañana, pero no estoy seguro de si voy a ir.#$e#Oh, es que... No lo sé.#$b#No es lo mismo para mí que antes. Pero si vas, ¡espero que te diviertas, por supuesto!$h",
"Anton.Dialogue.winter_24": "Antes pasaba la Fiesta de la Estrella de Invierno con Kiarra, Lorenzo, y nuestros padres.#$b#Ahora es un poco diferente... pero sigue siendo bonito reunirse con la familia.$h",

//Days of the Week

//0 Hearts
"Anton.Dialogue.Mon": "¡Oh, hola! Espero que estés teniendo un buen día.$h",
"Anton.Dialogue.Tue": "Me pareció escuchar algo en medio de la noche, resulta que sólo fue un sueño.$u#$b#De todos modos, me tengo que ir, ¡que tengas un buen día!$h",
"Anton.Dialogue.Wed": "¡Ah, perdón! Me voy a trabajar un poco.",
"Anton.Dialogue.Thu": "¿Qué pasa?#$b#¡Espero que el día te trate bien!",
"Anton.Dialogue.Fri": "¿Alguna vez caminas por la cresta de noche?#$b#Muchas cosas espeluznantes, ¿verdad? Jaja. ¡Que tengas un buen día!$h",
"Anton.Dialogue.Sat": "Al hotel le vendría bien una pequeña reparación...#$b#¿Huh? Oh, nada. No he dicho nada. ¡Hasta luego!$h",
"Anton.Dialogue.Sun": "¿Cómo te va?#$b#¡Espero que tengas un buen día!$h",

//2 Hearts
"Anton.Dialogue.Mon2": "Hey, no puedo parar y hablar por mucho tiempo. ¡Tengo que ir a trabajar!$h#$e#¿Qué estoy haciendo?#$b#Uh... cosas del trabajo. Sí, ¡totalmente!",
"Anton.Dialogue.Tue2": "¿Cómo va todo?#$b#Día ocupado, ¿verdad?",
"Anton.Dialogue.Wed2": "Ya conociste a Paula, ¿no?#$b#Es una persona muy buena. Tiene unos chistes que te dejarían boquiabierto, jaja.$h",
"Anton.Dialogue.Thu2": "¿Conoces a mis hermanos?#$b#Kiarra y Lorenzo son buena gente. Aunque a veces me vuelvan loco.$h",
"Anton.Dialogue.Fri2": "Me pidieron que construyera un gabinete.#$b#Yo, em... lo rechacé.$s#$e#¿Por qué? Oh, uh... simplemente no me apetecía.",
"Anton.Dialogue.Sat2": "Anoche vi algo fuera de mi ventana. Parecía una fruta. Tal vez estaba soñando.",
"Anton.Dialogue.Sun2": "¿Qué pasa? Bonito día para hacer algo. O quedarse dentro y relajarse, jaja.",

//4 Hearts
"Anton.Dialogue.Mon4": "Anoche me tumbé en la cama y escuché música un rato. Sólo me relajé.$h#$b#Es tan agradable tomarse un tiempo para uno mismo, ¿sabes?$h",
"Anton.Dialogue.Tue4": "¡Hola! Espero que tu día vaya bien.$h",
"Anton.Dialogue.Wed4": "Anoche construí una silla.#$b#Me llevó dos semanas... y se rompió cuando me senté en ella.$s#$b#Paula dice que a veces me meto en mi propia cabeza y estropeo las cosas.$s",
"Anton.Dialogue.Thu4": "Anoche salí con Paula. ¡Lo pasamos muy bien! ¿Eh? Oh, no, así no, jaja. Sólo comimos algo. Totalmente casual.$5",
"Anton.Dialogue.Fri4": "¿Eh, sí?#$b#Oh, no, estoy bien.#$b#Sólo perdido en mis pensamientos, jaja.$h",
"Anton.Dialogue.Sat4": "Lorenzo vino anoche y estuvo hablando sobre cómo tengo que empezar a trabajar en mí mismo.#$b#Entiendo de dónde viene, pero... fue realmente incómodo.$s",
"Anton.Dialogue.Sun4": "Hola. He tenido una noche un poco dura, pero ya estoy bien.$s#$e#¿Cómo te va?$h#$b#¡Que tengas un buen día!$h",

//6 Hearts
"Anton.Dialogue.Mon6": "¡Hey, @! ¿Qué pasa?#$b#Otro día, otro desastre, jaja.$h#$b#Sólo bromeaba, estoy bien.",
"Anton.Dialogue.Tue6": "Tío, anoche hubo una gran tormenta que salió de la nada y arrancó el tejado de mi casa.$u^Tía, anoche hubo una gran tormenta que salió de la nada y arrancó el tejado de mi casa.$u#$e#¿Qué?#$b#Oh, no, fue un sueño. Lo siento, me olvidé de mencionar esa parte, ¡ja!$h",
"Anton.Dialogue.Wed6": "El otro día pillé a Kiarra y a Paula riéndose de algo y mirándome.$4#$b#No sé lo que era, pero espero que no se estuvieran burlando de mí.$s",
"Anton.Dialogue.Thu6": "¿Necesitas que te arreglen algo?#$b#No sé si podré ayudar, pero...$s#$b#Sin duda podría intentarlo, jaja.$h",
"Anton.Dialogue.Fri6": "¿Alguna vez has mirado las estrellas por la noche?#$b#Realmente te ayuda a despejar la cabeza cuando tienes muchas cosas en la cabeza.",
"Anton.Dialogue.Sat6": "Oh, hola, ¿qué haces?#$e#¡Que te vaya bien el día!",
"Anton.Dialogue.Sun6": "Anoche salí a comer con mis hermanos y Paula.#$b#Lo pasamos muy bien.$h#$e#A veces es muy agradable relajarse con los amigos y la familia, ¿sabes?$h",

//8 Hearts
"Anton.Dialogue.Mon8": "¡Hola! ¿Cómo te va?#$b#¡Espero que no te diviertas mucho en esa granja!$h#$b#Jaja, sólo bromeaba. Espero que te vaya bien.",
"Anton.Dialogue.Tue8": "¡Eh, @! Anoche terminé los últimos retoques de una pieza muy bonita en la que he estado trabajando.$h#$b#Puede que me haya cortado las manos un par de veces tallando, pero sin duda mereció la pena.$h",
"Anton.Dialogue.Wed8": "Vi a Maive el otro día y establecimos contacto visual...#$e#La mirada en sus ojos...$s#$b#Sé que todavía hay malos sentimientos ahí.$s#$b#Pero lo haré mejor. Todo lo que puedes hacer es aprender de tus errores, ¿sabes?",
"Anton.Dialogue.Thu8": "Paula y yo fuimos a dar un paseo por la cresta ayer.$h#$b#Fue muy agradable estar en la naturaleza, charlando y pasando el rato. Ella es una persona realmente genial.$4",
"Anton.Dialogue.Fri8": "¿Cómo te va?#$b#¿Necesitas algo?#$e#Sé que no soy la mejor persona para pedir ayuda, pero... si puedo, te ayudaré con gusto.$h",
"Anton.Dialogue.Sat8": "Kiarra me estaba hablando de un libro que leyó sobre la historia del activismo en las Islas Helecho.#$b#No entendí muy bien todo lo que decía, pero me encanta lo feliz que es haciendo lo que le gusta.",
"Anton.Dialogue.Sun8": "Otra semana más. Otra semana más.#$b#Me encanta la nueva semana; un nuevo comienzo para hacer algo nuevo.$h",

//10 Hearts
"Anton.Dialogue.Mon10": "¡Oh, hey @! ¡Estoy tan feliz de verte!$h#$b#No creerías las ideas que tengo para unos nuevos planes de arquitectura.$h#$b#Eso le mostrará a Maive lo que realmente puedo hacer, jaja.$h",
"Anton.Dialogue.Tue10": "Voy a pasar el rato con Paula en la cresta mañana.#$b#Tenemos algunas cosas que arreglar.#$e#¿Hm? Oh, no, nada malo.$u#$b#Estaba intentando decirme que su equipo favorito es mejor que el mío.$h#$b#No quieres saberlo.$u",
"Anton.Dialogue.Wed10": "Hey, gracias por charlar conmigo.#$b#Realmente aprecio que vengas a decir 'hola' de vez en cuando.#$b#Eres muy guay, @.",
"Anton.Dialogue.Thu10": "¿Qué pasa, @?#$b#Espero que te acuerdes de tomarte un tiempo para relajarte y desahogarte de vez en cuando.$h",
"Anton.Dialogue.Fri10": "Me lo pasé muy bien en Pika's la otra noche.#$b#¡Ese hombre sí que sabe cocinar!$h#$e#Lorenzo y Kiarra estaban un poco avergonzados por lo intenso que se puso todo, pero bueno, ¡me encanta la buena comida!$h",
"Anton.Dialogue.Sat10": "¿Cómo te va?#$b#Espero que estés logrando todo lo que quieres.$h",
"Anton.Dialogue.Sun10": "Hace un buen día, la vida es buena y me siento muy bien.$h#$b#Las cosas no pueden ir mucho mejor, ¿eh, @?$h",

//ARIAH DIALOGUE (mamaesh the queen)
"keahiprank.Ariah": "¿Qué es ese olor?$u#$b#Creo que tienes que ir a bañarte.$u.",

//Introduction
"Ariah.Dialogue.Introduction": "Hola, he oído que te llamas @.#$b#Si deseas saber más sobre leyes, historia y arte,- podría ser de ayuda.#$b#Me gustaría practicar las teorías de mi curso de pre-ley para jóvenes siempre que pueda!$h#$b#De lo contrario, por favor no me molestes. Tengo toneladas de trabajo que hacer.#$b#Ahora, si me disculpas.",

//Spring
"Ariah.Dialogue.spring_1": "La brisa primaveral es relajante. A veces, sólo quiero dormir, pero tengo que ir a clase.",
"Ariah.Dialogue.spring_12": "No me he unido a estas búsquedas de huevos antes.$s#$b#Siempre estaba demasiado ocupada.",
"Ariah.Dialogue.spring_23": "Hazme saber qué se siente al bailar con alguien que te gusta.#$b#Tengo bastante curiosidad.$s",

//Summer
"Ariah.Dialogue.summer_1": "Creo que esta temporada trae mucha serotonina y dopamina.$h",
"Ariah.Dialogue.summer_10": "Espero que la abuela no me haya colocado en su horario de mañana.#$e#Todavía tengo que repasar para mi sesión de debate.#$b#Es agotador...$s",
"Ariah.Dialogue.summer_27": "Estoy deseando que llegue la noche de mañana.#$b#Los cuerpos bioluminiscentes de las medusas son un espectáculo para los ojos.$h",

//Fall
"Ariah.Dialogue.fall_1": "Las hojas que caen me recuerdan los derechos humanos que seguirán cayendo si no se vota sabiamente.",
"Ariah.Dialogue.fall_15": "La exposición de mi familia ha sido un gran espectáculo cada año bajo la supervisión de mi abuela.#$b#Suerte con tu exposición para mañana.",
"Ariah.Dialogue.fall_26": "Hay algo en mí que disfruta de la fiesta de la Víspera de los Espíritus cada año.$4",

//Winter
"Ariah.Dialogue.winter_1": "La nieve es el clima perfecto para el chocolate caliente y el estudio.$h",
"Ariah.Dialogue.winter_7": "Recuerdo que mi abuelo me enseñó a pescar en el hielo.#$b#Lo extraño...",
"Ariah.Dialogue.winter_24": "¡Espero que hayas tenido un gran año, y que este nuevo año te traiga más alegría y conocimiento, @!$h",

//Days of the Week

//0 Hearts
"Ariah.Dialogue.Mon": "Uh, ¿perdón? ¿Puedes apartarte?$a#$e#Oh, no quiero ser grosera.#$b#Es sólo que tengo prisa por volver a mi libro.#$b#No querría perderme ni un minuto de estudio, ya sabes.",
"Ariah.Dialogue.Tue": "Oh, hola.#$b#¡Uh, sí! Que tengas un buen día, también.",
"Ariah.Dialogue.Wed": "Debo apresurarme a llegar a casa. Tendrás que disculparme, @.",
"Ariah.Dialogue.Thu": "Vestirse adecuadamente es una obligación cuando se va a la mansión.#$b#La abuela no aprobaría vestirse de forma descuidada.",
"Ariah.Dialogue.Fri": "Oh, hola.#$b#Sí, hace tiempo que no puedo socializar.#$e#La escuela me ha mantenido bastante ocupada estos días.",
"Ariah.Dialogue.Sat": "No tengo tiempo para ti, así que, si me disculpas.#$b#Me gustaría volver a mis estudios ahora.",
"Ariah.Dialogue.Sun": "No existe un día de descanso para nosotros.#$b#Tenemos muchas responsabilidades con nosotros mismos y con esta aldea.",

//2 Hearts
"Ariah.Dialogue.Mon2": "¿Has visto mis tarjetas de memoria?#$b#Parece que las perdí al volver a casa del museo la última vez.$s",
"Ariah.Dialogue.Tue2": "Formar parte de la línea Amethyne ha sido una gran responsabilidad.#$b#Todos esos años en el internado entrenando para ser lo mejor que puedo ser añade mucha presión.#$e#Oh, bueno. Estoy acostumbrada, supongo.",
"Ariah.Dialogue.Wed2": "¿Conoces alguna organización benéfica que esté necesitada ahora mismo?#$b#Mi abuela ha estado buscando otra organización benéfica en la que invertir.",
"Ariah.Dialogue.Thu2": "Hola, @.#$b#Debo darme prisa ahora. Estamos preparando la llegada de Zayne.",
"Ariah.Dialogue.Fri2": "Irene me ha estado dando la lata para ir a dar un paseo por la cresta.#$b#Sin embargo, no creo que tenga tiempo.",
"Ariah.Dialogue.Sat2": "¿Ya te has instalado, @?",
"Ariah.Dialogue.Sun2": "Irene hizo unas tortillas estupendas hace un rato.#$b#Creo que es la mejor cocinera de la aldea.",

//4 Hearts
"Ariah.Dialogue.Mon4": "Mi madre me ha estado insistiendo para que fije un calendario para mi retrato.#$b#Dijo que todos en la línea de sucesión de la familia debemos tener uno antes o cuando cumplamos los 21 años.",
"Ariah.Dialogue.Tue4": "Los estudios demuestran que beber café ayuda mucho a promover el estado de alerta y a reducir la fatiga.#$b#Sin embargo, provoca insomnio e inquietud.#$b#¿Qué crees que debo hacer?$s#$b#¿Debo seguir bebiendo café?",
"Ariah.Dialogue.Wed4": "¿Conociste a Sonny en la mansión?#$b#Ha estado en nuestra familia por generaciones.",
"Ariah.Dialogue.Thu4": "No he tenido la oportunidad de preparar mis preguntas para mi declaración simulada de la próxima semana.#$b#Debo apresurarme a llegar a casa ahora.",
"Ariah.Dialogue.Fri4": "Oh, hola. No te olvides de leer algunos libros de vez en cuando, ¿de acuerdo?#$b#Tienes que leer mucho si quieres aprender cosas nuevas y ser el mejor.^Tienes que leer mucho si quieres aprender cosas nuevas y ser la mejor.",
"Ariah.Dialogue.Sat4": "¿Eh? ¿Puedes dejar de molestarme? Me gustaría disfrutar de la vida en paz, ya sabes.$a",
"Ariah.Dialogue.Sun4": "Estoy deseando terminar de aprender la estructura de las ordenanzas, porque eso significa que puedo pasar a analizar su contenido.",

//6 Hearts
"Ariah.Dialogue.Mon6": "Disculpa si parezco estar fuera de lugar. Últimamente, he estado tratando de encontrar una manera de extender la caridad de mi familia a lugares lejanos.$s#$b#He leído sobre los efectos recientes de la guerra, aunque indirectos, hacia los afectados por la pobreza.$s#$e#¿Eh? ¿Qué? ¿Parezco preocupada?$u#$b#¡Uh, no! *glup* ¡Claro que no!$a#$e#Sólo estoy... Uh, buscando formas de difundir lo noble que es mi familia.$4#$b#Uh - ¡sí! ¡Eso es! No estoy cuidando, o algo parecido a una tontería, como tú dices.$4",
"Ariah.Dialogue.Tue6": "Si planeas visitar la mansión, tal vez podría pedirle a Irene que te prepare algunos bocadillos.#$b#Ella hace los más deliciosos Bollos Tella Chocky.$h",
"Ariah.Dialogue.Wed6": "Ha sido duro vivir bajo la sombra de todos los antepasados de Amethyne.$s#$b#Se siente como si todos ellos estuvieran observando cada uno de mis movimientos...$s",
"Ariah.Dialogue.Thu6": "¡Saludos, @!#$b#Deberías cuidarte.#$b#¡De acuerdo, adiós!",
"Ariah.Dialogue.Fri6": "Lo siento, no quiero hablar ahora mismo.#$b#Estoy un poco ocupada repasando la Constitución en mi cabeza. Los juicios simulados empiezan el próximo semestre.",
"Ariah.Dialogue.Sat6": "Es curioso lo parecidos que son los humanos y los animales.#$b#La gente se ofende mucho cuando les llaman animales, pero lo que no se dan cuenta es que todos estamos aquí en esta Tierra con un único propósito: sobrevivir.",
"Ariah.Dialogue.Sun6": "Hola, ¿cómo estás?#$b#No te preocupes por mí. Tengo muchas cosas que hacer, así que tengo que irme corriendo.#$b#¡Adiós!",

//8 Hearts
"Ariah.Dialogue.Mon8": "Ser parte de la línea de sucesión en mi familia ha sido una gran responsabilidad.#$b#Todos esos años en el internado entrenando para ser lo mejor que puedo ser añade mucha presión.$s#$e#Oh, bueno. Estoy acostumbrada, supongo.$s",
"Ariah.Dialogue.Tue8": "¡Buenos días, @!$h#$b#¿Te ha ido bien?",
"Ariah.Dialogue.Wed8": "Hmm, debes llevarme a tu granja alguna vez.$4#$b#Me encantaría que te tomaras el tiempo de enseñarme sobre agricultura.$h",
"Ariah.Dialogue.Thu8": "Oh, eres tú otra vez. ¿Qué tan beneficioso es que me haya encontrado contigo hoy?$h#$e#¿Te gustaría donar a la organización benéfica de mi familia?#$b#Es para un pequeño pueblo de las afueras.#$e#Si estás dispuesto, por favor deja los detalles de tu donación con Sonny.$h^Si estás dispuesta, por favor deja los detalles de tu donación con Sonny.$h",
"Ariah.Dialogue.Fri8": "He oído hablar de la cresta antes, pero no he tenido la oportunidad de visitarla todavía.#$b#¿Tal vez te gustaría ir conmigo alguna vez, @?$h",
"Ariah.Dialogue.Sat8": "Lo siento, no quiero hablar ahora mismo. Estoy un poco ocupada repasando la Constitución en mi cabeza. Los juicios simulados empiezan el próximo semestre.",
"Ariah.Dialogue.Sun8": "Lo siento, es que ahora mismo tengo que concentrar mi energía en el estudio.",

//10 Hearts
"Ariah.Dialogue.Mon10": "La política es ciertamente un tema controvertido.#$b#Las opiniones pueden variar para diferentes personas, pero hay que recordar que los desarrollos y avances en la sociedad vistos a través del currículum de cada candidato son una base mucho mejor que las falsas promesas hechas durante las campañas.#$e#Ah, es un poco estresante aprender sobre todo esto.",
"Ariah.Dialogue.Tue10": "¡Hola de nuevo, @!#$b#Ha sido un poco estresante últimamente. Espero no haberte agobiado con mis cambios de humor.$s",
"Ariah.Dialogue.Wed10": "La presión y el ojo vigilante del público sólo añaden presión a los estándares que la abuela tiene para mí.$s#$b#Todo el mundo espera mucho.$s",
"Ariah.Dialogue.Thu10": "Hmm, no me he sentido bien últimamente.$4#$b#Disculpa un momento. Tengo que pedirle a Sonny que revise mi agenda y que me organice una cita con el médico.",
"Ariah.Dialogue.Fri10": "Realmente sólo quiero que mi abuela esté orgullosa de mí.$s#$b#No quiero ser una vergüenza para la familia.$s",
"Ariah.Dialogue.Sat10": "Louie se ha convertido en una estirada, lo sé.#$b#Sin embargo, creo que sólo está actuando.#$b#Sé cómo se siente...$s",
"Ariah.Dialogue.Sun10": "¡Ha sido un día tan largo!$s#$b#¡Pero sé que los cursos oficiales de pre-derecho no serán más fáciles una vez que termine la secundaria!$s#$b#*Suspiro* ¡La adultez suena intimidante! ¿No estás de acuerdo, @?$s",

//BLAIR DIALOGUE (mamaesh the queen)
"keahiprank.Blair": "Oh, hombre, ¿qué es ese olor?$u#$b#Uh, ¿@?#$b#No creo que debas estar cerca de nadie en este momento.$u",

//Introduction
"Blair.Dialogue.Introduction": "Sabes, nunca te he visto aquí antes.#$b#¿Cómo te llamas?$h#$b#¡Oh, hola, @! ¡Soy Blair, tu futura esposa!$h#$b#¡Es una broma! ¡Ja, ja!$h",

//Spring
"Blair.Dialogue.spring_1": "¡Ah!$h#$b#Qué día tan maravilloso.#$b#¡Las bonitas florecillas me alegran!$h",
"Blair.Dialogue.spring_12": "El festival de mañana es algo interesante.$7#$b#Imagínate buscando huevos duros.$6#$b#Parece una locura, ¿no crees?",
"Blair.Dialogue.spring_23": "Hmm, me pregunto cómo será que te inviten a bailar...$7#$b#Ver a gente sudorosa pidiendo a otros que bailen será interesante mañana.$7",

//Summer
"Blair.Dialogue.summer_1": "¡Una temporada perfecta para pescar!$h#$b#Oh, a quién quiero engañar. Todas las estaciones son perfectas para pescar.",
"Blair.Dialogue.summer_10": "Voy a hacer mi mejor pesca de esta semana para el festival de mañana.$h#$b#¿Y tú, @? ¿Qué piensas llevar?",
"Blair.Dialogue.summer_27": "Estoy bastante emocionada por el festival de mañana por la noche.$h#$b#De alguna manera le da a todo el mundo la oportunidad de ver la belleza del mar.$4#$b#Jeje, ¿lo pillas?$h",

//Fall
"Blair.Dialogue.fall_1": "Ah, la encantadora brisa del otoño.$7#$b#Las hojas se ven tan bonitas cuando caen.#$b#Es como pequeños trozos de colores cayendo del cielo.$h",
"Blair.Dialogue.fall_15": "¡Estoy tan emocionada por ir a la feria mañana!#$b#Sean y Keahi han estado esperando para darnos una paliza a Trinnie y a mí.$h",
"Blair.Dialogue.fall_26": "¿Piensas disfrazarte mañana?#$b#Sean y yo estamos pensando en venir de superespías. ¡¡SUPERESPÍAS!!$h",

//Winter
"Blair.Dialogue.winter_1": "¿No crees que es un buen día para acurrucarse en casa?$7#$b#Hmm, ¿quieres pasar el rato junto al fuego, @?$7#$b#Jajaja, sólo bromeaba.$h#$b#Bueno, podríamos hacerlo real si quieres.$4",
"Blair.Dialogue.winter_7": "¡Apuesto a que no podrías ganarme en la pesca en hielo mañana!$h#$b#¡Más vale que pongas tu mejor cara de juego, @!",
"Blair.Dialogue.winter_24": "Hmm... Me pregunto cuál es el mejor cultivo para plantar la próxima primavera. Necesitamos los ingresos extra, ¿sabes?#$b#La pesca no cubre exactamente todos los gastos.$7#$b#*suspiro* Toda esta matemática es agotadora. Lo resolveré más tarde cuando me tome una cerveza.$7",

//Days of the Week

//0 Hearts
"Blair.Dialogue.Mon": "¡Oh, oh, oh!$h#$b#¡Quiero ir de compras a un gran centro comercial algún día!$h#$e#¡Ah! ¡Piensa en los lindos vestidos, en los dulces, en las caras nuevas!$h#$b#¡Oooh, especialmente en las lindas!$h#$e#¡Oh, lo siento!$6#$b#¿He dicho eso en voz alta?$6",
"Blair.Dialogue.Tue": "¿Conoces a Sean?#$b#Es mi mejor amigo en todo el mundo.#$e#Ahora que lo pienso, creo que necesito un nuevo mejor amigo.$u^Ahora que lo pienso, creo que necesito una nueva mejor amiga.$u#$b#¡¡Sólo bromeo!! Pero estoy abierta a nuevos amigos.$h^¡¡Sólo bromeo!! Pero estoy abierta a nuevas amigas.$h",
"Blair.Dialogue.Wed": "Willy me ha dicho que tenemos un potencial aprendiz.^Willy me ha dicho que tenemos una potencial aprendiz.#$b#¿Eres tú?",
"Blair.Dialogue.Thu": "Trinnie me ha estado molestando para que la ayude con Keahi.#$b#Esa niña es tan... peleona.$h",
"Blair.Dialogue.Fri": "Mi padre me enseñó a elegir el mejor cebo para el pez que quiero pescar.#$b#A menudo me decía 'Sabes Blair, ¡tienes que saber de peces, para pescar!'#$b#No lo entendí bien al principio pero, oh bueno. Las palabras de los sabios siguen siendo el mejor consejo que te dan.$7",
"Blair.Dialogue.Sat": "Oh, hola de nuevo.#$b#Es un gran día para estar viva, ¿no?$h",
"Blair.Dialogue.Sun": "Mi madre me ha estado dando la lata para que consiga un cubo más nuevo para mi cebo.#$b#Sigue agarrando los míos y acaban resbalando en sus manos. ¡Caramba!$u",

//2 Hearts
"Blair.Dialogue.Mon2": "Oh, ¡hola!#$b#Me encantaría quedarme a charlar aquí contigo, pero mis postes necesitan ser atendidos.#$e#Oh, también tengo que recoger algo de cebo.",
"Blair.Dialogue.Tue2": "No he visto un mejor pescador que mi padre.$h#$b#Echo de menos a ese grandulón.$s",
"Blair.Dialogue.Wed2": "¿Alguna vez te has preguntado qué pasa en tu cerebro cuando duermes?#$e#¿Dónde viaja nuestro subconsciente?#$b#¿Nuestro espíritu viaja en diferentes reinos?#$e#Hmm, tal vez debería preguntarle a alguien más sabio.$7",
"Blair.Dialogue.Thu2": "Todo el mundo está preocupado por sus granjas.#$b#¿No saben que la pesca es la próxima gran cosa?$u#$b#¡Bromeando! ¡Hazlo tú, amigo!$h^¡Bromeando! ¡Hazlo tú, amiga!$h",
"Blair.Dialogue.Fri2": "Sean es un cabrón.#$b#¡Bueno Yoba, tengo que conseguirle un trabajo!$u",
"Blair.Dialogue.Sat2": "¿No es increíble cómo la brisa sopla a través de nuestro pelo?#$b#¿De dónde viene el viento?#$e#Hmm, tengo que preguntarle a Maddie sobre esto.$7",
"Blair.Dialogue.Sun2": "Tienes que relajarte a veces, @.#$b#Creo que ya veo líneas de expresión en tu cara.$u",

//4 Hearts
"Blair.Dialogue.Mon4": "¡Hola! ¿Cómo va tu granja?#$b#¡Si quieres aprender a pescar, podría enseñarte!$h#$b#¡Apuesto a que soy la mejor maestra que hay!$h",
"Blair.Dialogue.Tue4": "%Blair parece somnolienta.#$e#Quiero dormir...$s",
"Blair.Dialogue.Wed4": "¡Oh, hola!#$b#No te vi.#$e#Estaba ocupada soñando despierta con mi futura boda.$4#$b#*risitas* Quiero que la mía sea al anochecer o al amanecer.$h#$b#¡Estoy tan emocionada!$h#$e#¿Huh?#$b#Oh, sí, claro. Ni siquiera estoy en una relación todavía.#$b#Bueno, ¿te gustaría estar conmigo?$6#$b#¡Ja, es broma!$h",
"Blair.Dialogue.Thu4": "Eres un encanto, ¿verdad?$7#$b#¡Espero encontrar a alguien tan guapo como tú!$h^¡Espero encontrar a alguien tan hermosa como tú!$h",
"Blair.Dialogue.Fri4": "La pesca siempre ha sido una buena forma de desahogarme.#$b#Ser una con el mar es realmente bueno para el alma.$4",
"Blair.Dialogue.Sat4": "%Blair parece estar hablando consigo misma.",
"Blair.Dialogue.Sun4": "¿Hablaste conmigo ayer?#$b#Si lo hiciste, siento haber estado un poco fuera de mí.$6",

//6 Hearts
"Blair.Dialogue.Mon6": "Mi abuelo me enseñó a pescar.#$e#Me recogía en casa por la mañana temprano.#$b#Luego dábamos un paseo por el arroyo que va hacia el campo.#$b#Hablábamos toda la mañana mientras me enseñaba cosas como qué hacer con el cebo o qué anzuelo usar.$7#$b#Ah, le echo de menos.$s",
"Blair.Dialogue.Tue6": "A veces, todavía me pregunto por mi padre...$s#$b#¿Me echa de menos alguna vez?$s#$e#Oh, bueno. Mientras sea bonita y esté bien alimentada. Estaré bien.$h#$e#¿Eh?#$b#Sí, por supuesto, estoy bien.$h#$b#Mi madre no puede verme así, o se burlará de mí por ello.$7",
"Blair.Dialogue.Wed6": "%Blair parece irritada.#$e#Mamá me está irritando mucho últimamente.$a#$e#¿Eh? Oh, no es nada. Ella sólo está... ¡Ugh!$a",
"Blair.Dialogue.Thu6": "Lo siento, tengo que irme.#$b#No estoy de humor para hablar con nadie ahora mismo.",
"Blair.Dialogue.Fri6": "¿Alguna vez te has preguntado cómo funciona la lluvia?#$b#¿Las nubes tienen estados de ánimo o algo así?$u#$b#¡Caramba! ¡Tengo que preguntarle a Maddie sobre esto otra vez!",
"Blair.Dialogue.Sat6": "Quiero vivir cerca de la playa algún día.#$b#Sería mucho más fácil ir al mar y pescar si eso ocurre.$h",
"Blair.Dialogue.Sun6": "¡Hola, @!#$b#Sabes, me gusta mucho hablar contigo.#$b#Es tan fácil hablar contigo.$h",

//8 Hearts
"Blair.Dialogue.Mon8": "¿Hay más bellezas como tú en tu lugar de origen, @?$7#$b#¡Jaja! ¡Sólo bromeaba!$h#$b#¡Te he pillado sonrojado!$h^¡Te he pillado sonrojada!$h",
"Blair.Dialogue.Tue8": "¡Oh, eres tú! No te había visto.#$b#Creo que soy sonámbula, ¿o es que estoy soñando? Uh, ahora no estoy tan segura.#$e#Supongo que he estado muy cansada últimamente.",
"Blair.Dialogue.Wed8": "Realmente no entiendo a mi madre.$s#$b#¿Por qué tiene que bromear así con mi padre?$s#$b#¿Ya no lo quiere?$s",
"Blair.Dialogue.Thu8": "%Blair está molesta. Es mejor dejarla ahora mismo.",
"Blair.Dialogue.Fri8": "Ugh, han sido un par de días muy duros.$7#$b#No sé... Con la marcha de mi padre y todo eso. Todavía no está bien para mí.$s",
"Blair.Dialogue.Sat8": "Sean ha sido un muy buen amigo para mí.#$e#No te preocupes, tú también eres un buen amigo para mí, @.^No te preocupes, tú también eres una buena amiga para mí, @.",
"Blair.Dialogue.Sun8": "Si quieres venir algún día, Sean y yo estamos planeando ir a un picnic con los niños pronto.$h",

//10 Hearts
"Blair.Dialogue.Mon10": "¡Hola, amigo! Jajaja, aww. ¿Te sorprende?$h^¡Hola, amiga! Jajaja, aww. ¿Te sorprende?$h#$e#Aunque realmente te considero mi mejor amigo.$4^Aunque realmente te considero mi mejor amiga.$4#$b#Has sido genial conmigo, @.#$b#Gracias.$4",
"Blair.Dialogue.Tue10": "Mi madre se ha esforzado mucho por mantener las bromas a raya.#$b#Le agradezco que lo haga por mí.",
"Blair.Dialogue.Wed10": "¡Eh, @! ¿Puedes cerrar los ojos para mí sólo un segundo?#$b#Bien, ahora ábrelos.#$b#Ahora, ¿has visto cómo sería mi mundo sin ti?$6#$b#Jaja, sólo bromeaba. ¡Me gusta cuando tus mejillas se ponen rojas!$h#$b#*risita* ¿Cómo van las cosas por el pueblo hoy?$h",
"Blair.Dialogue.Thu10": "%Blair parece estar soñando despierta.#$e#¡Whoa! ¡Mi cabeza estaba en las nubes!$h#$b#¡Gracias por despertarme, amigo!^¡Gracias por despertarme, amiga!",
"Blair.Dialogue.Fri10": "Aunque mi madre me explicó por qué no le gustaba mi padre, sigo echándole de menos.$s#$e#¡Gracias por consolarme, amigo!$h^¡Gracias por consolarme, amiga!$h",
"Blair.Dialogue.Sat10": "¡Me alegro mucho de que te hayas quedado por aquí, grandulón!^Me alegro mucho de que te hayas quedado por aquí, @.#$b#Eres una de las mejores personas que han venido a la aldea.$4",
"Blair.Dialogue.Sat10.GN": "¡Me alegro mucho de que te hayas quedado por aquí, @!#$b#Eres una de las mejores personas que han venido a la aldea.$4",
"Blair.Dialogue.Sun10": "¡Hola, @!#$b#Gracias por escuchar mis problemas.#$b#Siento que a veces soy una gran carga para ti.$s",

//BRYLE DIALOGUE
"keahiprank.Bryle": "¡Hey!$u#$b#¿Tienes algo que te preocupa, @?$s#$b#¡Ey! ¡No estoy juzgando! ¡Pero puede que te hayas olvidado de tomar una ducha o dos!$u",

//Randomized
"Bryle.Dialogue.random.1" : "Jeric es un buen tipo.#$b#Sólo ignora toda la onda de 'soy un hombre hermoso' y estarás bien.$h",
"Bryle.Dialogue.random.2" : "Lenny me ha estado invitando a su oficina últimamente.#$b#Dice que quiere que le transmita algunos mensajes al Gobernador.#$e#Es una gran trabajadora, ¿no?$h",
"Bryle.Dialogue.random.3" : "¿Qué pasa con esa chica Faye?$a#$b#Se quedó mirándome mientras comía en Pika's, es preocupante.$s#$b#Una vez derramó café caliente sobre mis pantalones cuando pasé por el mostrador, así que ahora tengo un poco de cuidado.",
"Bryle.Dialogue.random.4" : "El gobernador me permitió tomarme el día libre hoy.#$b#Pensé que sería bueno usarlo para visitar las montañas.$h",
"Bryle.Dialogue.random.5" : "¡Ah! ¡Este aire fresco del valle es fuego!$h#$b#Oh! Es una manera de hablar.#$b#¿No sería preocupante si el aire estuviera literalmente en llamas?$h",
"Bryle.Dialogue.random.6" : "¡Ah, tío!$u^¡Ah, tía!$u#$b#¡Olvidé devolver la chaqueta que me prestó Zayne!$s#$e#Bueno, quizá lo vuelva a ver pronto cuando visite al Gobernador.#$b#Ya que soy su guardaespaldas personal y todo eso.$h",
"Bryle.Dialogue.random.7" : "Ese chico, Keahi, es muy divertido.$h#$b#El otro día le vi ponerle una chinche a un visitante.#$b#¡Esas bromas inofensivas son un tesoro!$h#$b#También lo hacíamos mucho en el ejército.$h",
"Bryle.Dialogue.random.8" : "La granja de Jeric parece estar creciendo.#$b#Me alegro de que mi viejo amigo sea feliz y le vaya bien.$h",
"Bryle.Dialogue.random.9" : "Debería ahorrar para comprar un coche.$s#$b#A veces es un poco cansador coger el autobús desde Zuzu hasta aquí.",
"Bryle.Dialogue.random.10" : "Una vez acompañé al Gobernador a una de sus vacaciones en las Islas Helecho.#$b#Ah, esta línea de trabajo tiene un montón de beneficios, ¿no?$h",
"Bryle.Dialogue.random.11" : "¿Cómo funciona la agricultura?#$b#Debería preguntarle a Jeric más al respecto. Tal vez quiera empezar sólo con una suculenta en casa.$h",
"Bryle.Dialogue.random.12" : "¡Guau! Parece que tienes mucho tiempo libre, ¿eh?$h#$b#Bueno, está bien relajarse de vez en cuando.",
"Bryle.Dialogue.random.13" : "¡Ah! Nada supera el ambiente del valle.$h#$b#Podría querer mudarme aquí algún día.",
"Bryle.Dialogue.random.14" : "Lewis y Lenny tienen una divertida relación de hermanos.$h#$b#Sin embargo, a veces, Lenny parece llevarlo demasiado lejos, ¡y puedo ver al viejo echando humo!$h#$b#El otro día estuve en la oficina de la señora, así es como vi sus intercambios.$h",
"Bryle.Dialogue.random.15" : "¡Hey, @!$h#$b#¿Te va bien, verdad?$h#$e#¡Cuídate!$h",
"Bryle.Dialogue.random.16" : "¡Hombre! Me gustaría volver a pasar una noche en el hotel.$h#$b#La última vez que estuve allí, dormí como un tronco y me olvidé de la hora de salida.$h#$b#Hombre, tiempos divertidos.",
"Bryle.Dialogue.random.17" : "Richard es un tipo estupendo. Me enseñó un poco sobre negocios el otro día y fue realmente útil.#$e#Podría considerar montar uno yo mismo si alguna vez quiero dejar este trabajo de seguridad, ¿sabes?",
"Bryle.Dialogue.random.18" : "El peligro viene con el trabajo, sin duda.#$b#Pero tengo algunos beneficios, como cenar en restaurantes de lujo y viajar en aviones privados.$h#$e#¡Hombre! ¡La familia del Gobernador está forrada!$h",
"Bryle.Dialogue.random.19" : "Me pregunto qué habrá más allá de la cresta.#$b#El bosque al norte me da escalofríos.$u",
"Bryle.Dialogue.random.20" : "¿Qué es esa historia de un kiwi rodante en el pueblo?#$b#A mí también me gustaría verlo.$h",

//CARMEN DIALOGUE (MAMAESH U BEAST) (NOTE: Carmen isn't that good with English because her native language is Spanish. Which is why naturally short sentences become long for her because sometimes unnecessary words are there. Imagine Gloria Pritchett from Modern Family - mamaesh)

"keahiprank.Carmen": "¡Ay dios mio!$u#$b#¿Qué es ese olor?$u#$b#¡Oh, no! ¡Hueles más que los peces!$u",

//Introduction
"Carmen.Dialogue.Introduction": "¡Hola!#$b#Mi nombre es Carmen.#$b#Si necesitas cualquier cosa de pesca, ¡te cubro la espalda!$h",

//Spring
"Carmen.Dialogue.spring_1": "Es un día tan bonito, ¿verdad, granjero?^Es un día tan bonito, ¿verdad, granjera?#$b#¡Las bonitas flores están brotando en el suelo, y el cielo es tan azul!$h",
"Carmen.Dialogue.spring_12": "No entiendo por qué están tan preocupados por lo de mañana.#$b#¿Por qué alguien querría pintar sus huevos?$u",
"Carmen.Dialogue.spring_23": "Mi ex-marido y yo nos conocimos durante un festival similar al de mañana hace años.#$b#Quién iba a pensar que me casaría con un vago como él.$u#$b#¡Gracias Yoba, eso se acabó!$h",

//Summer
"Carmen.Dialogue.summer_1": "Ay, qué calor hace.$u#$b#Esta temporada me está dando dolores de cabeza.$s",
"Carmen.Dialogue.summer_10": "¡Estoy tan emocionada de hacer mi contribución a la sopa de la olla mañana!$h#$b#Me aseguré de escoger el mejor ingrediente.$h",
"Carmen.Dialogue.summer_27": "No te alejes demasiado en la oscuridad mañana.#$b#Así es como accidentalmente te metes en problemas.$4",

//Fall
"Carmen.Dialogue.fall_1": "¡Es la estación perfecta, con el clima perfecto!#$b#No hace demasiado calor, ni demasiado frío. Todo lo que necesitas es una chaqueta ligera.$h",
"Carmen.Dialogue.fall_15": "Oh, espero poder ganar un taka taka taka.$h#$b#Ya sabes, esos modelitos de la cosa voladora que hace 'taka taka taka'.$h",
"Carmen.Dialogue.fall_26": "Ay, quiero vestirme como la bruja de la aldea mañana.$h#$b#Quiero asustar a los espíritus vivos de los demás.$4#$e#Si me dan la oportunidad me gustaría asustar a mi ex marido hasta que se desviva.$h",

//Winter
"Carmen.Dialogue.winter_1": "Brr...#$b#No estoy tan acostumbrada al frío.#$b#Lo único bueno que tiene es el pescado en el agua helada.#$b#Lo hace delicioso, ¿sabes?",
"Carmen.Dialogue.winter_7": "Apuesto a que no podrías ganarnos a mí y a mi hija en el concurso de mañana.$4",
"Carmen.Dialogue.winter_24": "Espero que tengas un próspero año nuevo por delante.$h#$b#Que tu futuro sea más brillante que el del vago de mi ex marido.$4",

//Days of the Week

//0 Hearts0
"Carmen.Dialogue.Mon": "¿Sabías que los peces no tienen cuerdas vocales?$h#$b#Ya me gustaría a mí que mi ex marido tampoco las tuviera, ¡ja!$h",
"Carmen.Dialogue.Tue": "Me apetece mucho un Pescado frito a la Ridge ahora mismo.$s",
"Carmen.Dialogue.Wed": "Ay, es muy cansador viajar de la aldea a la playa todos los días.#$b#Pero quiero a mi hija, quiero darle lo mejor.",
"Carmen.Dialogue.Thu": "Willy le dijo hace poco a Blair que es muy buena.$h#$b#Incluso le dijo que será una buena estudiante asistente.#$e#Estoy muy orgullosa de mi hija.$h#$b#Realmente no se parece en nada a su padre.$4",
"Carmen.Dialogue.Fri": "¡Ay, Blair!$a#$b#Le he dicho que se compre un cubo nuevo porque el que tiene ahora está muy resbaladizo.$a#$b#Se siente como el lomo de una rana. Ayayay.$u",
"Carmen.Dialogue.Sat": "¡Oh hola, hijo!$h^Oh hola, hija!$h#$b#Sabes que me recuerdas a mi primo de la ciudad.",
"Carmen.Dialogue.Sat.GN": "¡Oh hola, cielo!$h#$b#Sabes que me recuerdas a mi primo de la ciudad.",
"Carmen.Dialogue.Sun": "¡Hoy debería ser un buen día para pescar!$h",

//2 Hearts
"Carmen.Dialogue.Mon2": "¡Hola, @!$h#$b#Espero que tengas un maravilloso día.$h",
"Carmen.Dialogue.Tue2": "¿Me he olvidado de cerrar las ventanas otra vez?$s#$b#¡Ay Dios mío, me estoy volviendo olvidadiza!$s",
"Carmen.Dialogue.Wed2": "¿Conoces algún buen sitio para pescar?#$b#Ay hijo, no te olvides de decírmelo, ¿vale?$h^Ay hija, no te olvides de decírmelo, ¿vale?$h",
"Carmen.Dialogue.Wed2.GN": "¿Conoces algún buen sitio para pescar?#$b#Ay cielo, no te olvides de decírmelo, ¿vale?$h",
"Carmen.Dialogue.Thu2": "Creo que necesito una o dos cervezas.$h#$b#¡Sólo quiero relajarme!",
"Carmen.Dialogue.Fri2": "¿Por qué Lenny y Lewis no juntan los dos pueblos y hacen un solo pueblo enorme?$h#$b#Así no tengo que viajar tan lejos sólo para pescar en la playa, si?$h",
"Carmen.Dialogue.Sat2": "Ese guapo muchacho terapeuta, Philip, me curó el brazo cuando me lesioné después de un intenso día de pesca.#$b#¡Mi hija debería encontrar un hombre como él!$h",
"Carmen.Dialogue.Sun2": "%Carmen bosteza.#$b#¡Ay dios mio, no he dormido bien!$s",

//4 Hearts
"Carmen.Dialogue.Mon4": "Ay hijo, no debes dejar que tu sudor gotee así.$u^Ay hija, no debes dejar que tu sudor gotee así.$u#$b#¡Debes ponerte una toalla en la espalda!$u",
"Carmen.Dialogue.Mon4.GN": "Ay cielo, no debes dejar que tu sudor gotee así.$u#$b#¡Debes ponerte una toalla en la espalda!$u",
"Carmen.Dialogue.Tue4": "Ese inútil de mi ex marido no sabía tratar bien a una mujer.$a#$b#Tienes que hacerlo mejor, hijo.^Tienes que hacerlo mejor, hija.#$e#¡Le doy las gracias a Yoba, Blair no sacó su personalidad de su padre!$a",
"Carmen.Dialogue.Tue4.GN": "Ese inútil de mi ex marido no sabía tratar bien a una mujer.$a#$b#Tienes que hacerlo mejor, cielo.#$e#¡Le doy las gracias a Yoba, Blair no sacó su personalidad de su padre!$a",
"Carmen.Dialogue.Wed4": "Los peces de la montaña son muy diferentes a los del mar.#$b#¡Deberías saber pescar todos y cada uno de los peces para poder conseguir más dinero!$h",
"Carmen.Dialogue.Thu4": "No debería olvidarme de beber mucha agua.$s#$b#Mi hija se enfadó conmigo el otro día porque me dolía mucho la cabeza por estar mucho tiempo al sol.$s",
"Carmen.Dialogue.Fri4": "Olga y Shanice son chicas divertidas con las que hablar.#$b#¡La última vez que hablamos, me contaron todos los detalles pícaros de los hombres mayores solteros de Pueblo Pelícano!$h",
"Carmen.Dialogue.Sat4": "¿Has comprado algún pescado a Willy, @?#$e#¡Alguno es de mi parte!$h",
"Carmen.Dialogue.Sun4": "%Carmen bosteza.#$b#¡Creo que dormiré después de pescar un poco!$h",

//6 Hearts
"Carmen.Dialogue.Mon6": "¡Ya no puedes confiar en nadie!$a#$b#Un día tienes un hijo con ellos, y al siguiente estás peleando por la manutención.$a#$b#¡Qué irresponsable!$a",
"Carmen.Dialogue.Tue6": "¡Los platos de Pika son asombrosos y deliciosos!$h#$b#Debería pedir pronto comida para llevar.",
"Carmen.Dialogue.Wed6": "¡Tengo la norma de no meter pescado en la nevera en casa y la cumplimos a rajatabla!$a#$b#Tenemos una nevera diferente para los pescados que vendemos así que todo es bueno.$h",
"Carmen.Dialogue.Thu6": "%Carmen bosteza.#$b#Debería tomar café o tal vez probar a beber té para variar.$h",
"Carmen.Dialogue.Fri6": "%Carmen parece estar distraída.#$e#¡Oh! ¡Ay Dios mio! Lo siento mucho, estaba pensando en la cantidad de pescado que vendimos el otro día.$h#$b#Creo que sería la mejor opción para llevar la cuenta de tus ventas, ¿sí?",
"Carmen.Dialogue.Sat6": "Richard es un buen muchacho.$h#$b#Quiero llamarlo mi lolo.$h",
"Carmen.Dialogue.Sun6": "Esa chica-no. Ese chico, Sean, es un buen hombre.$h#$b#Sin embargo, a veces es un poco vago, lo que no me gusta mucho.$s#$b#Pero al menos no es un alborotador.",

//8 Hearts
"Carmen.Dialogue.Mon8": "¿Cómo va todo, hijo?^¿Cómo va todo, hija?#$b#Ay, espero que el día te haya tratado bien.$h",
"Carmen.Dialogue.Mon8.GN": "¿Cómo va todo, cielo?#$b#Ay, espero que el día te haya tratado bien.$h",
"Carmen.Dialogue.Tue8": "¿Cómo está tu granja, hijo?^¿Cómo está tu granja, hija?#$b#Espero que todo vaya bien allá.$h#$b#Tienes mucho talento, así que sé que puedes hacerlo.",
"Carmen.Dialogue.Tue8.GN": "¿Cómo está tu granja, cielo?#$b#Espero que todo vaya bien allá.$h#$b#Tienes mucho talento, así que sé que puedes hacerlo.",
"Carmen.Dialogue.Wed8": "¿Hay peces en tu granja, @?#$b#Pero no tanto comparado con las montañas y el mar, ¿si?$h",
"Carmen.Dialogue.Thu8": "Mi hija, Blair, a veces se mete en berrinches y nos peleamos durante horas y horas.$s#$b#No me gustan mucho esas horas.$s",
"Carmen.Dialogue.Fri8": "Apuesto a que tienes muchos amigos y amigas, ¿si?$h#$b#Eres una buena persona, así que debes caerle bien a la gente.",
"Carmen.Dialogue.Sat8": "No sé realmente si lo que estoy haciendo es lo mejor para mi hija.$s#$b#Pero lo único que sé es que voy a trabajar duro todos los días por nuestra familia.",
"Carmen.Dialogue.Sun8": "%Carmen parece estar somnolienta.#$b#No he tenido una buena noche de sueño.$s#$b#Estaba ocupada preparando nuestro envío.",

//10 Hearts
"Carmen.Dialogue.Mon10": "Estoy muy agradecida por mis padres, ¿sabes?#$b#Me ayudaron a criar a mi pequeña hija.#$e#Y sé que tal vez no lo exprese muy bien, pero...#$b#Ella es realmente la mejor parte de mí y de su padre.#$b#Estoy orgullosa de ella.",
"Carmen.Dialogue.Tue10": "¿Hijo?^¿Hija?#$b#Si alguna vez necesitas ayuda o una tita divertida, aquí estoy, ¿vale?$h#$b#Eres un buen amigo, y yo quiero serlo también para ti.^Eres una buena amiga, y yo quiero serlo también para ti.",
"Carmen.Dialogue.Tue10.GN": "¿Cielo?#$b#Si alguna vez necesitas ayuda o una tita divertida, aquí estoy, ¿vale?$h#$b#Tenemos una buena amistad, y yo quiero ser buena contigo también.",
"Carmen.Dialogue.Wed10": "Ahora entiendo por qué Blair siempre se enfadaba cuando bromeaba sobre su padre.#$b#Gracias por prestarle tu oído, @.",
"Carmen.Dialogue.Thu10": "Lenny es una buena amiga. Ha estado a mi lado desde entonces hasta ahora.#$b#¡Si algún día quiere casarse, me aseguraré de ser la dama de honor porque lo haré todo por esa chica, ella es mi chica!$h",
"Carmen.Dialogue.Fri10": "¿Has oído hablar del espiritu de montana?#$b#He oído que es una persona preciosa con pelaje rojo y ojos verdes.$h#$b#Eso suena mágico, ¿verdad?$h",
"Carmen.Dialogue.Sat10": "¿Estanques de peces? Robin puede construirlos, ¿no?#$b#Creo que deberíamos construir uno en la aldea también.#$e#¡Me haré totalmente responsable de ello!$h",
"Carmen.Dialogue.Sun10": "%Carmen está bostezando.#$b#¿Hijo?^¿Hija?#$b#¡Oh! ¡Casi me duermo!$h#$e#Muchas gracias por despertarme.$h",
"Carmen.Dialogue.Sun10.GN": "%Carmen está bostezando.#$b#¿Cielo?#$b#¡Oh! ¡Casi me duermo!$h#$e#Muchas gracias por despertarme.$h",

//FAYE DIALOGUE (tiakall is majestic)
"keahiprank.Faye": "¡Por Yoba, @! ¡Ve a casa y lava esa ropa AHORA MISMO, o nunca te quitarás ese hedor!$u",

//Introduction
"Faye.Dialogue.Introduction": "Buenos días. ¿Tú también eres nuevo en el campo?$h^Buenos días. ¿Tú también eres nueva en el campo?$h#$b#¡Me llamo Faye! ¡Encantada de conocerte!$h#$b#Creo que Ridgeside es el lugar perfecto para lanzar mi carrera en la moda.$h#$b#Además, trabajo como camarera en el restaurante Pika's.#$b#¡Espero que tengas una maravillosa carrera agrícola!$h",

//Spring
"Faye.Dialogue.spring_1": "Hay algo tan delicado en todos los pequeños brotes que empiezan a crecer. Me dan ganas de crear un diseño más sutil.",
"Faye.Dialogue.spring_12": "Me encanta ver lo que la gente se pone en la Fiesta del Huevo. Todo el mundo saca sus elegantes colores pastel.",
"Faye.Dialogue.spring_23": "Me encantaría colaborar con Emily en un nuevo diseño de vestido para la Danza Floral. ¿Tal vez algo inspirado en flores reales?",

//Summer
"Faye.Dialogue.summer_1": "¡El verano se caracteriza por la elección de colores fuertes y atrevidos! Pero eso es lo que lo hace tan divertido.$h",
"Faye.Dialogue.summer_10": "¡Me encantan las comidas comunitarias! ¡Todo el mundo se expresa a través del poder del sabor!$h",
"Faye.Dialogue.summer_27": "Podría hacer toda una línea de vestidos basada en las líneas y el movimiento de las medusas. Me pregunto si alguien lo ha intentado ya.",

//Fall
"Faye.Dialogue.fall_1": "¡Me encantan los colores del otoño! ¡Qué increíble paleta!$h",
"Faye.Dialogue.fall_15": "Me alegro mucho de que Pueblo Pelícano también tenga una feria. No me gustaría renunciar a mi tradición anual de algodón de azúcar y pastel de embudo.$h",
"Faye.Dialogue.fall_19": "¡Voy a poner a la venta algunos accesorios en la reunión de mañana! Espero que los tengan en cuenta.$h",
"Faye.Dialogue.fall_26": "@, espero que hayas pensado detenidamente en tu disfraz de la Víspera de los Espíritus. ¡Estoy deseando verlo!",

//Winter
"Faye.Dialogue.winter_1": "La forma en que la nieve fresca cubre todo con unas curvas tan bonitas es tan inspiradora. Sin embargo, necesitarías una tela muy ligera para lograrlo.",
"Faye.Dialogue.winter_7": "He oído que hay esculturas de hielo en el Festival de Hielo. Tal vez me sirva de inspiración.#$b#Lástima que no haya un bufé...",
"Faye.Dialogue.winter_24": "Acabo de terminar de enviar a mi familia algunos conjuntos de Estrella de Invierno por correo. Los he diseñado yo misma, así que espero que les gusten.",
"Faye.Dialogue.winter_27": "¡El año ha pasado muy rápido! Todavía estoy muy lejos de mis objetivos, pero no siento que el tiempo que he pasado aquí haya sido desperdiciado en absoluto.",

//Work
"Faye.Dialogue.work.1": "¡Bienvenido a Pika's, el principal restaurante de Ridgeside!$h^¡Bienvenida a Pika's, el principal restaurante de Ridgeside!$h",
"Faye.Dialogue.work.2": "¡Bienvenido a Pika's! ¿Dónde quieres sentarte?$h^¡Bienvenida a Pika's! ¿Dónde quieres sentarte?$h",
"Faye.Dialogue.work.3": "¡Bienvenido a Pika's, hogar del Pescado frito a la Ridge!$h^¡Bienvenida a Pika's, hogar del Pescado frito a la Ridge!$h",
"Faye.Dialogue.work.4": "¡Bienvenido a Pika's! ¿Quieres pedir en casa o pedir para llevar?$h^¡Bienvenida a Pika's! ¿Quieres pedir en casa o pedir para llevar?$h",
"Faye.Dialogue.work.5": "¡Hola, y bienvenido a Pika's! ¿Quieres un menú?$h^¡Hola, y bienvenida a Pika's! ¿Quieres un menú?$h",
"Faye.Dialogue.work.6": "¡Bienvenido a Pika's! ¿Te gustaría conocer los especiales de hoy?$h^¡Bienvenida a Pika's! ¿Te gustaría conocer los especiales de hoy?$h",
"Faye.Dialogue.work.7": "¡Bienvenido a Pika's! Si quieres sentarte donde quieras, ¡estaré allí!$h^¡Bienvenida a Pika's! Si quieres sentarte donde quieras, ¡estaré allí!$h",
"Faye.Dialogue.work.8": "¡Bienvenido a Pika's! ¡Por favor, siéntate libre de echar un vistazo a nuestras impresionantes vistas de la montaña!$h^¡Bienvenida a Pika's! ¡Por favor, siéntate libre de echar un vistazo a nuestras impresionantes vistas de la montaña!$h",
"Faye.Dialogue.work.9": "¡Hola, @, bienvenido a Pika's! ¿Has probado el último plato de la temporada?$h^¡Hola, @, bienvenida a Pika's! ¿Has probado el último plato de la temporada?$h",
"Faye.Dialogue.work.10": "¡Bienvenido a Pika's, @! Déjame limpiar esta mesa por ti.$h^¡Bienvenida a Pika's, @! Déjame limpiar esta mesa por ti.$h",
"Faye.Dialogue.work.11": "¡Bienvenido a Pika's! ¿Quieres empezar con una bebida o un aperitivo?$h^¡Bienvenida a Pika's! ¿Quieres empezar con una bebida o un aperitivo?$h",
"Faye.Dialogue.work.12": "¡Bienvenido a Pika's, @! ¿Sabes lo que quieres o necesitas un momento?$h^¡Bienvenida a Pika's, @! ¿Sabes lo que quieres o necesitas un momento?$h",
"Faye.Dialogue.work.13": "¡Hola, @! ¿Has probado ya el batido de cereza? Es mi favorito.$h",
"Faye.Dialogue.work.14": "¡Hola, @! ¿Necesitas un menú o sabes lo que quieres?$h",
"Faye.Dialogue.work.15": "¡Bienvenido a Pika's, @! ¡Me alegro de verte!$h^¡Bienvenida a Pika's, @! ¡Me alegro de verte!$h",
"Faye.Dialogue.work.16": "¡Bienvenido, @! ¿Has probado a sentarte en la mesa de aquí? Creo que la vista es la mejor allí.$h^¡Bienvenida, @! ¿Has probado a sentarte en la mesa de aquí? Creo que la vista es la mejor allí.$h",
"Faye.Dialogue.work.17": "¡Hola, @! ¡Tu mesa favorita está lista para ti!$h",
"Faye.Dialogue.work.18": "¡Hola, @! ¿Quieres lo de siempre?$h",
"Faye.Dialogue.work.19": "¡Bienvenido, @! ¡Haré saber a Pika y a Corine que estás aquí!$h^¡Bienvenida, @! ¡Haré saber a Pika y a Corine que estás aquí!$h",
"Faye.Dialogue.work.20": "¡Bienvenido, @! Ven a quitarte un peso de encima y a descansar.$h^¡Bienvenida, @! Ven a quitarte un peso de encima y a descansar.$h",
"Faye.Dialogue.work.21": "¡Hola, @! Pide lo que quieras, esta la pago yo.",
"Faye.Dialogue.work.22": "¡Hola, @! ¿Has venido a verme o quieres hacer un pedido? Por supuesto, quieres hacer un pedido, ¿verdad?$h",
"Faye.Dialogue.work.23": "¡Hola, @! Todavía estoy en el tiempo, pero podría tomar un descanso durante unos minutos si querías hablar.$h",
"Faye.Dialogue.work.24": "¡Hola, @! Pika debía saber que venías, acaba de poner una olla nueva.$h",

