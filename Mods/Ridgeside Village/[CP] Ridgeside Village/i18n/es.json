		//Wumbus (SCI-FI) (COMEDY) LIKE
"MovieData.Daia.SummerMovie1.Like.BeforeMovie": "¡Oh! Esto parece divertido.$6",
"MovieData.Daia.SummerMovie1.Like.DuringMovie": "%Daia se ríe a carcajadas.",
"MovieData.Daia.SummerMovie1.Like.AfterMovie": "Casi me desmayo de todos esas bromas.$h#$b#¡Gracias por la invitación, {{cutie}}!$h",

		//Howls in the Rain (HORROR) LOVE
"MovieData.Daia.FallMovie1.Love.BeforeMovie": "Estoy muy emocionada por esta.$h",
"MovieData.Daia.FallMovie1.Love.DuringMovie": "Vaya vaya.$7",
"MovieData.Daia.FallMovie1.Love.AfterMovie": "Eso fue hermoso. Mi favorito era el de los mil dientes.$7",

		//Zuzu City Express (CLASSIC) (ROMANCE) LOVE
"MovieData.Daia.WinterMovie1.Love.BeforeMovie": "¡Una película romántica clásica! ¡Encantador!$6",
"MovieData.Daia.WinterMovie1.Love.DuringMovie": "Jiji.$7",
"MovieData.Daia.WinterMovie1.Love.AfterMovie": "Es un secreto, pero me encantan las películas románticas. Siempre quise ser la heroína de una. ¿Quieres actuar conmigo?$7",

//BELINDA DIALOGUE
"keahiprank.Belinda": "¿Granjero, querido?^¿Granjera, querida?#$b#Aprende a bañarte, ¿quieres?$h",

//Randomized
"Belinda.Dialogue.random.1" : "Saludos, querido granjero.$h^Saludos, querida granjera.$h#$b#¿Tomando un descanso, supongo?",
"Belinda.Dialogue.random.2" : "Me pregunto qué ve Raeriyala en esta montaña.#$b#Nunca la entenderé.",
"Belinda.Dialogue.random.3" : "Tu abuelo era un humano interesante, querido granjero.^Tu abuelo era un humano interesante, querida granjera.#$b#Se parecía mucho a ti.$h",
"Belinda.Dialogue.random.4" : "A tu abuela siempre le gustaba trenzarme el pelo.#$b#Sin embargo, no podía hacerlo con el pelaje desordenado de mi amada.$h",
"Belinda.Dialogue.random.5" : "Las ofrendas que los mortales traen a Raeriyala son bastante aburridas.#$b#En cambio, deberían unirse a mis seguidores.$h",
"Belinda.Dialogue.random.6" : "Daia es una hija mía con talento.#$b#También es bastante astuta y engañosa, así que no te encariñes demasiado con ella.$4",
"Belinda.Dialogue.random.7" : "Jio es un elfo interesante.#$b#Parece estar preocupado por algún suceso del pasado.#$b#Muy interesante.$4",
"Belinda.Dialogue.random.8" : "¿Has conocido a los Daniels?#$b#Oh, no mucho.$h#$b#Su hija es interesante, eso es todo.$4",
"Belinda.Dialogue.random.9" : "Me pregunto dónde estará mi preciosa Kiwi.$4#$b#Tengo nuevas misiones para esa Junimo.$h",
"Belinda.Dialogue.random.10" : "Soy un espíritu, aunque no estoy segura de qué.$s#$b#Pero todo lo que sé es que estoy feliz de que mi amada me haya salvado.$h",
"Belinda.Dialogue.random.11" : "El suelo de este valle es rico en magia.#$b#Específicamente, de la magia de Raeriyala y su conexión con la entidad de la vida.$h#$b#También conocida como lo que ustedes los mortales llaman, 'Yoba'.",
"Belinda.Dialogue.random.12" : "Nunca subestimes a los secuaces de Gabriella, querido granjero.^Nunca subestimes a los secuaces de Gabriella, querida granjera.#$b#Algunos tienen más de un corazón.$a#$b#Y algunos son figuras prominentes en tu sociedad.$a",
"Belinda.Dialogue.random.13" : "Cuida tu granja, querido granjero.^Cuida tu granja, querida granjera.#$b#Tu abuela amaba ese lugar.$h",
"Belinda.Dialogue.random.14" : "Recuerdo que mi amada sospechaba de tu abuelo cuando tus abuelos se conocieron.$h#$b#Es como ver a un padre siendo demasiado protector con su hija.$h",
"Belinda.Dialogue.random.15" : "Salvador y Esmeralda, me pregunto cómo estarán esos dos...#$b#¿Oh? ¿Quiénes son?$4#$b#No te incumbe, así que vete.$h",
"Belinda.Dialogue.random.16" : "Desconfía del hombre llamado Qi, querido granjero.$a^Desconfía del hombre llamado Qi, querida granjera.$a#$b#Ese ente es una anomalía.$a",
"Belinda.Dialogue.random.17" : "Estoy bastante interesada en los bosques al sur de su granja.#$b#Específicamente el lago oculto a otro mundo.$h",
"Belinda.Dialogue.random.18" : "Me pregunto dónde se esconde la gente de las sombras...$4#$b#Oh, bueno, supongo que el Gremio de Aventureros se ha encargado de ese asunto.$h",
"Belinda.Dialogue.random.19" : "Una vez fui una Víbora Suprema, un peligroso espíritu demoníaco corrupto conjurado por Gabriella.$s#$b#Me alegro mucho de que mi amada me haya salvado.$4",
"Belinda.Dialogue.random.20" : "¡Este lugar es aburrido!$a#$b#¡Exijo entretenimiento!$h",

//Before Festivals
"Belinda.Dialogue.spring_12": "El festival de acción de gracias se ha convertido en un festival del huevo.#$b#Los humanos son bastante bizarros.#$e#Oh, bueno. Lo que sea que les mantenga entretenidos a los mortales.$h#$b#Disfrutad mañana, queridos.",
"Belinda.Dialogue.spring_23": "Mi amada adora las festividades de mañana.#$b#Nunca entendí por qué, pero cualquier cosa que la haga sonreír es lo suficientemente decente para mí.$h",
"Belinda.Dialogue.summer_10": "Durante siglos, nunca entendí el propósito de su fiesta de mañana.#$b#Suerte a todos si alguna vez un espíritu travieso dona un ingrediente venenoso.$h",
"Belinda.Dialogue.summer_27": "Raeriyala y yo visitaremos a los Lunaloos mañana por la noche.$4#$b#Son una gran compañía.$h",
"Belinda.Dialogue.fall_15": "¡Vaya, una feria!$h#$b#Tu abuela solía arrastrarnos a visitar ese ruidoso festival.#$b#Ah, era un ángel.$4#$e#Disfruta mañana, querido granjero.$h^Disfruta mañana, querida granjera.$h",
"Belinda.Dialogue.fall_19": "A esta montaña le encanta la energía que desprenden los lugareños con la fiesta de mañana.#$b#Al menos, eso es lo que me dice mi amada.$h",
"Belinda.Dialogue.fall_26": "Ten cuidado mañana por la noche, querido granjero.$a^Ten cuidado mañana por la noche, querida granjera.$a#$b#A Gabriella le encanta meterse con los pueblos durante este tipo de fiestas.$a",
"Belinda.Dialogue.winter_7": "¿Pescado? Sólo me interesan los peces vinculados a esta montaña.#$b#Los que se parecen a algunos de los lugareños del pueblo.#$e#Me pregunto cómo empezó ese fenómeno.$4",
"Belinda.Dialogue.winter_24": "El espíritu de la escarcha nos visitará mañana.#$b#Es un tipo bastante festivo.$h",
"Belinda.Dialogue.winter_27": "El espíritu de las resoluciones nació de las esperanzas y los sueños de los mortales.#$b#Es bastante extraño, siempre dormido, pero siempre motivado para hacer más.#$b#¿Un reflejo de las promesas y los sueños de los mortales, quizás?$4",

//BLISS DIALOGUE
"keahiprank.Bliss": "Deberías prestar más atención a la higiene.",

//Randomized
"Bliss.Dialogue.random.1" : "¿No tienes nada mejor que hacer?",
"Bliss.Dialogue.random.2" : "La dama me ha enviado a una misión.#$b#No hagas más preguntas.",
"Bliss.Dialogue.random.3" : "%Bliss bosteza.#$e#No, no tengo sueño.$s",
"Bliss.Dialogue.random.4" : "Me pregunto si la chica del pelo verde y el chico ruidoso jugarían conmigo si me mostrara.#$e#¡No has oído nada!$a",
"Bliss.Dialogue.random.5" : "El reino de los espíritus ¿eh?#$b#Sólo deseo conocerlos si alguna vez voy allá...$s#$e#No hagas preguntas.",
"Bliss.Dialogue.random.6" : "No estoy aquí. Sólo soy un producto de tu imaginación.#$e#Ahora que lo piensas, ¿no sería raro que te imaginaras a un niño pequeño de la nada?$h",
"Bliss.Dialogue.random.7" : "Por favor, no me molestes.",
"Bliss.Dialogue.random.8" : "¿La vida en la granja es tranquila?#$b#Interesante.",
"Bliss.Dialogue.random.9" : "Sigo y protejo a mi dama.#$b#Pero en este momento, ella es demasiado poderosa incluso para protegerla.$h",
"Bliss.Dialogue.random.10" : "Daia parece saber mucho sobre...#$b#¡Oops! ¡No importa!$h#$e#No te hagas ilusiones.",
"Bliss.Dialogue.random.11" : "No me toques.#$b#Te cortaré.$a",
"Bliss.Dialogue.random.12" : "¿Mis manos?#$b#Oh confía en mí, no quieres ver mis manos.$h",
"Bliss.Dialogue.random.13" : "Debería comprar algunas estrellas ninja.#$b#Me pregunto si esa vieja todavía las vende.",
"Bliss.Dialogue.random.14" : "He visto a este chico tranquilo alimentando a una tortuga en el pueblo.#$e#Creo que nos llevaremos bien si alguna vez pienso hablar con él.$h",
"Bliss.Dialogue.random.15" : "El otro día estaba paseando por el hotel para buscar a los secuaces de Gabriella, cuando este chico ruidoso con el pelo desordenado salió de la nada y me dio la bienvenida a la aldea.#$b#Después me dio una palmadita en la espalda.$a#$b#Poco sabía, que le cambié el bicho apestoso por el caramelo en la mano en el último segundo.$4#$b#Deberías haber estado allí cuando se estaba escurriendo la boca con cubos de agua.$h",
"Bliss.Dialogue.random.16" : "Percibo un luchador potencial entre los aldeanos de la montaña.#$b#Su aura me recuerda a alguien.",
"Bliss.Dialogue.random.17" : "Me pregunto dónde estará la general Helen.#$e#Suele visitar esta casa a altas horas de la noche.#$b#¿Tal vez sea su misión?",
"Bliss.Dialogue.random.18" : "¿¡Dónde está Kiwi!?$a#$b#¡Echo de menos a Kiwi!$s#$e#¡Ahí está Kiwi!$h#$e#¡Ven aquí, Kiwi! ¡Vamos a pelearnos!$4",
"Bliss.Dialogue.random.19" : "Siempre soy leal y obediente a la dama.#$b#Pero temo esos días en los que tiene la necesidad de usarme como una muñeca y vestirme con varios vestidos y trajes bonitos.$u#$b#*escalofrío*$u",
"Bliss.Dialogue.random.20" : "El restaurante del pueblo parece tener un chef asombroso.#$b#¡Incluso desde aquí, mi elevado sentido del olfato me permite respirar el sabroso aroma!$h#$b#¡Esto es simplemente una bendición!$h",

"keahiprank.Sari": "En el nombre de Aranie Vare, ¿¡qué es ese olor!?",

//Randomized
"Sari.Dialogue.random.1" : "Espero que Stefi no se esté metiendo en problemas en su casa.$4#$b#...$u#$b#¡Espía! ¡Sinvergüenza! ¡Rapscallion! ¡Bribón!$a^¡Espía! ¡Sinvergüenza! ¡Rapscallion! ¡Bribona!$a",
"Sari.Dialogue.random.2" : "¡Protegeré al Aranel!$a",
"Sari.Dialogue.random.3" : "¡Los enemigos de Verde experimentarán una tremenda miseria!$a",
"Sari.Dialogue.random.4" : "Por qué no quiere escuchar...$s",
"Sari.Dialogue.random.5" : "Por el poder que me han conferido el Ara y el Ris de Verde, defenderé a los Aranel.$a#$b#Se refiere al rey, la reina y la princesa, ¿acaso la gente de Ferngill no habla élfico?$u#$b#Guau, ¿muy incultos?$h",
"Sari.Dialogue.random.6" : "Ferngill significa Luz del Haya.#$b#Dicen que un antiguo bosque mágico fue quemado por los elementales del fuego.$s#$b#De las cenizas surgió la república siglos después.$4",
"Sari.Dialogue.random.7" : "Gil Midh Tum, el lugar al que llamas Stardew Valley, emite una extraña aura mágica.$4#$b#Tú emites el mismo tipo de energía.#$b#Los elfos pueden sentir la magia, ya sabes.$h",
"Sari.Dialogue.random.8" : "No me distraigas de mi empresa, granjero.$4^No me distraigas de mi empresa, granjera.$4#$b#Quiero decir, como, ugh, no me distraigas.$a",
"Sari.Dialogue.random.9" : "Hueles a tierra, ¿eres una especie de criatura del bosque?$h",
"Sari.Dialogue.random.10" : "A veces me preocupa Pipo.$s#$b#Su intelecto y carisma le sacan de los problemas normalmente...$4#$b#¿Pero qué pasa si un día no lo hace?$s",
"Sari.Dialogue.random.11" : "Pareces un poco cansado, ¿estás seguro de que estás descansando lo suficiente?$s^Pareces un poco cansada, ¿estás segura de que estás descansando lo suficiente?$s",
"Sari.Dialogue.random.12" : "No entiendo por qué los granjeros de Ferngill no utilizan cultivos mágicos.$4#$b#En Verde todo lo que hacen los granjeros es cosechar.$h",
"Sari.Dialogue.random.13" : "Para salvaguardar a la princesa, debemos alejarnos antes del amanecer y refugiarnos durante el crepúsculo.",
"Sari.Dialogue.random.14" : "Aquellos que se interpongan en el camino de la Aranie Vare...$4#$b#NO. PODRÁN. ¡PASAR!$a",
"Sari.Dialogue.random.15" : "Los elfos no visitan Ferngill a menudo.#$b#La gente de aquí desconfía de lo extraordinario.$4#$b#¡Dicen cosas raras sobre nuestras orejas!$s",
"Sari.Dialogue.random.16" : "Bellota y Pipo son inseparables.#$b#Me gustaría creer que el pequeño mantiene a Pipo fuera de problemas, ¡ja!$h",
"Sari.Dialogue.random.17" : "Debe haber estado muy asustada, sola y sin nadie que la proteja.$s",
"Sari.Dialogue.random.18" : "¿Está comiendo lo suficiente? ¿Duerme lo suficiente? Los Ara y Ris deben estar tan preocupados.$s",
"Sari.Dialogue.random.19" : "¿No echa de menos su casa?$s",
"Sari.Dialogue.random.20" : "Por favor, Aranel, escucha mi voz.$s",

//PIPO DIALOGUE (Obamoose da mvp)
"keahiprank.Pipo": "Esto huele como lo que los alquimistas llamamos 'el hedor de las tumbas'.$u#$b#¡Suele ser emitido por bichos apestosos, no por personas!$4",

//Randomized
"Pipo.Dialogue.random.1" : "Actualmente estoy estudiando cómo realizar la crisopeya.#$b#Significa convertir el plomo en oro.$4",
"Pipo.Dialogue.random.2" : "Algunos magos acuden a la alquimia cuando las pociones y los hechizos no funcionan.$s#$b#Algunos científicos utilizan la alquimia para ir más allá de la ciencia.#$b#¿A mí? Me gusta la alquimia porque es fácil y divertida.#4",
"Pipo.Dialogue.random.3" : "¿Por qué es tan difícil encontrarla?$a",
"Pipo.Dialogue.random.4" : "Hmm, 'ojo de tritón y dedo de rana, lana de murciélago y lengua de perro...'#$b#¿Por qué no podían decir simplemente semilla de mostaza, ranúnculo, hojas de acebo y lengua de sabueso?$a#$b#Nunca confíes en brujas y magos para una lista de ingredientes.$4",
"Pipo.Dialogue.random.5" : "¡Un día voy a inventar un Elixir de la Inmortalidad y luego lo voy a destruir!$h#$b#Sería peligroso si el mal se hiciera con él.$s#$b#Además, sólo quiero hacerlo por diversión.$4",
"Pipo.Dialogue.random.6" : "Dejé mi alambique en Verde.$s#$b#Tal vez pueda... conseguir... uno del Magister Rasmodius o del Magister Tenaliana cuando no estén mirando.$4",
"Pipo.Dialogue.random.7" : "He oído que los habitantes del valle se disfrazan durante el Sinye de la Feria.#$b#Tu gente lo llama la Víspera de los Espíritus.$4#$e#Debería conseguir que Bellota se disfrazara.$h",
"Pipo.Dialogue.random.8" : "Siendo mis padres Aranie Vare, Guardias Reales, naturalmente yo también me convertí en uno.#$b#Porque Verde es bastante seguro, puedo dedicar todo ese tiempo libre a estudiar alquimia.$h",
"Pipo.Dialogue.random.9" : "Un día querrá volver a casa, espero.$s",
"Pipo.Dialogue.random.10" : "Echo de menos a Verde.$s",
"Pipo.Dialogue.random.11" : "¿Por qué no me escucha?$a",
"Pipo.Dialogue.random.12" : "Sólo quiero que esté a salvo.$s",
"Pipo.Dialogue.random.13" : "Mi madre y mi padre son bastante influyentes, ambos forman parte del Aranie Vare.#$b#Mi padre es incluso miembro del Ore Corin, el Círculo Interior.",
"Pipo.Dialogue.random.14" : "Conocí a Bellota durante el viaje de Verde a Ferngill.#$b#Los Junimo hablan una forma antigua de élfico así que puedo entender la mayor parte de lo que dicen.$h#$b#¿Hablas Junimo?$4",
"Pipo.Dialogue.random.15" : "Lo siento, no tengo tiempo que perder. Debo proteger al Aranel.$a",
"Pipo.Dialogue.random.16" : "No puedo hablar ahora. Debo proteger a la princesa.$a",
"Pipo.Dialogue.random.17" : "Saludos.#$e#¡Sigue así, Bellota!$h",
"Pipo.Dialogue.random.18" : "Saludos.#$e#¡Bellota! ¿Ya tienes hambre?$h",
"Pipo.Dialogue.random.19" : "¿Sabías que la alquimia se originó en Cálico?#$b#¡Deberías coger un libro de vez en cuando!$4",
"Pipo.Dialogue.random.20" : "Me pregunto si Junimo es el resultado de la alquimia...$u#$b#Hey Bellota, ven aquí un segundo.$h",

