  // ===== DYNAMIC PRICE CALCULATION TOKENS =====
  "DynamicTokens": [
    {
      "Name": "JojaBasicSprinklerPriceCalculated",
      "Value": "{{Query:{{BasicSprinklerPrice}} * (100 - {{JojaDiscount}}) / 100}}"
    },
    {
      "Name": "JojaQualitySprinklerPriceCalculated",
      "Value": "{{Query:{{QualitySprinklerPrice}} * (100 - {{JojaDiscount}}) / 100}}"
    },
    {
      "Name": "JojaIridiumSprinklerPriceCalculated",
      "Value": "{{Query:{{IridiumSprinklerPrice}} * (100 - {{JojaDiscount}}) / 100}}"
    }
  ],
  "Changes": [
    { "LogName": "JJ Include CraftingRecipes", "Action": "Include", "FromFile": "data/CraftingRecipes.json", "When": { "EnableMod": "true", "HasFile:data/CraftingRecipes.json": true } },
    { "LogName": "JJ Include Assets", "Action": "Include", "FromFile": "data/Assets.json", "When": { "EnableMod": "true", "HasFile:data/Assets.json": true } },
    { "LogName": "JJ Include TriggerActions", "Action": "Include", "FromFile": "data/TriggerActions.json", "When": { "EnableMod": "true", "HasFile:data/TriggerActions.json": true } },
    { "LogName": "JJ Include Shops", "Action": "Include", "FromFile": "data/Shops.json", "When": { "EnableMod": "true", "HasFile:data/Shops.json": true } },
    { "LogName": "JJ Include Mail", "Action": "Include", "FromFile": "data/Mail.json", "When": { "EnableMod": "true", "HasFile:data/Mail.json": true } },
    { "LogName": "JJ Include Quests", "Action": "Include", "FromFile": "data/Quests.json", "When": { "EnableMod": "true", "HasFile:data/Quests.json": true } },
    { "LogName": "JJ Include Compatibility", "Action": "Include", "FromFile": "data/Compatibility.json", "When": { "EnableMod": "true", "HasMod": "rtrox.LineSprinklersRedux", "HasFile:data/Compatibility.json": true } }
  ]
