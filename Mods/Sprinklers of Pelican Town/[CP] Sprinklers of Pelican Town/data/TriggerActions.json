{
  // ===== TRIGGER ACTIONS =====
  "Changes": [
    {
      "LogName": "JJ Remove sprinkler journal quests when immersive Clint progression is disabled",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "{{ModId}}.RemoveImmersiveJournalQuests": {
          "Id": "{{ModId}}.RemoveImmersiveJournalQuests",
          "Trigger": "DayStarted",
          "Condition": "ANY \"{{HasActiveQuest |contains=555001}}\" \"{{HasActiveQuest |contains=555002}}\" \"{{HasActiveQuest |contains={{ModId}}_QualityJournal}}\" \"{{HasActiveQuest |contains={{ModId}}_IridiumJournal}}\"",
          "MarkActionApplied": false,
          "Actions": [
            "RemoveQuest 555001",
            "RemoveQuest 555002",
            "RemoveQuest {{ModId}}_QualityJournal",
            "RemoveQuest {{ModId}}_IridiumJournal"
          ]
        }
      },
      "When": {
        "ImmersiveProgression": "false"
      }
    },
    {
      "LogName": "JJ Pierre basic sprinklers mail (CC complete)",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
