          "Id": "{{ModId}}.PierreBasicSprinklersCCTrigger",
          "Trigger": "DayStarted",
          "Condition": "PLAYER_FARMING_LEVEL Any 3, !PLAYER_HAS_MAIL Host {{ModId}}.PierreBasicSprinklersCC, !PLAYER_HAS_MAIL Host {{ModId}}.PierreBasicSprinklers",
          "MarkActionApplied": false,
          "Actions": ["AddMail All {{ModId}}.PierreBasicSprinklersCC Now"]
