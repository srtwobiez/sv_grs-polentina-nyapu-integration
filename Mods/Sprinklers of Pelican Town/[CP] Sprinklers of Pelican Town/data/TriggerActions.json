    // ===== MIGRATE HARDCODED QUEST IDS TO QUALIFIED IDS =====
    {
      "LogName": "JJ Migrate Hardcoded Quest IDs to Qualified IDs",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "{{ModId}}.MigrateQuest.QualityJournal": {
          "Id": "{{ModId}}.MigrateQuest.QualityJournal",
          "Trigger": "DayStarted",
          "Condition": "{{HasActiveQuest |contains=555001}}",
          "Actions": [
            "RemoveQuest 555001",
            "AddQuest {{ModId}}_QualityJournal"
          ]
        },
        "{{ModId}}.MigrateQuest.IridiumJournal": {
          "Id": "{{ModId}}.MigrateQuest.IridiumJournal",
          "Trigger": "DayStarted",
          "Condition": "{{HasActiveQuest |contains=555002}}",
          "Actions": [
            "RemoveQuest 555002",
            "AddQuest {{ModId}}_IridiumJournal"
          ]
        }
      }
    },
    // ===== HOST MAIL REPAIR =====
    {
      "LogName": "JJ Repair host Quality Journal Complete mail when Any has it but Host does not",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "{{ModId}}.RepairHostQualityJournalComplete": {
          "Id": "{{ModId}}.RepairHostQualityJournalComplete",
          "Trigger": "DayStarted",
          "Condition": "!PLAYER_HAS_MAIL Host {{ModId}}.QualityJournalComplete, PLAYER_HAS_MAIL Any {{ModId}}.QualityJournalComplete",
          "MarkActionApplied": false,
          "Actions": ["AddMail Host {{ModId}}.QualityJournalComplete received"]
        },
        "{{ModId}}.RepairHostIridiumJournalComplete": {
          "Id": "{{ModId}}.RepairHostIridiumJournalComplete",
          "Trigger": "DayStarted",
          "Condition": "!PLAYER_HAS_MAIL Host {{ModId}}.IridiumJournalComplete, PLAYER_HAS_MAIL Any {{ModId}}.IridiumJournalComplete",
          "MarkActionApplied": false,
          "Actions": ["AddMail Host {{ModId}}.IridiumJournalComplete received"]
        }
      },
      "When": {
        "ImmersiveProgression": "true"
      }
    }
