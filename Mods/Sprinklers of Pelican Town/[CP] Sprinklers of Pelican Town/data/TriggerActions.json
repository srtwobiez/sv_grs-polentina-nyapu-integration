    // ===== QUEST SYSTEM TRIGGERS =====
    {
      "LogName": "JJ Add Quality Journal Request Trigger",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "{{ModId}}.QualityJournalRequestTrigger": {
          "Id": "{{ModId}}.QualityJournalRequestTrigger",
          "Trigger": "DayStarted",
          "Condition": "PLAYER_FARMING_LEVEL Current 6, !PLAYER_HAS_MAIL Current {{ModId}}.QualityJournalRequest",
          "MarkActionApplied": false,
          "Actions": ["AddMail Current {{ModId}}.QualityJournalRequest Now"]
        }
      },
      "When": {
        "ImmersiveProgression": "true",
        "Relationship:Clint": "Friendly"
      }
    },
    {
      "LogName": "JJ Add Quality Journal Complete Trigger",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "{{ModId}}.QualityJournalCompleteTrigger": {
          "Id": "{{ModId}}.QualityJournalCompleteTrigger",
          "Trigger": "DayStarted",
          "Condition": "!PLAYER_HAS_MAIL Host {{ModId}}.QualityJournalComplete",
          "MarkActionApplied": false,
          "Actions": ["AddMail All {{ModId}}.QualityJournalComplete Now"]
        }
      },
      "When": {
        "ImmersiveProgression": "true",
        "HasActiveQuest |contains={{ModId}}_QualityJournal": false,
        "HasReadLetter": "{{ModId}}.QualityJournalRequest"
