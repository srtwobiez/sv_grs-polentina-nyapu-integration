  "JojaCashier1.Default": "Welcome to JojaMart! How are you today?",
  "JojaCashier2.Default": "Remember, as a JojaMart member, you get more for less!",
  "JojaCashier3.Default": "Join us and thrive on our special offers for select items!",  
  
// 1.9.0 update special lines for Joja cashier rotations.
  "JojaCashier1.Daena": "Heya! Welcome to JojaMart!",
  "JojaCashier2.Daena": "Hope your day's going great! Let's get this sorted, yeah?",
