	//CONFIG
	"config.section.gameplay.name": "Jugabilidad",
	"config.section.graphics.name": "Gráficos",
	"config.section.compatibility.name": "Compatibilidad",
	// "config.MatureEvent.name": "Evento sugerente",
	// "config.MatureEvent.description": "¿Debería el evento de 14 Corazones incluir contenido softcore?",
	"config.AutoSingle.name": "Soltero forzado",
	"config.AutoSingle.description": "¿Empezar con Caroline como personaje único? (Recomendado para jugadores que regresan o aquellos que no están interesados en sus Eventos de Corazón)",
	"config.SorkrimArt.name": "Arte de Sorkrim",
	"config.SorkrimArt.description": "¿Deberías usar los retratos y sprites proporcionados por este mod? (Pon false si quieres usar otro mod visual.)",
	"config.PortraitStyle.name": "Estilo Retrato (Muebles)",
	"config.PortraitStyle.description": "Elija cómo se mostrará el retrato de Caroline. Hay más opciones disponibles; desplázate para verlas.",
	"config.PortraitStyle.values.Spring": "Primavera",
	"config.PortraitStyle.values.Summer": "Verano",
	"config.PortraitStyle.values.Fall": "Otoño",
	"config.PortraitStyle.values.WinterIndoor": "Invierno - Interior",
	"config.PortraitStyle.values.WinterOutdoor": "Invierno - En el exterior",
	"config.PortraitStyle.values.Beach": "Playa",
	"config.PortraitStyle.values.FlowerDance": "Danza Floral",
	"config.PortraitStyle.values.SpiritEve": "Víspera de los Espíritus",
	"config.MarriageDialogue.name": "Diálogos matrimoniales",
	"config.MarriageDialogue.description": "Desactiva esta opción para usar los diálogos matrimoniales de Caroline es soltera. Si prefieres usar los mios, tienes que borrar manualmente su archivo de dialogo matrimonial: [CP] Caroline Is Single > Data > Dialogue > MarriageDialogue.json.",

	//DIALOGUE
	//Unique Dialogue
	"Caroline.Introduction": "¡Vaya! ¿Cómo va todo?#$b#¿Te acuerdas de mí, ${querido^querida}$?$5#$b#Pensé que te habías olvidado de mí.$8#$b#No esperaba verte aquí. Quizá podamos volver a ser ${amigos^amigas}$.",
	"Caroline.FlowerDanceAccept": "Bien, ${querido^querida}$, hagámoslo.$1#$b#No veo ningún inconveniente en decir que sí por ahora.",
	"Caroline.FlowerDanceAccept.Spouse": "Vamos a darlo todo, cariño.$1#$b#Siempre hemos sido un buen equipo, ¿verdad?$6",
	"Caroline.FlowerDanceDecline": "¿Me estás invitando a bailar?#$b#Podría enseñarte un par de cosas, pero te dejaré divertirte esta vez.$8",
	"Caroline.divorced": "¿Cómo que...?$11#$b#¿Después de todo lo que hemos pasado?$2#$b#Puedes irte ahora, entiendo...$3",
	"Caroline.breakUp": "Nunca pensé que llegaría a esto...$11#$b#¡Necesito espacio!$3#$b#Verte duele más de lo que me gustaría admitir.$2",
	"Caroline.dumped": "Nunca pensé que pudieras ser tan cruel...$2#$b#Espero que estés contento con tu elección.$3^Espero que estés contenta con tu elección.$3",
	"Caroline.secondChance": "Las segundas oportunidades son raras.$11#$b#No lo estropeemos, ¿vale?$3",
	"Caroline.SpouseGiftJealous": "Jodi mencionó que le diste a alguien más ese mismo regalo...$2#$b#¿Me estás engañando?$3#$b#Lo siento, cariño. Es difícil no sentirse así cuando te veo con otra persona.$11",
	"Caroline.DumpsterDiveComment": "¡Te pillé con las manos en la masa! ¿Debería preocuparme o es tu nueva afición?$3#$b#Si estás buscando algo, podrías haberme pedido ayuda.$8",
	"Caroline.StardropTea": "¡Oh, un té de fruta estelar! Te acordaste de lo mucho que me gusta esto.$1#$b#Gracias, significa más de lo que crees, ${querido^querida}$.$4",
	"Caroline.AcceptBouquet.1": "¡Vaya! ¡Qué flor tan bonita!$5#$b#Espera un minuto... Esto no es para mí, ¿verdad?$3#$b#Oh, ¿hablas... en serio?$11#$b#Tu... ¿Promesa de infancia? ¿Qué es eso? No recuerdo nada.$2#$b#(Ah, parece que está a punto de llorar)$10#$b#Vale, vale... ¡Sólo te estaba tomando el pelo! ¡Lo recuerdo!$8#$b#¡Acepto! Sabes que no puedo resistirme a ti.$5",
	"Caroline.AcceptBouquet.2": "¿Así que todavía te gusto?$11#$b#Realmente te comprometiste con nuestra Promesa de la Infancia, ¿verdad?$8#$b#Ah, los recuerdos me invaden ahora.$10#$b#Está bien, lo admito, todavía tienes un lugar especial en mi corazón, ${querido^querida}$.$5",
	"Caroline.AcceptBouquet.3": "Oh, ¿un ramo tuyo? Qué inesperado...$2#$b#Después de todo con Pierre, nunca pensé que recibiría algo así.$11#$b#Es un símbolo de nuevos comienzos, ¿no?#$b#Gracias. Acepto.$5",
	"Caroline.RejectBouquet.1": "Pierre me dijo que compraste este ramo para alguien especial, pero estoy segura de que esta flor no era para mí, ¿verdad?$3",
	"Caroline.RejectBouquet.2": "Oh, te vi comprar un ramo antes.$8#$b#Entonces... ¿Quién es ${la afortunada^el afortunado}$?$8#$b#¿Oh? ¿Es para mí?$2#$b#Muy bien, ya basta.$3#$b#¿Por qué siempre tienes que molestarme así?$8",
	"Caroline.RejectBouquet.NotDatable.1": "¿Qué significa esto?$3#$b#¡Guárdalo antes de que alguien más lo vea! Sinceramente...$11",
	"Caroline.RejectBouquet.NotDatable.2": "¡Qué flor tan bonita!$5#$b#Espera...#$b#Esto no es para mí, ¿verdad? Debes estar bromeando.$2#$b#No puedes actuar así por capricho.$3",
	"Caroline.AcceptMermaidPendant.1": "¿Qué significa esto?$9#$b#¡¿Propuesta de matrimonio?! Oh, hablas en serio...$9#$b#Esto es tan repentino que ni siquiera sé qué decir.$10#$b#No puedes precipitarte en algo así, ¿sabes?$10#$b#¿Tan ${ansioso^ansiosa}$ estás por reclamarme?$2",
	"Caroline.AcceptMermaidPendant.2": "He estado esperando esto desde que hicimos nuestra promesa.$5#$b#Yo también te amo, ${querido^querida}$.$4",
	"Caroline.RejectMermaidPendant.1": "Si lo guardas ahora, fingiré que nunca lo vi.$3",
	"Caroline.RejectMermaidPendant.2": "Oh, ${querido^querida}$, esto es tan considerado.$4#$b#Pero algo tan especial no debería regalarse a menos que se haga con todo el corazón.$3",
	"Caroline.RejectMermaidPendant.NotDatable.1": "¡Guárdalo! No dejes que nadie lo vea.$11#$b#¿Intentas ponerme nerviosa a propósito?$3",
	"Caroline.RejectMermaidPendant.NotDatable.2": "No sabes cómo funcionan las cosas por aquí, ¿verdad?$3#$b#¡Guárdalo! Esta broma no tiene gracia...$2",
	"Caroline.Divorced.1": "¿Después de todo lo que pasamos? Lo siento, pero no puedo volver a pasar por eso.$2",
	"Caroline.Divorced.2": "%Caroline no quiere hablar contigo.",
	"Caroline.NpcAlreadyMarried.1": "Flirteando mientras estás casado, ¿verdad?$2#$b#Cariño, será mejor que tengas cuidado antes de que se lo diga a tu ${compañera^compañero}$.$3",
	"Caroline.NpcAlreadyMarried.2": "Cariño, está claro que has hecho tu elección, y no soy yo.$2#$b#Deja de enviarme señales contradictorias, no es justo.$11",
	"Caroline.SpouseStardrop": "Cariño, ¿puedes guardarme esto?#$e#Es sólo un pequeño detalle para demostrar lo mucho que significas para mí.$4",
	"Caroline.WipedMemory": "Uf, me duele la cabeza...$3#$b#Hola, ${querido^querida}$, estás aquí.$8#$b#Espera, ¿no hemos tenido esta conversación antes?$2#$b#Tal vez me estoy imaginando cosas. En estos días, mi memoria no es tan aguda como solía ser.$8",
	"Caroline.GreenRain.1": "${Querido^Querida}$, ¿alguna vez has visto llover así?$11#$b#Se siente extraño... ¿Estás ${seguro^segura}$ de que es seguro?$2#$b#Me preocuparé por ti ahí fuera. Por favor, cuídate.$11",
	"Caroline.GreenRain.2": "¡Oh, es esa lluvia especial otra vez!$5#$b#Esta vez, voy a disfrutar hasta la última gota.#$e#Y es la excusa perfecta para acurrucarse con una taza de té caliente.$1",

	//Location Dialogue
	"Caroline.Resort.Entering": "Willy repartió galletas de pescado a todos.#$b#Todavía estoy masticando el mío. Está... delicioso.$1",
	"Caroline.Resort.Leaving": "Creo que esta noche voy a dormir como un bebé.$h",
	"Caroline.Resort.Shore": "El agua aquí está mucho más caliente que en el valle.#$b#¡Se siente increíble!$1",
	"Caroline.Resort.Chair": "%Caroline se estira en la silla, parece lista para una siesta.",
	"Caroline.Resort.Bar": "Le pedí a Gus que me sorprendiera y preparó un té verde helado de cáscara de mango. ¡Es increíble!$h",
	"Caroline.Resort.Bar6": "Si esto fuera hace años, te habría arrastrado a explorar la selva cercana.#$b#Todavía quiero, ¡de verdad!$1#$e#Aunque me pregunto... ¿crees que Abigail heredó de mí su sentido de la aventura?$11",
	"Caroline.Resort.Bar10": "Este lugar se parece a esa isla encantada con la que soñábamos de niños.#$b#¿Te acuerdas? Es como si nuestros sueños de infancia se hicieran realidad.$1",
	"Caroline.Resort": "Hola, @. ¿Estás aquí para desconectar o para mantenerte ${ocupado^ocupada}$?",

	//Spring Dialogue
	"Caroline.spring1": "¡La primavera ya está aquí!#$b#Todo parece tan vivo de nuevo, ¿verdad?$1",
	"Caroline.springMon": "¡Oh, hola! Me alegro de verte ${instalado^instalada}$ en el pueblo.#$e#Empezar una granja no es tarea fácil...$11#$b#Estoy segura de que te las arreglarás.$8",
	"Caroline.springMon2": "Te vi trabajando en tu granja antes.#$b#Me recordó lo ${decidido^decidida}$ que solías ser de ${niño^niña}$.$1#$b#Nunca hiciste nada a medias, ¿verdad?$6",
	"Caroline.springMon4": "Sabes, verte de nuevo después de todos estos años...#$b#Parece un poco surrealista. Pero en el buen sentido.$8",
	"Caroline.springMon6": "El otro día pensaba en nuestra infancia.$11#$e#Es curioso cómo el tiempo lo cambia todo, y sin embargo... algunas cosas siguen igual.$8",
	"Caroline.springMon8": "Realmente te has convertido en alguien impresionante, ${querido^querida}$.$5#$b#Aunque todavía puedo ver destellos de ${aquel niño al^aquella niña a la}$ que solía perseguir.$6",
	"Caroline.springMon10": "Siempre has hecho que mi corazón se acelere, incluso entonces.$4#$e#Y ahora... bueno, algunas cosas nunca cambian, ${querido^querida}$.$10",
	"Caroline.springTue": "Es bueno verte haciendo tu vida aquí.#$b#A Pueblo Pelícano le vendría bien un poco de energía fresca.$1",
	"Caroline.springTue2": "Siempre estás ${ocupado^ocupada}$, ¿verdad?$8#$b#Es un buen rasgo, siempre que no te pases.$6",
	"Caroline.springTue4": "Hoy me he sorprendido a mí misma sonriendo, pensando en una de nuestras viejas aventuras.#$b#Me pregunto, ¿alguna vez recuerdas aquellos días?$1",
	"Caroline.springTue6": "Te has instalado tan bien que es como si nunca te hubieras ido.#$b#Es agradable tenerte por aquí de nuevo.",
	"Caroline.springTue8": "Siempre supiste cómo meterte bajo mi piel, ${querido^querida}$.$2#$b#No sé si debería estar molesta o encantada.$3",
	"Caroline.springTue10": "¡Eres ${peligroso^peligrosa}$, ${querido^querida}$!$3#$b#Apareciendo después de todos estos años, mirándome así...#$b#¿Qué se supone que debo hacer contigo?$9",
	"Caroline.springWed": "Solía preguntarme qué había sido de ti.#$b#Es agradable tener por fin mi respuesta.$1",
	"Caroline.springWed2": "Hay una calidez en volver a ver a ${un viejo amigo^una vieja amiga}$.#$b#Espero que sientas lo mismo.$8",
	"Caroline.springWed4": "Siempre has sabido hacer que la gente se sintiera a gusto.#$b#Es una de las cosas que admiraba de ti, incluso entonces.$5",
	"Caroline.springWed6": "Estuvimos tan cerca una vez.$11#$b#Me hace preguntarme... ¿crees que habríamos seguido así si las cosas hubieran sido diferentes?$2",
	"Caroline.springWed8": "Tienes suciedad en la cara otra vez.#$e#Quédate ${quieto^quieta}$, ${querido^querida}$...#$b#Honestamente, eres tan ${desordenado^desordenada}$ como entonces.$8",
	"Caroline.springWed10": "Si sigues mirándome así, ${querido^querida}$, empezaré a creer que nunca te fuiste.$4#$e#¿No sería algo?$10",
	"Caroline.springThu": "Jodi me habló de sus recetas.#$b#Jura por su mezcla secreta de especias, pero creo que sólo está siendo dramática.$8",
	"Caroline.springThu2": "Jodi dice que debería intentar meditar para relajarme.$11#$b#¿Me imaginas sentada quieta tanto tiempo? Parece imposible.$8",
	"Caroline.springThu4": "Sabes, Jodi y yo solíamos competir por la mejor comida casera.$8#$b#Tal vez debería retarte a ti después. ¿Crees que podrás con mi cocina?$6",
	"Caroline.springThu6": "Jodi me dijo algo interesante hoy...$2#$b#Aparentemente, hablo de ti más de lo que creo.$8#$e#Extraño, ¿verdad, ${querido^querida}$?$4",
	"Caroline.springThu8": "Jodi me ha estado dando estas miradas últimamente.$11#$b#Como si ella supiera algo que yo no sé.$2#$b#¿Debería preocuparme, ${querido^querida}$?$8",
	"Caroline.springThu10": "Jodi casi me llama en medio de nuestra conversación de hoy.$11#$b#Es aguda, pero no tanto como tú, ${querido^querida}$...$6#$e#Ya sabes lo que estoy pensando, ¿verdad?$8",
	"Caroline.springFri": "El museo es un lugar tan tranquilo.#$b#Aunque siempre siento que tengo que susurrar, incluso cuando no hay nadie cerca.$8",
	"Caroline.springFri2": "Pasé por el museo para leer un rato.#$b#Elliott también estaba ahí... Creo que estaba juzgando mis elecciones de libros.$2",
	"Caroline.springFri4": "Hay algo agradable en perderse en un libro.$1#$b#Sin tareas, sin expectativas... sólo palabras que te llevan a un lugar nuevo.$5",
	"Caroline.springFri6": "Hoy he encontrado un viejo diario en el museo.#$b#Me hizo preguntarme... si alguien leyera sobre tu vida, ¿qué tipo de historia encontraría, ${querido^querida}$?$6",
	"Caroline.springFri8": "Sabes, ${querido^querida}$, si alguna vez quieres acompañarme al museo, no me importaría la compañía.#$b#Pero no esperes que comparta mi lugar de lectura.$8",
	"Caroline.springFri10": "Me enfrasqué tanto en mi libro que casi perdí la noción del tiempo.$2#$e#Curioso... la única otra persona que me distrae así eres tú, ${querido^querida}$.$10",
	"Caroline.springSat": "Hoy me levanté temprano para hacer cosas...$2#$b#Y ahora sólo quiero echarme una siesta. Ser responsable es agotador.$3",
	"Caroline.springSat2": "Algunos clientes son tan quisquillosos...$2#$b#Me pregunto cómo Pierre tiene la paciencia con eso.$8",
	"Caroline.springSat4": "Estaba pensando en probar una nueva imagen.#$b#Algo atrevido. ¿Quizá un nuevo peinado? ¿Qué te parece?$6",
	"Caroline.springSat6": "Sabes, creo que podrías ser una mala influencia para mí.$2#$e#Cuanto más hablamos, más ganas tengo de romper mis rutinas.$5",
	"Caroline.springSat8": "No dejas de sorprenderme, ${querido^querida}$.#$b#No puedo decidir si eso es emocionante o peligroso.$2",
	"Caroline.springSat10": "Debería estar terminando mis recados, pero tienes una forma de distraerme.$2#$b#Dime, ${querido^querida}$... ¿es intencionado?$3",
	"Caroline.springSun": "Esta mañana he pasado un rato en mi invernadero.#$b#Las plantas no se quejan, simplemente crecen. Es bonito.$1",
	"Caroline.springSun2": "Hoy me he permitido dormir hasta tarde.#$b#Por una vez, no me sentí culpable por ello.$1",
	"Caroline.springSun4": "Las cenas de los domingos son mis favoritas.#$b#Buena comida, buena compañía...$1#$e#Aunque no me importaría cambiar de aires de vez en cuando.$5",
	"Caroline.springSun6": "Iba a pasar el día descansando, pero ahora me estoy planteando una pequeña aventura.#$b#¿Quieres acompañarme, ${querido^querida}$?$8",
	"Caroline.springSun8": "Me gustan los domingos tranquilos, pero no me importaría un poco de emoción.#$e#¿Conoces a alguien que pueda ayudar con eso, ${querido^querida}$?$6",
	"Caroline.springSun10": "Debería estar descansando, pero aquí estoy, atrapada en otra conversación contigo.$2#$e#Dime, ${querido^querida}$... ¿siempre tienes este efecto en la gente?$10",

	//Summer Dialogue
	"Caroline.summer1": "¡Por fin ha llegado el verano!#$e#Estoy deseando que lleguen todas las frutas y verduras frescas.$1#$b#¡No hay nada mejor que un jugoso melón en un día caluroso!$6",
	"Caroline.summerMon": "Otro día cálido por delante.#$b#Probablemente debería quedarme dentro, pero ¿dónde está la diversión en eso?$8",
	"Caroline.summerMon2": "Me encanta el olor del verano.#$e#Esa mezcla de aire fresco y tierra calentada por el sol... es reconfortante.$1",
	"Caroline.summerMon4": "Hoy estaba pensando en hacer limonada casera.#$b#Hay algo en el verano que pide una bebida refrescante, ¿no crees?$6",
	"Caroline.summerMon6": "Hace demasiado calor para hacer nada serio hoy.$2#$b#Quizá busque un lugar a la sombra y finja que mis responsabilidades no existen durante un tiempo.$11",
	"Caroline.summerMon8": "Deberías tener cuidado con este calor, ${querido^querida}$.$5#$b#No me gustaría verte ${agotado^agotada}$ antes de que empiece el día.$8",
	"Caroline.summerMon10": "Te ves ${preocupado^preocupada}$ hoy, ${querido^querida}$.$2#$e#Algo me dice que ni siquiera me importará.$11",
  	"Caroline.summerTue": "La clase de aeróbic ha sido agotadora hoy.$2#$b#Tal vez sea sólo el verano, pero sentí que me estaba derritiendo a mitad de camino.$3",
	"Caroline.summerTue2": "Hoy hemos probado una nueva rutina en aeróbic.#$b#Pensé que sería fácil. Estaba muy equivocada.$8",
	"Caroline.summerTue4": "Hoy me he sorprendido a mí misma riéndome mientras hacía aerobic.$8#$b#Jodi casi tropezó con sus propios pies, y bueno... era difícil no reaccionar.$3",
	"Caroline.summerTue6": "Estaba completamente agotada después del aeróbic, pero de alguna manera todavía tenía energía para charlar después.#$e#Es curioso cómo funciona, ¿verdad, ${querido^querida}$?$9",
	"Caroline.summerTue8": "Debo... haber estado distraída durante los aeróbicos de hoy.$11#$b#Seguía estropeando los movimientos, y las otras definitivamente lo notaron.$3#$b#Me pregunto qué -o quién- tenía en mente, ${querido^querida}$.$4",
	"Caroline.summerTue10": "El aeróbic era agotador, ¿pero la verdadera sorpresa?#$b#Me encontré pensando en ti en lugar de contar repeticiones.$6#$e#Eso... es peligroso, ${querido^querida}$... te... estás convirtiendo en toda una distracción.$10",
	"Caroline.summerWed": "El sol está fuerte hoy.#$b#Probablemente debería llevar un sombrero...$11",
	"Caroline.summerWed2": "Pasé la mañana cuidando mi jardín.#$b#Las plantas prosperan con este calor.$1#$e#Ojalá pudiera decir lo mismo de mí.$8",
	"Caroline.summerWed4": "Antes he paseado por el pueblo y he visto a unos niños jugando con globos de agua.#$b#Por un segundo, casi deseé unirme a ellos.$8",
	"Caroline.summerWed6": "Hay un pequeño puesto a las afueras del pueblo que vende el mejor helado.#$b#Tal vez haga un viaje allá más tarde... a menos que quieras traérmelo.$6",
	"Caroline.summerWed8": "El calor no me molesta mucho, pero admito...#$b#No me importaría tener una excusa para quedarme a la sombra un poco más.$6",
	"Caroline.summerWed10": "Me miras como si tuvieras algo en mente, ${querido^querida}$.$2#$e#Cuidado ahora... podrías tentarme a preguntar qué es.$10",
	"Caroline.summerThu": "Jodi y yo tuvimos una agradable charla en la plaza hoy.#$b#Siempre tiene algo interesante que decir... incluso cuando se trata de listas de la compra.",
	"Caroline.summerThu2": "Pasé algún tiempo con Jodi antes.#$b#Tenía muchas cosas en la cabeza... pero, ¿cuándo no?$11",
	"Caroline.summerThu4": "Jodi y yo hablamos hoy de recetas de verano.#$b#Sugirió un nuevo adobo para verduras a la parrilla. Tendré que probarlo.$1",
	"Caroline.summerThu6": "Jodi se burló de mí por algo antes.$2#$b#Dijo que me ilumino cuando estás cerca.$3",
	"Caroline.summerThu8": "Jodi me hizo una pregunta para la que no estaba preparada hoy.#$b#Quería saber lo que realmente pienso de ti...$4#$e#Me reí, pero se me quedó grabado, ${querido^querida}$.$10",
	"Caroline.summerThu10": "Jodi me miró hoy.$2#$b#Ella no dijo nada.$11#$e#De alguna manera, eso fue peor, ${querido^querida}$.$10",
	"Caroline.summerFri": "Pasé un rato por el museo.#$b#Era agradable y tranquilo... justo como me gusta.$1",
	"Caroline.summerFri2": "Acabé leyendo en el museo más tiempo del previsto.#$b#Los buenos libros roban el tiempo, ¿verdad?$8",
	"Caroline.summerFri4": "Hoy me he topado con un libro fascinante.#$b#Es extraño pensar cuánto se olvida con el tiempo.$11",
	"Caroline.summerFri6": "Estuve a punto de chocar con alguien en el museo porque estaba demasiado absorta en mi libro.$8#$b#¿Distraída? Tal vez. O tal vez mi mente estaba en otra parte.$6",
	"Caroline.summerFri8": "Hoy encontré un libro sobre relaciones.$6#$b#Por pura curiosidad, claro...$8#$b#Afirmó que los hombres y las mujeres no pueden tener conexiones verdaderamente desinteresadas...$11#$b#¿Qué te parece, ${querido^querida}$?$9",
	"Caroline.summerFri10": "Estaba tan perdida en mi libro que ni siquiera me di cuenta de que pasaba el tiempo.$8#$b#Eso sólo parece ocurrir cuando estoy leyendo...$11#$b#O hablando contigo, ${querido^querida}$.$6",
 	"Caroline.summerSat": "Tenía una lista llena de cosas que hacer hoy.#$b#Y sin embargo, de alguna manera, acabé no haciendo ninguna de ellas.$2",  
	"Caroline.summerSat2": "Salí de compras antes.#$b#Sólo estaba curioseando, la verdad... aunque acabé comprando algunas cosas que no necesitaba.$2",  
	"Caroline.summerSat4": "La tienda estaba ocupada hoy.#$b#Siempre disfruto viendo a la gente comprar nuestras cosas.$8",  
	"Caroline.summerSat6": "Tenía toda la intención de ser productiva hoy...#$b#Entonces encontré un lugar cómodo a la sombra y, de repente, mis prioridades cambiaron.$6",  
	"Caroline.summerSat8": "Antes me sorprendí a mí misma buscándote.$8#$e#Es gracioso... Ni siquiera me doy cuenta de que lo estoy haciendo hasta que sucede, ${querido^querida}$.$4",  
	"Caroline.summerSat10": "Me dije que hoy no me distraería.$2#$b#Pero entonces te vi, y bueno... adiós a ese plan, ${querido^querida}$.$8",  
	"Caroline.summerSun": "He pasado la mañana ordenando.#$b#Es increíble lo rápido que se complican las cosas cuando no prestas atención.",  
	"Caroline.summerSun2": "Di un paseo antes de que hiciera demasiado calor.#$e#El pueblo se siente diferente por la mañana temprano... más tranquilo, casi como si aún estuviera despertando.$11",  
	"Caroline.summerSun4": "Hoy hice un gran almuerzo, sólo porque me apetecía.#$b#A veces, no hace falta una razón para disfrutar de la buena comida.$8",  
	"Caroline.summerSun6": "Hoy quería tomarme un descanso, pero algo me empujaba en diferentes direcciones.$11#$b#O tal vez sólo quería una excusa para estar ocupada.$6",  
	"Caroline.summerSun8": "Hoy he tenido un momento en el que todo parecía... quieto.#$b#Entonces me sorprendí pensando en ti, y de repente, ya no estaba tan tranquilo.$3",  
	"Caroline.summerSun10": "Pasé la mayor parte del día ensimismada.#$b#Y si te soy sincera, ${querido^querida}$...$11#$b#Buena parte de esos pensamientos tenían algo que ver contigo.$10",  

	//Fall Dialogue
	"Caroline.fall1": "El otoño es una estación encantadora, ¿no crees?",
	"Caroline.fallMon": "El aire refresca y las hojas empiezan a cambiar.#$b#A Abigail le encanta esta estación... dice que el mundo parece más vivo cuando se está muriendo.",  
	"Caroline.fallMon2": "Hoy encontré mi vieja bufanda.#$b#Esto me trae tantos recuerdos.$4",  
	"Caroline.fallMon4": "Hoy he pasado un rato en el invernadero adaptando las plantas al cambio de tiempo.#$b#A ellas no les importa que cambien las estaciones... pero creo que a mí sí.$11",  
	"Caroline.fallMon6": "Esta mañana he salido y he respirado hondo.#$e#Hay algo en el aire fresco que te hace sentir despierta.$1",  
	"Caroline.fallMon8": "El pueblo se siente diferente en otoño... más tranquilo, tal vez.#$b#O tal vez estoy notando cosas que antes no notaba...$6",  
	"Caroline.fallMon10": "Hoy me he quedado un rato junto a la ventana.#$b#Sólo mirando las hojas doradas pasar.$8#$e#Y me di cuenta, ${querido^querida}$... Te estaba esperando.$10",  
	"Caroline.fallTue": "La clase de aeróbic ha sido diferente hoy.#$b#Tal vez sea el clima más fresco, o tal vez simplemente no estaba tan motivada.$11",  
	"Caroline.fallTue2": "Probamos algunos estiramientos nuevos durante el aeróbic.#$b#Me hizo darme cuenta de lo fuera de forma que estoy en realidad.$8",  
	"Caroline.fallTue4": "Jodi y yo terminamos hablando más que haciendo ejercicio hoy.#$e#No es que me queje... a veces, ponerse al día es más importante que sudar.$1",  
	"Caroline.fallTue6": "El aeróbic fue agotador, pero no me importó demasiado.#$b#Un poco de dolor vale la pena si me hace sentir lo mejor posible.$6",  
	"Caroline.fallTue8": "Después de la clase de aeróbic, me quedé un rato más fuera, disfrutando del aire fresco.#$b#Y tal vez... esperando que pasaras por acá.$8",
	"Caroline.fallTue10": "Se suponía que el aeróbic me despejaría la mente, pero tuvo el efecto contrario.$11#$e#En cambio, seguí pensando en ti, ${querido^querida}$...$6",  
	"Caroline.fallWed": "Fui a comprobar nuestras existencias para la temporada.#$b#Con lo mucho que le gusta el otoño a Abigail, siempre se nos acaban los dulces de temporada demasiado rápido.$2",  
	"Caroline.fallWed2": "Hoy he pasado por el centro cívico.#$b#Incluso después de todos estos años, sigue pareciendo un lugar lleno de historias que esperan ser contadas.",  
	"Caroline.fallWed4": "El aroma de las hojas caídas llenó hoy el aire.#$b#Es algo tan sencillo, pero no pude evitar detenerme para asimilarlo.",  
	"Caroline.fallWed6": "Hoy me he sorprendido a mí misma mirando al cielo más a menudo.#$b#Hay algo en la forma en que las nubes se mueven en esta época del año que me hace sentir... diferente, ${querido^querida}$.$4",  
	"Caroline.fallWed8": "El pueblo parece más pequeño en otoño, ¿no crees?$4#$b#O tal vez sólo se siente más como en casa cuando ciertas personas están cerca, ${querido^querida}$.$4",  
	"Caroline.fallWed10": "Algunos momentos parecen eternos, como si el mundo mismo contuviera la respiración.#$b#Y en esos momentos, ${querido^querida}$, me encuentro pensando en ti.$4",  
	"Caroline.fallThu": "Jodi y yo hablábamos de cómo el otoño siempre pone nostálgica a la gente.#$e#Dijo que le recordaba a cuando Sam era pequeño...#$b#Entonces dije que me recordaba lo rápido que pasa el tiempo.$2",  
	"Caroline.fallThu2": "Hoy he visto un montón de gansos volando hacia el sur.#$e#Jodi bromeó sobre seguirlos a un lugar más cálido...$8#$b#Pero no sé, creo que prefiero quedarme aquí.$6",  
	"Caroline.fallThu4": "Jodi mencionó que últimamente se levanta más temprano.#$b#Dice que las mañanas son diferentes en esta época del año.#$b#Creo que simplemente disfruta de la tranquilidad antes de que empiece realmente el día.$8",  
	"Caroline.fallThu6": "Jodi me pilló distraída en medio de la conversación.$11#$b#Se limitó a sonreír y dijo: '¿Pensando en alguien?'$8#$e#...No sé por qué sonríes, ${querido^querida}$.$2",  
	"Caroline.fallThu8": "Jodi hizo un comentario fuera de lugar sobre cómo parezco más feliz últimamente.$2#$e#Le pregunté qué quería decir y se echó a reír.$8#$b#Supongo que algunas cosas son obvias, ¿no?$6",  
	"Caroline.fallThu10": "Jodi me dijo: 'Últimamente estás diferente.'$2#$b#No sabía qué decir, así que me limité a sonreír.$8#$e#Pero creo que ambos sabemos la razón, ${querido^querida}$.$10",  
	"Caroline.fallFri": "Cogí un libro en el museo.#$b#Luego me pasé media hora mirando por la ventana.$8#$e#Demasiado para una tarde tranquila.$2",  
	"Caroline.fallFri2": "Es curioso cómo algunos libros te atraen, mientras que otros...#$b#Bueno, digamos que hoy he pasado más tiempo echando la siesta que leyendo.$8",  
	"Caroline.fallFri4": "Encontré un libro sobre las antiguas tradiciones del valle.#$b#Al parecer, la gente solía dejar pequeñas ofrendas a los espíritus del bosque en otoño.$11#$e#Me pregunto si algo de eso aún perdura por aquí.",  
	"Caroline.fallFri6": "Volví a distraerme en el museo.$8#$e#Esta vez no por los libros...$6#$b#Por cierta persona que cruza mi mente.$8",  
	"Caroline.fallFri8": "Intenté leer, de verdad...$2#$b#Pero mis pensamientos seguían desviándose a otra parte.$3#$e#¿O debería decir, a otra persona, ${querido^querida}$?$8",  
	"Caroline.fallFri10": "Debo haber releído la misma frase cinco veces.$2#$e#No porque fuera complicado, sino porque mi mente estaba atascada en ti, ${querido^querida}$.$6",  
	"Caroline.fallSat": "Pasé la mañana reorganizando mi jardín.#$b#Los meses más fríos siempre se acercan rápido... tengo que asegurarme de que todo esté listo.$1",  
	"Caroline.fallSat2": "Marnie dice que los animales salvajes son cada vez más activos.#$b#Supongo que también saben que llega el invierno.$6",  
	"Caroline.fallSat4": "Hoy he recogido moras y me he comido la mitad de camino a casa.$6#$b#Ups.$8",  
	"Caroline.fallSat6": "Acabé con tierra en la cara después de atender el jardín.$2#$b#Debí de parecer ridícula, pero me reí.$8",  
	"Caroline.fallSat8": "Casi tropiezo en mi jardín.#$b#Supongo que debería prestar más atención...$2#$b#Pero bueno, no es culpa mía que me distrajera el clima.$3",  
	"Caroline.fallSat10": "Encontré una calabaza con forma de corazón.#$b#O tal vez sólo estaba viendo cosas...$4#$e#¿Qué te parece, ${querido^querida}$?$6",  
	"Caroline.fallSun": "Esta mañana he preparado un té con especias.#$b#Puede que me haya pasado con la canela, pero oye, me ha despertado.$8",  
	"Caroline.fallSun2": "Pierre se quejaba de que la chimenea era una molestia de limpiar.#$b#Pero adivina quién será el primero en sentarse a su lado cuando haga frío.$8",  
	"Caroline.fallSun4": "Vi algunos cuervos reuniéndose en los campos.#$b#Algo en ellos siempre se siente... No sé, como si estuvieran mirando.$11",  
	"Caroline.fallSun6": "Hoy no he parado de encontrar excusas para salir.#$b#Tal vez sólo quería respirar aire fresco...$1#$e#O quizá esperaba encontrarme con alguien.$6",  
	"Caroline.fallSun8": "Estaba a punto de acomodarme para pasar la noche, pero entonces tuve este pensamiento...$10#$b#¿Y si en vez de eso aparecieras en mi puerta?$5#$b#Ahora no puedo dejar de pensar en ello, ${querido^querida}$.$6",  
	"Caroline.fallSun10": "La casa está tranquila, la noche es fría...$11#$e#Y sin embargo, de alguna manera, mi corazón sigue caliente.$4#$b#Creo que sabes por qué, ${querido^querida}$.$4",  

	//Winter Dialogue
	"Caroline.winter1": "El invierno es una época tan serena y tranquila, ¿no te parece?",
	"Caroline.winterMon": "Me desperté temprano y vi la nieve caer junto a mis ventanas.#$b#Siempre es un poco encantador... hasta que tienes que salir a la calle, claro.$2",
	"Caroline.winterMon2": "La casa siempre está más tranquila en invierno.#$b#Quizá sea la forma en que el frío amortigua el sonido...#$b#O quizá sólo esté en mi cabeza.",
	"Caroline.winterMon4": "Pasé la mañana intentando calentarme junto al fuego.#$b#De alguna manera, incluso estando justo al lado, mis dedos seguían fríos.$8#$b#Supongo que sólo necesito a alguien que me los sostenga.$6",
	"Caroline.winterMon6": "¿Te has fijado alguna vez en que algunas personas soportan mejor el frío que otras?#$b#Mientras tanto, otros se limitan a temblar y quejarse hasta que alguien se apiada de ellos.$8#$e#No es que vaya a dar nombres, por supuesto.$6",
	"Caroline.winterMon8": "El aire es cortante, el suelo está helado.#$b#¿Pero mi corazón?$4#$b#De alguna manera, todavía se siente caliente, ${querido^querida}$.$5",
	"Caroline.winterMon10": "Las mañanas de invierno pueden ser duras.$11#$e#...Pero despertarse con alguien en la mente los hace un poco más suaves, ¿no crees?$10",
	"Caroline.winterTue": "El aeróbic fue una lucha hoy.#$b#El invierno me hace querer acurrucarme e hibernar, no estirarme y sudar.$2",
	"Caroline.winterTue2": "Jodi y yo estamos de acuerdo en que hacer ejercicio con frío es el doble de agotador.$6#$b#Aunque Marnie dijo que es sólo una excusa para ser perezosa.$8",
	"Caroline.winterTue4": "Jodi jura que vio vapor saliendo de nosotras después del aeróbic.#$b#Le dije que estaba imaginando cosas.$6#$b#¿Pero sinceramente? No me sorprendería.$8",
	"Caroline.winterTue6": "Hoy el suelo estaba helado.$2#$b#Casi salté cuando mis pies lo tocaron.$3",
	"Caroline.winterTue8": "El aeróbic no me calentó tanto como esperaba.$2#$e#Tal vez sólo necesito una forma diferente de mantenerme caliente.$6",
	"Caroline.winterTue10": "Dicen que el ejercicio hace fluir la sangre...#$e#Pero de alguna manera, tienes una forma de hacer que mi corazón se acelere aún más.$10",
	"Caroline.winterWed": "La nieve hace que todo vaya más despacio.#$b#Como si todo el valle estuviera... descansando.",
	"Caroline.winterWed2": "El frío hace que se me entumezcan las manos muy rápido.#$b#Siempre me digo que me compraré guantes mejores, pero nunca lo hago.$2",
	"Caroline.winterWed4": "Vi a unos niños jugando en la nieve.#$b#Por un segundo, casi olvidé el frío que hacía...$1#$b#Bueno, casi.$8",
	"Caroline.winterWed6": "Alguna pobre alma resbaló en el hielo esta mañana.$2#$b#Espero que estén bien.$11",
	"Caroline.winterWed8": "Es el tipo de frío que perdura, ¿sabes?#$e#Del que se te queda en la piel, en los huesos...$6#$b#Pero incluso entonces, pensar en ti es suficiente para ahuyentarlo.$9",
	"Caroline.winterWed10": "Nevadas, aire frío, calles heladas...$11#$e#Y sin embargo, un pensamiento de ti, y te juro que puedo sentir el calor de nuevo...$11",
	"Caroline.winterThu": "Jodi y yo terminamos hablando del verano hoy.#$b#Supongo que incluso ella se está cansando del invierno.$8#$b#Aunque entre ${nosotros^nosotras}$, creo que sólo echa de menos tener una excusa para comer helado.$6",  
	"Caroline.winterThu2": "Hoy hemos tenido una larga charla sobre niños.#$b#Dijo que Vincent sigue corriendo fuera sin su abrigo.$8#$b#Mientras tanto, Abigail no sale de casa a menos que sea absolutamente necesario.$2",  
	"Caroline.winterThu4": "Jodi estaba de mal humor hoy, así que traté de animarla.#$b#Incluso la hice reír, una de esas risas de verdad, de las que te hacen sostener la barriga.$8#$b#Si eso no es una victoria, no sé lo que es.$5",  
	"Caroline.winterThu6": "Hoy había un fuerte viento en la plaza.#$e#Pensé que estaba lo suficientemente abrigada...$8#$b#Luego casi me roba la bufanda.$2#$b#Si ves que pasa volando, avísame.$3",  
	"Caroline.winterThu8": "Jodi dice que el invierno la pone sentimental.#$b#No puedo culparla.$4#$b#Días fríos, noches largas... es fácil empezar a pensar en ciertas personas, ${querido^querida}$.$5",  
	"Caroline.winterThu10": "Apenas escuché una palabra de lo que Jodi decía hoy.$2#$e#¡No es culpa mía! Mis pensamientos estaban en otra parte.$3#$b#¿O debería decir, en alguien, hmm? ¿${Querido^Querida}$?$6",  
	"Caroline.winterFri": "Hoy he encontrado un libro con un título ridículo.#$b#Algo sobre el amor, el destino y un apuesto duque.$6#$b#Naturalmente, tuve que leer las primeras páginas.$8",  
	"Caroline.winterFri2": "Hay algo en la biblioteca en invierno.#$e#La tranquilidad, el calor, el olor a páginas viejas...$4#$b#Casi me dan ganas de quedarme ahí todo el día.$8",  
	"Caroline.winterFri4": "Hoy me he perdido completamente en un libro.#$b#Entonces levanté la vista y me di cuenta de que el sol ya se había puesto.$2#$e#No es la peor manera de pasar una tarde, supongo.$1",  
	"Caroline.winterFri6": "Escuché a alguien en la biblioteca suspirar dramáticamente.#$b#Resultó que estaban leyendo un romance trágico.$8#$e#Fue tan exagerado que casi me reí...$8#$b#Bueno, casi.$6",  
	"Caroline.winterFri8": "Hoy he leído algo interesante.#$b#Decía que el calor no es sólo cuestión de temperatura, sino también de personas.$4#$e#Parece una forma elegante de decir que algunas personas hacen la vida más acogedora, ${querido^querida}$.$5",  
	"Caroline.winterFri10": "Me quedé en la biblioteca más tiempo de lo habitual.#$b#Pero no por los libros.$6#$e#Estaba esperando a que alguien entrara y me diera una mejor razón para quedarme.$10",  
	"Caroline.winterSat": "Pierre trató de hacerme probar una nueva mezcla de té hoy.#$b#Digamos que...$2#$b#No todos los experimentos tienen éxito.$8",  
	"Caroline.winterSat2": "Encontré una vieja caja de adornos de invierno en casa.#$b#La mitad se están cayendo a pedazos, pero no me atrevo a tirarlos.$11",  
	"Caroline.winterSat4": "Pasé la mañana horneando.#$b#Mi objetivo era 'delicado y elegante'...$2#$b#Pero de alguna manera terminó con 'ligeramente quemado pero aún comestible'.$3",  
	"Caroline.winterSat6": "Me quedé mirando por la ventana durante un buen rato.#$e#No a nada en particular.$6#$b#Observando cómo se ralentiza el mundo en invierno.$11",  
	"Caroline.winterSat8": "Preparé té, me senté junto a la ventana y dejé pasar el día.#$b#Habría sido perfecto si hubiera tenido a alguien con quien compartirlo, ${querido^querida}$.$6",  
	"Caroline.winterSat10": "Una mañana tranquila, una bebida caliente y alguien que me mira a través de la mesa...$6#$e#Ese sería el día de invierno perfecto, ${querido^querida}$.$5",  
	"Caroline.winterSun": "Me desperté con el sonido de Pierre paleando nieve.#$b#Debería haber ayudado, pero...$8#$b#Bueno, mi manta estaba demasiado caliente para dejarla.$6",  
	"Caroline.winterSun2": "El invierno es perfecto para no hacer absolutamente nada.#$b#No es que llegue a...$11#$b#Pero es un bonito pensamiento.$8",  
	"Caroline.winterSun4": "Hoy he intentado tejer.#$b#Si alguna vez necesitas una bufanda desigual, acepto peticiones.$8",  
	"Caroline.winterSun6": "Hoy he salido un segundo.#$b#Una bocanada de ese aire helado e inmediatamente me arrepentí.$8#$b#Nunca más.$8",  
	"Caroline.winterSun8": "Hay algo en el frío que hace que el calor siente aún mejor.$6#$e#Y no me refiero sólo a sentarse junto al fuego, ${querido^querida}$.$10",  
	"Caroline.winterSun10": "Una tarde nevada, una casa tranquila y la idea de que alguien me dé calor...$11#$e#Quizá el invierno no sea tan malo después de todo, ${querido^querida}$.$10",  

	//Marriage Dialogues
	"Caroline.RainyDay.0": "Vaya, parece que hoy llueve a cántaros.$2#$b#Pero eso está bien, porque significa que puedo pasar aún más tiempo contigo.",
	"Caroline.RainyDay.1": "¡Está lloviendo! ¡Amorcito!#$b#Hoy no tenemos que regar las plantas, podemos tomarnos un descanso y relajarnos un rato.$8",
	"Caroline.RainyDay.2": "Los días así siempre hacen que la granja resulte acogedora.#$b#Aunque será difícil concentrarse cuando lo único que quiero es sentarme contigo y escuchar la lluvia.$6",
	"Caroline.RainyDay.3": "No te mojes demasiado, ten cuidado de no resfriarte, ¿vale?#$b#Si alguna vez enfermas, no podrás cuidar bien de tus cultivos.$6",
	"Caroline.RainyDay.4": "¿Crees que las minas se mojarán en el fondo cuando llueve?$11#$b#¡Lo siento, puede parecer una pregunta tonta, pero no puedo evitar preguntármelo!$8",
	"Caroline.RainyDay.5": "¿Todavía te gustan los paseos en días lluviosos, como cuando éramos ${niños^niñas}$?$1#$b#Pero eso es algo que siempre me ha gustado de ti, ¿sabes?$5",
	"Caroline.RainyDay.6": "Mira la lluvia en la ventana, mi amor.#$b#Ten cuidado ahí fuera, ¿vale?$1#$b#Intenta no preocuparme demasiado.$5",
	"Caroline.RainyDay.7": "He oído que los peces legendarios pican en este tiempo.#$b#¿Mi pequeño campeón de la pesca va a probar suerte?$6#$b#Por otra parte, siempre has sido mi pequeño milagro. Por supuesto que pescarás algo.$5",
	"Caroline.RainyDay.8": "Está lloviendo mucho ahí fuera, ¿eh?#$b#Ten cuidado por donde pisas.$1#$b#Estaré aquí, enviándote pensamientos cálidos hasta que llegues sano y salvo a casa.$5",
	"Caroline.RainyDay.9": "No te quedes mucho tiempo ahí fuera con este tiempo, cariño.$5",
	"Caroline.RainyDay.10": "¿Crees que los cultivos estarán bien con toda esta lluvia?#$b#Pero bueno, esto es Stardew Valley. Estoy segura de que estarán bien.",
	"Caroline.RainyDay.11": "Vuelve pronto a casa, ¿vale?#$b#Los caminos pueden estar resbaladizos cuando están mojados.$6",
	"Caroline.RainyNight.0": "La lluvia golpeando contra la ventana es tan relajante.#$b#Es la excusa perfecta para quedarse cerca y no hacer nada por una vez.$5",
    "Caroline.RainyNight.1": "Oye, estaba pensando.$11#$b#La lluvia es perfecta para quedarse en la cama y relajarse.$5#$b#¿Por qué no lo hacemos?$6",
	"Caroline.RainyNight.2": "Hola~$6#$b#Te pillé mirando otra vez, ¿no?$8#$b#No eres sutil, sabes. No es que me importe.$4",
    "Caroline.RainyNight.3": "La lluvia solía inquietarme.#$b#Ahora, estoy deseando pasarlo contigo.$4",
    "Caroline.RainyNight.4": "Noches como ésta me recuerdan cuando solíamos sentarnos ${juntos^juntas}$ en el porche.#$b#No creo que hayamos hablado mucho... pero fue agradable, ¿no?$5",
    "Caroline.RainyNight.5": "Deberías descansar pronto.#$e#Vamos, a dormir.$5",
	"Caroline.IndoorDay.0": "Llevar una granja ${juntos^juntas}$ no es exactamente lo que me imaginaba.$11#$b#Pero tengo que admitir que no lo cambiaría por nada.$6",
    "Caroline.IndoorDay.1": "Siempre estás trabajando muy duro.#$e#No te olvides de hacer descansos, ¿vale?$2#$b#En serio...$3",
	"Caroline.IndoorDay.2": "A veces pienso que deberíamos viajar por ahí.#$e#Este mundo es tan grande que podemos ir a explorarlo todo.$1",
    "Caroline.IndoorDay.3": "La casa se queda un poco tranquila cuando estás fuera trabajando.#$b#Pero siempre me alegra verte entrar por esa puerta.$1",
	"Caroline.IndoorDay.4": "Puedes trabajar duro, pero prométeme que te mantendrás a salvo.#$b#Pensaré en ti cuando no estés.$2",
	"Caroline.IndoorDay.5": "¿El trabajo en la granja es demasiado exigente?#$e#[614]No te esfuerces demasiado, cariño.#$b#Ven a tomar una taza de té conmigo.$0",
	"Caroline.IndoorNight.0": "Es agradable tener noches así, ¿verdad?#$e#Sin prisas, sin preocupaciones... sólo ${nosotros^nosotras}$.$10",
	"Caroline.IndoorNight.1": "La noche aún es larga...$10#$b#Hablemos de otras cosas...$6",
    "Caroline.IndoorNight.2": "Oye, mira esa luna esta noche.#$b#Es tan brillante como para iluminar toda la granja.$1",
	"Caroline.IndoorNight.3": "¿Hmm...?$7#$b#No es nada, solo quiero besarte$6",
	"Caroline.IndoorNight.4": "¡Oh, ya has vuelto!$1#$b#Hoy he intentado cocinar algo diferente.#$b#¿Quieres probarlo por mí? Sé ${sincero^sincera}$, ¿vale? [218 732 207 224]$1",
	"Caroline.Outdoor.0": "¿Oh? ¿Quieres un poco también? [613 398 634]$8#$b#¡Qué! ¡No me llames gorda!$2",
	"Caroline.Outdoor.1": "¡Vamos, sigue trabajando!$5#$b#¿No solía animarte a hacer algo así antes?$6",
    "Caroline.Outdoor.2": "Sinceramente, verte aquí trabajando en el campo sigue siendo un poco surrealista.$5#$b#¡${El viejo^La vieja}$ tú ya debe estar ${cansado^cansada}$!$8",
    "Caroline.Outdoor.3": "Asegúrate de tomar descansos cuando los necesites, amorcito.$5#$e#Sabes que no puedo evitar preocuparme por ti.$2",
	"Caroline.Outdoor.4": "El aire de hoy es refrescante.$1#$e#Después de tanto tiempo fuera de la ciudad, casi me he acostumbrado a este tipo de aire.$1",
	"Caroline.OneKid.0": "Amorcito, es hora de cambiar la forma en que te diriges a mí...$2#$b#Especialmente no delante de nuestro hijo...$8#$e#¡Así es! ${Papi^Mami}$, ven a darme un abrazo.~$7",
	"Caroline.OneKid.1": "%pet y %kid1 parecen llevarse muy bien.#$b#Les pillé antes sentados juntos.$1",
	"Caroline.OneKid.2": "¿Vamos a enviar a %kid1 a estudiar en la ciudad en el futuro?#$b#Pero si dependiera de ti, dejar que %kid1 herede esta granja también sería una buena opción.$1#$b#¿Tengo razón o estoy pensando demasiado a largo plazo?$11",
	"Caroline.OneKid.3": "No puedo creer que ahora tengamos un hijo, nada de esto parece real.#$b#Todo esto es tan hermoso que parece casi irreal, demasiado perfecto para ser real.$5",
	"Caroline.TwoKids.0": "Tenemos que proporcionar el mismo nivel de cuidados a nuestros dos hijos.#$b#¿No lo crees, ~amorcito~?$6",
    "Caroline.TwoKids.1": "¿Has visto a %kid1 sonriendo a %kid2 antes?#$e#Son momentos como ése los que hacen que todo parezca tan bien.$1#$b#Ahora somos una familia de verdad, ¿no?$5",
    "Caroline.TwoKids.2": "¿Podrías encargarte de cambiar el pañal de %kid1 esta vez?$11#$b#Necesito alimentar a %kid2 antes de que empiece a llorar otra vez.$2",
	"Caroline.TwoKids.3": "Cuidar de dos niños me tiene más ocupada que nunca, ¡y me siento completamente agotada!$2#$e#Necesito un empujoncito tuyo, amorcito...$10",
    "Caroline.TwoKids.4": "Es increíble, ¿verdad? Nuestra familia se siente tan completa.$1#$b#Estoy impaciente por ver qué nos depara el futuro.$8",	
	"Caroline.Good.0": "Me siento tan afortunada de haberme casado contigo. Cada momento contigo me hace feliz.$1#$e#Siempre seremos así de felices, ¿verdad?$1",
    "Caroline.Good.1": "~Amorcito~, lo eres todo para mí.$4#$e#Incluso después de todo este tiempo, esa sensación no ha cambiado.$5",
	"Caroline.Good.2": "Me hace feliz que nuestro matrimonio no haya anquilosado nuestra relación.#$e#Oh, espera, ¿por qué pensé que eso pasaría?$8",
    "Caroline.Good.3": "No sé por qué, pero nunca doy por sentado ni un solo día contigo.#$b#Es demasiado precioso.$5",
    "Caroline.Good.4": "La forma en que trabajas tan duro cada día... es realmente admirable.#$b#Es increíble ver cuánto has crecido, amorcito.$8",
	"Caroline.Good.5": "¿Te gusta más vivir aquí que en la ciudad?#$e#Quizá podamos vivir aquí hasta que envejezcamos, ¿es eso lo que quieres?$6",
    "Caroline.Good.6": "Siento que nos entendemos como la mayoría de las parejas no lo hacen.$6#$b#¿Quizás porque crecimos ${juntos^juntas}$?$6",
    "Caroline.Good.7": "Estás convirtiendo mis sueños en realidad.#$b#Por eso te amo más que a nada.$1",
	"Caroline.Good.8": "¿Sabes lo que me gusta de ${nosotros^nosotras}$?#$b#No necesitamos grandes gestos llamativos para demostrar nada.$1#$e#Simplemente nos entendemos. Eso es lo único que importa.$8",
    "Caroline.Bad.0": "¿Por qué me tratas así...$2",
    "Caroline.Bad.1": "Has estado tan distante últimamente...$11#$e#¿He hecho algo mal?$2",
    "Caroline.Bad.2": "Pensé que eras diferente...$11",
    "Caroline.Bad.3": "Pensé que me amabas de verdad...$11",
	"Caroline.funLeave.0": "Estaré fuera un rato, sólo necesito algo de tiempo en el pueblo.#$b#No me eches mucho de menos, ¿vale, amorcito?$6",
	"Caroline.funLeave.1": "¡Voy a salir un rato!#$e#Si te portas bien, puede que te traiga una sorpresa.$6",
	"Caroline.funLeave.2": "Voy a salir un rato.#$b#No te preocupes-$7#$b#Estaré pensando en ti todo el tiempo.$5",
	"Caroline.funLeave.3": "Sólo necesito un poco de aire fresco.#$b#...$7#$b#Volveré antes de que te des cuenta.$5",
	"Caroline.funLeave.4": "Me apetece pasear un rato por el pueblo.#$b#¡Será mejor que tengas un abrazo preparado para cuando vuelva!$6",
	"Caroline.funLeave.5": "Me voy a hacer unos recados.#$b#¡No te diviertas mucho sin mí!$8",
	"Caroline.funLeave.6": "Estaré fuera un rato, amorcito.#$b#No te metas en líos mientras no estoy, ¿eh?$2",
	"Caroline.funLeave.7": "Voy a salir un rato.#$b#Mantén la cama caliente para mí, ¿de acuerdo, amorcito?$6",
	"Caroline.funLeave.8": "El día es demasiado bonito para desperdiciarlo en casa.#$b#¡Volveré antes de que me eches de menos!$8",
	"Caroline.funLeave.9": "Estaré fuera un rato.$7#$e#¿Amorcito?$2#$b#¡Nunca pienses que me olvidaré de ti!$3",
	"Caroline.funLeave.10": "Me voy, cariño. Quizás vaya a ver a Abby.$1#$b#¿Ah? Sabes que nunca podría olvidarte.$5",
	"Caroline.funLeave.11": "Voy a salir a hacer ejercicio.$0#$b#No querrás que pierda la forma, ¿verdad?$3",
	"Caroline.funLeave.12": "Hoy voy a cuidar mis flores con Evelyn.$1#$e#[591]Toma, esta flor me recuerda a ti, porque eres tan ${encantador^encantadora}$ como este tulipán.$6",
	"Caroline.funLeave.13": "Hoy puedo sentir la brisa marina...$1#$b#¿Podríamos ir ${juntos^juntas}$ a la playa más tarde, cariño?$6#$b#Quizás encontremos algunas conchas bonitas.$0",
	"Caroline.funLeave.14": "Voy a visitar el pueblo dentro de un rato. ¿Tienes algún plan?$1#$b#Quizás incluso te encuentres conmigo.$8",
	"Caroline.funLeave.15": "¿Recuerdas aquellas aventuras con las que soñábamos ${juntos^juntas}$ cuando éramos jóvenes?$3#$b#Creo que me gustaría volver a vivir una.$5",
	"Caroline.funLeave.16": "Las bayas silvestres están creciendo de nuevo, así que pensé en ir a recoger algunas.$1#$b#Quizás te traiga una pequeña sorpresa.$6",
	"Caroline.funLeave.17": "Voy a la biblioteca a leer.$0#$b#Después de todo, los libros fueron lo que nos unió.$5",
	"Caroline.funLeave.18": "Me voy a ir pronto.$0#$b#¿Qué tal un beso para despedirme?$6",
	"Caroline.funLeave.19": "Voy a salir un rato. Cuídate mucho mientras no esté.$3#$b#Me enfadaré si no te cuidas bien.$8",
	"Caroline.funLeave.20": "El paisaje está precioso hoy.#$b#Pueblo Pelícano está tan bonito como siempre, así que creo que voy a dar un paseo.$1#$e#No te preocupes por mí.$5",
	"Caroline.funLeave.21": "Pueblo Pelícano tiene su propio encanto especial. Creo que voy a salir a tomar un poco de aire fresco.$3#$b#No te olvides de calentar la cama para mí.$5",
	"Caroline.funLeave.22": "Cariño, ¿te has fijado en lo maravilloso que está hoy el océano?$0#$b#Creo que voy a disfrutar de las hermosas vistas.$3",
	"Caroline.funReturn.0": "¡He vuelto! El pueblo estaba animado hoy.$5#$b#¡Yo también he traído comida!$1#$b#Comamos juntos. [207 218 244 610]$8",
	"Caroline.funReturn.1": "¡He vuelto!$8#$b#¿Qué? ¿Me extrañaste?$6#$b#Traje un pequeño regalo para ti. [207 218 244 610]$5",
	"Caroline.funReturn.2": "Me siento tan bien en casa.#$b#Te he echado de menos, amorcito.$7",
	"Caroline.funReturn.3": "¡He vuelto!$1#$b#No empezaste a cenar sin mí, ¿verdad?$2",
	"Caroline.funReturn.4": "¡Estoy en casa!#$b#No te creerías las historias que he oído hoy en el pueblo.$6",
	"Caroline.funReturn.5": "En el pueblo estuvo divertido, pero me alegro de estar de vuelta.#$b#Aquí, tengo algo para compartir. [207 218 244 610]$5",
	"Caroline.funReturn.6": "Hoy he visto cosas interesantes en el museo.#$b#¿Quizá podamos ir juntos la próxima vez?$5^¿Quizá podamos ir juntas la próxima vez?$5",
	"Caroline.funReturn.7": "He vuelto, amorcito.#$b#¿Me has echado de menos?$5#$b#Oh, no pongas esa cara de sorpresa. Yo también te he echado de menos.$8",
	"Caroline.funReturn.8": "Es bueno estar en casa.#$b#No hay otro lugar donde prefiera acabar el día que aquí contigo.$1",
	"Caroline.funReturn.9": "Hoy el camino de vuelta a casa me ha parecido más largo.$11#$b#Tal vez sea porque no podía esperar a volver contigo.",
	"Caroline.funReturn.10": "¡Ya estoy de vuelta!#$b#No te imaginas lo que he encontrado.$1#$b#[394]¡Una concha arcoíris!$5",
	"Caroline.funReturn.11": "Las bayas silvestres estaban tan deliciosas que te traje algunas.$1#$b#[296]Son increíblemente dulces, como tú.$5",
	"Caroline.funReturn.12": "No vas a creer lo que acabo de ver.$3#$b#¡Los cerdos de Marnie se alinearon y cayeron en la zanja, uno tras otro!$8",
	"Caroline.funReturn.13": "Estoy en casa.$1#$b#[593]Esta es tu recompensa por ser tan paciente.$8",
	"Caroline.funReturn.14": "¿Adivina qué vi fuera?$1#$b#[136]¡Una perca saltó directamente a la orilla!$8#$b#¿No es gracioso? ¡Te la traje!$1",
	"Caroline.funReturn.15": "Te extrañé. ¿Tú también me extrañaste?$5#$b#Parece que han pasado diez años desde la última vez que te vi.$7",
	"Caroline.funReturn.16": "Qué bueno es estar de vuelta en nuestro acogedor hogar.$3#$b#Que me esperes es una de las cosas que más me gustan de ti.$5",
	"Caroline.funReturn.17": "Pasar todo el día sin besarte se siente tan extraño.$2#$b#¿Qué tal si me compensas ahora?$6",
	"Caroline.funReturn.18": "Hoy pasé un rato jugando con nuestra mascota.$1#$b#Fue realmente maravilloso.$3",
	"Caroline.funReturn.19": "El aire exterior era tan refrescante. Deberías venir conmigo a dar un paseo la próxima vez.$3",
	"Caroline.funReturn.20": "Te traje algo.$3#$b#[233]Sé que te va a encantar.",
	"Caroline.funReturn.21": "¿Cómo te ha ido hoy en el trabajo? Espero que no demasiado agotador.$1#$b#Me duele verte trabajar en exceso.$2",
	"Caroline.funReturn.22": "¡Ya estoy en casa! Mientras estabas fuera, %pet y yo lo hemos pasado genial juntos.$6",
	"Caroline.patio.0": "Estirarse bajo el sol sienta muy bien.#$b#Deberías unirte a mí alguna vez, para relajarte un poco.$1",
	"Caroline.patio.1": "La brisa es perfecta hoy.#$b#No me mires así.$2#$b#No estoy exagerando.$3",
	"Caroline.patio.2": "Estás mirando fijamente.$2#$b#¿Te estoy distrayendo?$3#$b#Bien.$6",
	"Caroline.patio.3": "No te preocupes por mí, amorcito.#$b#Me he puesto crema solar, estaré bien.$8#$e#Quizás entre pronto, pero por ahora, el sol sienta bien.$1",
	"Caroline.patio.4": "Ya no soy tan joven como antes, pero aún puedo tocarme los dedos de los pies.#$b#¿Y tú?",
	"Caroline.spouseRoom.0": "Acabo de preparar una tetera.#$b#¿Quieres compartir una taza conmigo?$5#$b#¡Ten, toma esto! [614]$1",
	"Caroline.spouseRoom.1": "La casa se siente acogedora hoy.#$b#Vamos a relajarnos un poco.$1",
	"Caroline.spouseRoom.2": "Encontré esta nueva mezcla de té.#$b#Es muy relajante.$5#$b#¡Toma un poco! [StardropTea]$1",
	"Caroline.spouseRoom.3": "Has estado trabajando duro.#$b#Siéntate, te serviré un poco de té. [614]$1",
	"Caroline.spouseRoom.4": "Incluso después de todo este tiempo, me siguen encantando estos momentos de tranquilidad contigo.#$b#Aunque, si sigues mirándome así.$2#$b#Puede que olvide lo que significa 'tranquilidad'.$6",
	"Caroline.spouseRoom.5": "Hoy estaré en casa todo el día.$1#$b#¿Te apetece buscar algo que hacer ${juntos^juntas}$?$5",
	"Caroline.spouseRoom.6": "Cuando estás en la granja, a menudo pienso en cuando éramos ${niños^niñas}$.$1#$b#Tenerte aquí conmigo ahora... es realmente maravilloso.$7",
	"Caroline.spouseRoom.7": "A veces todo esto parece un sueño.$2#$b#Pero entonces recuerdo que lo que tenemos es real.$5",
	"Caroline.spouseRoom.8": "Si pudiera volver atrás en el tiempo, habría encontrado el camino hacia ti mucho antes.$1#$b#Y más te vale que no me hubieras rechazado.$4",
	"Caroline.spouseRoom.9": "Siempre estás trabajando tan duro.$2#$b#Tómate un descanso y ven a tomar un té conmigo.[614]$0",
	"Caroline.spouseRoom.10": "Tómate el día libre conmigo hoy.$0#$b#Me duele verte trabajar hasta el agotamiento todos los días.$2",
	"Caroline.spouseRoom.11": "¿Recuerdas cuando éramos ${niños^niñas}$ y nos escondíamos en nuestro lugar secreto para jugar todo el día?$1#$b#Ahora tenemos nuestro propio escondite, solo para ${nosotros^nosotras}$.$5",
	"Caroline.spouseRoom.12": "Hoy me quedaré en casa.#$b#No te olvides de mí mientras trabajas.$6",
	"Caroline.spouseRoom.13": "¿Qué te parece mi conjunto?#$b#Estoy limpiando mi armario.$1#$b#Admítelo, ¿no estoy aún más guapa ahora?$8",
	"Caroline.spouseRoom.14": "Hoy he decidido ser completamente vaga. #$b#¡Buena suerte con tu trabajo, cariño!$5",
	"Caroline.spring_1.M": "La primavera está aquí, amorcito. Todo parece tan fresco y vivo.#$e#¡Aprovechemos al máximo la temporada!$1",
	"Caroline.spring_12.M": "La búsqueda de los huevos siempre nos trae recuerdos de nuestra infancia.#$e#Quizá deberíamos tomarnos un tiempo para revivir un poco aquellos días.$6",
	"Caroline.spring_13.M": "El Festival del Huevo está a punto de comenzar.#$b#Asegúrate de planificar bien tu día.$4",
	"Caroline.spring_23.M": "Los trajes de la danza floral son siempre tan elegantes y atemporales.#$e#Es agradable ver que se conservan este tipo de tradiciones.$8",
	"Caroline.spring_24.M": "Hoy es la Danza Floral.#$b#Vas a pedirme que baile, ¿verdad?$6",
	"Caroline.summer_1.M": "Han vuelto las cigarras: ese sonido siempre me dice que es verano.$2#$e#Espero que la granja prospere tanto como los árboles con este calor.$1",
	"Caroline.summer_10.M": "¿Tienes todo listo para el Luau de mañana?#$e#Es uno de esos acontecimientos en los que realmente se nota el esfuerzo de todos.$5",
	"Caroline.summer_11.M": "Estoy deseando probar la sopa de hoy.$1#$b#Solo prométeme que no le añadirás nada raro.$2",
	"Caroline.summer_27.M": "¡Las Medusas Lunares llegan mañana!#$b#Volverán a deslizarse por las aguas.$1",
	"Caroline.summer_28.M": "Llevaba mucho tiempo esperando con ilusión el Baile de las Medusas Lunares.#$b#Todo parece más mágico cuando lo vivo contigo.$5",
	"Caroline.fall_1.M": "El otoño ya está aquí y es hora de centrarse en la cosecha.#$b#No te preocupes, amorcito, estaré aquí para que todo vaya sobre ruedas.$8",
	"Caroline.fall_15.M": "¿Ya has decidido qué llevarás a la feria este año?#$e#¡Nuestro objetivo debe ser causar una impresión duradera!$8",
	"Caroline.fall_16.M": "¿Estás ${listo^lista}$? Hoy es la feria de Stardew Valley.#$b#Sé que me harás sentir orgullosa, nunca me decepcionas.$5",
	"Caroline.fall_26.M": "Recibí este vestido ayer, fue un pequeño regalo sorpresa.#$b#No le has dicho nada a nadie, ¿verdad?$2",
	"Caroline.fall_27.M": "¡Ten cuidado en el laberinto de la víspera de los Espíritus esta noche!$1",
	"Caroline.winter_1.M": "¡Está nevando! El invierno es tan tranquilo y sereno.#$b#Disfrutemos ${juntos^juntas}$ de esta apacible estación.$5",
	"Caroline.winter_7.M": "¿Estás ${preparado^preparada}$ para el festival de mañana?#$e#Te he visto practicar y sé que causarás sensación.$8",
	"Caroline.winter_8.M": "Buena suerte en el Festival del Hielo de hoy.#$b#Sé que puedes ganar, al fin y al cabo eres mi persona favorita.$8",
	"Caroline.winter_24.M": "¡Estoy tan emocionada, amorcito!$5#$b#Estoy impaciente por ver qué sorpresa me tienes preparada.$6",
	"Caroline.winter_25.M": "La Fiesta de la Estrella de Invierno está a punto de comenzar.#$b#¡No olvides traer un regalo!$1#$b#[74]Esto es para ti. ¡Feliz Fiesta de la Estrella de Invierno!$8",
	"Caroline.winter_28.M": "El año está a punto de terminar... han pasado tantas cosas, pero lo mejor ha sido pasarlo todo contigo.$5",

	//Schedule Dialogues
	"Caroline.Museum_Reading.1": "Por fin... Un poco de tiempo para mí.#$b#Pero conociéndote, seguro que encuentras la forma de interrumpirme, ¿no?$6",
	"Caroline.Museum_Reading.2": "La biblioteca es la escapada perfecta.#$b#Y no, no puedes burlarte de mis preferencias de lectura, ${querido^querida}$.$2",
	"Caroline.Museum_Reading.3": "A veces, creo que la biblioteca está infravalorada.#$b#No todo el mundo se da cuenta de lo agradable que es sentarse y disfrutar de un libro.$1",
	"Caroline.Museum_Reading.4": "Shh, no le digas a nadie que estoy aquí.$3#$b#Este es mi lugar secreto para descansar.$2",
	"Caroline.Museum_Reading.5": "Si vas a distraerme, al menos haz que valga la pena.$2#$b#Sólo bromeaba...$8#$b#¿O no?$6",
	"Caroline.Altar.1": "¿La sala del altar? Lleva aquí más tiempo que yo.#$b#Lo mantengo limpio para quien necesite un momento de tranquilidad.$1",
	"Caroline.Altar.2": "Es un bonito pensamiento, tener un espacio como la sala del altar.#$b#Aunque yo no lo utilice, respeto lo que significa para los demás.$1",
	"Caroline.Altar.3": "La sala del altar tiene una presencia tranquila.#$b#A veces me siento ahí un momento para aclarar mis ideas.",
	"Caroline.Altar.4": "La sala del altar ha visto su parte de gente buscando consuelo.#$b#Espero que siga siendo un lugar donde los demás se sientan bienvenidos.$1",
	"Caroline.Altar.5": "Algunos espacios tienen una energía tranquila.#$b#La sala del altar es una de ellas, aunque no esté ahí a menudo.",
	"Caroline.Visit_Harvey_1.1": "Las revisiones anuales son un mal necesario.#$b#Pero prefiero estar fuera disfrutando del aire fresco del otoño.$2",
	"Caroline.Visit_Harvey_2.1": "Oh, ¿tú también estás esperando?#$b#Quizá podamos intercambiar consejos sobre cómo sobrevivir a las conferencias de Harvey.$8",
	"Caroline.Visit_Harvey_3.1": "Muy bien, ¡deséame suerte!#$b#Si oyes risas, probablemente sea porque he confesado que desayuno galletas.$6",
	"Caroline.Visit_Harvey_1.2": "Harvey siempre consigue que estas visitas resulten menos desalentadoras.#$b#Es una habilidad, supongo.$11",
	"Caroline.Visit_Harvey_2.2": "¡Oh, hola!#$b#¿Estás aquí para asegurarte de que no me eche atrás? Porque es tentador.$8",
	"Caroline.Visit_Harvey_3.2": "Bueno, aquí no pasa nada.$2#$b#Harvey me va a decir que deje de picar entre comidas, ¿no?$3",
	"Caroline.Visit_Harvey_1.3": "Nunca sé si estoy más nerviosa o aburrida en la sala de espera.$2#$b#Quizá sea un poco de ambas cosas.$8",
	"Caroline.Visit_Harvey_2.3": "¿Y tú? ¿También estás aquí para una revisión?#$b#En cualquier caso, es bueno tener a alguien con quien hablar.$1",
	"Caroline.Visit_Harvey_3.3": "Muy bien, ¡vamos a ver lo bien que me he cuidado este año!$6",
	"Caroline.Visit_Harvey_1.4": "Me pregunto si Harvey se cansa de estas revisiones rutinarias.#$b#Aunque siempre parece tan paciente.$1",
	"Caroline.Visit_Harvey_2.4": "¿Tú también estás aquí?#$b#Déjame adivinar... ¿Harvey te dijo que dejaras de trabajar tanto en la granja?$6",
	"Caroline.Visit_Harvey_3.4": "¡Deséame suerte!#$b#Esperemos que no añada nada nuevo a mis 'objetivos de salud'.$6",
	"Caroline.Visit_Harvey_1.5": "Hoy es mi revisión anual.$2#$b#Esperemos que sea rápida e indolora.$2",
	"Caroline.Visit_Harvey_2.5": "¿Tú también estás aquí? ¿Tú también estás aquí? ¿Harvey hizo un doble turno?$2#$b#Bueno, al menos me da alguien con quien charlar.$8",
	"Caroline.Visit_Harvey_3.5": "Disculpa, tengo que decirle algunas cosas al Doctor Harvey en privado.#$b#No te pongas ${celoso^celosa}$ ahora, ¿vale, ${querido^querida}$?$6",
	"Caroline.Aerobics_1.1": "Hmm... ¿Debería llevar mi diadema brillante hoy?$11#$b#Es un poco atrevido, ¿pero por qué no?$8",
	"Caroline.Aerobics_2.1": "Jodi, ¡te ves tan fuerte estos días!#$b#¿Cuál es tu secreto? No me lo ocultes.",
	"Caroline.Aerobics_3.1": "Espero haberme acordado de mi botella de agua.#$b#¡Lo último que quiero es desplomarme a mitad de camino!$8",
	"Caroline.Aerobics_1.2": "¡Día de aeróbic!#$b#Es hora de ver si puedo seguir el ritmo de las demás.",
	"Caroline.Aerobics_2.2": "Marnie, ¡siempre aportas una gran energía al grupo!#$b#Aunque creo que en secreto te encantaría ser el centro de atención.$8",
	"Caroline.Aerobics_3.2": "Debería haber desayunado más ligero.#$b#Las sentadillas y las tortitas no combinan bien...$3",
	"Caroline.Aerobics_1.3": "¿Debería intentar dirigir el calentamiento hoy?#$b#Tal vez... o tal vez se lo deje a Jodi.",
	"Caroline.Aerobics_2.3": "Marnie, ¡hablabas de probar el yoga en vez del aeróbic!#$b#¡No puedo imaginar que te quedes quieta tanto tiempo!$8",
	"Caroline.Aerobics_3.3": "Creo que me he ganado un tentempié después del entrenamiento.#$b#Tal vez sólo una galleta. O dos.$6",
	"Caroline.Aerobics_1.4": "¿Crees que debería cambiar a correr en lugar de hacer aeróbic?#$b#Por otra parte, echaría demasiado de menos al grupo.",
	"Caroline.Aerobics_2.4": "Emily, sigues diciendo que deberíamos añadir baile a la rutina.#$b#¡No me importaría, parece muy divertido!",
	"Caroline.Aerobics_3.4": "Ya siento el ardor sólo de pensar en la sesión de hoy.#$b#Pero merece la pena... casi siempre.",
	"Caroline.Aerobics_1.5": "¿Crees que debería cambiar a correr en lugar de hacer aeróbic?$11#$b#Por otra parte, echaría demasiado de menos al grupo.$8",
	"Caroline.Aerobics_2.5": "Jodi, ¡siempre te exiges tanto!#$b#Recuerda, no pasa nada por tomárselo con calma de vez en cuando.",
	"Caroline.Aerobics_3.5": "Hora de una larga ducha y una siesta.#$b#¿Por qué sienta tan bien el cansancio después de entrenar?",
	"Caroline.NightMarket.1": "¡Las compras navideñas están en pleno apogeo!#$b#Esperemos que este año no me olvide de nadie de la lista.$6",
	"Caroline.NightMarket.2": "Las vacaciones son una época muy ajetreada, pero me encanta su energía.#$b#Es agradable ver que todo el mundo se anima.$1",
	"Caroline.NightMarket.3": "Me gusta elegir regalos para las personas que quiero.#$b#Es mi forma de demostrarles lo mucho que significan para mí.$1",
	"Caroline.NightMarket.4": "¿Crees que me paso con las compras navideñas?#$b#¿No? Bien, porque tengo una sorpresa planeada para ti también.$6",
	"Caroline.NightMarket.5": "Déjame adivinar, tienes curiosidad por tu regalo.#$b#Tendrás que esperar un poco más, ${querido^querida}$.$8",

	//Marriage Schedule Dialogues
	"Caroline.BathHouse_Pool.1": "Solía pensar en momentos como éste cuando éramos más jóvenes.$5#$b#Nunca te lo dije, ¿verdad?$8",
	"Caroline.BathHouse_Pool.2": "El vapor se siente bien...#$b#Pero creo que eres tú quien me hace sentir tan cálida.$9",
	"Caroline.BathHouse_Pool.3": "Se suponía que vendría aquí a relajarme...$2#$b#Que estés aquí me hace sentir de todo menos tranquila.$3",
	"Caroline.BathHouse_Pool.4": "¿Oh? ¿Me has seguido hasta aquí, amorcito?$3#$b#Si viene alguien, ¿qué pensará de que estemos tan cerca?$8",
	"Caroline.BathHouse_Pool.5": "Nunca pensé que compartiría un momento como este contigo.#$b#¡Si alguien me lo hubiera dicho entonces, me habría reído!$8#$b#...O sonrojado.$4",
	"Caroline.BathHouse_Pool.6": "Si te vas a sentar tan cerca de mí, es justo que me des un beso.$6#$b#No te pongas tan ${nervioso^nerviosa}$. ¡Sólo estoy pidiendo un besito!$8",
	"Caroline.Fountain.1": "El reflejo de la fuente siempre me hace pensar...$2#$b#¿Soy quien quería llegar a ser?$11",
	"Caroline.Fountain.2": "¿Recuerdas cuando jugábamos junto al viejo arroyo?$6#$b#¡Siempre pensé que te caerías un día, con lo torpe que eras!$8",
	"Caroline.Fountain.3": "La vida no siempre sale como la planeamos, ¿pero volver a verte?$11#$b#Se siente como el destino.$1",
	"Caroline.Fountain.4": "Pueblo Pelícano tiene su encanto.$1#$b#Aunque a veces echo de menos los campos por los que corríamos de ${niños^niñas}$.$5",
	"Caroline.Fountain.5": "Algunos lugares son perfectos para pensar.$11#$b#Este es uno de ellos para mí.$8",
	"Caroline.Graveyard.1": "A veces me la imagino sonriéndonos...$2#$b#¿Crees que estaría contenta con cómo han salido las cosas?$11",
	"Caroline.Graveyard.2": "Me pregunto si Mona alguna vez se sintió atrapada.$2#$b#Como si... hubiera algo más que quisiera de la vida.$11",
	"Caroline.Graveyard.3": "Creo que Abigail se siente más cerca de Mona acá.$2#$b#Quizá por eso viene acá.$11",
	"Caroline.Graveyard.4": "Este lugar me hace reflexionar sobre lo que realmente importa.$2#$b#Estoy agradecida por ti, ¿sabes?",
	"Caroline.Graveyard.5": "Abigail no dice mucho, pero creo que este lugar también significa algo para ella.$2",
	"Caroline.Marnie.1": "Marnie y yo estábamos charlando sobre sus animales.$1#$b#Dice que una de las vacas se ha portado mal, ¿quizá sea el tiempo?$11",
	"Caroline.Marnie.2": "Marnie me ha estado contando cómo mantiene a sus animales tan sanos.#$b#Es fascinante el cuidado que se pone en mantener felices a los animales.$1",
	"Caroline.Marnie.3": "Siempre admiro el esfuerzo que Marnie dedica a su granja.#$b#Es inspirador, de verdad.$1",
	"Caroline.Marnie.4": "La dedicación de Marnie a su trabajo es inspiradora.#$b#Debería volver a poner el mismo cuidado en mis mezclas de té.$1",
	"Caroline.Marnie.5": "¿Sabías que Marnie elige el mejor heno para sus animales?#$b#Me recuerda a elegir las hojas de té adecuadas.$8#$b#Las pequeñas cosas realmente importan, ¿verdad?$1",
	"Caroline.Traveling_Cart.1": "¡La semana pasada había aquí un libro con magníficas ilustraciones de plantas!$1#$b#Pero las palabras eran todas extranjeras, no tengo ni idea de lo que salía.$2",
	"Caroline.Traveling_Cart.2": "Me dijo que sus mercancías venían de lugares lejanos.#$b#Me hace preguntarme sobre las historias que hay detrás de todo lo que vende.$11",
	"Caroline.Traveling_Cart.3": "Una vez me vendió unas hierbas que hacían que mi té supiera tan fresco.$1#$b#Esperaba volver a encontrarlas aquí.$2",
	"Caroline.Traveling_Cart.4": "Ella tenía este hermoso juego de té aquí una vez.#$b#No lo compré en aquel momento y todavía me arrepiento.$2#$b#Quizá tenga suerte hoy.$11",
	"Caroline.Traveling_Cart.5": "¿No se parece su pelo un poco al mío?$11#$b#¡Quizá seamos primas lejanas o algo así!$8",
	"Caroline.Museum_Reading.Spouse.1": "Este libro dice que cocinar es cuestión de amor y cuidado.#$b#¿Debería probar esa teoría contigo esta noche, amorcito?$1#$b#Apuesto a que no te importaría ser mi probador.$8",
	"Caroline.Museum_Reading.Spouse.2": "Encontré un viejo libro sobre observación de estrellas.#$e#¿Recuerdas cuando salíamos a escondidas a contar las estrellas?$8#$b#Tal vez deberíamos revivir esas noches... pero esta vez como una pareja casada.$6",
	"Caroline.Museum_Reading.Spouse.3": "Siempre tienes esa mirada cuando me miras fijamente.$2#$e#¿Debería dejar de leer y centrarme en ti?$3#$e#Sabes que no me importa.$6",
	"Caroline.Museum_Reading.Spouse.4": "Esta guía de jardinería afirma que hablar con las plantas las ayuda a crecer mejor.#$b#¿Crees que crecerían más rápido si les dijera cuánto te amo?$8",
	"Caroline.Museum_Reading.Spouse.5": "Me he sorprendido a mí misma sonriendo mientras leía de nuevo tu libro.#$b#La forma en que me describiste...$4#$b#¡Me has hecho parecer la chica perfecta!$8#$b#¿Estoy a la altura del papel, amorcito?$6",
    "Caroline.Robin.1": "Oops, me pillaste conspirando con Robin sobre nuestros... *proyectos privados de renovación*#$b#Estamos trabajando en una sorpresa que alegrará el lugar...$6#$b#-¡Literalmente!$8",
    "Caroline.Robin.2": "¿Recuerdas cómo construíamos fuertes de mantas que 'accidentalmente' se derrumbaban?#$b#Robin me está enseñando integridad estructural...$1#$b#Aunque, ¿qué tiene eso de divertido?$8",
    "Caroline.Robin.3": "Le pedí a Robin que me hiciera un especiero para mis nuevas mezclas de té.#$b#Aunque podría necesitar que...$11#$b#*Pruebes la estabilidad* de las estanterías más tarde.$6",
	"Caroline.Robin.4": "Le pregunté a Robin si podía ampliar mi jardín.$1#$e#Me sugirió algo extravagante, pero le dije que lo sencillo era más mi estilo.#$b#Estás de acuerdo, ¿no?$2",
	"Caroline.Robin.5": "Robin dice que nuestra casa necesita paredes más gruesas.#$e#¿Debería preocuparme por lo que ha oído?$8#$b#O...#$b#*halagada*?$6",
    "Caroline.Playground.1": "Solíamos pelearnos por quién se columpiaba más alto...#$b#Ahora sólo me pregunto cómo miras tan ${tranquilo^tranquila}$.$11",
	"Caroline.Playground.2": "Este tobogán es más empinado que el anterior.#$b#Pero oye, ¿recuerdas cuando me retabas a ir hacia atrás?$8",
	"Caroline.Playground.3": "Cuesta creer que solíamos gobernar el patio de recreo como si fuera nuestro reino.#$b#Ahora míranos a ${nosotros^nosotras}$, adultos que pretendemos ser responsables.$8#$b#¿Alguna vez echas de menos construir castillos conmigo en el arenero?$6",
	"Caroline.Playground.4": "¿Recuerdas cuando corríamos hasta la cima del trepador?#$b#Siempre me dejabas ganar...#$b#O eso creía.$2#$b#Resulta que sólo estabas siendo amable.$3#$b#Eso no va a cambiar pronto, ¿verdad?$5",
	"Caroline.Playground.5": "Solíamos sentarnos en bancos como éste, inventando historias sobre la gente que pasaba.#$b#Ahora, somos ${nosotros^nosotras}$ los que tenemos historias que contar.$1",
	"Caroline.Helping.1": "Evelyn dice que George necesita ahora tres almohadas para estar cómodo.#$b#Hace que me pregunte... ¿acolchonarás mis almohadas cuando tenga esa edad?$6",
	"Caroline.Helping.2": "Hoy plantaremos plantas perennes.#$b#Me dije que estas flores durarían más que cualquier mala decisión... como mi primera boda.$8",
	"Caroline.Helping.3": "Evelyn parece tener una conexión especial con las plantas.#$b#Nunca había visto a alguien tan concentrada mientras las regaba.$11",
	"Caroline.Helping.4": "Finalmente aprendí la receta del té de la artritis de Evelyn.#$b#Supongo que lo necesitaré cuando seamos ${viejos^viejas}$ y crujamos.$11#$b#No te preocupes, haré suficiente para ti también.$6",
	"Caroline.Helping.5": "Evelyn se burló de mí diciendo que aún somos jóvenes y estamos ${enamorados^enamoradas}$.#$b#Así que mantente fuerte, ¿vale, amorcito?$5#$b#Seguiré queriendo que me acerques cuando sea mayor.$6",
	"Caroline.Bridge.1": "Abigail aún me pide que le trence el pelo antes de sus aventuras.#$b#Bueno, algunas cosas nunca cambian, aunque ella pretenda que sí.$11",
	"Caroline.Bridge.2": "Le dije a Abigail que las espadas no resolverán todos sus problemas...#$b#Bueno, al menos heredó mis agudos instintos.$8",
	"Caroline.Bridge.3": "Abby actúa como si no habláramos.$11#$b#Pero sigo remendándole la ropa y poniéndole parches después de cada 'aventura'.$8#$b#Ser su madre no se detiene sólo porque me casé contigo, ya sabes.$5",
	"Caroline.Bridge.4": "Abby sigue poniendo los ojos en blanco cuando le doy consejos.$2#$b#Aunque, sé que está escuchando.",
	"Caroline.Bridge.5": "Abby siempre será mi niña.#$b#Saber que tiene a alguien como yo en quien confiar hace que sea más fácil dejarla ir.",
    "Caroline.Mountains.1": "Creí que Abby había venido a deprimirse...#$b#Ahora entiendo por qué. El viento aquí es tan refrescante.$1#$e#Yo... debería haber traído una bufanda.$2#$b#O... ¿podrías calentarme tú mismo, ~amorcito~?$6^O... ¿podrías calentarme tú misma, ~amorcito~?$6",
	"Caroline.Mountains.2": "Es curioso, yo solía pensar que el silencio era incómodo...#$b#Pero aquí contigo, me siento bien.",
    "Caroline.Mountains.3": "Nunca entendí el amor de Abby por las Amatistas...#$b#Entonces vi un cuarzo...$4#$b#Brilla como tus ojos al atardecer.$5#$b#Oh, oye... No dejes que eso se te suba a la cabeza.$2",
	"Caroline.Mountains.4": "Las montañas hacen que todo lo demás parezca tan pequeño...#$b#Me alegro de que estés aquí conmigo para verlo.$1",
    "Caroline.Mountains.5": "Creo que por fin entiendo por qué a Abigail le encanta estar aquí...#$b#Es su forma de escapar y encontrarse a sí misma.$11#$b#Supongo que se parece a mí más de lo que pensaba.$11",

	// FESTIVALS
	//// Pre-Marriage
	"Caroline.Egg.0": "¡Vaya, esto me transporta al pasado!#$b#¿Recuerdas cuando recogíamos huevos en el patio?$8#$b#Apuesto a que aún tropezarías con tus propios pies si te emocionaras demasiado.$6",
	"Caroline.Egg.1": "El festival ha crecido un poco desde que éramos ${niños^niñas}$, ¿verdad?#$b#Echo de menos lo simple que solía ser, sólo ${nosotros^nosotras}$ dos corriendo por ahí.$5",
	"Caroline.Egg.2": "Ya te oigo gritar: '¡He encontrado la mayor cantidad de huevos!'$6#$b#Algunas cosas nunca cambian... ¿o me equivoco esta vez?$6",	  
	"Caroline.Egg.2.0": "El festival es un poco diferente cada año.#$b#Aun así, ver todos estos huevos me recuerda los juegos tontos a los que solíamos jugar.$11",
	"Caroline.Egg.2.1": "¿Recuerdas cuando intentabas esconder huevos en los lugares más ridículos?$8#$b#Me sorprende que no hayamos perdido a la mitad para siempre.",
	"Caroline.Egg.2.2": "Solías tomarte muy en serio lo de encontrar los 'mejores' huevos.#$b#Siempre te dejaba ganar, por supuesto... o eso me decía a mí misma.$8",
	"Caroline.Egg.2.3": "Creo que vi unos huevos de oro en la mesa.#$b#Es como si supieran que ibas a aparecer.$8",
	"Caroline.Egg.2.4": "Hay algo en estos festivales que me hace sentir joven de nuevo.#$b#¡Aunque dudo que pudiera seguirte el ritmo ahora!$8",
	"Caroline.Dance.0": "La Danza Floral no ha cambiado mucho a lo largo de los años, ¿verdad?#$b#Me recuerda la vez que intentamos enseñarnos a bailar.$1",
	"Caroline.Dance.1": "Siempre pensé que estos bailes eran tan elegantes.#$b#Por supuesto, también pensé que te tropezarías con los pies, y entonces me diste la razón.$8",
	"Caroline.Dance.2": "Este festival siempre ha sido un poco incómodo, ¿no crees?#$b#¡Pero al menos no tenemos que quedarnos en una esquina como cuando éramos ${niños^niñas}$!$6",
	"Caroline.Dance.2.0": "¿Alguna vez has sentido que la Danza Floral es una excusa para presumir?$2#$b#No es que me queje, es agradable ver que todo el mundo se divierte.$8",
	"Caroline.Dance.2.1": "Es un poco extraño tener esta sensación después de todos estos años.$11#$b#Supongo que algunas tradiciones nunca pierden su encanto.$1",
	"Caroline.Dance.2.2": "Te vi intentando bailar antes.$6#$b#Diría que has mejorado desde que éramos ${niños^niñas}$, pero probablemente estaría mintiendo.$8",
	"Caroline.Dance.2.3": "Estas coronas de flores siempre me hacen sentir tan tonta.#$b#¿Crees que las llevábamos mejor cuando éramos ${niños^niñas}$?$1#$b#No estoy tan segura.$6",
	"Caroline.Dance.2.4": "A veces me pregunto si deberíamos haber bailado entonces en lugar de limitarnos a mirar.$11#$b#Pero conociéndonos, probablemente la habríamos liado parda.$8",
	"Caroline.Luau.0": "El Luau siempre me recuerda lo bonito que puede ser Pueblo Pelícano.#$b#Es fácil olvidarlo cuando estás ocupada corriendo de un lado para otro cada día.",
	"Caroline.Luau.1": "Antes vi a alguien tirar un melón en perfecto estado a la sopa.$2#$b#Una parte de mí quiere pescarlo, pero quizá coja un plato más tarde.$8",
	"Caroline.Luau.2": "No se lo digas a nadie.#$b#...Pero siempre me he preguntado qué pasaría si alguien añadiera chiles picantes a la sopa.$6#$b#¿Crees que Lewis sobreviviría?$8",
	"Caroline.Luau.2.0": "Antes vi a Emily bailando en la orilla.$5#$b#Me hizo darme cuenta de que hacía años que no bailaba.#$b#Quizá la próxima vez.$1",
	"Caroline.Luau.2.1": "¡Vaya, vaya, esa sopa huele deliciosa! ¿No la hueles?$1#$b#¿Qué pusiste ahí?$2#$b#No te preocupes, ¡seguro que saldrá deliciosa!$8",
	"Caroline.Luau.2.2": "Este año pensé en añadir mis hojas de té verde a la sopa.#$b#Entonces recordé... que no todo el mundo tiene mis gustos.",
	"Caroline.Luau.2.3": "El océano es refrescante, ¿verdad?#$b#A veces me pregunto por qué no voy a la playa más a menudo.$11",
	"Caroline.Luau.2.4": "Antes pillé al alcalde Lewis mirando nervioso la sopa.#$b#No pusiste nada sospechoso ahí, ¿verdad?$2",	  
	"Caroline.Jellies.0": "Es una noche tranquila.#$b#La forma en que todo el mundo se reúne aquí lo hace especial, incluso antes de que lleguen las medusas.$1",
	"Caroline.Jellies.1": "Me pregunto si las medusas se dan cuenta de cuánta gente viene a verlas.$11#$b#¡Quizá piensen que nosotros somos los raros!$8",
	"Caroline.Jellies.2": "Cuando era más joven, pensaba que las medusas eran seres mágicos.#$b#Incluso ahora, me lo sigo creyendo.$1",
	"Caroline.Jellies.2.0": "Sabes, solía pensar que este festival era sólo una bonita tradición.$11#$b#...Pero últimamente, me encuentro deseándolo más de lo que debería.",
	"Caroline.Jellies.2.1": "Hay algo en este festival que transmite tanta paz.#$b#Me quedaría aquí toda la noche si pudiera.$1",
	"Caroline.Jellies.2.2": "Pierre no entiende por qué disfruto de este festival.$2#$b#No entiende cuánto importan momentos como éste.$3",
	"Caroline.Jellies.2.3": "La espera de las medusas se hace más larga cada año.$2#$b#Tal vez sea porque sigo esperando que pase otra cosa antes.$6",
	"Caroline.Jellies.2.4": "Pierre dice que las medusas son sólo una atracción turística, pero creo que se equivoca.$2#$b#Algunas cosas son bellas simplemente porque lo son.$5#$b#¿No estás de acuerdo?$8",
	"Caroline.Fair.0": "¿Te lo estás pasando bien?#$b#¿Cuántas fichas has ganado hasta ahora?$6#$b#Suficiente para un premio, ¿espero?$8",
	"Caroline.Fair.1": "La energía aquí es contagiosa.#$b#Hasta yo tengo ganas de probar uno de estos juegos...#$b#¿Crees que sería bueno?$1",
	"Caroline.Fair.2": "Todo el pueblo está disfrutando... Es bonito, ¿verdad?#$b#Días como estos me hacen olvidar lo rápido que pasan las estaciones.$11",
	"Caroline.Fair.2.0": "Vi a alguien perder todas sus fichas estrella de una sola vez...$11#$b#Trágico, realmente. No es que alguna vez sería tan imprudente.$6",
	"Caroline.Fair.2.1": "Déjame adivinar... ¿tienes algo increíble en esa exposición agrícola?#$b#No seas demasiado ${engreído^engreída}$ cuando ganes.$6",
	"Caroline.Fair.2.2": "Es divertido ver cómo todo el mundo se vuelve tan competitivo por unos simples juegos.$8#$b#No te preocupes, no te juzgaré si tú también te pasas.$6",
	"Caroline.Fair.2.3": "Hay un truco para ganar estos partidos, estoy segura de ello.$2#$b#Si lo averiguo antes, te contaré el secreto.$1#$b#...Por un precio.$6",
	"Caroline.Fair.2.4": "Este festival es muy acogedor. Creo que por eso me gusta tanto. Noches como ésta hacen que la vida parezca un poco más ligera.",
	"Caroline.Halloween.0": "¿Te gusta mi disfraz?#$b#No estaba segura de que fuera apropiado, pero Pierre insistió.$2#$b#Es curioso, no se siente como yo en absoluto.$3",
	"Caroline.Halloween.1": "Este festival nos trae recuerdos de tiempos más sencillos.#$b#¿No echas de menos esas noches sin preocupaciones, sólo riendo y correteando?$8",
	"Caroline.Halloween.2": "El laberinto no da tanto miedo cuando has pasado por cosas peores, ¿eh?#$b#Aun así, me sentiría más segura con alguien a mi lado.$6",
	"Caroline.Halloween.2.0": "Te pillé mirando antes.$6#$b#¿Te ha sorprendido mi disfraz o sólo te sorprende que me lo ponga?$8",
	"Caroline.Halloween.2.1": "La Víspera de los Espíritus siempre se siente un poco... pesada, ¿no?$11#$b#Tal vez sea sólo yo.$2#$b#O tal vez necesito mejor compañía.$2",
	"Caroline.Halloween.2.2": "No puedo creer que Pierre me dejara usar esto esta noche.$2#$b#Aunque me pregunto si se habrá dado cuenta.$3",
	"Caroline.Halloween.2.3": "Escuché a alguien decir que este traje me queda bien.#$b#¿Estás de acuerdo o sólo estaba siendo educado?$11",
	"Caroline.Halloween.2.4": "¿Crees que alguien se daría cuenta si desapareciéramos durante un tiempo?#$b#Sólo para hablar, por supuesto.$6",
	"Caroline.Ice.0": "Pierre sigue refunfuñando por el frío, pero le pillé tomando a escondidas una segunda taza de chocolate.#$b#Está disfrutando en secreto.$8",
	"Caroline.Ice.1": "Abigail parece fascinada por las esculturas de hielo.#$b#Creo que secretamente espera algo más dramático, como un dragón de hielo.$1",
	"Caroline.Ice.2": "¡Tienes nieve en la nariz!#$b#No te muevas-$2#$b#Ya está, todo se ha ido.$1#$b#¡De nada!$6",
	"Caroline.Ice.2.0": "Cada año, estas esculturas parecen más elaboradas.#$b#Si alguna vez hacen una de ti, espero que consigan que tu sonrisa sea perfecta.$1",
	"Caroline.Ice.2.1": "Escuché a alguien decir que este festival es su día favorito del invierno.#$b#Sinceramente, entiendo por qué.$1",
	"Caroline.Ice.2.2": "Hoy el lago parece de cristal.#$b#Es tentador deslizarse por él, pero no me arriesgaré a tener un trasero magullado.$8",
	"Caroline.Ice.2.3": "Antes vi a Abigail admirando las esculturas.#$b#Tiene buen ojo. ¿Quizás lo heredó de mí?$8",
	"Caroline.Ice.2.4": "Si alguna vez añaden una pelea de bolas de nieve a este festival.#$b#Cuento contigo para que estés en mi equipo.$8",
	"Caroline.Christmas.0": "No me digas que envolviste tu regalo en el último minuto.$2#$b#Déjame adivinar: o es creativo o es un desastre total.$8#$b#¿Cuál es?$8",
	"Caroline.Christmas.1": "¡Feliz Navidad!$1#$b#¿De verdad viniste hasta acá sin bufanda?$2#$b#Nunca aprendiste a vestirte para el invierno.$6",
	"Caroline.Christmas.2": "Apuesto a que no esperabas verme tan bien.#$b#Adelante, dilo-$6#$b#No se lo diré a Pierre.$5",
	"Caroline.Christmas.2.0": "No te habrás olvidado de traer un regalo, ¿verdad?$2#$b#Eso sería... incómodo.$11",
	"Caroline.Christmas.2.1": "Cuidado-$2#$b#Pierre me está mirando mientras hablo contigo.$3#$b#No hagas que parezca que estamos tramando algo, o sentirá curiosidad.$2",
	"Caroline.Christmas.2.2": "¿Recuerdas cuánta nieve comíamos de ${niños^niñas}$?#$b#Estoy bastante segura de que la mitad era tierra.$8",
	"Caroline.Christmas.2.3": "¡Yo ayudé a decorar el árbol este año!$1#$b#No te preocupes, no dejé que Pierre eligiera los adornos.$8",
	"Caroline.Christmas.2.4": "Si hoy te sientes ${tranquilo y perfecto^tranquila y perfecta}$, es porque formas parte de ello.#$b#Espero que lo sepas.$1",

	//// Post-Marriage
	"Caroline.Egg.spouse.0": "¡Amorcito, mira todos estos huevos!#$b#Me recuerda a cuando éramos ${niños^niñas}$niños.$1#$b#¡Solías ser tan ${competitivo^competitiva}$ durante la búsqueda de huevos!$8#$b#¿Sigues siendo tan ${rápido^rápida}$ como antes?$6",
	"Caroline.Egg.spouse.1": "El olor a huevos recién horneados me hace la boca agua.$6#$b#¿Me pregunto si puedo tentarte para que me dejes colarme uno antes?$8",
	"Caroline.Egg.spouse.2": "Es divertido ver a todos estos niños entusiasmados por buscar huevos.#$b#Creo que deberíamos unirnos a ellos, ¿y tú?$5#$b#¿O sería demasiado embarazoso para ti?$8",	  
	"Caroline.Egg.2.spouse.0": "¿Otra Fiesta de los Huevos?#$b#El tiempo vuela cuando estás con alguien que mantiene la vida interesante.$4$#$b#Hagamos nuevos recuerdos ${juntos^juntas}$, cariño.$6",
	"Caroline.Egg.2.spouse.1": "La mesa ya está llena de platos de huevos.#$b#Me pregunto si se darían cuenta si compartiéramos uno a escondidas.$6",
	"Caroline.Egg.2.spouse.2": "La decoración es sencilla, pero tiene cierto encanto.#$b#Es refrescante ver algo tan feliz, ¿verdad, amorcito?$1",
	"Caroline.Egg.2.spouse.3": "He visto que algunos de los huevos tienen pequeños dibujos.#$b#Me pregunto si deberíamos pintar algunos ${juntos^juntas}$ el año que viene.$5",
	"Caroline.Egg.2.spouse.4": "Oí que algunos de los huevos venían de la granja de Marnie.#$b#¿No te dan ganas de criar más pollos en nuestra granja?$8",
	"Caroline.Egg.2.spouse.5": "¿ Crees que la búsqueda de los huevos tendrá alguna vez una ronda 'sólo para adultos'?$8#$b#Me encantaría ver a todo el mundo revolviéndose, sería divertidísimo.$8",
	"Caroline.Egg.2.spouse.6": "Estos festivales son bonitos, pero nada se compara con estar aquí contigo, amorcito.#$b#Eres mi parte favorita de todo esto, sabes.$4",
	"Caroline.Egg.2.spouse.7": "¿Piensas volver a ganar la búsqueda de los huevos este año, amorcito?$6#$b#Si no lo haces, puede que tenga que burlarme de ti más tarde.$6",
	"Caroline.Egg.2.spouse.8": "Ver todos estos huevos me recuerda a cuando éramos ${niños^niñas}$.#$b#Pero por aquel entonces, nunca imaginé que buscaría la felicidad y en su lugar te encontraría a ti.$5",
	"Caroline.Egg.2.spouse.9": "Parece que hoy tienes ganas de divertirte.$6#$b#¡Intenta que no te distraiga demasiado de la competición!$8",	  
	"Caroline.Dance.spouse.0": "Bailar contigo bajo el cielo abierto parece sacado de un sueño.#$b#Prométeme que haremos de esto una tradición, ¿vale?$5",
	"Caroline.Dance.spouse.1": "Siempre me ha gustado la Danza Floral.#$b#...Pero estar aquí contigo lo hace mucho más dulce.$5#$b#No me pises los pies, ¿vale, amorcito?$6",
	"Caroline.Dance.spouse.2": "¿Recuerdas cómo nos reíamos de las parejas que bailaban cuando éramos ${niños^niñas}$?$8#$b#Nunca imaginé que un día estaría aquí contigo... y amando cada momento.$5",
	"Caroline.Dance.2.spouse.0": "Es curioso, antes pensaba que estos bailes eran un poco tontos.#$b#Ahora, no puedo imaginarme perderme un solo contigo, amorcito.$5",
	"Caroline.Dance.2.spouse.1": "Amorcito, ¿recuerdas nuestra primera danza floral?#$b#Entonces eras demasiado ${tímido^tímida}$ para pedírmelo, pero mírate ahora.$1#$b#Sigues siendo ${el chico más guapo^la chica más guapa}$ de acá.$6",
	"Caroline.Dance.2.spouse.2": "¿Crees que la gente se da cuenta de lo bien que lo estamos pasando?$6#$b#Haces que este festival sea tan especial, amorcito.$5",
	"Caroline.Dance.2.spouse.3": "Todas estas parejas a nuestro alrededor...#$b#Me enorgullece saber que bailaré con la mejor pareja de acá.$5",
	"Caroline.Dance.2.spouse.4": "Estos pasos son tan sencillos, pero de alguna manera parecen nuevos cuando estoy contigo.$4#$b#Es curioso cómo funciona, ¿verdad?$8",
	"Caroline.Dance.2.spouse.5": "Veo a algunas personas que nos miran.$11#$b#No puedo culparlos, causaste una gran impresión, amorcito.$5",
	"Caroline.Dance.2.spouse.6": "Las flores, la música, el aire... ¡todo es precioso!#$b#Pero tú eres lo único en lo que puedo concentrarme ahora mismo.$4",
	"Caroline.Dance.2.spouse.7": "No tienes que ser ${el mejor bailarín^la mejor bailarina}$ para hacerme feliz.#$b#No me sueltes la mano, ¿vale?$3",
	"Caroline.Dance.2.spouse.8": "Son momentos como estos los que me recuerdan lo afortunada que soy.#$b#Realmente eres mi mayor alegría.$4",
	"Caroline.Dance.2.spouse.9": "Creo que he estado sonriendo todo el día, y es enteramente culpa tuya.$2#$b#¿Cómo consigues siempre hacerme sentir así, amorcito?$5",	  
	"Caroline.Luau.spouse.0": "Nunca pensé que volveríamos a estar ${juntos^juntas}$ en un festival como éste.#$b#Es curioso cómo la vida da vueltas, ¿verdad?$1",
	"Caroline.Luau.spouse.1": "Pierre solía odiar venir a estos.$2#$b#Me pasaría la mitad del tiempo disculpándome por su ceño fruncido.$3#$b#¿Pero ahora? Creo que simplemente disfrutaré de la vista... contigo.$5",
	"Caroline.Luau.spouse.2": "Te pillé mirando, amorcito.$6#$b#¿Qué, me veo tan bien con este vestido?$5",	  
	"Caroline.Luau.2.spouse.0": "Es curioso, no importa a cuántos de estos asista.$2#$b#La sopa siempre huele igual.$11#$b#¿Y tú?$6#$b#Haces que parezca nuevo cada vez.$5",
	"Caroline.Luau.2.spouse.1": "Que Lewis no nos pille probando antes de que la olla esté lista.$6#$b#No es que me importe romper una regla contigo.$8",
	"Caroline.Luau.2.spouse.2": "El Luau siempre saca lo mejor y lo peor de la gente.#$b#Menos mal que ya tengo la mejor parte aquí conmigo.$5",
	"Caroline.Luau.2.spouse.3": "Estaba pensando... quizás el año que viene.#$b#Podríamos traer algo especial para la sopa.$1#$b#Un ingrediente secreto que sólo ${nosotros^nosotras}$ sepamos.$6",
	"Caroline.Luau.2.spouse.4": "Amorcito, deja de preocuparte por la sopa.$2#$b#¡Todo va a salir bien! Disfruta del día conmigo, ¿vale?$5",
	"Caroline.Luau.2.spouse.5": "Esta brisa se siente tan refrescante.#$b#Casi se puede olvidar lo caótica que se vuelve la granja durante el verano, ¿verdad?$1",
	"Caroline.Luau.2.spouse.6": "Tienes una mancha de algo en la cara.$2#$b#Quédate ${quieto^quieta}$.$5#$b#Ya está, todo mejor.$5#$b#Ahora, ¿dónde está mi agradecimiento?$6",
	"Caroline.Luau.2.spouse.7": "¡Hagamos un trato!$6#$b#Si Lewis dice que la sopa es sosa.#$b#Nos escapamos a la playa con nuestro propio picnic.$8",
	"Caroline.Luau.2.spouse.8": "Cada Luau me recuerda lo mucho que me gusta el verano.#$b#Aunque, es mejor ahora que estás en mis veranos también.$5",
	"Caroline.Luau.2.spouse.9": "Amorcito, ¿recuerdas cómo odiaba que me cayera arena en los zapatos cuando éramos más jóvenes?#$b#Tienes suerte de que haya madurado.$6",
	"Caroline.Jellies.spouse.0": "¿No es curioso que todo el pueblo se reúna para ver medusas brillantes?#$b#Sin embargo, aquí estoy, y no me lo perdería por nada del mundo.$8",
	"Caroline.Jellies.spouse.1": "Abby me retaba a tocar una medusa si una se acercaba.#$b#Le dije que lo haría si ella iba primero.$6#$b#¡No le gustó esa respuesta!$8",
	"Caroline.Jellies.spouse.2": "El océano siempre me recuerda lo pequeños que somos.$11#$b#Pero estando a tu lado, siento que puedo enfrentarme al mundo entero.$5",
	"Caroline.Jellies.2.spouse.0": "Sabes, solía traer a Abby a este festival cuando era pequeña.#$b#Por aquel entonces, pensaba que las medusas eran extraterrestres que venían a visitarnos.$8",
	"Caroline.Jellies.2.spouse.1": "Acércate un poco más, amorcito.$4#$b#Esta noche hace frío y me vendría bien el calor.$5",
	"Caroline.Jellies.2.spouse.2": "Creo que ya he visto una medusa por ahí.$11#$b#O puede que mis ojos me estén jugando una mala pasada.$2#$b#En cualquier caso, es emocionante.$1",
	"Caroline.Jellies.2.spouse.3": "El océano se siente tan tranquilo esta noche.#$b#Si cierro los ojos, casi puedo imaginarnos a la deriva.$8",
	"Caroline.Jellies.2.spouse.4": "Abigail mira el agua como si contuviera todas las respuestas de la vida.#$b#Lo saca de mí, ¿sabes?",
	"Caroline.Jellies.2.spouse.5": "¿Sientes eso?#$b#La marea está cambiando... silenciosa pero poderosa.$1#$b#Me recuerda cómo has cambiado mi vida.$5",
	"Caroline.Jellies.2.spouse.6": "Alguien me dijo que las medusas brillan porque celebran su viaje.#$b#Es un bonito pensamiento, ¿verdad?#$b#Encontrar la alegría en simplemente... estar aquí.$5",
	"Caroline.Jellies.2.spouse.7": "Cuando éramos ${niños^niñas}$, solíamos perseguir luciérnagas.#$b#Ahora estamos aquí, viendo medusas.$1#$b#Al menos esta vez, no tropezarás con tus propios pies, ¿verdad?$6",
	"Caroline.Jellies.2.spouse.8": "Algunas personas vienen aquí con la esperanza de que las medusas les traigan suerte.#$b#¿Yo? Yo ya no necesito suerte.$6#$b#Ya tengo todo lo que quiero.$5",
	"Caroline.Jellies.2.spouse.9": "Antes de que lleguen las medusas, hay un momento perfecto de quietud.#$b#Estar aquí contigo lo hace aún mejor.$5",
	"Caroline.Fair.spouse.0": "Ganes o pierdas, sigo pensando que tu exposición es la mejor.#$b#Pero si ganas, puede que tenga que robarte parte del mérito.$6",
	"Caroline.Fair.spouse.1": "Las ferias siempre me hacen sentir como una niña otra vez.#$b#Sólo por hoy, olvidemos nuestras responsabilidades y divirtámonos.$8#$b#Incluso puedes comprarme un capricho... si te sientes ${generoso^generosa}$.$6",
	"Caroline.Fair.spouse.2": "Nuestra primera feria como matrimonio...#$b#Se siente diferente, ¿no?$1#$b#Todo es un poco más brillante, un poco más cálido.$5#$b#O quizá sólo sea yo.$4",
	"Caroline.Fair.2.spouse.0": "Deberíamos jugar juntos y ver quién es el mejor usando el tirachinas.$6^Deberíamos jugar juntas y ver quién es el mejor usando el tirachinas.$6#$b#¡${El ganador^La ganadora}$ elige la cena!$8",
	"Caroline.Fair.2.spouse.1": "¿Un festival en el que puedes ganar premios y atiborrarte de comida?#$b#Creo que he descubierto por qué te gusta tanto este evento.$1",
	"Caroline.Fair.2.spouse.2": "Vamos, amorcito, presume un poco.#$b#No todos los días se reúne todo el pueblo para admirar tu trabajo.$5#$b#Bueno, más que nada admirar... George probablemente está juzgando.$8",
	"Caroline.Fair.2.spouse.3": "Sé que tu objetivo son las fichas estrella, pero a mí me interesa más ganar un premio de los juegos.#$b#¿Crees que puedes ganarme algo bonito?$6",
	"Caroline.Fair.2.spouse.4": "¡Dime la verdad!$2#$b#¿Has venido por la feria o sólo por los premios?$2#$b#No voy a juzgarte.$8#$b#...Mucho.$6",
	"Caroline.Fair.2.spouse.5": "Estos juegos tienen cierto encanto.#$b#Me pregunto si alguien ha descubierto alguna vez la estrategia perfecta.$1#$b#...Además de la pura suerte, claro.$8",
	"Caroline.Fair.2.spouse.6": "Oh no, estás mirando esa prueba de fuerza otra vez. Recuerda, cariño, que tu valor no se mide por la fuerza con la que puedas blandir un martillo. Pero si pierdes, puede que me ría.",
	"Caroline.Fair.2.spouse.7": "Hay algo divertido en ver cómo todo el pueblo se suelta por un día. Incluso los tipos serios sonríen. Debe ser la magia de la feria... o la comida gratis.",
	"Caroline.Fair.2.spouse.8": "El alcalde Lewis siempre sonríe cuando alguien cuestiona los partidos.$2#$b#Nunca dará una respuesta directa, ¿verdad?$3",
	"Caroline.Fair.2.spouse.9": "Apuesto a que aún podría ganarte en el juego de la pesca. Pero no te preocupes, no te obligaré a demostrarlo. No hoy, al menos.",
	"Caroline.Halloween.spouse.0": "Pensé en disfrazarme de diosa esta noche.#$b#¿Qué te parece?$1#$b#¿Es demasiado?$6#$b#O tal vez sólo lo suficiente para tu esposa, ¿eh?$6",
	"Caroline.Halloween.spouse.1": "Tienes esa mirada en tu cara otra vez.$2#$b#Vamos, escúpelo.$3#$b#¿Es por el disfraz o por el hecho de llevarlo?$8",
	"Caroline.Halloween.spouse.2": "El laberinto puede ser espeluznante, pero creo que tú eres lo más espeluznante aquí.#$b#¡Robarme el corazón así debería ser un delito!$5",
	"Caroline.Halloween.2.spouse.0": "Amorcito, te he pillado mirando más de una vez esta noche.$5#$b#¿Tan deslumbrante estoy o es que te encanta verme así?$4",
	"Caroline.Halloween.2.spouse.1": "Espero que no esperes que me arrastre por el laberinto con este atuendo.#$b#Prefiero pasar la tarde contigo.$5",
	"Caroline.Halloween.2.spouse.2": "Han pasado años, y de alguna manera todavía consigues hacerme sentir como la única persona en la habitación.#$b#¿Cómo lo haces?$4",
	"Caroline.Halloween.2.spouse.3": "Las luces, la música, los disfraces...#$b#...Pero honestamente, lo único que me importa es estar aquí contigo.$5",
	"Caroline.Halloween.2.spouse.4": "Algunos dijeron que esta noche parecía una diosa.#$b#Qué curioso, creía que ya estaba casada con el dios del encanto.$8",
	"Caroline.Halloween.2.spouse.5": "Será mejor que te quedes cerca esta noche.$2#$b#Este disfraz podría llamar la atención más de lo que esperaba.$6",
	"Caroline.Halloween.2.spouse.6": "El laberinto no puede ser tan malo, ¿verdad?$3#$b#Tal vez el laberinto no sea tan malo si lo enfrentamos ${juntos^juntas}$.$1",	
	"Caroline.Halloween.2.spouse.7": "Si me perdiera en el laberinto, ¿vendrías a buscarme?#$b#¿O me esperarías en algún lugar... solo en la oscuridad?$6",
	"Caroline.Halloween.2.spouse.8": "Amorcito, la víspera de los Espíritus es bonita y todo...#$b#...¿Pero no sería más divertido que desapareciéramos un rato?$6#$b#Sólo tú y yo.$8",
	"Caroline.Halloween.2.spouse.9": "Podría llevar este disfraz todos los días si sigue recibiendo esa mirada tuya. ¿Quién iba a decir que disfrazarse podía ser tan gratificante?",
	"Caroline.Ice.spouse.0": "Solía ser muy competitiva en estos concursos.$1#$b#Ahora, creo que disfruto más viendo...#$b#...A menos que me estés desafiando, por supuesto.$8",
	"Caroline.Ice.spouse.1": "Hace un frío que pela, pero merece la pena ver cómo se divierten todos.#$b#¡Te animaré desde acá!$5",
	"Caroline.Ice.spouse.2": "¿Recuerdas cuando intentábamos pescar de ${niños^niñas}$?#$b#No creo que ninguno de ${los^las}$ dos pescara nada, pero nos reímos tanto que casi nos caemos.$8",
	"Caroline.Ice.2.spouse.0": "Será mejor que me guardes un sitio junto al fuego más tarde.#$b#Después de tanto frío, necesitaré descongelarme contigo.$9",
	"Caroline.Ice.2.spouse.1": "No estarás pensando en resbalarte y caerte, ¿verdad?#$b#Porque si lo haces, primero me río y luego ayudo.$8",
	"Caroline.Ice.2.spouse.2": "El aire está tan fresco hoy.$2#$b#Es el tipo de frío que te hace querer agarrar a alguien caliente...$9",
	"Caroline.Ice.2.spouse.3": "Estaba pensando en apuntarme este año.#$b#Pero verte ahí fuera es suficiente entretenimiento para mí.$5",
	"Caroline.Ice.2.spouse.4": "Intenta no parecer tan ${serio^seria}$ ahí fuera.#$b#¡Es un festival, no un campeonato!$2",
	"Caroline.Ice.2.spouse.5": "Si pescas el pez más grande, te haré la cena con él.#$b#Si no, te toca servir platos.$6#$b#¿Te parece justo?$8",
	"Caroline.Ice.2.spouse.6": "No te preocupes, amorcito, estoy pendiente del concurso.#$b#Me aseguraré de que nadie haga trampa...$2#$b#...Excepto quizá tú.$6",
	"Caroline.Ice.2.spouse.7": "Verte pescar hace que me pregunte si debería haber traído mi propia caña. O al menos una bebida caliente.",
	"Caroline.Ice.2.spouse.8": "¿Es malo que te apoye para que ganes? No se lo digas a los demás, o dirán que tengo favoritos.",
	"Caroline.Ice.2.spouse.9": "Después de este festival, nos vamos directos a casa. Necesito una manta, un fuego caliente y a ti a mi lado.",	  
	"Caroline.Christmas.spouse.0": "La nieve está preciosa, ¿verdad?#$b#Tranquilo pero lleno de vida, como la gente que está aquí hoy.$1",
	"Caroline.Christmas.spouse.1": "Vi a algunos niños riendo junto al árbol.#$b#Me hizo sonreír: hay algo en su alegría que resulta contagioso.$1",
	"Caroline.Christmas.spouse.2": "Abby estaba entusiasmada con su regalo.#$b#Es agradable verla tan alegre, me recuerda a cuando era pequeña.$5",
	"Caroline.Christmas.2.spouse.0": "Realmente espero que seas mi ${amigo^amiga}$ invisible, cariño.$1#$b#¡Estoy impaciente por ver qué sorpresa me das!$5",
	"Caroline.Christmas.2.spouse.1": "¿Te ha gustado tu regalo?#$b#No, de verdad, dime la verdad.$2#$b#Porque si no, puede que tenga que compensarte más tarde.$6",
	"Caroline.Christmas.2.spouse.2": "Tienes nieve en el pelo, no te muevas.#$b#Ya está, todo se ha ido.$5#$b#Aunque no me importaría tener una excusa para seguir mimándote un poco más.$6",
	"Caroline.Christmas.2.spouse.3": "No olvides tomarte un momento para respirar.#$b#Los días así deben disfrutarse, no apresurarse.$1",	  
	"Caroline.Christmas.2.spouse.4": "¡Espero que te mantengas caliente!#$b#No eres invencible, lo sabes.$2#$b#No hagas que me preocupe.$3",
	"Caroline.Christmas.2.spouse.5": "Estás temblando.#$b#Ven, acércate.$5#$b#¿Cómo?$8#$b#Sólo estoy siendo práctica. No le des demasiada importancia...$4#$b#...O hazlo. Tú eliges.$9",
	"Caroline.Christmas.2.spouse.6": "Te pillé mirando.$2#$b#No en al árbol-$2#$b#No a la fiesta-$3#$b#...Sólo a mí.#$b#Espero que no esperaras que apartara la vista antes.$6",
	"Caroline.Christmas.2.spouse.7": "Hoy no necesito regalos.#$b#Ver esa sonrisa tuya es más que suficiente para mí.",
	"Caroline.Christmas.2.spouse.8": "La nieve parece más blanda este año.#$b#O tal vez sólo estoy de buen humor.$1#$b#En cualquier caso, me alegro de que estemos aquí ${juntos^juntas}$.$4",
	"Caroline.Christmas.2.spouse.9": "La energía de Emily hoy es otra cosa. Está prácticamente zumbando, me pregunto por qué está tan excitada.",

	//EVENTS
	//2 Hearts
	"Caroline.MuseumBook.0": "Hoy he venido a la biblioteca para darle algo a Caroline. Tenía el presentimiento de que estaría aquí.",
	"Caroline.MuseumBook.1": "¡Oh! ¡${Querido^Querida}$!#$b#No esperaba que fueras a aparecer hoy.$1",
	"Caroline.MuseumBook.2": "¿Aunque, no es un poco sofocante aquí? Tal vez sea sólo yo...$11#$b#En fin, ¿qué te trae por acá? ¿Algo ha captado tu interés?#$b#¿O acaso Pierre mencionó que estaría aquí?$2",
	"Caroline.MuseumBook.Question.1": "#Debo confesar que vine a la biblioteca esperando encontrarme contigo.#No mucho, sólo pasé por aquí para leer algo ligero.",
	"Caroline.MuseumBook.Question.2": "#¡Espera! Caroline...#Vale Caroline, ¡nos vemos!",
	"Caroline.MuseumBook.Flirt": "Oh, ¿en serio? ¡Estás ${lleno^llena}$ de sorpresas!$3#$b#Pero para que lo sepas, burlarme es mi trabajo.$8#$b#Pero de verdad, me alegro de verte acá.$4#$b#Bueno... ${Querido^Querida}$...$9#$b#Aprecio el sentimiento. Es refrescante tener una presencia tan encantadora alrededor, especialmente cuando es la tuya.$10",
	"Caroline.MuseumBook.Flirt.2": "¿Qué pasa? ~¿${Querido^Querida}$?",
	"Caroline.MuseumBook.Flirt.3": "Hace poco terminé de escribir un libro y no puedo evitar pensar en ti a la hora de compartirlo.#¿Te interesaría leerlo?#Me encantaría saber lo que piensas. Serías la primera persona con la que querría compartirlo.",
	"Caroline.MuseumBook.Flirt.4": "Claro, ${querido^querida}$. Me aseguraré de leerlo.$1#$b#Me pregunto-$11",
	"Caroline.MuseumBook.Flirt.5": "Le diste a Caroline el libro que escribiste sobre el tiempo que pasaron ${juntos^juntas}$ en el instituto.#De acuerdo entonces, Caroline. ¡Hasta luego!",
	"Caroline.MuseumBook.Flirt.6": "¡Oye espe-!#$b#Acaba de irse...$2#$b#Sin embargo, me pregunto de qué se trata.$11#$b#Supongo que tendré que averiguarlo por mí misma.$1",
	"Caroline.MuseumBook.3": "Oh, ¿estás aquí sólo para una lectura ligera?$11#$b#Ya veo... Bueno, hay mucho para hojear aquí, ${querido^querida}$.$1#$b#Estas viejas estanterías son fascinantes, ¿no te parece?$1",
	"Caroline.MuseumBook.4": "¿Y a ti? ¿Qué te trae por acá?",
	"Caroline.MuseumBook.5": "¿Yo? Estaba disfrutando de este libro sobre el té.$5#$b#Me gusta venir aquí de vez en cuando. Es maravillosamente tranquilo y silencioso.$8#$b#Es el lugar perfecto para leer, ya sabes, como preparar una taza de té puede ser un pequeño escape del día.$1#$b#Encontrar pequeños momentos de paz, como saborear un buen libro o disfrutar de una taza caliente.#$b#¿No estás de acuerdo, ${querido^querida}$?",
	"Caroline.MuseumBook.6": "Simplemente leer sobre ello me hace sentir que puedo escapar un poco.$11#$b#Pero una buena taza de Earl Grey tiene algo especial. Es muy sencilla de preparar pero es realmente buena para el paladar.$1#$b#Sólo tienes que hervir agua, añadir una bolsita de té u hojas sueltas, dejar reposar unos minutos y añadir un chorrito de leche si lo deseas.$5#$b#Vaya, me he dejado llevar...$8#$b#Probablemente debería volver a este libro antes de que cierre el museo.$1#$b#Nos vemos, ${querido^querida}$.",
	"Caroline.MuseumBook.7": "Me hubiera gustado charlar un poco más con Caroline, pero me sentía demasiado ${tímido^tímida}$ para mantener la conversación.",
	"Caroline.MuseumBook.8": "Supongo que veré qué hay de interesante acá.",
	"Caroline.MuseumBook.9": "Han pasado unas horas y el museo está a punto de cerrar.",
	"Caroline.MuseumBook.10": "¡Oh! ¡Se está haciendo tarde!$2#$b#Debería irme, Pierre debe estar muy preocupado.",
	"Caroline.MuseumBook.11": "¿${Querido^Querida}$? ¿Todavía estás aquí?$2#$b#Bueno, debería irme ya, ¡hasta luego!$1",
	"Caroline.MuseumBook.12": "¡Oh, rayos! ¡Olvidé darle este libro!",
	"Caroline.MuseumBook.13": "Puede que lo deje aquí, en el lugar habitual donde siempre elige sus libros.",
	"Caroline.MuseumBook.14": "Dejaste el libro que escribiste sobre el tiempo que pasaron ${juntos^juntas}$ en el instituto. Con una nota adhesiva que dice '-Para Caroline'.#Esperemos que se dé cuenta pronto.",
	"Caroline.MuseumBeauty.1": "Me encontré con Caroline.",
	"Caroline.MuseumBeauty.2": "Quiero hablar con ella.#Pero mi timidez me frenaba.#Me encontré hojeando la misma sección que ella, con la esperanza de llamar su atención.",
	"Caroline.MuseumBeauty.3": "Estaba sentada junto a la ventana, el resplandor dorado le salpicaba las pestañas y le llegaba a los ojos a través de unos escasos rayos de luz, que parpadeaban y titilaban en un abrir y cerrar de ojos.",
	"Caroline.MuseumBeauty.4": "En ese momento, recordé el pasado, recordé aquella tarde en el rincón de la sala de estudio.",
	"Caroline.MuseumBeauty.5": "Me acordé de mí ${mismo^misma}$, cuando reuní el valor para confesarme en voz alta.",
	"Caroline.MuseumBeauty.6": "Por alguna razón, la forma en que te recuerdo con el uniforme del instituto poco a poco parece coincidir con tu aspecto actual.",
	"Caroline.MuseumBeauty.7": "Es difícil entender lo que pasó entre ${nosotros^nosotras}$, dejaste muchas sombras del pasado, pero también me abandonaste en algún momento.#¿Qué estuviste haciendo todos esos días que no estuve a tu lado?#¿Por qué elegiste casarte con otra persona?",
	"Caroline.MuseumBeauty.8": "Teníamos nuestra promesa, ¿no? Que un día, pondría un anillo en tu dedo.#Cómo me gustaría poder volver atrás en el tiempo.",
	"Caroline.MuseumBeauty.9": "Mi mejor amiga de la infancia, Caroline.",
	"Caroline.MuseumBeauty.10": "Vaya... ¡Al principio me daba vergüenza tomarlo porque la protagonista se llama igual que yo!$4#$b#No sabía qué esperar, ¡pero este libro es fantástico! Me alegro mucho de haberlo terminado.$1",
	"Caroline.MuseumBeauty.11": "~${Querido^Querida}$~... ¿Oh?#$b#¿Qué te pasa? ¿Por qué te limpias las lágrimas en secreto detrás de estas estanterías?$s#$b#¿Alguien te ha hecho daño?$3",
	"Caroline.MuseumBeauty.12": "No, no, te equivocas.#Se me llenaron los ojos de polvo cuando cogí este libro.#Me voy por ahora, adiós Caroline.",
	"Caroline.MuseumBeauty.13": "¡Oye! Espera un min-",

	//4 Hearts - Photo Album
	"Caroline.PictureBook.1": "*cantando* ¡Chisporrotea y estalla! ¡Chiles brillantes!#$b#¡Algo especial se está cocinando a la perfección!$8",
	"Caroline.PictureBook.2": "¡Oh, ${querido^querida}$! No esperaba verte acá.$1#$b#Ah, ¿por qué estás tan lejos?$2#$b#Vamos, no seas ${tímido^tímida}$. Prácticamente solíamos cocinar ${juntos^juntas}$, ¿recuerdas?$8",
	"Caroline.PictureBook.3": "¿Has estado ocupado últimamente? Ya casi no te veo por acá.^¿Has estado ocupada últimamente? Ya casi no te veo por acá.#$b#Deberías venir más a menudo. Cocinar sola a veces me hace sentir solitaria.$1",
	"Caroline.PictureBook.4":"Ah... Qué tiempos aquellos...$5#$b#Entonces hacías como que me ayudabas a cocinar, pero en realidad sólo querías probar lo que hacía.$6#$b#A veces, desearía poder volver atrás en el tiempo. Volver a ser joven y despreocupada, como éramos entonces.",
	"Caroline.PictureBook.Question": "#Sí... Quiero decir, esos tiempos fueron agradables.#Supongo que sí. Pero, las cosas cambian, ¿no?#No puedo evitar preguntarme, ¿para quién estás cocinando?",
	"Caroline.PictureBook.Response.1": "Recordar todos los momentos que hemos compartido siempre me hace sonreír.$4",
	"Caroline.PictureBook.Response.2": "Supongo que tienes razón. La vida avanza, lo queramos o no.$11#$b#Pero aún hay belleza en mirar atrás, ¿no crees?",
	"Caroline.PictureBook.Response.3": "¡Esto es para mí!$1#$b#¿Por qué me miras así? ¿Tú también quieres?$2#$b#Pero tal vez...$6#$b#Vale, vale, eres mi mejor ${amigo^amiga}$, así que quizá pueda dejar que le des un mordisco... ¡más tarde!$8",
	"Caroline.PictureBook.Fail": "Me pasé el tiempo cocinando con Caroline.#Fue agradable, pero después lo di por terminado.#A veces me pregunto qué habría pasado si hubiera hecho las cosas de otra manera.",
	"Caroline.PictureBook.5": "Oh, Dios mío, me quedé tan atrapada en nuestra conversación, que me olvidé por completo del libro de cocina.$8#$b#¿Puedes traérmelo, ${querido^querida}$? Está en mi habitación junto a la estantería.",
	"Caroline.PictureMemory.1": "Encontraste un álbum con fotos tuyas y de Caroline.#Está en la parte inferior de la estantería.#Hojeaste las páginas y lo miraste durante mucho tiempo.",
	"Caroline.PictureMemory.2": "${Querido^Querida}$, ¿por qué tardas tanto?", 
	"Caroline.PictureMemory.3": "¿No es esta una foto nuestra del instituto?$1#$b#¡Eras tan ${pequeño^pequeña}$ entonces!$8", 
	"Caroline.PictureMemory.4": "¿Qué te pasa? ¿Por qué no me hablas?#$b#La última vez en la biblioteca, también parecías triste y te fuiste como si tuvieras algo en la mente.$2#$b#¿Puedes hablarme de ello?", 
	"Caroline.PictureMemory.Question.1": "#¿Cuándo te casaste?#No es nada, de verdad...",
	"Caroline.PictureMemory.Response.1": "¿Yo? Conocí a Pierre después de venir acá. Me cortejó durante unos años y nos casamos.#$b#¡Ah! No estás ${celoso^celosa}$ porque estoy casada, ¿verdad?$8#$b#No te preocupes, no te descuidaré sólo porque me casé con Pierre.$6#$b#Eres como un hermano pequeño para mí.$5^Eres como una hermana pequeña para mí.$5",
	"Caroline.PictureMemory.Response.2": "${Querido^Querida}$, no puedes ocultármelo.$2#$b#Sé cuando algo no está bien. Puedes hablar conmigo, ¿vale?$10",
	"Caroline.PictureMemory.Question.2": "#Agradezco tu preocupación, pero te prometo que estoy bien.#¿De verdad no recuerdas nada? ¿No recuerdas el día que me confesé a ti?",
	"Caroline.PictureMemory.Response.Lie": "Oh, ${querido^querida}$... Ya veo lo que pasa.$11#$b#Está bien, no tienes que decir nada si no quieres.#$b#Estoy aquí para apoyarte a pesar de todo.$1#$b#Al fin y al cabo soy tu hermana mayor, no lo olvides nunca.$5",
	"Caroline.PictureMemory.Response.Truth.1": "¿Qué cosas?$2#$b#...$11#$b#Lo siento, realmente no recuerdo qué era. ¿Puedes decírmelo?$2", 
	"Caroline.PictureMemory.Response.Truth.2": "Oh, ¿una confesión?$11#$b#Espera...$2#$b#Espera un momento...$2", 
	"Caroline.PictureMemory.Response.Truth.3_1": "No te estarás burlando de mí con el libro que me regalaste, ¿verdad?$3#$b#Pero tengo que decir, ${querido^querida}$, que tu libro era realmente interesante.$5#$b#Pero no estoy segura de qué relación tiene con lo que estamos hablando.$11",
	"Caroline.PictureMemory.Response.Truth.3_2": "¿Era tu libro el de la biblioteca? ¿El de la personaje principal que comparte mi nombre?$3#$b#%No puedo negar que el libro es mío, y lo he colocado en secreto en una estantería a la que suele ir últimamente.",
	"Caroline.PictureMemory.5": "¡Oh, ya entiendo!#$b#¿Estás ${enfadado^enfadada}$ porque tu mejor amiga de la infancia se casó sin que lo supieras?$8#$b#No te preocupes, no te descuidaré sólo porque me casé con Pierre.$6#$b#Eres como ${un hermano pequeño^una hermana pequeña}$ para mí.$5#$b#Pero bueno, para compensarlo, déjame prepararte una gran comida. <$8", 
	"Caroline.PictureMemory.6": "Por cierto, ¿ya has encontrado el libro de cocina?#$b#Juro que estaba justo acá...$11",
	"Caroline.PictureMemory.7": "Bueno, supongo que estaba en la cocina después de todo.$8",
	"Caroline.PictureMemory.8": "%Después de ayudar a Caroline a cocinar, me dio parte de la comida que habíamos preparado.#$b#[907]",

	// 4 Hearts - Reminiscence
	"Caroline.PastPlay.1": "Hola, ${querido^querida}$.#$b#No esperaba que nadie viniera por acá...$11",
	"Caroline.PastPlay.2": "Hacía siglos que no me paraba a mirar este lugar.$11#$b#Cuando Abby era más joven, solíamos venir mucho acá.#$b#Gritaba: '¡Mamá, quiero tocar el cielo!'$8#$b#Ahora apenas me dice lo que piensa.$2",
	"Caroline.PastPlay.Question.0": "Pero quizá sea así. Los niños crecen. Los padres se convierten en... ruido de fondo.",
	"Caroline.PastPlay.A.0.0": "No eres ruido de fondo. Ella te necesita.",
	"Caroline.PastPlay.A.0.1": "Eso espero.$11#$b#Pero a veces me pregunto si siquiera me ve como una persona.$2#$b#No sólo... una mamá.$2",
	"Caroline.PastPlay.B.0.0": "¿No solías odiar que tu madre estuviera siempre pendiente de ti?",
	"Caroline.PastPlay.B.0.1": "Buen punto.$11#$b#Mi madre aún me trata como si tuviera doce años.$2#$b#Tal vez estoy condenada a repetir el ciclo, ¿eh?$2",
	"Caroline.PastPlay.C.0.0": "Apuesto a que algún día ella traerá acá a sus propios hijos.",
	"Caroline.PastPlay.C.0.1": "¡Ni siquiera bromees con eso!$3#$b#¡Aún no estoy preparada para ser abuela!$2",
	"Caroline.PastPlay.3": "Aunque, es gracioso. Verla entonces me hizo pensar en cómo éramos de niños.$8^Aunque, es gracioso. Verla entonces me hizo pensar en cómo éramos de niñas.$8",
	"Caroline.PastPlay.Question.1": "¿Recuerdas cómo corríamos hasta los columpios y nos retábamos a saltar?",
	"Caroline.PastPlay.A.1.0": "Sí, estabas demasiado asustada para saltar.",
	"Caroline.PastPlay.A.1.1": "¡No tenía miedo!$3#$b#Fui... cuidadosa.$2#$b#Hay una diferencia.$2",
	"Caroline.PastPlay.B.1.0": "Por supuesto, fuiste una mala influencia.",
	"Caroline.PastPlay.B.1.1": "Oh, claro, échame la culpa de todas las 'locuras'.$3#$b#Pero, ¿quién era ${el^la}$ que acababa siempre con la rodilla magullada?$2",
	"Caroline.PastPlay.C.1.0": "Estoy bastante ${seguro^segura}$ de que saltaste primero la mayoría de las veces.",
	"Caroline.PastPlay.C.1.1": "Me parece recordarte empujándome en cada desafío.$2#$b#No actúes como si no fueras tan ${malo^mala}$ como yo.$2",
	"Caroline.PastPlay.4": "Pero ya sabes... este no es el patio de recreo con el que crecimos.$2#$b#El nuestro tenía ese gran roble con el columpio de neumáticos, ¿recuerdas?$11#$b#Del que te caíste intentando impresionarme.$6",
	"Caroline.PastPlay.5": "Pero este lugar... es como una imitación barata.$2#$b#No hay balanceo de neumáticos.$11#$b#No hay arroyo para hacer saltar piedras.$11#$b#Sólo... esto.$2",
	"Caroline.PastPlay.6": "Es extraño, ¿verdad?$2#$b#Estamos acá de pie, pero nuestro patio de recreo... ha desaparecido.$11#$b#Y ya no somos ${esos niños^esas niñas}$.$2#$b#A veces desearía...$2#$b#¿Sabes una cosa?",
	"Caroline.PastPlay.Question.2": "No importa. Suficiente sentimentalismo por hoy.",
	"Caroline.PastPlay.A.2.0": "¿Desearía qué?",
	"Caroline.PastPlay.A.2.1": "...Que podría volver atrás y decirle a mi yo más joven que se aferrara a momentos como estos.#$b#Antes de que se escapen.$10",
	"Caroline.PastPlay.B.2.0": "Sigues siendo la misma Caroline para mí.",
	"Caroline.PastPlay.B.2.1": "Siempre supiste decir lo correcto, ¿verdad?$4",
	"Caroline.PastPlay.7": "Gracias por escucharme, ${querido^querida}$.#$b#Es... agradable recordar que a veces soy algo más que 'la madre de Abigail'.$1#$b#Bueno, creo que he abusado de mi hospitalidad aquí.#$b#Debería volver antes de que Pierre empiece a preguntarse adónde he ido.$8",

	//6 Hearts
	"Caroline.WoodsGather.1": "¡¿Quién está ahí?!$3",
	"Caroline.WoodsGather.2": "Oh... Eres tú... ${querido^querida}$...$1#$b#¿Por qué estás aquí? ¿Me has seguido?$2",
	"Caroline.WoodsGather.Question.1": "#Te vi sola y me preocupé.#Me preocupaba que pudieras estar bajo algún hechizo.#¡Vi al Mago! ¡¡¡Te está acechando!!!",
	"Caroline.WoodsGather.A": "¿${Preocupado^Preocupada}$?$3#$b#Qué amable de tu parte preocuparte por mí.$8#$b#Aunque, debo decir, soy perfectamente capaz de caminar por estos bosques por mi cuenta.$2#$b#Puede que sea vieja, pero NO tanto.$3",
	"Caroline.WoodsGather.B": "¿Un hechizo, dices?$2#$b#¿De verdad sigues creyendo en esos cuentos de hadas, ${querido^querida}$?#$b#No, ${querido^querida}$, no estoy bajo ningún hechizo.$1#$b#No creerás que estoy hechizada por la naturaleza, ¿verdad?$8#$b#Tal vez tengas razón. Supongo que sigues siendo ${ese hermano pequeño^esa hermana pequeña}$ que se preocupa por mí.$5",
	"Caroline.WoodsGather.C": "¿Mago? ¿Qué Mago? ¿Qué quieres decir con eso?$2#$b#En realidad no crees que existan los magos, ¿verdad?$3#$b#Sabes, siempre tuviste una vívida imaginación. Pero me temo que los magos sólo son reales en los cuentos, ${querido^querida}$11",
	"Caroline.WoodsGather.3": "Pero di, ${querido^querida}$, por qué no te sientas conmigo.$11#$b#Quería hablar contigo.$11",
	"Caroline.WoodsGather.Question.2": "#Claro, Caroline...#En realidad... Sólo estoy aquí por la madera noble.",
	"Caroline.WoodsGather.Fail": "¡¡¡!!!$2#$b#Muy bien, ${querido^querida}$. Parece que tienes las manos llenas hoy.#$b#¡Entonces nos vemos luego!$1",
	"Caroline.WoodsGather.Doubt": "Parece que podría estar pasando por algo.#Bueno, sea lo que sea con lo que esté lidiando, sinceramente le deseo lo mejor.",
	"Caroline.WoodsGather.4": "A veces... Una chica sólo necesita un pequeño momento de paz...$2#$b#Desaparecer en el bosque y fingir que vuelve a ser una niña.$11#$b#Sin responsabilidades, sin una sola preocupación en mente.$2",
	"Caroline.WoodsGather.5": "Sabes, llevar la tienda con Pierre puede ser abrumador a veces.$2#$b#Y no me hagas hablar de Abby. Los adolescentes son una raza totalmente diferente en estos días.$3#$b#Es curioso cómo la vida te lanza cosas.$3#$b#Crees que lo tienes todo resuelto, y entonces... Todo parece desmoronarse a tu alrededor.$2#$b#¿Crees que soy miserable por sentirme así?$2#$b#Se supone que debo ser fuerte y confiable, pero aquí estoy...$2#$b#Qué patética excusa de madre soy...$2",
	"Caroline.WoodsGather.Question.3": "#No estás sola. Vamos a resolverlo $juntos}$.#Eres fuerte, vas a estar bien.",
	"Caroline.WoodsAnger.1": "No, ${querido^querida}$... Tú no lo entiendes.$2#$b#No es sólo la tienda o Abby. Es todo.$3#$b#La vida simplemente... sucedió. Y no de la manera que esperaba.$3",
	"Caroline.WoodsAnger.2": "Solíamos serlo todo.$11#$b#Y sé que hace años que no nos vemos, pero volver a verte hizo que me doliera el corazón.$2",
	"Caroline.WoodsAnger.3": "A lo mejor no te acuerdas. Tal vez es sólo un recuerdo tonto para ti ahora.$2#$b#Pero para mí... a veces, parece que fue ayer.$2#$b#Y, sin embargo, aquí estoy, ahogada en facturas, cuidando de una hija que ni siquiera me quiere y de un matrimonio que parece desvanecerse poco a poco.$3",
	"Caroline.WoodsAnger.4": "Tal vez realmente soy patética.$3#$b#Quizá debería aceptar que, a veces, las cosas no salen como queremos.$2",
	"Caroline.WoodsAnger.5": "Me siento tan perdida.$3#$b#¡Como si estuviera fallando en todo!$3", 
	"Caroline.WoodsAnger.6": "...Siento haberte involucrado.$2#$b#Pero quizá... quizá algún día, cuando las cosas se calmen, podamos volver a hablar de esto. Como es debido.$3",
	"Caroline.WoodsAnger.7": "Creo que metí la pata hasta el fondo.#Si hubiera hablado de otra manera, quizá las cosas habrían salido mejor.",
	"Caroline.WoodsComfort.1": "¿Qué quieres decir con eso ${querido^querida}$? No sabes que...$2#$b#No quiero que te involucres demasiado en mis problemas.$11",
	"Caroline.WoodsComfort.2": "Oh, vamos...$2#$b#Sabes que puedo arreglármelas sola. Además, ya tienes suficientes preocupaciones con tu granja.$11",
	"Caroline.WoodsComfort.3": "Quiero ayudar. No eres sólo alguien que conocí en el instituto, eres... eres mi mejor amiga.",
	"Caroline.WoodsComfort.4": "¿Una amiga? ¿En qué sentido?$10",
	"Caroline.WoodsComfort.5": "Creíste en mí cuando nadie más lo hizo.#Y nunca olvidaré las veces que me sostuviste cuando me caía.#Sé que las cosas están complicadas ahora, pero eso no significa que no pueda estar ahí para ti.#¿Debería alejarme de ti, aunque siempre hayas estado a mi lado?",
	"Caroline.WoodsComfort.6": "Oh, ${querido^querida}$...$2#$b#Has cambiado.#$b#Recuerdo cuando empezaste a venir a la biblioteca, ${tímido y reservado^tímida y reservada}$.$11#$b#Pero ahora, mírate, ofreciendo consuelo a una mujer vieja como yo.$8#$b#Te has convertido en todo ${un jovencito^una jovencita}$.$4",
	"Caroline.WoodsComfort.7": "Pero sabes, ${querido^querida}$, ya has hecho más de lo que crees.#$b#Estar aquí, escuchándome divagar, significa mucho para mí.$4",
	"Caroline.WoodsComfort.8": "Caroline y yo nos quedamos en el bosque todo el día.#Ella no quería que me fuera, y yo sentía lo mismo.#Charlamos durante horas.#Hasta que decidimos dar por terminado el día para ir a dormir.#Ojalá todos los días pudieran ser así.",
	
	//8 Hearts - I'm here for you
	"Caroline.SunKiss.1": "¡Oh, Pierre!#$b#¿Has traído las semillas que-$1",
	"Caroline.SunKiss.2": "Oh, eres tú, ${querido^querida}$...$3#$b#¿Me has echado de menos?$1#$b#¡Sólo bromeaba! Pero de verdad, es bueno verte de nuevo.$8",
	"Caroline.SunKiss.3": "Sabes, ayer significó mucho para mí. Nuestro pequeño momento en el bosque.$1#$b#Fuiste tan dulce, escuchándome desahogarme por todo.$5",
	"Caroline.SunKiss.4": "Pero entonces la realidad volvió y recordé...$11",
	"Caroline.SunKiss.5": "Que no importa lo que haga, seguiré atrapada en esta vida.$2#$b#Es sofocante, ¿sabes? La lucha constante, el ciclo interminable de decepciones.$2#$b#Intento mantener la calma, pero algunos días es demasiado.$3",
	"Caroline.SunKiss.6": "Y Pierre... ya no es el mismo.$2#$b#Todas las noches es lo mismo. Llega a casa pasada la medianoche, borracho como una cuba y gritando lo mucho que odia su trabajo y a Joja.$2#$b#No sé cuánto tiempo más podré soportarlo.$3",
	"Caroline.SunKiss.7": "Y Abigail... no se merece esto. Es demasiado joven para todos estos problemas.$3#$b#No puedo protegerla de todo, por mucho que lo intente.$3",
	"Caroline.SunKiss.8": "Estoy tan cansada, ${querido^querida}$. Cansada de fingir que todo va bien, cansada de poner cara de valiente.$2#$b#Sólo quiero... Sólo quiero escapar de todo.$3#$b#Pero no puedo, y a veces... a veces me pregunto si merece la pena seguir haciéndolo.$3",
	"Caroline.SunKiss.Question": "#Deberíamos huir. Olvidémonos de todo esto.#No puedes huir de tus problemas.",
	"Caroline.SunKiss.A.1": "¿En serio? Huir conmigo, ¿verdad?$2#$b#Bueno, no eres tú ${el caballero^la caballera}$ de brillante armadura.$3#$b#Pero, ¿dónde iríamos? ¿Alguna sugerencia?$10",
	"Caroline.SunKiss.A.2": "Ojalá pudiéramos.$10#$b#A veces desearía haberme casado contigo.$9",
	"Caroline.SunKiss.A.3": "Si no tuviera a Abigail, ya habría dejado a Pierre y te habría elegido a ti.$9",
	"Caroline.SunKiss.A.4": "¡Abigail, espera!$2",
	"Caroline.SunKiss.A.5": "Oh Dios... ¿qué he hecho? Abigail, no quise decir eso...$3",
	"Caroline.SunKiss.A.6": "Pude ver el arrepentimiento grabado en su cara, el peso de sus palabras hundiéndose.#Me miró, con los ojos llenos de remordimiento, y me di cuenta de que no sabía qué hacer a continuación.#Pero en lugar de ir tras Abigail, ella se quedó a mi lado, ensimismada en sus pensamientos.",
	"Caroline.SunKiss.B.1": "No estoy huyendo... Sólo estoy... expresando lo que siento.$2#$b#Pensé que lo conseguirías. Supongo que me equivoqué.$2#$b#Mira, vamos a olvidarlo, ¿vale? Tengo que ayudar a tender con la tienda.",
	"Caroline.SunKiss.B.2": "¡Mamá, no encuentro mi cartera! ¿La has visto?",
	"Caroline.SunKiss.B.3": "No, Abby, no la he visto.#$b#¿Quizás está en tu habitación?$1",
	"Caroline.SunKiss.B.4": "Bueno...$2",
	"Caroline.SunKiss.B.5": "Mamá, ¿estás bien? ¿Por qué tienes los ojos rojos?$6",
	"Caroline.SunKiss.B.6": "Oh, no es nada, Abby. Sólo tengo algo en ellos.",
	"Caroline.SunKiss.B.7": "Bueno...$9",
	"Caroline.SunKiss.B.8": "Eso estuvo cerca...#Espero que no empiece a hacer más preguntas.",

	//8 Hearts - You're strong
	"Caroline.SaloonHuh.1": "¡Vaya día!#$b#Después de un duro día de trabajo, no hay otro lugar en el que prefiera estar que en el Salón.$1",
	"Caroline.SaloonHuh.2": "¡Gus! ¡Tráeme lo de siempre, por favor!$1",
	"Caroline.SaloonHuh.3": "Muy bien, Pierre. ¡Cinco botellas de cerveza, enseguida!$3",
	"Caroline.SaloonHuh.4": "*glup*$1#$b#Ya conoces a Gus.#$b#Los negocios... ya no son lo que eran.$2#$b#MercaJoja está chupando la vida del pueblo.$3#$b#Todo el mundo va allá a por su chatarra barata producida en serie.$2",
	"Caroline.SaloonHuh.5": "Sé que ha sido duro para todos.$3#$b#Y entiendo que ha sido duro, especialmente para ti, enfrentarte así a Joja.$3#$b#Pero has estado aquí durante años, Pierre.$2#$b#La gente conoce tu calidad, tu dedicación.$2",
	"Caroline.SaloonHuh.6": "¡Sí! ¡Solían hacerlo!$3#$b#Pero ahora todo el mundo parece haberlo olvidado.$2",
	"Caroline.SaloonHuh.7": "Y Abigail...$2#$b#Abigail ya casi ni me habla.$2#$b#Dice que estoy anclado en el pasado, aferrado a viejas tradiciones.$3#$b#Solíamos tener largas conversaciones sobre su futuro, sus sueños.$2#$b#Ahora, es como si estuviera en un mundo completamente diferente.$2",
	"Caroline.SaloonHuh.8": "Los niños de hoy en día...$2#$b#Sé que es duro ver a tu propia hija alejarse.$3#$b#Sobre todo cuando parece que persigue algo superficial en lugar de las cosas que de verdad importan.$3#$b#Pero no puedes culparla del todo, Pierre. Los tiempos cambian, y la gente cambia con ellos.$2",
	"Caroline.SaloonHuh.9": "¡Un cambio a peor, en mi opinión!$3",
	"Caroline.SaloonHuh.10": "Este pueblo solía ser una comunidad que se apoyaba mutuamente.$2#$b#Ahora, es como si todo el mundo estuviera centrado en sí mismo.$3",
	"Caroline.SaloonHuh.11": "Hola, papá.$2",
	"Caroline.SaloonHuh.12": "Hola, Abigail.#$b#¿Todo bien?",
	"Caroline.SaloonHuh.13": "Sí, sólo...$9#$b#Mamá ha estado preguntando por ti últimamente.$2#$b#Dice que no has estado mucho por allá.$2",
	"Caroline.SaloonHuh.14": "El trabajo ha sido un poco exigente, eso es todo.",
	"Caroline.SaloonHuh.15": "Bien...$9#$b#¿Tal vez podrías venir a casa pronto? Te echa de menos.$2",
	"Caroline.SaloonHuh.16": "Mira, Abigail, aprecio tu preocupación, ¡pero sé cómo manejar mis asuntos!$3#$b#¿No confías en mí?$3",
	"Caroline.SaloonHuh.17": "¡Por supuesto, papá!$5#$b#Pero...$2",
	"Caroline.SaloonHuh.18": "¡Entonces déjalo estar!$3#$b#¡Esto ni siquiera debería ser una discusión!$3#$b#¡Soy un hombre adulto, puedo cuidar de mí mismo!$3",
	"Caroline.SaloonHuh.19": "Yo-Yo solo... Me preocupo por ustedes, ¿vale?$5#$b#Tal vez... tal vez deberías dejar el alcohol por un tiempo.$2#$b#Mamá está muy preocupada y, sinceramente, yo también.$2",
	"Caroline.SaloonHuh.20": "¡No te atrevas a decirme lo que tengo que hacer, Abigail!$3#$b#Además, ¡no es asunto tuyo!$3",
	"Caroline.SaloonHuh.21": "¡Es asunto mío, papá!$5#$b#Odio verte así. Siempre estás en el Salón, apenas en casa, y...$5#$b#Y ya no eres tú mismo.$2",
	"Caroline.SaloonHuh.22": "Pierre, ¿qué es esto?$2#$b#¿Por qué tratas así a Abby?$3",
	"Caroline.SaloonHuh.23": "Estaba sobrepasando sus límites.$3#$b#¡No es asunto suyo cómo empleo mi tiempo!$3",
	"Caroline.SaloonHuh.24": "¡Es su preocupación cuando afecta a toda la familia!$3#$b#Has estado descuidando tus responsabilidades, alejando a Abigail, ¿y ahora arremetes contra ella por expresar preocupación?$2#$b#No se trata de unas copas, Pierre, ¡se trata de tu comportamiento!$3",
	"Caroline.SaloonHuh.25": "Por favor... Pierre.$11#$b#¡Piensa en Abby, piensa en nosotros! Tienes que parar esto. No es bueno para ti.",
	"Caroline.SaloonHuh.26": "¡No me sermonees!$3#$b#¡Sé lo que hago!$3",
	"Caroline.SaloonHuh.27": "¿Y tú?$2",
	"Caroline.SaloonHuh.28": "Porque desde mi punto de vista, estás destruyendo todo lo que construimos.$2#$b#¡Estás lastimando a tu hija, y me estás alejando!$3",
	"Caroline.SaloonHuh.29": "¡Muy bien!$3#$b#Si eso es lo que piensas, ¡tal vez debería irme!$3",
	"Caroline.SaloonHuh.30": "Está bien, Abby.#$b#No le hagas caso. Esto no es culpa tuya.",
	"Caroline.SaloonHuh.Question": "#Conforta a Caroline.#Enfréntate a Pierre.",
	"Caroline.SaloonHuH.C.1": "Vamos, Abby, quedémonos aquí un rato.$11#$b#Preferiría no enfrentarme a tu padre hasta que se haya calmado.$3",
	"Caroline.SaloonHuH.C.2": "Oh, eres tú, ${querido^querida}$.$11",
	"Caroline.SaloonHuH.C.3": "¿Tengo buen aspecto?$2#$b#Mi marido acaba de abandonarme y ahora mi hija está llorando.$3",
	"Caroline.SaloonHuH.C.4": "Lo sé, lo siento. Sólo quería asegurarme de que estás bien.",
	"Caroline.SaloonHuH.C.5": "¿Y eso por qué? ¿De repente te preocupas por mí?$2",
	"Caroline.SaloonHuH.C.6": "Caroline, sé que no siempre he estado ahí como debería.#Pero ahora estoy aquí, y quiero apoyarte en esto.",
	"Caroline.SaloonHuH.C.7": "¿Y qué ha cambiado? ¿Por qué ahora?$2",
	"Caroline.SaloonHuH.C.8": "Por fin me he dado cuenta de lo mucho que significas para mí.#Antes tenía miedo, miedo de perderte.#Pero ya no tengo miedo. Estoy ${listo^lista}$ para estar aquí para ti.",
	"Caroline.SaloonHuH.C.9": "¡No te atrevas a venir aquí con tus disculpas a medias y esperar que te perdone y olvide!$3",
	"Caroline.SaloonHuH.C.10": "Caroline, yo...",
	"Caroline.SaloonHuH.C.11": "¡No! Por favor, vete.$2#$b#No quiero que las cosas sean aún más complicadas de lo que son en realidad.$3",
	"Caroline.SaloonHuH.C.12": "Empiezo a pensar que meterme en problemas ajenos fue una mala idea.#Especialmente en asuntos familiares.",
	"Caroline.SaloonHuH.P.1": "¡Pierre!#No deberías haber hecho eso. Tu familia te quiere. Te necesitan.",
	"Caroline.SaloonHuH.P.2": "¿Quién te crees que eres?$3#$b#No eres parte de esta familia.$3",
	"Caroline.SaloonHuH.P.3": "Puede que no sea pariente de sangre, pero he formado parte de la vida de Carolines más tiempo del que tú llevas ahogándote en cerveza.#Entiendo tu dolor, pero arremeter contra tu mujer no es la respuesta.#Estás destrozando a tu familia.",
	"Caroline.SaloonHuH.P.4": "¿Ah, sí? ¿Me miras a los ojos como si nada hubiera pasado?$3#$b#Me miras como si fuera culpa mía cuando deberías ser tú quien sintiera lástima de ti ${mismo^misma}$.$3#$b#¿No tienes conciencia?$3",
	"Caroline.SaloonHuH.P.5": "Pierre, ¿qué quieres decir?#Lo que dices no tiene sentido.",
	"Caroline.SaloonHuH.P.6": "¡¿De verdad crees que no me he dado cuenta?!$3#$b#¡¿Acaso sabes cómo es?!$3#$b#¡¿Ver a mi mujer reír y hablar contigo como solía hacerlo conmigo?!$3#$b#Ahora me siento como si fuera el forastero.$3",
	"Caroline.SaloonHuH.P.7": "Pierre, Caroline y yo hemos sido amigos desde que éramos niños.#Es natural que tengamos un vínculo.",
	"Caroline.SaloonHuH.P.8": "¿Vínculo? ¡Más bien estás intentando reemplazarme!$3",
	"Caroline.SaloonHuH.P.9": "Eso no es cierto, Pierre. Nunca he intentado reemplazarte.#Eres familia para mí, pero nos has estado alejando.",
	"Caroline.SaloonHuH.P.10": "¿Te preocupas por mí? ¿Entonces por qué dejaste que esto pasara?$3#$b#¡¿Sabes qué?! Estoy totalmente convencido de que estás aquí sólo para consolar a Caroline, para ser su '${Caballero^Caballera}$', ¡¿me equivoco?!$3",
	"Caroline.SaloonHuH.P.11": "¡Porque nos dejaste fuera, Pierre!#Te has estado ahogando en el Salón, alejando a las personas que más se preocupan por ti.",
	"Caroline.SaloonHuH.P.12": "¡No entiendes nada!$3#$b#¡Nunca estuviste ahí para mí!",
	"Caroline.SaloonHuH.P.13": "Uh-huh...#Parece que Pierre me noqueó para siempre...#Pero antes de perder del todo la conciencia, oí a Caroline gritar mi nombre.",
	"Caroline.SaloonHuH.P.14": "¡@!$10#$b#¡Oh, no, ${querido^querida}$, despierta!$3",
	"Caroline.SaloonHuH.P.15": "Pierre, nada de esto habría pasado si hubieras dejado de beber.$2#$b#¡Ahora mira lo que has hecho! ¡Por eso te digo que pares!$3",
	"Caroline.SaloonHuH.P.16": "...$4",
	"Caroline.SaloonHuh.P.17": "...#Oí a Caroline pidiendo ayuda...#...#...#...#Al día siguiente me desperté en la clínica de Harvey. Le pregunté a Harvey qué había pasado, ya que no recordaba haber venido ayer.#Harvey mostró una expresión de asombro en su rostro antes de decir que tuve una pelea con Pierre que resultó en una conmoción cerebral leve.#Sabiendo lo que pasó, aún no puedo creer que algo así pudiera suceder.#Como no tenía más preguntas, le pregunté a Harvey si podía irme de su clínica y al final decidió darme el alta antes de tiempo, ya que mi estado era leve.#Supongo que tuve suerte...",

	//8 Hearts - 6 Hearts is skipped
	"Caroline.BrokenFrame.1": "¿Qué? ¿Pero qué...?$7",
	"Caroline.BrokenFrame.2": "Es la foto de familia.$2#$b#¿Por qué se ha roto? ¿Se cayó? ¿O...?$2#$b#...Esto no parece un accidente.$9",
	"Caroline.BrokenFrame.3": "Oh, eres tú, @.#$b#¡Caray, no te acerques así a la gente!$3#$b#Déjame adivinar, estás aquí para ver a mamá, ¿verdad?$6#$b#Últimamente pasas mucho tiempo con ella.$6",
	"Caroline.BrokenFrame.4": "¿Abigail? ¿${Querido^Querida}$? Qué—",
	"Caroline.BrokenFrame.5": "¿Qué pasó, mamá?$3#$b#¿Papá y tú se han vuelto a pelear?$2",
	"Caroline.BrokenFrame.6": "Oh, no seas tonta. Sólo estamos... ocupados.",
	"Caroline.BrokenFrame.7": "No es nada, Abby. No debes preocuparte.$11#$b#A veces las cosas simplemente... se caen.$2",
	"Caroline.BrokenFrame.8": "Cierto. Porque los marcos se caen y se hacen pedazos.$3#$b#En serio, mamá, ¿qué está pasando?$2#$b#Tú y papá han estado actuando muy raro últimamente.$2",
	"Caroline.BrokenFrame.9": "¡Caroline! Hablamos de esto.$3#$b#¡Te dije que limpiaras esto!$3",
	"Caroline.BrokenFrame.10": "¿Y qué hace @ aquí?$3#$b#¿Es otro de tus pequeños 'momentos'?$3",
	"Caroline.BrokenFrame.11": "¿Mis 'momentos'?$2#$b#Al menos no soy yo la que se está ahogando en cerveza y... ¡lo que sea que hayas estado escondiendo!$3",
	"Caroline.BrokenFrame.12": "...$4#$b#¡¿Crees que disfruto con esto?!$3#$b#Mientras tú estás fuera reviviendo tus 'recuerdos' con ${el granjero^la granjera}$, ¡yo soy el que mantiene este techo sobre nuestras cabezas!$3",
	"Caroline.BrokenFrame.13": "¡Basta ya!$5#$b#¡Ambos actúan como si ya no les importara el otro!$2",
	"Caroline.BrokenFrame.Question": "...#Pierre, estás alejando a todo el mundo.#Caroline, esto no ayuda.",
	"Caroline.BrokenFrame.A.1": "¿Alejándolos?$2#$b#¡Mira a tu alrededor, @!$3#$b#Las estanterías están medio vacías, Joja está chupando clientes... ¡y ella está aquí soñando despierta contigo!$2#$b#¿Crees que quiero ser así?$3",
	"Caroline.BrokenFrame.A.2": "Pierre, no se trata de ${él^ella^ellos}$—$2",
	"Caroline.BrokenFrame.A.3": "¡SIEMPRE SE TRATA DE ${ÉL^ELLA^ELLOS}$!$3",
	"Caroline.BrokenFrame.A.4": "¿Crees que no veo cómo ella se ilumina cuando vienes de visita?$3",
	"Caroline.BrokenFrame.A.5": "¡PARA!$5#$b#¡Eres patético!$5#$b#Mamá te ha estado cubriendo... ¡y lo único que te importa es tu orgullo!$5",
	"Caroline.BrokenFrame.A.6": "Abigail-$2",
	"Caroline.BrokenFrame.A.7": "¡No! ¡No puede culparte por su desastre!$5",
	"Caroline.BrokenFrame.A.8": "Y tú...$2#$b#No actúes como si estuvieras aquí para ayudar.$5",
	"Caroline.BrokenFrame.A.9": "${Querido^Querida}$, deberías irte.$2",
	"Caroline.BrokenFrame.A.10": "Quizá no debería haber tomado partido.#¿En qué estaba pensando?",
	"Caroline.BrokenFrame.B.1": "¡¡Por fin, alguien que lo entiende!!#$b#¡Alguien que habla con sentido común!$1",
	"Caroline.BrokenFrame.B.2": "...Oh.$2#$b#Entonces... ¿eso es lo que realmente piensas?$2#$b#Pensé... que al menos...$11",
	"Caroline.BrokenFrame.B.3": "Papá, ¿puedes parar?$3#$b#Mamá, no lo escuches. Sólo está siendo...$2",
	"Caroline.BrokenFrame.B.4": "No, Abby. @ tiene razón.$2#$b#Esto no tiene sentido.$3#$b#No deberíamos perder el tiempo en... discusiones tontas.$3",
	"Caroline.BrokenFrame.B.5": "C-Caroline, espera.$4#$b#No quise decir-$2",
	"Caroline.BrokenFrame.B.6": "Necesito... revisar el jardín.$2#$b#Por favor, discúlpenme.$2",
	"Caroline.BrokenFrame.B.7": "'No ayuda.'$3#$b#¿En serio? ¿Eso es todo lo que tenías que decir?$3",
	"Caroline.BrokenFrame.B.8": "Vamos a...$2#$b#Volver a los negocios.#$b#No hay necesidad de exagerar.$1",
	"Caroline.BrokenFrame.B.9": "Increíble...$5",
	"Caroline.BrokenFrame.B.10": "Eso no salió bien.#Sólo quería calmar las cosas, pero acabé empeorándolas.",

	//10 Hearts Part 3
	"Caroline.TheDisclosure.1": "¡Oh Dios! ¡Es Abigail!$2",
	"Caroline.TheDisclosure.2": "¡Abigail! ¡Despierta!",
	"Caroline.TheDisclosure.3": "Oh, mi dulce niña.$2#$b#Me temo que... Abby parece no responder...$2",
	"Caroline.TheDisclosure.4": "¡Rápido! ¡Necesitamos que Harvey venga acá y eche un vistazo!$s",
	"Caroline.TheDisclosure.5": "¡Somnus Profundus!",
	"Caroline.TheDisclosure.6": "Invocación fallida.",
	"Caroline.TheDisclosure.7": "Un pequeño error de cálculo.#$b#Parece que la bendición del bosque que di sobre @ ha sido involuntariamente contraproducente.",
	"Caroline.TheDisclosure.8": "¿Qué hacías?$4#$b#¡¿Será que nos has estado haciendo algo?!$3#$b#¡¿Le has hecho algo a Abigail, verdad?!$3",
	"Caroline.TheDisclosure.9": "No es algo que deba preocuparte.",
	"Caroline.TheDisclosure.10": "¡¿Qué has dicho?!$3#$b#¡Te oí claramente! ¡Intentaste hechizarnos!$3#$b#¿Te importa una explicación?$3",
	"Caroline.TheDisclosure.11": "Pierre, por favor, cálmate.$2#$b#Debe haber una razón por la que el Mago está aquí. Déjalo hablar.$11",
	"Caroline.TheDisclosure.12": "¿Saben qué? ¡Sospechaba esto desde hace mucho tiempo!$3#$b#¡¿Tuviste una aventura con el mago?!$3#$b#¡Ni siquiera intentes engañarme! Lo veo tan claro como el día, ¡el pelo de Abigail es exactamente del mismo tono que el suyo!$3#$b#Lo sé desde el día en que nació Abigail, ¡¿crees que no me daría cuenta de algo así?!$3",
	"Caroline.TheDisclosure.13": "*tos* *tos*$s",
	"Caroline.TheDisclosure.14": "¡Abby! ¿Qué tal estás?$2",
	"Caroline.TheDisclosure.15": "Yo... ¿Cuándo me desmayé?$s",
	"Caroline.TheDisclosure.16": "¡Tú! ¡¿Qué le has hecho?!$3#$b#¡Di algo, lo que sea!$3#$b#Necesito saber qué está pasando.$2",
	"Caroline.TheDisclosure.17": "Bueno...#$b#Abigail es de hecho mi hija...",
	"Caroline.TheDisclosure.18": "Espera... ¿qué...? ¿Quieres decir que Abigail no es mi hija?$s#$b#¿Qué quieres decir con que es tu hija?$3",
	"Caroline.TheDisclosure.19": "Mi mujer, su madre biológica, fue una vez una humana normal.#$b#Era una mujer brillante y curiosa. Nos enamoramos y tuvimos una hija.#$b#La llamamos Abigail.#$b#Pero atraída por la magia del bosque como una polilla por una llama, se volvió inestable.#$b#La magia aquí no era dócil en ese entonces. Se filtró en ella, la retorció.#$b#Era como si una hermosa flor se convirtiera en algo venenoso.#$b#Vi su espíritu, su sabiduría ancestral, y me sentí obligado a ser su guardián, a proteger el delicado equilibrio.#$b#Mi esposa, sin embargo, veía un poder crudo e indomable. Ansiaba controlarlo, doblegar la naturaleza de la magia a su voluntad.#$b#La magia nos llevó en direcciones diferentes y no pudimos permanecer juntos.",
	"Caroline.TheDisclosure.20": "De acuerdo, no estoy convencida, eso no aporta nada.$2#$b#¿Cómo es tu hija exactamente?$3#$b#Aún recuerdo cómo di a luz a Abigail. Ella ES mi hija.$3#$b#Ya podríamos haber hecho venir a Harvey en vez de escuchar esto.$11",
	"Caroline.TheDisclosure.21": "¡Caroline tiene razón!$3#$b#Abigail está en peligro, debemos actuar pronto antes de que sea demasiado tarde.$3",
	"Caroline.TheDisclosure.22": "Mi mujer se dio cuenta de que no podía vencerme, así que fue a por donde más duele.", 
	"Caroline.TheDisclosure.23": "En un acto de desesperación, había lanzado una maldición sobre nuestra hija, Abigail.#$b#Siempre que Abigail dudara de su propio nacimiento. Siempre que Abigail estuviera cerca de mí.#$b#La maldición se dispararía y la debilitaría, como un veneno que le robaría lentamente la fuerza vital.#$b#No quería que estuviera aletargada el resto de su vida.#$b#Así que tomé la decisión de que tuviera una vida feliz con otra familia.#$b#Que los recuerdos de sus padres adoptivos serían alterados para que crean que Abigail fuese su hija biológica.",
	"Caroline.TheDisclosure.24": "Espera... ¿Podría significar...?$11#$b#¡No parece justo!$2#$b#Podías habérnoslo pedido. No tenías que imponernos esta obligación.$3",
	"Caroline.TheDisclosure.25": "¡No tenía elección! ¡Cualquiera que estuviera cerca de mí corría el riesgo de ser maldecido!#$b#Si no hubiera hecho lo que hice, mi mujer habría echado la maldición sobre la familia que cuidase de Abigail.",
	"Caroline.TheDisclosure.26": "¿Significa esto que mi matrimonio contigo no fue real?$2#$b#¿Todo lo que hemos hecho hasta ahora fue sólo fingido?$2",
	"Caroline.TheDisclosure.27": "Pero las cosas finalmente están mejorando. Gracias a la ayuda ${del granjero^de la granjera}$.#$b#He terminado mi investigación para romper la horrible maldición sobre Abigail.#$b#¡Ya no tendrá que sufrir más! Por fin podremos volver a ser una familia.",
	"Caroline.TheDisclosure.28": "¡No! ¡No te dejaría tener a Abigail!$3#$b#Abigail es MI hija.$3",
	"Caroline.TheDisclosure.29": "No lo dices en serio mamá, ¿verdad?$s#$b#@ está pidiendo tu mano en matrimonio, ¿verdad?$s#$b#Obviamente puedes aprovechar esta oportunidad para estar con ${él^ella}$, ¿no?$s",
	"Caroline.TheDisclosure.30": "¿Dónde has oído eso, Abby?$3#$b#No puedes inventarte historias. Puede herir a la gente.$2",
	"Caroline.TheDisclosure.31": "¿No es así, @? Tú también lo crees, ¿verdad?$s",
	"Caroline.TheDisclosure.Question": "#Todavía amo a Caroline.#Somos ${amigos^amigas}$ desde la infancia.",
	"Caroline.TheDisclosure.A.1": "Todavía te amo, Caroline.#Aprovecharía cualquier oportunidad con tal de estar contigo.#Prometí casarme contigo, Caroline. ¿No te acuerdas?",
	"Caroline.TheDisclosure.A.2": "¿De qué estás hablando, ${querido^querida}$?$3#$b#No es el momento de hacer bromas.$2#$b#Quiero a mi familia, @. Me necesitan y no puedo dejarlos.$10",
	"Caroline.TheDisclosure.A.3": "Caroline, ${ambos^ambas}$ merecemos amor y felicidad.#Esto no está bien, ¿verdad?#No te quedes sólo porque sientas que tienes que hacerlo.#No te quedes por culpa. Escucha a tu corazón, Caroline, sé feliz.",
	"Caroline.TheDisclosure.A.4": "Yo...$10#$b#Todavía ${lo^la}$ amo.$10#$b#Pierre... Abigail... Siento haberlos decepcionado. No puedo ignorar mis sentimientos por @ por más tiempo.$10",
	"Caroline.TheDisclosure.A.5": "Mamá, mereces ser feliz.$1#$b#Esto no es culpa tuya, y no se me ocurriría culparte.",
	"Caroline.TheDisclosure.A.6": "Abby... Mi maravillosa hija. Gracias, Abby.$4",
	"Caroline.TheDisclosure.A.7": "¡Un momento!$2#$b#¡Espera!$3#$b#¿Y yo qué? ¿Has considerado siquiera mis sentimientos?$2#$b#Llevábamos una buena vida como familia, pero entonces apareció ${este tipo^esta chica}$, ¿y ahora nos separamos?$2",
	"Caroline.TheDisclosure.A.8": "Papá, sé que esto es difícil de entender para ti.$s#$b#Pero ninguno de nosotros quería que esto sucediera, sin mencionar que mamá no es tu posesión.$2",
	"Caroline.TheDisclosure.A.9": "Esta familia significa mucho para mí. ¿No tienes ningún recuerdo de nosotros?$2",
	"Caroline.TheDisclosure.A.10": "¡Esto no tiene sentido! ¿Cómo puedes olvidar todo lo que hemos pasado?$3",
	"Caroline.TheDisclosure.A.11": "Escucha, papá, sé que esto no es lo que querías. Está bien sentirse asustado en este momento.$s#$b#Pero por favor, tienes que entender que las cosas no funcionan desde hace tiempo. Todos necesitamos una oportunidad para ser felices.$s",
	"Caroline.TheDisclosure.A.12": "Abby, realmente has crecido.#$b#Antes siempre pensé que eras rebelde, pero en realidad has madurado bastante.$1#$b#Me avergüenzo de que las cosas hayan salido así. A veces desearía que las cosas fueran diferentes.$2#$b#Aun así, me alegro de que pasemos estos momentos juntas en familia.$1",
	"Caroline.TheDisclosure.A.13": "Está bien, mamá, está bien.$2#$b#Deberías ir con @.$1#$b#Papá y yo cuidaremos de nosotros mismos. Sólo necesita algo de tiempo para recuperarse.",
	"Caroline.TheDisclosure.A.14": "Abby, pareces fuerte, pero sé que esto debe ser estresante para ti.#$b#Así que, ven aquí, mi pequeña. Déjame abrazarte una vez más, como tu madre.",
	"Caroline.TheDisclosure.A.15": "Ay... este incidente me ha enseñado una lección.#$b#Apuesto a que ni la propia vieja bruja se lo esperaba.#$b#Tu destino se entrelaza con el de Caroline como hilos estrechamente entretejidos que pueden soportar cualquier interferencia, lo que ${los^las}$ lleva a reencontrarse una vez más.#$b#Pero el poder del destino no puede cambiarse simplemente manipulándolo.",
	"Caroline.TheDisclosure.A.16": "Abigail tiene razón. Soy yo quien no ha tenido el coraje.$2",
	"Caroline.TheDisclosure.A.17": "Mago, te lo ruego, ayúdanos a olvidar nuestro pasado.$2",
	"Caroline.TheDisclosure.A.18": "Así es mejor para todos.$2",
	"Caroline.TheDisclosure.A.19": "Y tú, @.$2#$b#${El^La}$ que se llevó a mi amada, dejándome con resentimientos.$2",
	"Caroline.TheDisclosure.A.20": "Realmente quiero culparte de todo.#$b#Pero sé que aunque lo intente, no creo que las cosas mejoren realmente.$2#$b#¡Pero por si acaso! ¡Mi medalla de oro en boxeo me va a venir bien cuando te derribe!$1",
	"Caroline.TheDisclosure.A.21":"Por fin lo he entendido y me he dado cuenta de que metí la pata.$2#$b#Debería haberte tratado mejor, Caroline, pero ahora es demasiado tarde. No puedo recuperarte.$2#$b#Así que cuando perdamos este capítulo de nuestro pasado, tal vez en otra vida, seré feliz con Caroline.",
	"Caroline.TheDisclosure.A.22": "Me alegro de que haya salido mejor de lo que esperaba.",
	"Caroline.TheDisclosure.B.1": "Tienes una imaginación salvaje, Abigail.#Somos ${amigos^amigas}$ desde que éramos ${niños^niñas}$, y eso nunca va a cambiar.",
	"Caroline.TheDisclosure.B.2": "¡Abigail! Esto no es un juego. No pongas ideas en la cabeza de tu madre.$3",
	"Caroline.TheDisclosure.B.3": "Pierre, no hay necesidad de ser tan duro.$3",
	"Caroline.TheDisclosure.B.4": "No les hagas caso, ${querido^querida}$. Es sólo... un malentendido.$2",
	"Caroline.TheDisclosure.B.5": "No me imaginaba que acabaría peor incluso que mis peores temores.#Pierre y Caroline siguieron casados, y Abigail se quedó para ser su hija.#En cuanto al Mago, digamos que se llevó la peor parte.#Si tan sólo hubiera sido ${sincero^sincera}$ sobre mis sentimientos.",

	//12 Hearts - A
	"Caroline.BeachFuss.1": "¡Hola amorcito! ¡Tardaste bastante!$1#$b#El aire salado se siente diferente sin ti acá.$10",
	"Caroline.BeachFuss.2": "¿No es increíble esta brisa?$4#$b#Siempre me recuerda a... bueno, a todas esas locas aventuras que vivíamos aquí de ${niños^niñas}$.$5",
	"Caroline.BeachFuss.3": "¿Como aquella vez que nos colamos en un barco por la noche, fingiendo ser piratas en busca de un tesoro enterrado?$6#$b#Eras terrible como pirata, cariño. Más como un gato asustado perdido en el mar.$8",
	"Caroline.BeachFuss.4": "¿Qué te parece el paisaje?",
	"Caroline.BeachFuss.Question": "#Uh, guau. Te ves... increíble.#El océano se ve bien, supongo.",
	"Caroline.BeachFuss.A.1": "¿Tú crees, amorcito?$9#$b#Pero esto es sólo un bikini blanco aburrido, ¿crees que me veo increíble en él?$8",
	"Caroline.BeachFuss.A.2": "Caroline, podrías llevar un saco de patatas y seguirías siendo la mujer más guapa de este muelle.#No, en toda esta playa.#Tal vez incluso todo el pueblo.",
	"Caroline.BeachFuss.A.3": "Siempre sabes qué decir, ¿verdad, amorcito?$4",
	"Caroline.BeachFuss.A.4": "Pero basta de hablar de mí, ¿qué hay de ti? ¿Cómo te sientes?",
	"Caroline.BeachFuss.A.5": "Sinceramente, Caroline, estar aquí contigo es como un sueño hecho realidad.#Nunca imaginé que tendría la suerte de llamarte esposa y de compartir contigo momentos como éste.",
	"Caroline.BeachFuss.A.6": "Yo siento lo mismo, amorcito.$9#$b#Cada momento contigo es un tesoro, y estoy muy agradecida de tenerte a mi lado.$1",
	"Caroline.BeachFuss.A.7": "Lo disfruté.#Me alegro de haberme casado con Caroline.",
	"Caroline.BeachFuss.B.1": "Me alegro de que encuentres el océano 'agradable'.$2#$b#Quiero decir, ¿quién necesita una belleza natural impresionante cuando tienes... lo 'agradable'?$3",
	"Caroline.BeachFuss.B.2": "Siempre pensé que el océano era algo más que 'agradable'.$3#$b#Pero yo qué sé, ¿verdad?$8",
	"Caroline.BeachFuss.B.3": "De todos modos, olvida que pregunté.$2#$b#Disfrutemos del 'agradable' paisaje en silencio, ¿de acuerdo?$11",
	"Caroline.BeachFuss.B.4": "Caroline me sorprendió. Ella actuó diferente hoy.#Pero sigo amándola mucho.",

	// 12 Hearts - B
	"Caroline.BeachBuddy.1": "...Ni siquiera sé por qué te traje aquí.$2",
	"Caroline.BeachBuddy.2": "Yo... no pensé que seguiría haciendo esto.$4#$b#...Qué tontería.$8",
	"Caroline.BeachBuddy.3": "-¡Ah!$3#$b#Tú...$2",
	"Caroline.BeachBuddy.Question.0": "...#No esperaba encontrarte aquí... y con un osito de peluche, nada menos.#¿En serio estás escondiendo un peluche ahora mismo?",
	"Caroline.BeachBuddy.A.0": "No es nada, ¿vale?$3#$b#No pensé que verías esto.$4",
	"Caroline.BeachBuddy.B.0": "Genial, ahora vas a burlarte de mí por esto.$2#$b#Debería haberme quedado en casa...$11",
	"Caroline.BeachBuddy.4": "...No pensaba traerlo, ¿sabes?",
	"Caroline.BeachBuddy.5": "No lo sé.$11#$b#Pensé en dejarlo en algún sitio y seguir adelante.$2",
	"Caroline.BeachBuddy.6": "Pero no pude...$2#$b#Sabes, siempre supe que pensabas que yo era la responsable.$11#$b#La que lo tenía todo pensado.$2#$b#Pero cuando era más joven, me aferraba a esto cada vez que sentía que no.$11",
	"Caroline.BeachBuddy.7": "Creías que siempre sabía qué hacer, ¿verdad?$6",
	"Caroline.BeachBuddy.8": "Porque tenía que hacerlo. Me admirabas.$10#$b#Pero la verdad es que tuve momentos en los que me sentí perdida.$11#$b#Sólo que nunca te dejé verlo.$11",
	"Caroline.BeachBuddy.Question.1": "...#No tenías que ocultármelo.#Así que todas esas veces que actuaste sin miedo... ¿estabas confiando secretamente en un osito de peluche?",
	"Caroline.BeachBuddy.A.1": "Sí, lo sé. Pero entonces, no quería arriesgarme.$11#$b#Se suponía que yo era la fuerte, ¿no?$2",
	"Caroline.BeachBuddy.B.1": "Si se lo dices a alguien, te juro...$3#$b#¿Sabes qué? Olvidemos que esto sucedió.$2#$b#Vamos a casa, amorcito.$2",
	"Caroline.BeachBuddy.9": "...Durante mucho tiempo, pensé que tenía que aferrarme a esto.$11#$b#Como si lo dejara ir, perdería la parte de mí que lo necesitaba.$2",
	"Caroline.BeachBuddy.10": "Pero ya no me siento así.#$b#Ya no lo necesito.#$b#Hace mucho que no lo hago.#$b#Pero quiero que lo tengas.$8",
	"Caroline.BeachBuddy.Question.2": "¿Qué te parece, amorcito?#Acepta el osito de peluche.#Rechaza el osito de peluche.",
	"Caroline.BeachBuddy.A.2.0": "¿Estás segura?#Ha sido tuyo durante tanto tiempo.",
	"Caroline.BeachBuddy.A.2.1": "Ya tengo a alguien que me hace sentir segura.$8#$b#Alguien real.$5#$b#Así que cuida de él por mí, ¿vale?",
	"Caroline.BeachBuddy.A.2.2": "Tal vez... no siempre estaba tan segura de sí misma como yo pensaba.#Quizá nunca tuvo que serlo.",
	"Caroline.BeachBuddy.B.2.0": "Si ha estado contigo en todo... quizá debería quedarse contigo.",
	"Caroline.BeachBuddy.B.2.1": "De acuerdo.$2#$b#Tal vez lo mantenga un poco más.#$b#Quizá ya no lo necesite como antes.$11#$b#Pero aferrarme a él ya no me resulta tan pesado.#$b#Supongo que la culpa es tuya.$6",
	"Caroline.BeachBuddy.B.2.2": "Tal vez nunca necesitó ser la persona que siempre pensé que era.#Quizá por fin se está permitiendo ser... ella misma.",

	//14 Hearts - BathHouse - Family Friendly
	"Caroline.BathLove.3": "Parece el paraíso, ¿verdad?#$b#Esta agua caliente derrite el día.$1",
	"Caroline.BathLove.4": "¿Lo ves? Te lo dije. Sabía que te encantaría una vez que te acostumbraras.$8#$b#Ya no tienes que ser ${tímido^tímida}$, amorcito.$4#$b#Estamos aquí para relajarnos. Además, te ves muy ${guapo^hermosa}$ con ese brillo rosado.$5",
	"Caroline.BathLove.5": "¿Cómo te va, amorcito?#$b#La agricultura es mucho más divertida que estar ${encerrado^encerrada}$ en una oficina, ¿verdad?$8",
	"Caroline.BathLove.Question.A": "#Es... diferente.#Más que facilidad, Caroline.",
	"Caroline.BathLove.A.1": "Es... diferente, Caroline.#Sin plazos, sin luces fluorescentes zumbando en mi cabeza todo el día.#Sólo el sol a mis espaldas y el tacto de la tierra bajo mis manos.#Pero hay mucho que aprender, mucho que no sé. A veces echo de menos la rutina, la previsibilidad de la vida en la ciudad.",
	"Caroline.BathLove.A.2": "Lleva tiempo, amorcito. ¿Recuerdas ese primer proyecto desafiante que me contaste?#$b#Entonces no lo sabías todo, ¿verdad?$8#$b#Lo resolveremos ${juntos^juntas}$. Además, piensa en las deliciosas verduras que podremos disfrutar.$1",
	"Caroline.BathLove.B.1": "Más que facilidad, Caroline.#Es una sensación de propósito que nunca había tenido.#Claro que el trabajo es agotador, pero ver brotar esas semillas, saber que estamos creando algo desde cero... es una satisfacción totalmente distinta.",
	"Caroline.BathLove.B.2": "Ver la alegría en tus ojos, amorcito, me hace darme cuenta de que esto es exactamente lo que esperábamos cuando decidimos esta nueva vida.#$b#Vivir fuera de la tierra, más cerca de la naturaleza, todo se está uniendo tan maravillosamente.$1",
	"Caroline.BathLove.6": "¿Recuerdas cuando éramos niños y soñábamos con estar juntos?^¿Recuerdas cuando éramos niñas y soñábamos con estar juntas?#$b#Parece que fue hace toda una vida, ¿verdad?$1#$b#Y ahora, aquí estamos, viviendo nuestro sueño codo con codo.$9",
	"Caroline.BathLove.7": "No se trata sólo de la granja.$8#$b#Se trata de ${nosotros^nosotras}$. Sobre la vida que estamos construyendo ${juntos^juntas}$, día a día.$1#$b#No lo cambiaría por nada del mundo.$5",
	"Caroline.BathLove.8": "Cada día contigo se siente como una bendición.#$b#No puedo imaginar mi vida sin ti a mi lado.$5",
	"Caroline.BathLove.9": "Me encantan estos momentos, amorcito.#$b#Más aventuras, más risas, más tiempo aquí contigo, disfrutando ${juntos^juntas}$ de las cosas sencillas.$5#$b#Sólo espero que podamos seguir sintiéndonos así de felices y ${^}$unidos para siempre.$4^Sólo espero que podamos seguir sintiéndonos así de felices y unidas para siempre.$4",
	"Caroline.BathLove.10": "Hablando de cosas sencillas, ¿qué tal si desayunamos mañana? Tenemos tantas opciones con todos los ingredientes frescos que producimos.#$b#Podríamos hacer tortitas para desayunar.$1#$b#Preparar tacos de pescado con las sobras de pescado.$8#$b#O incluso crear una mezcla gigante de verduras con todas esas remolachas y tomates que tengo por ahí.#$b#¿Te parece bien, amorcito?",
	"Caroline.BathLove.Question.B": "#Tortita#Taco de pescado#Mezcla de verduras",
	"Caroline.BathLove.11": "Tomo nota, amorcito. Me aseguraré de preparar algo especial para ${nosotros^nosotras}$ mañana.$1",
	"Caroline.BathLove.12": "Perdimos la noción del tiempo en el spa, hablando hasta el amanecer.#Un recuerdo maravilloso.",

	//14 Hearts - BathHouse - NSFW
	"Caroline.BathFuss.1": "¿Amorcito? ¿Qué haces aquí?$2",
	"Caroline.BathFuss.Question.A": "#Sólo he venido a descansar.#No esperaba que estuvieras acá, lo juro.",
	"Caroline.BathFuss.A.1": "¿A estas horas? ¡No seas ${tonto^tonta}$!$8#$b#¿Seguro que no echabas de menos a tu hermana mayor favorita?$6",
	"Caroline.BathFuss.A.2": "¿No es una coincidencia?$8#$b#¿Me has seguido hasta aquí?$6",
	"Caroline.BathFuss.2": "Vamos, vamos, no seas ${tímido^tímida}$.$6#$b#Además, ¿a quién le importa? ¡Nadie lo sabrá!$8#$b#No es que no nos hayamos colado ya en la misma cama, ¿verdad?$10",
	"Caroline.BathFuss.3": "¡Mira, por fin llegamos al spa!$1#$b#Relájate, amorcito, el agua está perfecta.$6#$b#Pero te prometo que esta agua no será lo único que se caliente esta noche.$9#$b#Cierra los ojos y deja que limpie tus preocupaciones. Te prometo que seré amable.$10",
	"Caroline.BathFuss.4": "Ahí, ahí, ¿no es bonito? Como en los viejos tiempos.$9#$b#Así es. ¿Recuerdas cuando solíamos escabullirnos y jugar junto al arroyo?$10#$b#Esto se parece un poco a eso, ¿no?$9",
	"Caroline.BathFuss.Question.B": "#Sí, excepto que... esto es un poco más... adulto.#Hmm, esto parece algo que los adultos entenderían mejor.",
	"Caroline.BathFuss.5": "Oh, amorcito, ya somos adultos.$10#$b#Y hablando de adultos.$9",
	"Caroline.BathFuss.6": "Shh... sin peros. Sólo relájate. Deja que te cuide.$10#$b#Permíteme aliviar la presión, amorcito.$9",
	"Caroline.BathFuss.7": "Sabes, todos estos años después, todavía mantienes cierta tensión ahí.$10#$b#Hmm, tal vez pueda ayudar con eso también. Sabes, un buen masaje puede hacer maravillas.$9",
	"Caroline.BathFuss.8": "Mmm, te sientes tan ${tenso^tensa}$.$10#$b#No te preocupes, amorcito. Cierra los ojos y deja que el agua caliente te calme.$9",
	"Caroline.BathFuss.9": "¿Puedes sentir los latidos de mi corazón, acelerándose sólo por ti?$9#$b#¿Puedes sentir los latidos de mi corazón, gritando sólo para ti?$10#$b#Bien. Porque ahora mismo, todo se trata de ${nosotros^nosotras}$. Nada más importa.$9",
	"Caroline.BathFuss.10": "Siempre he querido hacerte esto... amorcito. Quiero... Te amo... @.$10#$b#¿Tú también me amas, amorcito?$9",
	"Caroline.BathFuss.Question.C": "#Absolutamente... Moriría por ti.#Sí... más que nada.",
	"Caroline.BathFuss.11": "Entonces muéstrame... muéstrame cuánto me deseas.$9",
	"Caroline.BathFuss.12": "Yo... No puedo contenerme más...",
	"Caroline.BathFuss.13": "¡Oh, sí...! <$9",
	"Caroline.BathFuss.14": "Ah... < ah... < ah... < justo así... <$9",
	"Caroline.BathFuss.15": "Quiero sentirte... ¡más profundo...! <$9#$b#Ugh... < Vamos a perdernos... en este momento... ¡${juntos^juntas}$...! <$9",
	"Caroline.BathFuss.16": "Soy tuya... completamente...$9#$b#Más fuerte... ugh... < más rápido... no pares... <$9",
	"Caroline.BathFuss.17": "Estoy... ugh... <$9#$b#Estoy tan cerca... <$9",
	"Caroline.BathFuss.18": "Ja... ja...$9#$b#Eso fue divertido... ja... ja... ¡eso se siente bien...! <$10#$b#¿Estás ${listo^lista}$ para la segunda ronda...? <$9#$b#Sigamos hasta que no podamos movernos, ¿verdad, amorcito? <$10#$b#Oh, vamos...$8#$b#¡Sé que tienes más en ti...!$10",
	"Caroline.BathFuss.19": "La noche se convirtió en un torbellino de pasión y deseo mientras nos perdíamos en las caricias del otro.#Cada momento parecía una eternidad de éxtasis, alimentado por el impulso primario de complacer y ser complacido.#Al amanecer, yacíamos entrelazados, sin aliento y ${agotados^agotadas}$, como testimonio de la intensidad de nuestro amor.",

	//QUEST
	"Caroline.TigerseyeCure.title": "La Piedra",
	"Caroline.TigerseyeCure": "El Mago necesita un Ojo de tigre para romper la maldición de Abigail.",
	"Caroline.TigerseyeCure.hint": "Dale un ojo de tigre al mago.",

	//MAIL
	//2 heart event
	"Caroline.BookRequest": "${Querido^Querida}$ @,^Gracias por pasarte ayer por la biblioteca <^^Fue un placer tenerte allá. Suelo perderme en mi propio mundo, ¡pero tu compañía fue como una taza de té caliente en un día helado!^^Y madre mía, ¡ese libro que me recomendaste!^Ya voy por la mitad y estoy completamente enganchada. Pero ahora, no puedo evitar preguntarme si había un mensaje oculto en el libro... ¿quizás lo estoy analizando demasiado? En cualquier caso, ¡muchas gracias!^^   -Caroline^^   P.D. Encontré un libro que me hizo pensar en ti.",
	"Caroline.BookRequest.title": "Gracias por recomendarme este libro",
	//6 heart event - bad ending
	"Caroline.WizardStalk": "${Queridísimo^Queridísima}$ @,^Los bosques susurrantes guardan secretos, y ayer, uno de esos secretos se desveló ante ti. Es posible que me hayas visto cerca de Caroline, y tal vez notaste una tensión invisible. La verdad no reside en la malicia, sino en un toque de magia que escapa a mi control. Caroline, un alma cercana a mi corazón, ha sido perturbada.^^Si alguna vez vuelves a verme cerca de Caroline, debes saber que no soy más que un amigo preocupado, con un toque delicado. Quizás, con el tiempo, la magia se asiente y pueda ofrecerle el consuelo que necesita.^^   -M. Rasmodius",
	"Caroline.WizardStalk.title": "Sobre el bienestar de Caroline",
	//6 heart event - good ending
	"Caroline.ComfortLove": "Mi ${querido^querida}$ ${amigo^amiga}$,^Sólo quería darte las gracias por estar a mi lado ayer. Tu apoyo significó mucho.^^Las cosas estaban difíciles en casa y yo me sentía bastante mal. Pero hablar contigo me ayudó a sentirme mejor. Eres ${un gran amigo^una gran amiga}$ y te agradezco que me hayas escuchado.^^Pongámonos al día pronto, ¿quizá tomando un té?^^   -Caroline",
	"Caroline.ComfortLove.title": "Gracias por estar ahí para mí <",
	//8 Heart Event - B
	"Caroline.PierreBribe": "${Querido^Querida}$ @,^Considera esto una... ofrenda de paz. Metido dentro de este sobre, encontrará un poco de algo - una muestra de, bueno, digamos que una disculpa.^^Me pasé de la raya el otro día. Verte a ti y a Caroline... bueno, digamos que los celos sacaron lo mejor de mí. No hay excusa para mi comportamiento, y por eso, me disculpo sinceramente.^^Pero aquí está la cosa, @. Eres una buena persona, así que por favor, mantén este incidente entre nosotros.  Piensa en ello como una inversión en nuestra, ejem, continua asociación de negocios.^^   -Pierre",
	"Caroline.PierreBribe.title": "¡Por favor, manténlo en secreto!",
	//10 heart event
	"Caroline.WizardCure": "${Queridísimo^Queridísima}$ @,^Hay un secreto que ya no puedo guardar. Abigail, la enérgica joven de cabello amatista, no es una habitante más de Pueblo Pelícano - es mi hija biológica.^^Hace años, una poderosa maldición amenazó a Abigail. En un intento desesperado por debilitar su poder, tomé la angustiosa decisión de confiar su cuidado a Pierre y Caroline. La magia era... volátil, y creí que separarme de ella disminuiría su influencia.^^Durante un tiempo, pareció funcionar. Abigail prosperaba bajo su cuidado y su espíritu aventurero florecía. Sin embargo, los recientes problemas en el hogar - un creciente distanciamiento entre Pierre y Caroline - parecen estar amplificando los efectos de la maldición. Esto me preocupa profundamente.^^He percibido un cambio en la magia y el tiempo apremia. Encuéntrame en el Bosque Secreto, pero sólo si traes el Ojo de tigre. Es la clave para romper la maldición.^^   -M. Rasmodius",
	"Caroline.WizardCure.title": "Urgente: Se necesita ayuda para Abigail",
	"Caroline.AbigailMissing": "A los residentes preocupados de Pueblo Pelícano^^A petición de Pierre y Caroline, la Alcaldía se dirige a la comunidad con una petición de ayuda. Su hija, Abigail, lleva desaparecida desde ayer por la tarde.^^Aunque Abigail es conocida por su espíritu aventurero y su amor por explorar la naturaleza, su prolongada ausencia ha causado una gran preocupación a su familia y a todo el pueblo.^^Abigail es una mujer joven con un característico pelo morado. Suele llevar botas de combate negras y una camiseta azul oscuro y morada. También es posible que lleve su tirachinas.^^Si tiene CUALQUIER información sobre el paradero de Abigail, por pequeño que parezca el detalle, póngase en contacto con la Alcaldía inmediatamente. Además, la información puede ser reportada directamente a Pierre o Caroline en la Tienda General de Pierre.^^La seguridad de los residentes es primordial, y cualquier pista podría ser crucial para reunir a Abigail con su preocupada familia.^^Atentamente,^Alcalde Lewis^Alcaldía de Pueblo Pelícano",
	"Caroline.AbigailMissing.title": "Urgente: ¿Has visto a Abigail?",
	"Caroline.AbigailSettle": "Hola, @,^¡Sólo estoy reportándome! Últimamente las cosas han sido, bueno, ¡más locas de lo que pensé que podrían ser! Pero tengo que decirte, todo se está asentando ahora.^^Al principio, las cosas se liaron después de que... bueno, durante un tiempo siempre me sentí un poco como un murciélago perdido en la oscuridad, sin encajar nunca en ningún sitio. Entonces, bueno, todo el asunto con mis padres explotó.^^Mamá y papá, ya sabes, decidieron separarse. Pero honestamente, creo que es lo mejor. Lo loco es que, aunque Pierre no sea de mi sangre o lo que sea, siempre ha estado ahí para mí. Lo mismo pasa con Caroline, aunque a veces se queje de mi color de pelo. El punto es, ellos son la familia que conozco, y eso no va a cambiar.^^En cuanto al Mago, me parece bien que las cosas sean como son. Un tipo misterioso y todo eso. La sangre no hace una familia, ¿sabes? Es la gente que está ahí para ti, en las buenas y en las malas, ¡como tú!^^De todos modos, pensé que te daría los detalles. La vida lanza algunas serias bolas curvas, pero oye, hay que aprender a balancearse con los golpes, ¿verdad?^^Gracias por ser siempre un buen oyente.^   -Abigail",
	"Caroline.AbigailSettle.title": "Sólo quería ponerle al día",
	"Caroline.AbigailStayed": "Hola, @,^¡Sólo estoy reportándome! Últimamente las cosas han sido, bueno, ¡más locas de lo que pensé que podrían ser! ¿Pero adivina qué? Las cosas están mejorando.^^Durante un tiempo después que... bueno, digamos que las cosas fueron difíciles. Me sentía perdida, como un murciélago con un ala rota, sin saber a dónde pertenecía. Entonces, las cosas se pusieron muy tensas con mamá y papá.^^Pero la buena noticia es que han decidido arreglar las cosas. Les ha costado, pero han vuelto a hablarse y parece que están mejor.^^Es un poco raro verlos tan diferentes, pero en el buen sentido. A pesar de todo, Pierre y Caroline han sido increíbles. No son mi familia biológica, pero siempre han estado ahí para mí, aunque Caroline todavía se queje a veces de mi color de pelo. Son la familia que elegí, y eso no va a cambiar.^^En cuanto al Mago, las cosas están bien entre nosotros. Misterioso como siempre, pero así es el Mago. Supongo que la sangre no define a la familia después de todo.^^Es la gente con la que puedes contar, pase lo que pase, ¡como tú! De todos modos, sólo quería ponerte al día. La vida lanza bolas curvas, pero hey, tenemos que aprender a balancearnos con los golpes, ¿verdad?^^Gracias por ser siempre tan ${buen amigo^buena amiga}$.^   -Abigail",
	"Caroline.AbigailStayed.title": "Sólo quería ponerle al día",

	//EVENT AFTERMATH
	//2 Heart Event - Museum Book
	"Caroline.ShyBook.Dialogue": "¡Ya está!$1#$b#¿El bibliotecario te asustó ayer.$8#$b#¿O era algo totalmente distinto?$6",
	//2 Heart Event - Museum Beuty
	"Caroline.CryBook.Dialogue": "¡Hola, ${querido^querida}$!$1#$b#¿Sigues ${deprimido^deprimida}$ por lo de ayer?$2#$b#${Querido^Querida}$, sé que la vida puede ser dura a veces, pero esconderse no es la solución.$5#$b#Pero no tienes que decírmelo ahora, ${querido^querida}$, si no quieres.$8#$b#Tómate tu tiempo, estaré aquí cuando estés ${listo^lista}$ para hablar de ello.$5",
	
	//8 Heart Event - A - Escape
	"Caroline.Caroline.SunKiss.Dialogue": "Abigail se niega a hablar conmigo... ¿Crees que me odia?$10",
	"Caroline.Abigail.SunKiss.Dialogue": "No quiero hablar ahora.$5#$b#¡Por qué no vas a hablar con mamá!$5#$e#%Abigail se niega a seguir hablando.",
	"Caroline.Pierre.SunKiss.Dialogue": "Abigail ha estado actuando raro últimamente.$2#$b#Espero que esté bien.$2",
	
	//8 Heart Event - B - Pierre
	"Caroline.Caroline.HuH.Dialogue": "¡${Querido^Querida}$! ¿Estás bien?$10#$b#No te lo mereces.$2#$b#No te preocupes, no dejaré que Pierre se salga con la suya.$3",
	"Caroline.Abigail.HuH.Dialogue": "Me siento... cansada.$2#$b#Creo que ni siquiera le importa lo que digo.$2#$b#Tal vez nunca lo hizo.$2",
	"Caroline.Pierre.HuH.Dialogue": "No debería haber reaccionado así. Fue infantil e incorrecto.$2#$b#Lo siento, @.$2",
	"Caroline.Lewis.HuH.Dialogue": "He oído que Joja ha puesto en aprietos a Pierre.$2#$e#No puedo culpar a Caroline por estar molesta...$2",
	"Caroline.Marnie.HuH.Dialogue": "Otra noche en el salón, otra tragedia en Pueblo Pelícano. La pobre Abigail sólo necesita a su padre.$2",
	"Caroline.Demetrius.HuH.Dialogue": "El salón parece ser la nueva plaza del drama. Tal vez algunas ofrendas de paz para Abigail están en orden...$2",
	"Caroline.Robin.HuH.Dialogue": "Vi que las cosas se pusieron feas en el salón anoche.$2#$b#Los niños no deberían tener que lidiar con eso.$2",
	"Caroline.Clint.HuH.Dialogue": "Semejante exhibición... Espero que Abigail no se asustara demasiado.$2",
	"Caroline.Willy.HuH.Dialogue": "Mares agitados en el salón, ¿eh? Espero que Abigail esté bien.$2#$b#Oí que sólo quería que su padre volviera a casa.$2",
	"Caroline.Gus.HuH.Dialogue": "El control de Joja sobre el pueblo se está estrechando, eso es seguro.#$b#Espero que Pierre encuentre una manera de mantener la cabeza fuera del agua... por el bien de Abigail, al menos.$2",
	"Caroline.Emily.HuH.Dialogue": "¡Qué negatividad!$2#$e#Quizá Abigail necesite un cristal o algunas afirmaciones positivas para ahuyentar esas malas vibraciones.$1",
	"Caroline.Pam.HuH.Dialogue": "Parece que Pierre necesita ahogar sus penas en otra parte.$2#$b#No me sorprende que Abigail quiera irse.$2",

	//8 Heart Event - C - Skipped
	"Caroline.Caroline.BrokenFrame.Dialogue": "Yo...$10#$b#Lo siento...$11#$b#No quería que te vieras ${envuelto^envuelta}$ en todo esto.$11",
	"Caroline.Abigail.BrokenFrame.Dialogue": "Sólo...$3#$b#Intenta no empeorar las cosas, ¿vale?$2#$b#No creo que mamá pueda soportar mucho más de esto.$2",
	"Caroline.Pierre.BrokenFrame.Dialogue": "Supongo que podría haber manejado mejor las cosas.$2#$b#No quería quebrarme así.$2#$b#En cualquier caso, gracias de nuevo por intervenir.#$b#Pero tal vez la próxima vez, sólo... mantente al margen.$2",

	//12 Heart Event
	"Caroline.BeachFuss.Dress.Dialogue": "Te encanta verme en bikini blanco, ¿verdad, amorcito?$5#$b#¿Quieres que me lo ponga más a menudo?$8",
	"Caroline.BeachFuss.Ocean.Dialogue": "Guau, amorcito, este día es realmente algo, ¿no?$2#$b#Debe ser 'agradable' tener todo ese tiempo libre, en este día de relajo.$3#$b#Debe ser 'agradable' ser tan ${despreocupado^despreocupada}$.$8#$b#¿No lo crees, amorcito?$2#$e#%Parece que Caroline no está interesada en hablar más.",
	
	//14 Heart Event - Wholesome
	"Caroline.BathLove.Food.1": "¿Recuerdas lo que mencionaste anoche?$1#$b#Bueno, cumplí mi promesa y lo hice para ti.$8",
	"Caroline.BathLove.Food.2": "Disfruta de tu día, amorcito.$5",
	
	//14 Heart Event - Lewd
	"Caroline.BathFuss.Dialogue": "Anoche fue salvaje, ¿verdad, amorcito?$8#$b#Me hiciste temblar y gemir tan fuerte que pensé que alguien nos oiría.$5#$b#Mantengámoslo en secreto entre ${nosotros^nosotras}$, ¿de acuerdo?$6",

	//MAIL AFTERMATH
	"Caroline.AbigailMissing.Dialogue": "¿Has visto a mi Abby? Mi corazón no está tranquilo...$10",
	"Pierre.AbigailMissing.Dialogue": "¿Has visto a Abigail? Se está haciendo tarde...$2",
	"Lewis.AbigailMissing.Dialogue": "¿Abigail desaparecida? Ella no es así en absoluto. Tenemos que encontrarla, @.$3",
	"Sam.AbigailMissing.Dialogue": "¿Has visto a Abby? Habíamos quedado anoche para ensayar con la banda, pero no apareció.$8",
	"Sebastian.AbigailMissing.Dialogue": "¿Abigail ha desaparecido? No la he visto. ¿Crees que está abajo en las minas de nuevo?$2",
	"Robin.AbigailMissing.Dialogue": "Sebastian mencionó que estuvo ayer en las minas.$2#$b#Pero segura que allá no estaría desaparecida, ¿verdad?$2",
	"Demetrius.AbigailMissing.Dialogue": "¿Desaparecida, dices? No tengo la menor idea de dónde puede estar Abigail.$2#$b#Tal vez simplemente se ha perdido explorando. ¿Has revisado las partes más profundas del bosque?$2",
	"Maru.AbigailMissing.Dialogue": "¿Abigail ha desaparecido? Eso es... inusual.$2#$e#¿Has mirado en el antiguo centro cívico? A veces le gusta echarse la siesta allá.",
	"Jodi.AbigailMissing.Dialogue": "Oh cielos, ¿Abigail desaparecida?#$e#Sam no la ha visto en todo el día... Todo esto es tan preocupante...$2",
	"Kent.AbigailMissing.Dialogue": "Desaparecida, ¿eh? Será mejor que la encuentres, ${chico^chica}$. No necesitamos que Abigail salga lastimada.",
	"Vincent.AbigailMissing.Dialogue": "¡${Señor^Señorita}$! ¡${Señor^Señorita}$! ¿Ya encontraste a Abby?$2#$b#¡Quizás se está escondiendo y nos va a asustar!$3",
	"Pam.AbigailMissing.Dialogue": "¿Abigail desaparecida? Huh, eso es extraño.$4#$b#No te creerías los líos en los que me metía cuando tenía su edad, pero al final siempre volvía.$1#$b#Probablemente esté explorando algún lugar salvaje.$2",
	"Penny.AbigailMissing.Dialogue": "Oh no... ¿Has mirado en la biblioteca? A veces va allá para escapar de su padre regañándola.$2#$b#No puedo imaginarla ausente tanto tiempo...$2",
	"Haley.AbigailMissing.Dialogue": "Bueno, es una persona menos con la que competir en el próximo concurso de baile...$2#$b#No es que me importe, pero si eso significa menos drama, que les vaya bien.$3",
	"Alex.AbigailMissing.Dialogue": "Aún así, no es mi problema. Deberías revisar las minas, siempre está buscando pelea con algún monstruo.$5",
	"Marnie.AbigailMissing.Dialogue": "Pero... ella no desaparecería así como así, ¿verdad?$2#$e#¿Has revisado el bosque? Ha estado hablando de esas extrañas setas brillantes últimamente...$2",
	"Shane.AbigailMissing.Dialogue": "Imagínate... Probablemente huyó a alguna parte con ese pelo púrpura suyo para evitar responsabilidades. No es mi problema.$2",
	"Jas.AbigailMissing.Dialogue": "¿La señorita Abigail ha desaparecido? Pero, ¿adónde podría haber ido?$2#$b#¡Quizá se ha vuelto a perder en el bosque!$4",
	"Wizard.AbigailMissing.Dialogue": "Relájate, está a salvo por ahora. La encontré en el bosque secreto, bajo una extraña influencia mágica.#$b#Estoy trabajando en una cura, pero necesitamos ser discretos. No se lo digas a Pierre y Caroline todavía, la preocupación complica las cosas.#$e#Vigila las rarezas cerca del bosque Tizón, ¿vale?",

	// ITEMS
	"Caroline.Teddy.name": "El osito de peluche de Caroline",
	"Caroline.Teddy.description": "Un recuerdo de la infancia, desgastado pero muy querido. Muévelo con cuidado, su abrazo tiene una fuerza sorprendente.",
	"Caroline.Portrait": "Retrato de Caroline",
	"Caroline.Poster": "Retrato de Caroline", // alt name if Caroline is Single is installed

	// STRINGS FROM MAPS
	"Caroline.CSCRoom.0": "El suave sonido del agua es tranquilizador.",
	"Caroline.CSCRoom.1": "Recuerdo haber visto esta planta en su antigua casa. Es agradable verla prosperar acá.",
	"Caroline.CSCRoom.2": "Trajo esto de su antigua casa, ¿no?",
	"Caroline.CSCRoom.3": "Caroline debe haber estado arreglando las plantas otra vez.#Siempre es muy exigente con los detalles.",
	"Caroline.CSCRoom.4": "Esta tubería lleva el agua a la fuente.#Probablemente insistió en mantenerla limpia",
	"Caroline.CSCRoom.5": "La luz aquí se siente cálida, igual que su presencia.",
	"Caroline.CSCRoom.6": "Un lugar acogedor para tomar el té.#Puedo imaginarme a Caroline sentada aquí.",
	"Caroline.CSCRoom.7": "Un osito de peluche muy querido.#Me pregunto si Caroline me contará alguna vez la historia que hay detrás.",
	"Caroline.CSCRoom.8": "Estas flores están dispuestas tan perfectamente.#Caroline debe haber pasado tiempo asegurándose de que se vean bien.",
	"Caroline.CSCRoom.9": "Estas plantas añaden un toque suave al espacio.",
}