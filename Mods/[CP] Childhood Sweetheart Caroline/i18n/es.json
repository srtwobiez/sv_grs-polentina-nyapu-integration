
{
	/************	2.2.0	************/
	//Gift Taste Dialogue
	//LOVE//
	"CSC.GiftTaste.Loved.0": "Siempre sabes qué traerme.#$b#¿Intentas que me sonroje?$1",
	"CSC.GiftTaste.Loved.1": "¡Oh, te has acordado!$1#$b#Ahora tengo que hacer algo dulce para ti también.$6",
	"CSC.GiftTaste.Loved.2": "Me malcrías, ¿lo sabías?$6#$b#No es que me queje.$8",
	"CSC.GiftTaste.Loved.3": "Esto es encantador.$1#$b#Realmente tienes debilidad por mí, ¿verdad?",
	"CSC.GiftTaste.Loved.4": "Nunca has necesitado regalos para hacerme feliz, pero esto hace que se me derrita el corazón.$1",
	"CSC.GiftTaste.FishTaco.0": "¿Un taco de pescado?#$b#Conoces el camino a mi corazón... o al menos a mi estómago.$6",
	"CSC.GiftTaste.FishTaco.1": "¡Te acordaste de que me encantan!$1#$b#Te has ganado oficialmente una sonrisa mía.$5",
	"CSC.GiftTaste.FishTaco.2": "No he tenido uno de estos en años.$8#$b#Realmente sabes cómo tratar a alguien.$1",
	"CSC.GiftTaste.TropicalCurry.0": "¡Curry tropical! Huele tan bien.$1",
	"CSC.GiftTaste.TropicalCurry.1": "No tenías por qué tomarte la molestia, pero me alegro de que lo hayas hecho.$1",
	"CSC.GiftTaste.TropicalCurry.2": "¡Se ve delicioso!#$b#Si luego no me encuentras, sabrás que estaré en la cocina disfrutándolo.$6",
	"CSC.GiftTaste.SummerSpangle.0": "¿Una lentejuela de verano? Te acordaste.$1#$b#Solía ponerlas detrás de mi oreja cuando era niña.$5",
	"CSC.GiftTaste.SummerSpangle.1": "Me siguen gustando tanto como entonces.$1",
	"CSC.GiftTaste.SummerSpangle.2": "¿Escogiste esto para mí? Eso es muy dulce de tu parte.$1",
	"CSC.GiftTaste.GreenTea.0": "Realmente conoces el camino a mi corazón, ¿verdad?$1",
	"CSC.GiftTaste.GreenTea.1": "Me acabas de alegrar el día.$1#$b#Sentémonos más tarde y compartamos una taza.$5",
	"CSC.GiftTaste.GreenTea.2": "La forma en que esto huele podría calmar a cualquiera.$1#$b#Quizá por eso me gusta tenerte cerca.$6",
	"CSC.GiftTaste.GreenTea.3": "Parece que siempre recuerdas las pequeñas cosas que me hacen feliz.$5#$b#Te juro que a veces me conoces mejor que yo misma.$8",
	"CSC.GiftTaste.GreenTea.4": "Cuidado, regalos como este podrían estropearme.$6#$b#Lo próximo será que espere té todas las tardes.$8",
	//LIKE//
	"CSC.GiftTaste.Liked.0": "Oh, esto me viene muy bien.#$b#Realmente sabes cómo mantener las cosas interesantes, ¿eh?$6",
	"CSC.GiftTaste.Liked.1": "Qué agradable sorpresa.$1#$b#Aún tienes buenos instintos.",
	"CSC.GiftTaste.Liked.2": "No está nada mal.#$b#Realmente tienes tus momentos.$5",
	"CSC.GiftTaste.Liked.3": "No me lo esperaba, pero me gusta.#$b#Parece algo que sólo tú elegirías.$4",
	"CSC.GiftTaste.Liked.4": "Sencillo, pero reflexivo.#$b#Siempre consigues acertar de alguna manera.$5",
	"CSC.GiftTaste.Daffodil.0": "¿Un narciso? Qué dulce.#$b#Me recuerda a cuando solíamos recogerlos junto a la valla.$1",
	"CSC.GiftTaste.Daffodil.1": "Estos siempre me hacen pensar en el comienzo de la primavera.#$b#Que aparezcas con uno encaja de alguna manera.$1",
	"CSC.GiftTaste.Daffodil.2": "¿Has encontrado esto por ahí?$2#$b#Me dan ganas de volver a pasear por los campos.",
	"CSC.GiftTaste.WildHorseradish.0": "Un... rábano silvestre, ¿eh?$11#$b#Siempre te gustó encontrar problemas en el bosque.$6",
	"CSC.GiftTaste.WildHorseradish.1": "Sólo ver esto me recuerda cuando nos retábamos a comerlo.$1#$b#Ese día casi te quemas la lengua.$8",
	"CSC.GiftTaste.WildHorseradish.2": "Sigue oliendo tan picante como lo recordaba.#$b#Entonces hacíamos el ridículo con esto, ¿no?$8",
	"CSC.GiftTaste.TeaLeaves.0": "¿Hojas de té frescas?#$b#Ya me imagino lo bien que olerá esto preparado.$5",
	"CSC.GiftTaste.TeaLeaves.1": "¿Las has cultivado tú ${mismo^misma}$?$1#$b#Haré algo bueno con esto más tarde.$5",
	"CSC.GiftTaste.TeaLeaves.2": "Estas parecen frescas.#$b#Debes haberlas elegido con cuidado.$1",
	"CSC.GiftTaste.TeaLeaves.3": "Su olor me recuerda a cuando cogíamos hierbas del jardín y fingíamos que hacíamos pociones mágicas.$8",
	"CSC.GiftTaste.TeaLeaves.4": "Tienes buen gusto. Estas serán perfectos para una tarde tranquila.$1",
	//NEUTRAL//
	"CSC.GiftTaste.Neutral.0": "Oh, este está... bien.$11#$b#No es exactamente lo mío, pero le encontraré un sitio.",
	"CSC.GiftTaste.Neutral.1": "Siempre me sorprendes con tus elecciones.#$b#Aún no estoy segura de lo que opino de ésto.$11",
	"CSC.GiftTaste.Neutral.2": "Hmm. No me encanta, pero tampoco está mal.",
	"CSC.GiftTaste.Neutral.3": "No sé si estás siendo ${considerado^considerada}$ o sólo tienes curiosidad por ver qué digo.$11",
	"CSC.GiftTaste.Neutral.4": "Bueno, no es terrible.$11#$b#Eso es algo, ¿verdad?$0",
	"CSC.GiftTaste.Neutral.5": "Esto no me hace mucho, pero aun así me lo quedaré.",
	"CSC.GiftTaste.Neutral.6": "Nunca se te acaban las ideas, ¿verdad?#$b#Te reconozco el mérito de intentarlo.",
	//DISLIKE//
	"CSC.GiftTaste.Disliked.0": "Oh... bueno, no es exactamente lo que esperaba, pero le encontraré alguna utilidad.$2",
	"CSC.GiftTaste.Disliked.1": "¿De verdad pensaste en mí con esto? Eso es... atrevido.$2",
	"CSC.GiftTaste.Disliked.2": "Agradezco la idea, aunque no sé muy bien qué debo hacer con esto.$2",
	"CSC.GiftTaste.Disliked.3": "Tienes un gusto interesante para los regalos.$3#$b#Lo reconozco.$2",
	"CSC.GiftTaste.Disliked.4": "Jaja, ¿me estás poniendo a prueba otra vez?$3#$b#¿Sólo quieres ver cómo reaccionaría?$2",
	"CSC.GiftTaste.Disliked.5": "Seré honesta, esto no es mi favorito.$2#$b#Pero que lo intentes cuenta para algo.$2",
	"CSC.GiftTaste.Disliked.6": "Tienes suerte de que me gustes más de lo que me disgusta este regalo.$2",
	//HATE//
	"CSC.GiftTaste.Hated.0": "De acuerdo, seré honesta...$3#$b#Ni siquiera puedo fingir que me gusta esto.$2",
	"CSC.GiftTaste.Hated.1": "No estoy segura de lo que estabas pensando, pero definitivamente no era sobre mí.$3",
	"CSC.GiftTaste.Hated.2": "Eso es... guau.$2#$b#Realmente encontraste algo que nunca podría usar.$8",
	"CSC.GiftTaste.Hated.3": "Por favor, dime que era una broma.$8#$b#Porque si no lo fuera, tenemos que hablar de tus elecciones de vida.$2",
	"CSC.GiftTaste.Hated.4": "Sabes que te adoro, ¿pero esto?$11#$b#Esto podría ponerlo un poco a prueba.$2",
	"CSC.GiftTaste.Quartz.0": "¿Cuarzo?$2#$b#Es bonito, lo reconozco, pero no es precisamente útil.$2",
	"CSC.GiftTaste.Quartz.1": "Sabes que no soy un cuervo, ¿verdad?$3#$b#No colecciono piedras brillantes.$2",
	"CSC.GiftTaste.Quartz.2": "Aprecio el esfuerzo, pero la próxima vez, quizá algo que no pertenezca a una caja de herramientas.$2",
	"CSC.GiftTaste.Salmonberry.0": "Oh... frambuesas.$11#$b#Tarta como siempre.$3#$b#Nunca me gustaron.$2",
	"CSC.GiftTaste.Salmonberry.1": "¿Recuerdas cuando intentamos hacer mermelada con esto?$8#$b#Sabía a arrepentimiento.$2",
	"CSC.GiftTaste.Salmonberry.2": "Sabes, he intentado que me gusten más veces de las que puedo contar.$2#$b#Nunca funciona.$3",

	//Engagement Dialogue
	"CSC.EngagementDialogue.A.0": "Mírate, ${querido^querida}$... sigues sonriendo así.#$b#Yo también sonrío, aunque me parece un poco surrealista.$1#$b#Después de todos estos años, aquí estamos, de alguna manera.$4",
	"CSC.EngagementDialogue.A.1": "Apenas dormí anoche, ${querido^querida}$.$3#$b#Cada vez que cerraba los ojos, te veía de pie con ese colgante.$6#$b#Supongo que no quería despertarme por si no era real.$8",
	"CSC.EngagementDialogue.A.2": "Sabes, cuando éramos más jóvenes, solía bromear con que me seguirías siempre.#$b#No pensé que te lo tomarías tan en serio, ${querido^querida}$.$8",
	"CSC.EngagementDialogue.A.3": "Se lo dije a Pierre esta mañana.#$b#Fingió estar ocupado con la caja registradora, pero vi que le temblaba la mano.$3#$b#Creo que todavía está tratando de procesar que me voy a casar contigo. No puedo culparlo.",
	"CSC.EngagementDialogue.A.4": "No dejo de tararear.#$b#Es una tontería, pero hoy todo parece más ligero.$4#$b#Como si el mundo hubiera estado esperando a que por fin nos diéramos cuenta, ${querido^querida}$.$5",
	"CSC.EngagementDialogue.B.0": "Mañana es el día, ${querido^querida}$.$1#$b#He tenido muchas mañanas en este pueblo, pero algo me dice que recordaré esa el resto de mi vida.$6",
	"CSC.EngagementDialogue.B.1": "Traté de ayudar a Jodi con su jardín hoy.#$b#...Pero ella sólo sonrió y dijo que lo tenía todo bajo control.$2#$b#Creo que todo el mundo por aquí está secretamente tratando de hacerme sonrojar.$3",
	"CSC.EngagementDialogue.B.2": "Me preocupaba que la gente hablara.#$b#Yo, la mayor, tú, aún descubriendo cosas.$6#$b#Pero míranos ahora, ${querido^querida}$. Supongo que les hemos dado una lección, ¿no?$8",
	"CSC.EngagementDialogue.B.3": "Aún no puedo creer que me levante y te vea todos los días.#$b#Pero que no se te suba a la cabeza. Aún espero que ayudes con los platos.$6",
	"CSC.EngagementDialogue.B.4": "No estoy nerviosa. Ni siquiera un poco.$3#$b#Sólo... emocionada.$4#$b#Es como si hubiera recorrido un largo camino y mañana por fin pudiera parar y descansar contigo, ${querido^querida}$.$5",

	//CSFiles Strings
	"CSC.AfterWedding.0": "No dejo de sonreír.#$b#Cada vez que lo pienso... estamos realmente ${casados^casadas}$.$1#$b#Después de todo, después de todos estos años. Se siente bien, ¿no es así, ~cariño~?$5",
	"CSC.AfterWedding.1": "Así que... ¿empiezo a llamarte cariño ahora o espero a que te lo hayas ganado, ${querido^querida}$? $6#$b#No te pongas tan ${nervioso^nerviosa}$, sólo bromeo a medias.$8",
	"CSC.AfterWedding.2": "Bueno, ~cariño~, lo hicimos.#$b#Ahora estás oficialmente ${atrapado^atrapada}$ conmigo.$8#$b#No te preocupes, intentaré no reordenar todos tus muebles... sólo las partes feas.$6",
	"CSC.AfterWedding.3": "Estaba practicando llamarte cariño antes, ~cariño~.#$b#Sonaba... bien. ¿Crees que podrías acostumbrarte a escuchar eso cada mañana?$1",
	"CSC.AfterWedding.4": "La ceremonia pasó tan rápido, ~cariño~.#$b#En un momento estaba ahí de pie intentando no llorar.$11#$b#Y al siguiente estábamos caminando ${juntos^juntas}$ a casa.$4#$b#Creo que esa es mi parte favorita.$5",
	"CSC.Engaged.0": "¡Vaya! El... ¿Colgante de sirena?$5#$b#Espera un minuto... Esto no es para mí, ¿verdad?$3#$b#Oh, ¿hablas... en serio?$11#$b#Tu... ¿Promesa de infancia? ¿Qué es eso? No recuerdo nada.$2#$b#(Ah, parece que ${él^ella}$ está a punto de llorar)$10#$b#Vale, vale... ¡Sólo te estaba tomando el pelo! ¡Lo recuerdo!$8#$b#¡Acepto! Sabes que no puedo resistirme a ti.$5#$b#",
	"CSC.Engaged.1": "¿Así que todavía te gusto?$11#$b#Realmente te comprometiste con nuestra Promesa de la Infancia, ¿verdad?$8#$b#Ah, los recuerdos me invaden ahora.$10#$b#Está bien, lo admito, todavía tienes un lugar especial en mi corazón, ${querido^querida}$.$5#$b#",
	"CSC.Engaged.2": "¿Oh? ¿Me estás dando esto? Qué inesperado...$2#$b#Después de todo con Pierre, nunca pensé que recibiría algo así.$11#$b#Es un símbolo de nuevos comienzos, ¿no?#$b#Gracias, ${querido^querida}$, acepto.$5",
	"CSC.Engaged.3": "Un... ¿Un colgante de sirena? ¿Para mí?#$b#Realmente has crecido, ¿verdad ${querido^querida}$? $8#$b#Aún recuerdo cuando ni siquiera podías mirarme a los ojos sin ponerte ${rojo^roja}$.$2#$b#Bueno, considéralo mi forma de decir... que me di cuenta.$5",
	"CSC.Engaged.4": "¿Me estás dando esto?$2#$b#Espero que te des cuenta de dónde te estás metiendo, ${querido^querida}$. $3#$b#Bebo demasiado té, hablo demasiado y tarareo cuando limpio.$8#$b#¿Todavía estás ${seguro^segura}$?$6#$b#...De acuerdo. Acepto.$1",
	"CSC.Engaged.C": "Se lo haré saber al alcalde Lewis... nuestra ceremonia será en tres días.$1#$b#No llegues tarde, ${querido^querida}$.$6",

	//Movie Dialogues
	"CSC.MovieInvitation.0": "¿Una película? Parece una forma perfecta de relajarse.#$b#Vámonos, ${querido^querida}$.$1",
	"CSC.MovieInvitation.1": "Sabes que nunca puedo decir que no a pasar tiempo contigo.$6#$b#Cuenta conmigo.$1",
	"CSC.MovieInvitation.2": "Hacía demasiado tiempo que no hacíamos algo así.#$b#Lo estoy deseando.$8",
	"CSC.MovieInvitation.spouse.0": "¿Una película?$2#$b#Claro, me vendría bien un descanso.#$b#Intenta no elegir nada que me haga dormir, cariño.$6",
	"CSC.MovieInvitation.spouse.1": "¿Tú también compras los aperitivos, o se supone que tengo que compartir tus palomitas?$6#$b#Muy bien, vamos.$1",
	"CSC.MovieInvitation.spouse.2": "Me preguntaba qué hacer conmigo misma.$11#$b#No hagas que me arrepienta, cariño.",
	"CSC.MovieInvitation.spouse.3": "Si esta es tu forma de librarte de las tareas, está funcionando.$6#$b#La granja puede esperar, supongo.$8",
	"CSC.MovieInvitation.spouse.4": "Sabes, para ser una pareja casada no hacemos esto lo suficiente.#$b#Más vale que sea bueno.$1",
	"CSC.Spring.0.Before": "¡Hace tanto que espero ver esta película!$8",
	"CSC.Spring.0.During": "%A medida que te acercas, la oyes susurrar.#$b#¡Espero que las semillas estén bien!$1#$b#Sigue adelante, no te rindas.$5#$b#%La encuentras totalmente encantadora.",
	"CSC.Spring.0.After": "Este ha sido el día más feliz.$1#$b#Gracias.$5#$b#¡Que seas tan resistente como ese arbolito!$8",
	"CSC.Spring.1.Before": "Solíamos amontonar mantas y ver cualquier cosa que saliera, ¿recuerdas?$6#$b#Siempre elegías las cosas más raras, pero nunca me importó.$1#$b#Supongo que aún tengo debilidad por tus sorpresas.$5",
	"CSC.Spring.1.During": "No sabía que existieran lugares tan hermosos en el mundo.$1",
	"CSC.Spring.1.After": "Pero aun así, Stardew Valley siempre será el mejor.$1#$b#Tenemos a Abby, nuestros amigos, y por supuesto...#$b#¿Esperabas que dijera otra cosa?$6#$b#Eres tú.$5",
	"CSC.Summer.0.Before": "¿Es este el juego del que Abby siempre habla?$1#$b#Gracias por ayudarme a entender mejor su mundo.$8",
	"CSC.Summer.0.During": "%Caroline está completamente absorta en la película.#$b#¡Dios mío, eso parece peligroso!$2#$b#¡Espero que el héroe pueda derrotar al villano!$3",
	"CSC.Summer.0.After": "Gracias por invitarme hoy.$1#$b# Me siento diez años más joven.$6",
	"CSC.Summer.1.Before": "Realmente tienes talento para elegir películas raras.$2",
	"CSC.Summer.1.During": "%Caroline te mira con una pequeña sonrisa.#$b#Sabes, esto no es muy interesante.$11#$b#Creo que prefiero mirarte a ti.$6",
	"CSC.Summer.1.After": "Eso fue decepcionante.$2#$b#Me pareció casi infantil.$11",
	"CSC.Fall.0.Before": "¿Invitarme a una película de terror?$2#$b#¿Esperas que me asuste y me aferre a ti?$3#$b#Bueno, puede que te decepcione~$6",
	"CSC.Fall.0.During": "%Caroline está temblando... claramente la está asustando.#$b#%De repente, te rodea con sus brazos.#$b#¡N-No tengo miedo!$3#$b#Sólo pensé... ¡que podrías necesitar algo de consuelo!$3",
	"CSC.Fall.0.After": "Eso no daba miedo en absoluto, ¿ves?$3#$b#¡Estuve perfectamente bien todo el tiempo!$3",
	"CSC.Fall.1.Before": "Ese cartel casi se parece al bosque en el que solíamos jugar.$1#$b#Cuesta creer que una vez pensáramos que las raíces invernales podían caminar.$8",
	"CSC.Fall.1.During": "%Caroline mira mientras charla contigo.#$b#Jaja, ¡estos efectos son tan realistas!$8#$b#Casi me hace creer que las raíces de invierno pueden caminar.$6",
	"CSC.Fall.1.After": "No es una mala película, aunque esa amenaza de maldición del final fue una tontería.$8",
	"CSC.Winter.0.Before": "¡Gracias por sacarme!#$b# Esto parece muy prometedor.$1",
	"CSC.Winter.0.During": "%Caroline la observa atentamente y de vez en cuando se gira para comentar la trama contigo.#$b#Todo irá bien, ¿verdad?#$b#Sólo tienen que seguir la leyenda.$1#$b#$12",
	"CSC.Winter.0.After": "Esa fruta me resulta familiar...$11#$b#No recuerdo dónde lo he visto.#$b#¡Es igual que el símbolo del salón!$2",
	"CSC.Winter.1.Before": "¿Me llevas a ver una película romántica?#$b#Sé exactamente lo que estás pensando.$6",
	"CSC.Winter.1.During": "%Caroline se da cuenta de que la observas y responde con un guiño juguetón.#$b#Te veo mirándome.$6#$b#Tu mirada prácticamente me atraviesa.$5",
	"CSC.Winter.1.After": "Fue agradable, pero si realmente quieres... pasar tiempo conmigo.#$b#¡Es broma!$6",

	//Summit Dialogue
	"CSC.Summit.0": "¿Recuerdas aquella vez que dijiste que yo era tu persona favorita?#$b#Fuiste demasiado ${honesto^honesta}$ para tu propio bien, cariño.$8#$b#Supongo que te funcionó.$6",
	"CSC.Summit.1": "A veces me pregunto qué habría sido de mi vida si no hubieras llegado al pueblo.$2#$b#Entonces me detengo, porque el pensamiento... se siente demasiado vacío.$11#$b#No puedo imaginarme una versión de mí sin esto... sin ${nosotros^nosotras}$.$8#$b#Esto, tú, ${nosotros^nosotras}$, es más de lo que jamás esperé.$5",

	// Marriage Dialogue - Neutral
	"CSC.Neutral.0": "Siento que algo anda mal entre nosotros últimamente...#$e#¿Qué te pasa?$11",
    "CSC.Neutral.1": "¿Podemos hablar un momento?#$e#Estamos ${casados^casadas}$, y quiero saber qué te ronda por la cabeza.$2",
    "CSC.Neutral.2": "Realmente necesito un abrazo...$10",
	"CSC.Neutral.3": "Has estado callada hoy, cariño...$2#$b#¿Me estás ocultando algo?$3",
	"CSC.Neutral.4": "Parecías ${distraído^distraída}$ esta mañana.$2#$e#¿Fue algo en la granja, o sólo estás tratando de poner a prueba mi paciencia?$11",
	"CSC.Neutral.5": "Mi persona favorita parece baja de energía.$2#$e#Ven aquí, déjame recargarte con un abrazo~$6",

	//10-Hearts Part 1
	"CSC.AbigailMissing.1": "Fui a ver junto al lago de montaña, donde ella toca la flauta.$2#$b#Nada. Ni siquiera una huella.$2#$b#¿Dónde más podría estar? Ha pasado todo el día.$3",
	"CSC.AbigailMissing.2": "Hablé con Jodi.$11#$b#Sam dijo que la vio en el museo esta mañana, pero eso fue hace horas.$2#$b#Incluso llamé a Robin para preguntarle si había pasado por su casa. Nada.$11",
	"CSC.AbigailMissing.3": "El cementerio, el museo, el salón... todo vacío.$2#$b#¿Has pasado por la Torre del Mago?$2#$b#Sabes que baja allá cuando está enfadada.$3",
	"CSC.AbigailMissing.4": "Claro que está enfadada.$2#$b#Sólo se acerca a ese lugar cuando intenta alejarse de nosotros.$3#$b#Si no hubiéramos tenido esa pelea esta mañana, tal vez todavía estaría en casa.$3",
	"CSC.AbigailMissing.5": "¿Una pelea? ¿Así es como lo llamas ahora?$3",
	"CSC.AbigailMissing.6": "Estábamos hablando, se enfadó y se fue enfadada.$3#$b#No debí haber levantado la voz, lo admito, pero no hagas como si la hubiera echado.$3#$b#Aparecerá. Siempre lo hace.$2",
	"CSC.AbigailMissing.7": "Siempre dices eso, Pierre, y cada vez lo sientes un poco menos.$3#$b#No puedes seguir fingiendo que esto está bien.$2#$b#Ella está por ahí, sola, y tú sigues intentando salvar las apariencias.$3",
	"CSC.AbigailMissing.8": "No actúes como si todo estuviera bajo control.$3#$b#Se ha ido, Pierre. Se ha ido de verdad.$3#$b#Y seguimos hablando en lugar de hacer algo.$2#$b#Si algo le pasa a ella, nunca te lo perdonaré. Ni a mí misma.$3",
	"CSC.AbigailMissing.9": "${Querido^Querida}$! Oh, gracias a Dios.#$b#No podemos encontrar a Abigail. Ha estado fuera todo el día.$10",
	"CSC.AbigailMissing.Q": "Si has visto algo, por favor, dínoslo, ${querido^querida}$. Nos estamos quedando sin lugares donde buscar.",
	"CSC.AbigailMissing.A": "Mencionó ir a un lugar tranquilo... a pensar.",
	"CSC.AbigailMissing.A.1": "En algún lugar tranquilo... eso suena como ella.$11#$b#Cuando se pone así, se esconde donde nadie pueda alcanzarla.$11",
	"CSC.AbigailMissing.A.2": "O tal vez esté en la Torre del Mago.$3#$b#Vamos, Caroline, al menos podríamos comprobarlo.$3",
	"CSC.AbigailMissing.A.3": "¡No empecemos de nuevo, Pierre!$3",
	"CSC.AbigailMissing.A.4": "Sólo tenemos que encontrarla ${querido^querida}$.$10#$b#...Si la ves, dile que venga a casa.$10#$b#Dile que no estamos enfadados, sólo muy preocupados.$10",
	"CSC.AbigailMissing.A.5": "Y si se niega, dile que estaremos esperando.$2#$b#Sólo necesitamos saber que está a salvo.$2",
	"CSC.AbigailMissing.A.6": "Gracias, ${querido^querida}$.#$b#No sé qué haríamos sin ti.$1",
	"CSC.AbigailMissing.B": "Puede que sólo necesite espacio. Abigail ha hecho esto antes, ¿verdad?",
	"CSC.AbigailMissing.B.1": "¿Espacio?$4#$b#Hoy ha tenido todo el espacio del mundo.$3#$b#¡Está oscureciendo! El espacio no la ayudará si se pierde.$3",
	"CSC.AbigailMissing.B.2": "Pierre, por favor. Tenemos que mantener la calma.$3#$b#Abigail es valiente, pero sabe que nos preocupamos por ella.$2",
	"CSC.AbigailMissing.B.3": "Aún así, ¿podrías echarle un ojo ${querido^querida}$?$11#$b#Si de verdad está despejándose, quizá hable contigo antes que con nosotros.$11",
	"CSC.AbigailMissing.B.4": "Confío en ti, ${querido^querida}$.$10#$b#Nunca me has dado una razón para no hacerlo.$10",
	"CSC.AbigailMissing.B.5": "Si la encuentras, dile que lo sentimos.$2#$b#A los dos.$2",
	"CSC.AbigailMissing.10": "Han buscado por todas partes: en el lago de la montaña, en el cementerio, en el salón, incluso han preguntado a todos sus amigos.#Pierre seguía mencionando la Torre del Mago.#Cada vez que lo hacía, Caroline cambiaba de tema como si no quisiera hablar de ello.#Es el único sitio al que no han ido.#Se está haciendo tarde.#Si Abigail realmente fue allá, entonces tal vez valga la pena comprobarlo por mí ${mismo^misma}$.",

	//10-Hearts Part 2.1
	"CSC.WizardTalk.1": "Ah... estás aquí.",
	"CSC.WizardTalk.2": "Buscas a Abigail, ¿verdad?#$b#Me lo temía.#$b#Las corrientes de la magia han estado inquietas hoy.#$b#Perturbadas.",
	"CSC.WizardTalk.3": "Su vida nunca debió ser así.#$b#No debía ser así, pero el destino rara vez necesita razones.",
	"CSC.WizardTalk.4": "Hay algo que mereces saber, aunque la carga de ello es mía.",
	"CSC.WizardTalk.5": "Abigail es mi hija.#$b#Unida a mí por la sangre, y sí, por la magia.#$b#Y por eso, mi mayor fracaso.",
	"CSC.WizardTalk.6": "Mi poder me hacía intocable, impermeable a sus ataques.#$b#En su rencor, buscó otro camino.",
	"CSC.WizardTalk.7": "Creía que separándonos, su fuerza se desvanecería.#$b#Esa distancia opacaría la maldición hasta que no fuera más que una sombra.",
	"CSC.WizardTalk.8": "No podía vigilarla yo mismo.#$b#Necesitaba una vida lejos de todo esto.",
	"CSC.WizardTalk.9": "Moldeé sus recuerdos, inserté sentimientos falsos en sus mentes.",
	"CSC.WizardTalk.10": "Para ellos, se convirtió en su hija.#$b#La amaban de verdad, aunque vivieran una mentira.",
	"CSC.WizardTalk.11": "Pero recientemente, algo ha vuelto a despertar la maldición.",
	"CSC.WizardTalk.12": "Miedo, conflicto, dolor... esas cosas se alimentan de las emociones humanas.#$b#Fui un tonto al pensar que alguna vez se iría de verdad.",
	"CSC.WizardTalk.13": "He rastreado su energía.#$b#El bosque secreto.#$b#Debemos alcanzarla pronto, antes de que la maldición la consuma por completo.",
	"CSC.WizardTalk.14": "Hay una cosa que necesitaré para ayudarla.#$b#Un ojo de tigre.",
	"CSC.WizardTalk.Q": "Tráemelo aquí, a mi torre.",
	"CSC.WizardTalk.A": "¿Hablas en serio? ¿Abigail está maldita?",
	"CSC.WizardTalk.A.1": "Gravemente.#$b#He estudiado su energía durante años, esperando el momento en que pudiera volver.#$b#Ese momento es ahora.",
	"CSC.WizardTalk.A.2": "Ve, prepárate.#$b#Cuando el cielo se despeje, tráeme el ojo de tigre.#$b#Su energía debe alcanzar el sol antes de que pueda utilizarlo.#$b#Debemos actuar con rapidez.",
	"CSC.WizardTalk.B": "Entonces... ¿debería decirle a Caroline que ha estado criando a tu hija todo este tiempo?",
	"CSC.WizardTalk.B.1": "...No.#$b#Es una carga que yo le impuse, y es mi responsabilidad levantarla.#$b#Cuando esto termine...#$b#Cuando Abigail esté a salvo...#$b#Yo mismo le diré la verdad a Caroline.",
	"CSC.WizardTalk.B.2": "Bromeas, pero tus palabras tienen peso.#$b#Aun así, tenemos poco tiempo.#$b#Trae el ojo de tigre, cuando el cielo esté despejado. Estaré listo.",

	//10-Hearts Part 2.2
	"CSC.WizardCure.1": "Así que has traído el ojo de tigre. Bien.",
	"CSC.WizardCure.2": "Empezaré a preparar el ritual.#$b#Dile a Pierre y Caroline que su hija vive, pero no sin peligro.#$b#Que se reúnan con nosotros antes del anochecer, si sus corazones pueden soportarlo.",
	"CSC.WizardCure.3": "Vamos, @.#$b#El bosque espera... y ella también.",

	//12 Hearts - Dance Practice
	"CSC.DancePractice.1": "Y un uno, y dos, y un... ¿dos?#$b#No, eso no está bien.$2#$b#Es el otro pie primero.$2#$b#Aún así. Cada año, este paso.$3",
	"CSC.DancePractice.2": "¡¿Quién está ahí?!$3",
	"CSC.DancePractice.3": "¡Oh! Cariño, ¿tú también estás aquí?$1#$b#Creía que era la única que conocía este lugar.$11",
	"CSC.DancePractice.4": "Estoy... practicando.$2#$b#La Danza Floral es mañana, y quiero estar perfecta.#$b#Es una tontería, lo sé. Una mujer de mi edad, escabulléndose para practicar un baile tonto.$6",
	"CSC.DancePractice.Q": "¿Qué estás haciendo aquí, cariño?",
	"CSC.DancePractice.A": "Te ves como cuando éramos ${niños^niñas}$.",
	"CSC.DancePractice.A.1": "Oh, silencio. Haces que suene como si fuera hace toda una vida.$2#$b#Apenas había salido de la adolescencia cuando tú perseguías insectos. $6#$b#Ahora soy yo quien persigue el recuerdo de cómo dar un simple paso de baile.$11#$b#Te hace sentir ${viejo^vieja}$, ¿eh, cariño?",
	"CSC.DancePractice.C": "(No digas nada, sólo da un paso adelante y endereza suavemente la corona de flores ladeada que lleva en la cabeza).",
	"CSC.DancePractice.C.1": "Estaba torcida, ¿no?#$b#Nunca se me dio bien ponerme esto.$11#$b#Siempre fuiste mejor con las manos.#$b#La agricultura.$1#$b#Arreglando cosas.$8#$b#Arreglándome.$6",
	"CSC.DancePractice.AC.1": "Este lugar me recordó al viejo pueblo.$11#$b#Antes de todo esto, antes de la tienda, antes de que el valle empezara a sentirse como un hogar.",
	"CSC.DancePractice.AC.2": "Encontré esto en mi primera primavera aquí.#$b#Se sentía... extraño, familiar de alguna manera.$11#$b#Como si me hubiera estado esperando.",
	"CSC.DancePractice.AC.3": "Sabes, solía sentarme aquí cuando era nueva en el pueblo.#$b#Cuando todo parecía demasiado tranquilo. Llevaba un libro o simplemente escuchaba el viento.$11#$b#Me recordaba a casa, a la gente que había dejado atrás.$2",
	"CSC.DancePractice.AC.4": "Cuando nos separamos... Pensé que eso era todo.$2#$b#Sólo un recuerdo de ${un chico^una chica}$ que conocí.$11#$b#Entonces apareciste en casa de Pierre, ${crecido^crecida}$ y con la mirada perdida.#$b#Casi no me creo que fueras tú.$6",
	"CSC.DancePractice.AC.5": "Nunca te lo dije, pero te escribía cartas.#$b#Durante un año después de mudarme.$11#$b#Nunca las envié.#$b#No tenía tu dirección.$2#$b#Solo... hablaba contigo en ellas.$2#$b#Te conté de este valle.#$b#Sobre Pierre.$2#$b#Sobre encontrar esta casa.",
	"CSC.DancePractice.AC.6": "Es una tontería, lo sé...$11#$b#Pero hizo que me sintiera menos como si hubiera perdido a mi mejor ${amigo^amiga}$.#$b#Me hizo sentir menos sola.$2",
	"CSC.DancePractice.AC.7": "Bien. Ahora conoces mi tonto secreto.#$b#Y todavía no soy mejor en el baile.$8#$b#Me he metido tanto en todo esto que ahora me muero de hambre.$2",
	"CSC.DancePractice.AC.Q": "Traje un taco de pescado y unas croquetas de patata. ¿Cuál quieres?",
	"CSC.DancePractice.AC.A": "Taco de pescado, por favor.",
	"CSC.DancePractice.AC.A.1": "Es mi favorito.$3#$b#Lo haces a propósito, ¿no?$2",
	"CSC.DancePractice.AC.A.2": "...Bien.#$b#Pero me debes una.$6#$b#Me llevo las croquetas de patata, pero no estoy contenta.$2",
	"CSC.DancePractice.AC.B": "Corquetas de patata para mí, gracias.",
	"CSC.DancePractice.AC.B.1": "Bien.$1#$b#El taco de pescado es para mí entonces.$8",
	"CSC.DancePractice.AC.B.2": "Esperaba que dijeras eso.#$b#Realmente quería esto.$6",
	"CSC.DancePractice.AC.8": "Creo que se está haciendo tarde, vamos, volvamos.#$b#Necesito sacarme este vestido antes de que lo ensucie.$2#$b#Todavía tengo que ponerme esto para mañana, ¿sabes?$6",
	
	//UNUSED, DO NOT TRANSLATE
	// "CSC.DancePractice.B": "¿Necesitas una pareja que no te juzgue?",
	// "CSC.DancePractice.B.1": "¿Tú? ¿Juzgarme?$2#$b#Me has visto en mi peor momento y, aun así, sigues mirándome con esos ojos.$1#$b#Creo que ya hemos dejado atrás la fase de intentar impresionarnos mutuamente.$8",
	// "CSC.DancePractice.B.2": "Pero sí. Por favor. Solo... sé indulgente conmigo.#$b#Hoy mi orgullo está frágil.$6",
	// "CSC.DancePractice.B.3": "Vale, y luego... y paso, y estirar, y...#$b#No. El tiempo no es el adecuado.$3",
	// "CSC.DancePractice.B.4": "No, esto está todo mal.$2#$b#Parece que nunca haya hecho esto antes.$2",
	// "CSC.DancePractice.B.5": "Mis pies se enredan cada vez.#$b#Pensé que si practicaba sola... bueno. #$b#Ya ves cómo va.",
