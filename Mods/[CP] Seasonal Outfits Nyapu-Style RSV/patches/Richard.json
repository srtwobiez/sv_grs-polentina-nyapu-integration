{
    "Changes": [
        
		{
            "LogName": "RSV Nyapu Edit - Richard Portraits",
            "Action": "EditImage",
			"Priority": "Late",
            "Target": "Portraits/Richard_spring, Portraits/Richard_summer, Portraits/Richard_fall, Portraits/Richard_winter, Portraits/Richard_spring24, Portraits/Richard_fall27-1, Portraits/Richard_fall27-2, Portraits/Richard_rain, Portraits/Richard_Beach",
            "FromFile": "assets/Portraits/Richard/{{TargetWithoutPath}}.png"
        },
		{
            "LogName": "RSV Nyapu Edit - Richard Portraits Base",
            "Action": "EditImage",
			"Priority": "Late",
            "Target": "Portraits/Richard",
            "FromFile": "assets/Portraits/Richard/Richard_fall.png"
        },		
		
		{
			"LogName": "RSV Nyapu Edit - Richard Rain Acc",
            "Action": "EditImage",
			"Priority": "Late",
			"Target": "Portraits/Richard_rain",
			"FromFile": "assets/Portraits/Richard/Richard_acc_rain.png",
			"When": {
				"Weather|contains=Rain, Storm": true,
				"IsOutdoors": true,
				"HasValue:{{DayEvent}}": false,
                "Query: {{Random:{{Range:1,10}}|key=RichardHat}} > 5": true,
			},
			"Update": "OnLocationChange",
			"PatchMode": "Overlay"
		},	
        {
			"LogName": "RSV Nyapu Edit - Richard Winter Acc",
            "Action": "EditImage",
			"Priority": "Late",
			"Target": "Portraits/Richard_winter",
			"FromFile": "assets/Portraits/Richard/Richard_acc_winter.png",
			"When": {
				"IsOutdoors": true,
				"HasValue:{{DayEvent}}": false,
                "Query: {{Random:{{Range:1,10}}|key=RichardHat}} > 5": true,
			},
			"Update": "OnLocationChange",
			"PatchMode": "Overlay"
		},
    ]
}