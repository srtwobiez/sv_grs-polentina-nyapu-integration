{
  "Changes": [
    {
      "LogName": "Fishing Pond Map Overlay",
      "Action": "EditImage",
      "Target": "LooseSprites/map, LooseSprites/map_{{season}}",
      "FromFile": "assets/Maps/Fishing Pond/Fishing.Pond_{{season}}.png",
      "PatchMode": "Overlay",
      "Update": "OnLocationChange",

      "When": {
        "HasMod:|contains=N3cro_92.ReMappingEarthySync": true,
        "HasMod:|contains=Tikamin557.CP.FishingPondFacilities": true,
        "N3cro_92.ReMappingEarthySync/FishingPond": "true"
      },

      "ToArea": {
        "X": 236,
        "Y": 62,
        "Width": 17,
        "Height": 16
      }
    },
    {
			"LogName": "Fishing Pond Grampleton Fields",
			"Action": "EditData",
			"Target": "Data/WorldMap",
      "PatchMode": "Overlay",
      "Update": "OnLocationChange",
			"TargetField": [ "Custom_GrampletonFields", "MapAreas" ],
			"When": {
        "HasMod:|contains=N3cro_92.ReMappingEarthySync": true,
				"HasMod:|contains=flashshifter.GrampletonFields": true,
				"HasMod:|contains=Tikamin557.CP.FishingPondFacilities": true,
        "N3cro_92.ReMappingEarthySync/FishingPond": "true"
      },
			"Entries": {
			   	"RMP Fishing Pond Grampleton Fields": {
					"Id": "Fishing_Pond_Grampleton_Fields",
					"PixelArea": { "X": 0, "Y": 62, "Width": 8, "Height": 16},
				  	"Textures": [{
						"Id": "Default",
						"Texture": "{{InternalAssetKey: assets/Maps/Fishing Pond/Fishing.Pond_{{season}}.png}}",
						"SourceRect": { "X": 9, "Y": 0, "Width": 8, "Height": 16  } }]
				}
			}
		}
  ]
}